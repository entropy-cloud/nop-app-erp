<?xml version="1.0" encoding="UTF-8" ?>
<!-- 测试专用桩 bean：接管 sales 域 IErpSalReturnBiz/IErpSalDeliveryBiz，避免引入 sales-service 形成 reactor 环
     （sales-service 已反向 test 依赖 quality-service 的强制质检门控）。仅 quality-service 测试使用。 -->
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:ioc="ioc">

    <bean id="testMockErpSalReturn" class="app.erp.qa.service.TestStubErpSalReturnBiz"
          ioc:type="app.erp.sal.biz.IErpSalReturnBiz"/>

    <bean id="testMockErpSalDelivery" class="app.erp.qa.service.TestStubErpSalDeliveryBiz"
          ioc:type="app.erp.sal.biz.IErpSalDeliveryBiz"/>
</beans>
