<?xml version="1.0" encoding="UTF-8" ?>
<!-- NCR-CAPA 统计报表（种子报表）。数据集 ds 由 ErpQaReportBizModel.buildNcrCapaSummaryDataset 注入，
     每行 {severity, ncrCount, resolvedNcrCount, capaActionCount, completedActionCount}。口径对齐
     docs/design/quality/state-machine.md：按严重度维度聚合 NCR 数 + CAPA 动作数。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="ncr-capa-summary" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="100.0"/>
                    <col width="90.0"/>
                    <col width="110.0"/>
                    <col width="110.0"/>
                    <col width="120.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="4" styleId="title"><model/><value>NCR-CAPA 统计表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>严重度</value></cell>
                            <cell styleId="header"><model/><value>NCR数</value></cell>
                            <cell styleId="header"><model/><value>已闭环NCR数</value></cell>
                            <cell styleId="header"><model/><value>CAPA动作数</value></cell>
                            <cell styleId="header"><model/><value>已完成动作数</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="cell">
                                <model ds="ds" expandType="r" field="severity"/>
                                <value>*=^ds!severity</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=ncrCount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=resolvedNcrCount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=capaActionCount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=completedActionCount</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="total"><model/><value>合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(B3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(C3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(D3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(E3)</valueExpr></model>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
