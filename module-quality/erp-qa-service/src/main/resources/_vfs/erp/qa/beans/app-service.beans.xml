<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- NCR 生命周期服务（plan 2026-07-02-2237-3 Phase 3）：REJECTED 自动生成 NCR + resolve 门控校验 -->
    <bean id="app.erp.qa.service.entity.NcrLifecycleService"
          class="app.erp.qa.service.entity.NcrLifecycleService"/>

    <!-- 召回目标定位器（plan 2026-07-03-1707-3 Phase 2）：经库存批次追溯 batchTrace 反查受影响销售出库 → ErpQaRecallTarget -->
    <bean id="app.erp.qa.service.entity.RecallTargetLocator"
          class="app.erp.qa.service.entity.RecallTargetLocator"/>

    <!-- 召回事件审批状态机 Processor -->
    <bean id="app.erp.qa.service.processor.ErpQaRecallProcessor"
          class="app.erp.qa.service.processor.ErpQaRecallProcessor"/>

    <!-- NCR 财务过账（plan 2026-07-05-2352-2）：报废损失凭证 Provider + 派发器 + 执行器 -->
    <bean id="app.erp.qa.service.posting.NcrScrapAcctDocProvider"
          class="app.erp.qa.service.posting.NcrScrapAcctDocProvider"/>

    <bean id="app.erp.qa.service.posting.NcrPostingDispatcher"
          class="app.erp.qa.service.posting.NcrPostingDispatcher"/>

    <bean id="app.erp.qa.service.posting.NcrPostingExecutor"
          class="app.erp.qa.service.posting.NcrPostingExecutor"/>

    <!-- NCR→RETURN 处置退货编排器（plan 2026-07-05-2352-2 Phase 3） -->
    <bean id="app.erp.qa.service.posting.NcrReturnOrchestrator"
          class="app.erp.qa.service.posting.NcrReturnOrchestrator"/>
</beans>