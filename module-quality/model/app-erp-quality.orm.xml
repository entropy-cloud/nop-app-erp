<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-quality ORM 模型 — 质量管理域（权威数据模型来源）
  ==================================================
  业务范围：质检单（关联采购入库/销售出库/工单）、质检模板与参数、
            不合格品处理（NCR 不符合报告）、纠正预防措施（CAPA）、风险登记

  三轴状态分离：
    - docStatus: 草稿/已生效/已作废（单据生命周期）
    - approveStatus: 未提交/已提交/已审核/已驳回（审核流程）
    - result/result: 质检结果独立维度

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-qa
    - entityPackage:  app.erp.qa.dao.entity
    - 实体类名:        ErpQa<Entity>     （如 ErpQaInspection、ErpQaNonConformance、ErpQaAction）
    - 表名:           erp_qa_<entity>   （如 erp_qa_inspection、erp_qa_non_conformance）
    - 字典命名空间:    erp-qa/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（物料、检验标准）
    - 被 app-erp-purchase 引用（采购入库触发来料质检）
    - 被 app-erp-sales 引用（销售出库触发发货质检）
    - 被 app-erp-manufacturing 引用（工单完工触发制程质检）
    - 质检不合格可触发采购退货/销售退货/工单返工（通过 I*Biz 反向通知）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="erp-qa" ext:entityPackageName="app.erp.qa.dao.entity"
     ext:basePackageName="app.erp.qa" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-quality"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
