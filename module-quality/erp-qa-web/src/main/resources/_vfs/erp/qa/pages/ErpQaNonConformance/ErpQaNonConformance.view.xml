<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpQaNonConformance.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="ncrDate" mandatory="true" sortable="true"/>
                <col id="sourceType" sortable="true"/>
                <col id="sourceCode" sortable="true"/>
                <col id="materialId" label="物料"/>
                <col id="inspection" label="质检单"/>
                <col id="quantity" ui:number="true" sortable="true"/>
                <col id="severity" mandatory="true" sortable="true"/>
                <col id="dispositionType" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="supplierId" label="供应商"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-investigate-button" label="评审" level="primary" icon="fa fa-search">
                    <api url="@mutation:ErpQaNonConformance__submitReview?ncrId=$id"/>
                    <confirmText>确认提交此 NCR 进入评审？</confirmText>
                    <messages>
                        <success>NCR 已进入评审</success>
                    </messages>
                    <visibleOn>${status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-resolve-button" label="解决" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpQaNonConformance__resolve?ncrId=$id&amp;resolution="/>
                    <confirmText>确认解决此 NCR？</confirmText>
                    <messages>
                        <success>NCR 已解决</success>
                    </messages>
                    <visibleOn>${status == 'IN_REVIEW'}</visibleOn>
                </action>
                <action id="row-reject-button" label="拒绝" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpQaNonConformance__cancel?ncrId=$id"/>
                    <confirmText>确认拒绝/取消此 NCR？</confirmText>
                    <messages>
                        <success>NCR 已取消</success>
                    </messages>
                    <visibleOn>${status == 'OPEN' || status == 'IN_REVIEW'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>