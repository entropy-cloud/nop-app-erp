<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpQaNonConformance" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/qa/model/ErpQaNonConformance/ErpQaNonConformance.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--报告日期-->
                <col id="ncrDate" mandatory="true" sortable="true"/>

                <!--来源类型-->
                <col id="sourceType" sortable="true"/>

                <!--来源单号-->
                <col id="sourceCode" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--质检单ID-->
                <col id="inspectionId" ui:number="true" sortable="true"/>

                <!--不合格数量-->
                <col id="quantity" ui:number="true" sortable="true"/>

                <!--问题描述-->
                <col id="description" sortable="true"/>

                <!--严重程度-->
                <col id="severity" mandatory="true" sortable="true"/>

                <!--处理决定-->
                <col id="dispositionType" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--供应商-->
                <col id="supplierId" ui:number="true" sortable="true"/>

                <!--不合格参数-->
                <col id="parameterName" sortable="true"/>

                <!--实测值-->
                <col id="measuredValue" sortable="true"/>

                <!--规格下限-->
                <col id="specMin" ui:number="true" sortable="true"/>

                <!--规格上限-->
                <col id="specMax" ui:number="true" sortable="true"/>

                <!--责任人-->
                <col id="assignedTo" ui:number="true" sortable="true"/>

                <!--解决人-->
                <col id="resolvedBy" ui:number="true" sortable="true"/>

                <!--解决时间-->
                <col id="resolvedAt" sortable="true"/>

                <!--解决措施-->
                <col id="resolution" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--已过账(报废处置已生成凭证)-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--关联退货单号(RETURN 处置编排退货域后登记)-->
                <col id="returnCode" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-不合格品报告" i18n-en:title="View Non-Conformance Report">
            <layout>
 id[ID] code[单号]
 ncrDate[报告日期] sourceType[来源类型]
 sourceCode[来源单号] materialId[物料]
 inspectionId[质检单ID] quantity[不合格数量]
 description[问题描述] severity[严重程度]
 dispositionType[处理决定] status[状态]
 supplierId[供应商] parameterName[不合格参数]
 measuredValue[实测值] specMin[规格下限]
 specMax[规格上限] assignedTo[责任人]
 resolvedBy[解决人] resolvedAt[解决时间]
 resolution[解决措施] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] posted[已过账(报废处置已生成凭证)]
 postedAt[过账时间] postedBy[过账人]
 returnCode[关联退货单号(RETURN 处置编排退货域后登记)] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-不合格品报告" i18n-en:title="Add Non-Conformance Report" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-不合格品报告" i18n-en:title="Edit Non-Conformance Report">
            <layout>
 id[ID] code[单号]
 ncrDate[报告日期] sourceType[来源类型]
 sourceCode[来源单号] materialId[物料]
 inspectionId[质检单ID] quantity[不合格数量]
 description[问题描述] severity[严重程度]
 dispositionType[处理决定] status[状态]
 supplierId[供应商] parameterName[不合格参数]
 measuredValue[实测值] specMin[规格下限]
 specMax[规格上限] assignedTo[责任人]
 resolvedBy[解决人] resolvedAt[解决时间]
 resolution[解决措施] remark[备注]
 returnCode[关联退货单号(RETURN 处置编排退货域后登记)] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-不合格品报告"
              i18n-en:title="Update Non-Conformance Report"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpQaNonConformance__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpQaNonConformance__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpQaNonConformance__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpQaNonConformance__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpQaNonConformance__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpQaNonConformance__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpQaNonConformance__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpQaNonConformance__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpQaNonConformance__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpQaNonConformance__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>