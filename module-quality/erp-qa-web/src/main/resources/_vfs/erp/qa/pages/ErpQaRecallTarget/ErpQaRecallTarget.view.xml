<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpQaRecallTarget.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="recallCode" label="召回事件"/>
                <col id="partnerName" label="客户"/>
                <col id="batchNo" sortable="true"/>
                <col id="serialNo" sortable="true"/>
                <col id="shippedQty" ui:number="true" sortable="true"/>
                <col id="returnStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>