<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpQaSpcSample.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="chart" label="控制图"/>
                <col id="orgId" label="组织"/>
                <col id="subgroupNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="sampleTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="mean" ui:number="true" sortable="true"/>
                <col id="range" ui:number="true" sortable="true"/>
                <col id="stdDev" ui:number="true" sortable="true"/>
                <col id="inspectorId" label="检验员"/>
                <col id="isOutOfControl" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>