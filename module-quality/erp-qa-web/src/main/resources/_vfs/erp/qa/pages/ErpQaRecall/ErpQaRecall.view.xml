<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpQaRecall.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="recallName" mandatory="true" sortable="true"/>
                <col id="triggerType" mandatory="true" sortable="true"/>
                <col id="sourceNcr" label="源不合格品"/>
                <col id="materialId" label="物料"/>
                <col id="severityLevel" mandatory="true" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approveStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'approveStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : "
                                    + valueProp + " == 'REJECTED' ? 'danger' : "
                                    + valueProp + " == 'SUBMITTED' ? 'info' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpQaRecall__submitForApproval?id=$id"/>
                    <confirmText>确认提交此召回事件审批？</confirmText>
                    <messages>
                        <success>召回事件已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpQaRecall__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此召回事件的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>召回事件已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpQaRecall__approve?id=$id"/>
                    <confirmText>确认批准此召回事件？</confirmText>
                    <messages>
                        <success>召回事件已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpQaRecall__reject?id=$id"/>
                    <confirmText>确认驳回此召回事件？</confirmText>
                    <messages>
                        <success>召回事件已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpQaRecall__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此召回事件？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>召回事件已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>