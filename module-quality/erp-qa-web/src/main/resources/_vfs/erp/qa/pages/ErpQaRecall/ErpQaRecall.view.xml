<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpQaRecall.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpQaRecall__submitForApproval?id=$id"/>
                    <confirmText>确认提交此召回事件审批？</confirmText>
                    <messages>
                        <success>召回事件已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpQaRecall__approve?id=$id"/>
                    <confirmText>确认批准此召回事件？</confirmText>
                    <messages>
                        <success>召回事件已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpQaRecall__reject?id=$id"/>
                    <confirmText>确认驳回此召回事件？</confirmText>
                    <messages>
                        <success>召回事件已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>