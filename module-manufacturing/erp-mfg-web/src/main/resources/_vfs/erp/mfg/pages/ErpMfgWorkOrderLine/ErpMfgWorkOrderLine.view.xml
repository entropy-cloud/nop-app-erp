<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgWorkOrderLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineType" sortable="true"/>
                <col id="materialId" label="物料名称"/>
                <col id="sourceWarehouseId" label="领料仓库"/>
                <col id="destWarehouseId" label="入库仓库"/>
                <col id="plannedQuantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualQuantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="scrappedQuantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="lineType" mandatory="true"/>
                <col id="materialId" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'materialId',
                                label: '物料',
                                required: true,
                                source: '/erp/md/pages/ErpMdMaterial/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="uoMId" mandatory="true"/>
                <col id="plannedQuantity" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'plannedQuantity',
                                required: true,
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '计划数量不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualQuantity">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'actualQuantity',
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '实际数量不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="scrappedQuantity">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'scrappedQuantity',
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '报废数量不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="sourceWarehouseId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'sourceWarehouseId',
                                label: '领料仓库',
                                source: '/erp/md/pages/ErpMdWarehouse/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="destWarehouseId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'destWarehouseId',
                                label: '入库仓库',
                                source: '/erp/md/pages/ErpMdWarehouse/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="lineType"/>
                <col id="materialId"/>
                <col id="uoMId"/>
                <col id="plannedQuantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualQuantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="scrappedQuantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="sourceWarehouseId"/>
                <col id="destWarehouseId"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] lineType[行类型]
 materialId[物料] skuId[SKU] uoMId[计量单位]
=========>quantity[数量信息]======
 plannedQuantity[计划数量] actualQuantity[实际数量]
 scrappedQuantity[报废数量]
 sourceWarehouseId[来源仓库] destWarehouseId[目标仓库]
=========>reference[业务关联]======
 workOrderId[工单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] lineType[行类型]
 materialId[物料] skuId[SKU] uoMId[计量单位]
=========>quantity[数量信息]======
 plannedQuantity[计划数量] actualQuantity[实际数量]
 scrappedQuantity[报废数量]
 sourceWarehouseId[来源仓库] destWarehouseId[目标仓库]
=========>reference[业务关联]======
 workOrderId[工单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] lineType[行类型]
 materialId[物料] workOrderId[工单]
 sourceWarehouseId[来源仓库]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="lineType" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="workOrderId" filterOp="eq"/>
                <cell id="sourceWarehouseId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>