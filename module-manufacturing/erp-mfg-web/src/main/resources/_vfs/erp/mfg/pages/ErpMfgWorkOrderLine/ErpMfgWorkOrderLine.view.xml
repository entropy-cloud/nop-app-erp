<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgWorkOrderLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineType" sortable="true"/>
                <col id="materialName" label="物料名称"/>
                <col id="plannedQuantity" ui:number="true" sortable="true"/>
                <col id="actualQuantity" ui:number="true" sortable="true"/>
                <col id="scrappedQuantity" ui:number="true" sortable="true"/>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>