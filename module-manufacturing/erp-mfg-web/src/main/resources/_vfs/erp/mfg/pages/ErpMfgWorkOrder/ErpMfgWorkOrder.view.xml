<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgWorkOrder.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="productId" label="产品(主产出)"/>
                <col id="currencyId" label="币种"/>
                <col id="plannedQuantity" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="completedQuantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="scrappedQuantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="businessDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="docStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approveStatus" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'approveStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : "
                                    + valueProp + " == 'REJECTED' ? 'danger' : "
                                    + valueProp + " == 'SUBMITTED' ? 'info' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg" layoutControl="tabs">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[工单号] orgId[业务组织]
 docStatus[单据状态] approveStatus[审核状态]
 priority[优先级] businessDate[工单日期]
=========>bom[BOM信息]======
 bomId[BOM] routingId[工艺路线]
 productionVersionId[生产版本] productId[产品(主产出)]
=========>plan[计划信息]======
 plannedQuantity[计划数量] completedQuantity[完工数量]
 scrappedQuantity[报废数量] plannedStartDate[计划开工日期]
 plannedEndDate[计划完工日期] actualStartDate[实际开工日期]
 actualEndDate[实际完工日期] sourceOrderType[来源单据类型]
 sourceOrderCode[来源单据号] sourceMrpPlanId[来源 MRP 计划]
 sourceScheduleId[APS排程来源(弱参照)]
=========>progress[工单进度仪表板]======
 workOrderProgress[工单进度](2)
=========>lines[明细行]======
 lines[明细行](2)
========^cost[成本信息]=========
 currencyId[币种] exchangeRate[汇率]
 materialCost[材料成本] laborCost[人工成本]
 overheadCost[制造费用] subcontractCost[委外成本]
 totalCost[总成本] unitCost[单位成本]
 amountSource[源币种金额] amountFunctional[本位币金额]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <!--
                  工单进度仪表板（F16 P1，plan §Phase 4，Phase 0 Decision）。
                  前端组装既有头字段（plannedQuantity/completedQuantity/scrappedQuantity）：
                    - 完工进度条 = completedQuantity / plannedQuantity × 100，颜色阈值：绿≥90% / 黄70-90% / 红<70%
                    - 报废进度条 = scrappedQuantity / plannedQuantity × 100（红色警示）
                    - 数量汇总 + 工单状态阶段（docStatus 语义化）
                  4 阶段进度条（plan/pick/report/complete）以阶段语义呈现：完工率覆盖 complete，报废覆盖 report 异常；
                  pick（领料）与 report（报工）明细经既有 F9 row-action drawer（MaterialIssue/JobCard）查看，不在此聚合（避免后端查询）。
                -->
                <cell id="workOrderProgress" custom="true" notSubmit="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'tpl',
                                tpl: '<div class="m-b">' +
                                    '<div class="text-muted m-b-xs">完工进度 <span class="font-bold">' + '${' + 'plannedQuantity ? (completedQuantity || 0) + " / " + plannedQuantity : "—"' + '}</span></div>' +
                                    '<div style="height:18px;background:#f0f0f0;border-radius:9px;overflow:hidden;position:relative;">' +
                                        '<div style="height:100%;width:' + '${' + 'plannedQuantity ? completedQuantity / plannedQuantity * 100 : 0' + '}%;background:' + '${' + 'plannedQuantity ? (completedQuantity / plannedQuantity >= 0.9 ? "#5cb85c" : (completedQuantity / plannedQuantity >= 0.7 ? "#f0ad4e" : "#d9534f")) : "#ccc"' + '}%;transition:width .3s;"></div>' +
                                        '<span style="position:absolute;right:8px;top:0;line-height:18px;color:#333;font-size:12px;">' + '${' + 'plannedQuantity ? Math.round(completedQuantity / plannedQuantity * 1000) / 10 + "%" : "0%"' + '}</span>' +
                                    '</div>' +
                                    '<div class="text-muted m-b-xs m-t-md">报废率 <span class="font-bold text-danger">' + '${' + 'plannedQuantity ? (scrappedQuantity || 0) + " / " + plannedQuantity : "—"' + '}</span></div>' +
                                    '<div style="height:14px;background:#f0f0f0;border-radius:7px;overflow:hidden;">' +
                                        '<div style="height:100%;width:' + '${' + 'plannedQuantity ? scrappedQuantity / plannedQuantity * 100 : 0' + '}%;background:#d9534f;"></div>' +
                                    '</div>' +
                                    '<div class="m-t-md"><span class="label label-' + '${' + 'docStatus == "COMPLETED" ? "success" : (docStatus == "IN_PROCESS" || docStatus == "STARTED" ? "primary" : (docStatus == "CANCELLED" ? "danger" : "default"))' + '}">工单阶段：' + '${' + 'docStatus' + '}</span></div>' +
                                    '</div>'
                            };
                        ]]></c:script>
                    </gen-control>
                </cell>
                <cell id="lines">
                    <view path="/erp/mfg/pages/ErpMfgWorkOrderLine/ErpMfgWorkOrderLine.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="edit" size="lg" layoutControl="tabs">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[工单号] orgId[业务组织]
 docStatus[单据状态] approveStatus[审核状态]
 priority[优先级] businessDate[工单日期]
=========>bom[BOM信息]======
 bomId[BOM] routingId[工艺路线]
 productionVersionId[生产版本] productId[产品(主产出)]
=========>plan[计划信息]======
 plannedQuantity[计划数量] completedQuantity[完工数量]
 scrappedQuantity[报废数量] plannedStartDate[计划开工日期]
 plannedEndDate[计划完工日期] actualStartDate[实际开工日期]
 actualEndDate[实际完工日期] sourceOrderType[来源单据类型]
 sourceOrderCode[来源单据号] sourceMrpPlanId[来源 MRP 计划]
 sourceScheduleId[APS排程来源(弱参照)]
=========>lines[明细行]======
 lines[明细行](2)
========^cost[成本信息]=========
 currencyId[币种] exchangeRate[汇率]
 materialCost[材料成本] laborCost[人工成本]
 overheadCost[制造费用] subcontractCost[委外成本]
 totalCost[总成本] unitCost[单位成本]
 amountSource[源币种金额] amountFunctional[本位币金额]
 remark[备注](2)
            </layout>
            <cells>
                <cell id="lines">
                    <view path="/erp/mfg/pages/ErpMfgWorkOrderLine/ErpMfgWorkOrderLine.view.xml" grid="sub-grid-edit"/>
                </cell>
            </cells>
        </form>
        <form id="add" x:prototype="edit" editMode="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[工单号] docStatus[单据状态]
 approveStatus[审核状态] businessDate[工单日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpMfgWorkOrder__submitForApproval?id=$id"/>
                    <confirmText>确认提交此工单审批？</confirmText>
                    <messages>
                        <success>工单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpMfgWorkOrder__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此工单的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>工单已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpMfgWorkOrder__approve?id=$id"/>
                    <confirmText>确认批准此工单？</confirmText>
                    <messages>
                        <success>工单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpMfgWorkOrder__reject?id=$id"/>
                    <confirmText>确认驳回此工单？</confirmText>
                    <messages>
                        <success>工单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpMfgWorkOrder__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此工单？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>工单已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-start-button" label="开工" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpMfgWorkOrder__start?workOrderId=$id"/>
                    <confirmText>确认开工此工单？</confirmText>
                    <messages>
                        <success>工单已开工</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED' &amp;&amp; (docStatus == 'NOT_STARTED' || docStatus == 'STOCK_RESERVED' || docStatus == 'STOCK_PARTIAL')}</visibleOn>
                </action>
                <action id="row-report-completion-button" label="报告完工" level="success" icon="fa fa-check-circle">
                    <api url="@mutation:ErpMfgWorkOrder__reportCompletion?workOrderId=$id&amp;completedQty=0"/>
                    <confirmText>确认报告此工单完工？</confirmText>
                    <messages>
                        <success>工单已报告完工</success>
                    </messages>
                    <visibleOn>${docStatus == 'IN_PROCESS'}</visibleOn>
                </action>
                <action id="row-close-button" label="结案" level="info" icon="fa fa-stop">
                    <api url="@mutation:ErpMfgWorkOrder__close?workOrderId=$id"/>
                    <confirmText>确认结案此工单？</confirmText>
                    <messages>
                        <success>工单已结案</success>
                    </messages>
                    <visibleOn>${docStatus == 'STARTED' || docStatus == 'COMPLETED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpMfgWorkOrder__cancel?workOrderId=$id"/>
                    <confirmText>确认作废此工单？</confirmText>
                    <messages>
                        <success>工单已作废</success>
                    </messages>
                    <visibleOn>${docStatus != 'CANCELLED' &amp;&amp; docStatus != 'CLOSED' &amp;&amp; docStatus != 'COMPLETED'}</visibleOn>
                </action>
                <action id="row-view-material-issue-button" label="查看领料单" level="info" icon="fa fa-list"
                        actionType="drawer">
                    <drawer page="/erp/mfg/pages/ErpMfgMaterialIssue/ref-work-order.page.yaml" size="xl">
                        <data>
                            <workOrderId>${id}</workOrderId>
                        </data>
                    </drawer>
                </action>
                <action id="row-view-job-card-button" label="查看报工单" level="info" icon="fa fa-list"
                        actionType="drawer">
                    <drawer page="/erp/mfg/pages/ErpMfgJobCard/ref-work-order.page.yaml" size="xl">
                        <data>
                            <workOrderId>${id}</workOrderId>
                        </data>
                    </drawer>
                </action>
                <action id="row-view-completion-move-button" label="查看完工入库" level="primary" icon="fa fa-arrow-right"
                        tooltip="跳转到库存移动单列表（按来源单据号筛选；mfg→inv 跨域非 FK，按 sourceBillCode 字符串匹配降级为 URL 跳转）"
                        link="/ErpInvStockMove-main"/>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>