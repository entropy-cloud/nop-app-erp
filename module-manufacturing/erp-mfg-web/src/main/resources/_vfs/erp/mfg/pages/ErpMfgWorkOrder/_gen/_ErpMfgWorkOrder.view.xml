<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpMfgWorkOrder" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/mfg/model/ErpMfgWorkOrder/ErpMfgWorkOrder.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--工单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--BOM-->
                <col id="bomId" ui:number="true" sortable="true"/>

                <!--工艺路线-->
                <col id="routingId" ui:number="true" sortable="true"/>

                <!--生产版本-->
                <col id="productionVersionId" ui:number="true" sortable="true"/>

                <!--来源 MRP 计划-->
                <col id="sourceMrpPlanId" ui:number="true" sortable="true"/>

                <!--来源单据类型-->
                <col id="sourceOrderType" sortable="true"/>

                <!--来源单据号-->
                <col id="sourceOrderCode" sortable="true"/>

                <!--产品(主产出)-->
                <col id="productId" mandatory="true" ui:number="true" sortable="true"/>

                <!--计划数量-->
                <col id="plannedQuantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--完工数量-->
                <col id="completedQuantity" ui:number="true" sortable="true"/>

                <!--报废数量-->
                <col id="scrappedQuantity" ui:number="true" sortable="true"/>

                <!--工单日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--计划开工日期-->
                <col id="plannedStartDate" sortable="true"/>

                <!--计划完工日期-->
                <col id="plannedEndDate" sortable="true"/>

                <!--实际开工日期-->
                <col id="actualStartDate" sortable="true"/>

                <!--实际完工日期-->
                <col id="actualEndDate" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--材料成本-->
                <col id="materialCost" ui:number="true" sortable="true"/>

                <!--人工成本-->
                <col id="laborCost" ui:number="true" sortable="true"/>

                <!--制造费用-->
                <col id="overheadCost" ui:number="true" sortable="true"/>

                <!--委外成本-->
                <col id="subcontractCost" ui:number="true" sortable="true"/>

                <!--总成本-->
                <col id="totalCost" ui:number="true" sortable="true"/>

                <!--单位成本-->
                <col id="unitCost" ui:number="true" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" sortable="true"/>

                <!--优先级-->
                <col id="priority" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--APS排程来源(弱参照)-->
                <col id="sourceScheduleId" ui:number="true" sortable="true"/>

                <!--审核人-->
                <col id="approvedBy" sortable="true"/>

                <!--审核时间-->
                <col id="approvedAt" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" mandatory="true" sortable="true"/>

                <!--源币种金额-->
                <col id="amountSource" sortable="true"/>

                <!--本位币金额-->
                <col id="amountFunctional" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-工单" i18n-en:title="View Work Order">
            <layout>
 id[ID] code[工单号]
 orgId[业务组织] bomId[BOM]
 routingId[工艺路线] productionVersionId[生产版本]
 sourceMrpPlanId[来源 MRP 计划] sourceOrderType[来源单据类型]
 sourceOrderCode[来源单据号] productId[产品(主产出)]
 plannedQuantity[计划数量] completedQuantity[完工数量]
 scrappedQuantity[报废数量] businessDate[工单日期]
 plannedStartDate[计划开工日期] plannedEndDate[计划完工日期]
 actualStartDate[实际开工日期] actualEndDate[实际完工日期]
 currencyId[币种] materialCost[材料成本]
 laborCost[人工成本] overheadCost[制造费用]
 subcontractCost[委外成本] totalCost[总成本]
 unitCost[单位成本] docStatus[单据状态]
 approveStatus[审核状态] priority[优先级]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] sourceScheduleId[APS排程来源(弱参照)]
 approvedBy[审核人] approvedAt[审核时间]
 exchangeRate[汇率] amountSource[源币种金额]
 amountFunctional[本位币金额] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-工单" i18n-en:title="Add Work Order">
            <layout>
 id[ID] code[工单号]
 orgId[业务组织] bomId[BOM]
 routingId[工艺路线] productionVersionId[生产版本]
 sourceMrpPlanId[来源 MRP 计划] sourceOrderType[来源单据类型]
 sourceOrderCode[来源单据号] productId[产品(主产出)]
 plannedQuantity[计划数量] completedQuantity[完工数量]
 scrappedQuantity[报废数量] businessDate[工单日期]
 plannedStartDate[计划开工日期] plannedEndDate[计划完工日期]
 actualStartDate[实际开工日期] actualEndDate[实际完工日期]
 currencyId[币种] materialCost[材料成本]
 laborCost[人工成本] overheadCost[制造费用]
 subcontractCost[委外成本] totalCost[总成本]
 unitCost[单位成本] docStatus[单据状态]
 approveStatus[审核状态] priority[优先级]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 sourceScheduleId[APS排程来源(弱参照)] approvedBy[审核人]
 approvedAt[审核时间] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-工单" i18n-en:title="Edit Work Order">
            <layout>
 id[ID] code[工单号]
 orgId[业务组织] bomId[BOM]
 routingId[工艺路线] productionVersionId[生产版本]
 sourceMrpPlanId[来源 MRP 计划] sourceOrderType[来源单据类型]
 sourceOrderCode[来源单据号] productId[产品(主产出)]
 plannedQuantity[计划数量] completedQuantity[完工数量]
 scrappedQuantity[报废数量] businessDate[工单日期]
 plannedStartDate[计划开工日期] plannedEndDate[计划完工日期]
 actualStartDate[实际开工日期] actualEndDate[实际完工日期]
 currencyId[币种] materialCost[材料成本]
 laborCost[人工成本] overheadCost[制造费用]
 subcontractCost[委外成本] totalCost[总成本]
 unitCost[单位成本] docStatus[单据状态]
 approveStatus[审核状态] priority[优先级]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 delVersion[逻辑删除版本] sourceScheduleId[APS排程来源(弱参照)]
 approvedBy[审核人] approvedAt[审核时间]
 exchangeRate[汇率] amountSource[源币种金额]
 amountFunctional[本位币金额] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-工单" i18n-en:title="Update Work Order"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgWorkOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgWorkOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpMfgWorkOrder__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpMfgWorkOrder__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpMfgWorkOrder__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpMfgWorkOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpMfgWorkOrder__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpMfgWorkOrder__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpMfgWorkOrder__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpMfgWorkOrder__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>