<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgSubcontractOrder.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="workOrderNo" label="来源工单"/>
                <col id="supplierName" label="委外供应商"/>
                <col id="workcenterName" label="外协工作中心"/>
                <col id="productName" label="产品"/>
                <col id="currencyName" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="processingFee" ui:number="true" sortable="true"/>
                <col id="totalAmount" ui:number="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>

        <!-- 发料参数收集（生命周期首个参数化 dialog 范式，plan 2026-07-13-0701-2 Phase 2）。
             无 objMeta 绑定，cells 显式声明 domain + gen-control（warehouse select）。 -->
        <form id="issueMaterials" title="发料" size="md" editMode="edit">
            <layout>
                sourceWarehouseId[发料仓库]
            </layout>
            <cells>
                <cell id="sourceWarehouseId" label="发料仓库" domain="long">
                    <gen-control>
                        <select clearable="@:true">
                            <source>
                                <url>@query:ErpMdWarehouse__findList/value:id,label:name?filter_status=ACTIVE</url>
                            </source>
                        </select>
                    </gen-control>
                </cell>
            </cells>
        </form>

        <!-- 收货参数收集：receivedQty 数量输入 + destWarehouseId 仓库选择器 -->
        <form id="receiveFinished" title="收货" size="md" editMode="edit">
            <layout>
                receivedQty[收货数量] destWarehouseId[收货仓库]
            </layout>
            <cells>
                <cell id="receivedQty" label="收货数量" domain="decimal" mandatory="true"/>
                <cell id="destWarehouseId" label="收货仓库" domain="long">
                    <gen-control>
                        <select clearable="@:true">
                            <source>
                                <url>@query:ErpMdWarehouse__findList/value:id,label:name?filter_status=ACTIVE</url>
                            </source>
                        </select>
                    </gen-control>
                </cell>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>

                <!-- 审批轴 5 按钮（镜像 ErpMfgWorkOrder.view.xml :81–120 范式，参数名 id） -->
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpMfgSubcontractOrder__submitForApproval?id=$id"/>
                    <confirmText>确认提交此委外单审批？</confirmText>
                    <messages>
                        <success>委外单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpMfgSubcontractOrder__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此委外单的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>委外单已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpMfgSubcontractOrder__approve?id=$id"/>
                    <confirmText>确认批准此委外单？</confirmText>
                    <messages>
                        <success>委外单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpMfgSubcontractOrder__reject?id=$id"/>
                    <confirmText>确认驳回此委外单？</confirmText>
                    <messages>
                        <success>委外单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpMfgSubcontractOrder__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此委外单？反审批后单据将回到未批准状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>委外单已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>

                <!-- 生命周期 4 按钮（首个 lifecycle 按钮范式；参数名 subcontractOrderId 与后端 BizModel 一致） -->
                <action id="row-cancel-button" label="取消" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpMfgSubcontractOrder__cancel?subcontractOrderId=$id"/>
                    <confirmText>确认取消此委外单？取消后单据将不可再推进。</confirmText>
                    <messages>
                        <success>委外单已取消</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT' || docStatus == 'SUBMITTED' || docStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-issue-materials-button" label="发料" level="primary" icon="fa fa-outdent">
                    <dialog page="issueMaterials"/>
                    <messages>
                        <success>委外单已发料</success>
                    </messages>
                    <visibleOn>${docStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-receive-finished-button" label="收货" level="primary" icon="fa fa-inbox">
                    <dialog page="receiveFinished"/>
                    <messages>
                        <success>委外单已收货</success>
                    </messages>
                    <visibleOn>${docStatus == 'ISSUED'}</visibleOn>
                </action>
                <action id="row-post-processing-fee-button" label="加工费过账" level="success" icon="fa fa-calculator">
                    <api url="@mutation:ErpMfgSubcontractOrder__postProcessingFee?subcontractOrderId=$id"/>
                    <confirmText>确认对此委外单进行加工费过账？过账后单据将完工。</confirmText>
                    <messages>
                        <success>委外单加工费已过账</success>
                    </messages>
                    <visibleOn>${docStatus == 'RECEIVED'}</visibleOn>
                </action>

                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>

        <!-- 生命周期参数化 dialog：simple 绑定 form + mutation API。
             subcontractOrderId=$id 来自行上下文，表单字段经 data 透传（$sourceWarehouseId / $receivedQty / $destWarehouseId）。 -->
        <simple name="issueMaterials" form="issueMaterials">
            <api url="@mutation:ErpMfgSubcontractOrder__issueMaterials?subcontractOrderId=$id">
                <data>
                    <sourceWarehouseId>$sourceWarehouseId</sourceWarehouseId>
                </data>
            </api>
        </simple>
        <simple name="receiveFinished" form="receiveFinished">
            <api url="@mutation:ErpMfgSubcontractOrder__receiveFinished?subcontractOrderId=$id">
                <data>
                    <receivedQty>$receivedQty</receivedQty>
                    <destWarehouseId>$destWarehouseId</destWarehouseId>
                </data>
            </api>
        </simple>
    </pages>
</view>
