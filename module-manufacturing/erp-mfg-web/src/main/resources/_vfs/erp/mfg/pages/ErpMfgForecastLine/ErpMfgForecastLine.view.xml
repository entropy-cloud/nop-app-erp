<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgForecastLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="forecastCode" label="预测单"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialName" label="物料"/>
                <col id="warehouseName" label="仓库"/>
                <col id="uomName" label="计量单位"/>
                <col id="periodStart" mandatory="true" sortable="true"/>
                <col id="periodEnd" mandatory="true" sortable="true"/>
                <col id="forecastQty" mandatory="true" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>