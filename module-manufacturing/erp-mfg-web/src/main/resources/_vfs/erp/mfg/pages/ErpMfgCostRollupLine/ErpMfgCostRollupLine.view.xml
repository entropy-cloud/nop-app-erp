<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgCostRollupLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="costRollup" label="滚算单"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="产品"/>
                <col id="uoMId" label="计量单位"/>
                <col id="currencyId" label="币种"/>
                <col id="materialCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="laborCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>cost[成本信息]======
 materialCost[材料成本] laborCost[人工成本]
 overheadCost[制造费用] subcontractCost[委外成本]
 totalCost[总成本] unitCost[单位成本]
 currencyId[币种]
=========>reference[业务关联]======
 costRollupId[成本滚算单]
 ========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>cost[成本信息]======
 materialCost[材料成本] laborCost[人工成本]
 overheadCost[制造费用] subcontractCost[委外成本]
 totalCost[总成本] unitCost[单位成本]
 currencyId[币种]
=========>reference[业务关联]======
 costRollupId[成本滚算单]
 ========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 costRollupId[成本滚算单] currencyId[币种]
 unitCost[单位成本]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="costRollupId" filterOp="eq"/>
                <cell id="currencyId" filterOp="eq"/>
                <cell id="unitCost" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>