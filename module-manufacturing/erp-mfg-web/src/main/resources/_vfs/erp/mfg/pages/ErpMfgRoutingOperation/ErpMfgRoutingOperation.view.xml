<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgRoutingOperation.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="routingCode" label="工艺路线"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="operationCode" sortable="true"/>
                <col id="operationName" sortable="true"/>
                <col id="workcenterName" label="工作中心"/>
                <col id="standardTime" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>