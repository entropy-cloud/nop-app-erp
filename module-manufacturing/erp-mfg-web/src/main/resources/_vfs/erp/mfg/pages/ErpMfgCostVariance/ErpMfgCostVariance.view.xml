<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgCostVariance.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="workOrder" label="工单"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="varianceType" mandatory="true" sortable="true"/>
                <col id="costElement" mandatory="true" sortable="true"/>
                <col id="materialId" label="物料"/>
                <col id="workcenterId" label="工作中心"/>
                <col id="varianceAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="businessDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>