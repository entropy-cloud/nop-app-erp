<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpMfgWorkOrderLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/mfg/model/ErpMfgWorkOrderLine/ErpMfgWorkOrderLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--工单ID-->
                <col id="workOrderId" mandatory="true" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--行类型(OUTPUT 产出/INPUT 投入/BYPRODUCT 联副)-->
                <col id="lineType" mandatory="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--SKU-->
                <col id="skuId" ui:number="true" sortable="true"/>

                <!--计量单位-->
                <col id="uoMId" mandatory="true" ui:number="true" sortable="true"/>

                <!--计划数量-->
                <col id="plannedQuantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--实际数量(完工/领用)-->
                <col id="actualQuantity" ui:number="true" sortable="true"/>

                <!--报废数量-->
                <col id="scrappedQuantity" ui:number="true" sortable="true"/>

                <!--领料仓库(投入用)-->
                <col id="sourceWarehouseId" ui:number="true" sortable="true"/>

                <!--入库仓库(产出用)-->
                <col id="destWarehouseId" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--物料名称-->
                <col id="materialName"/>

                <!--领料仓库名称-->
                <col id="sourceWarehouseName"/>

                <!--入库仓库名称-->
                <col id="destWarehouseName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-工单行" i18n-en:title="View Work Order Line">
            <layout>
 id[ID] workOrderId[工单ID]
 lineNo[行号] lineType[行类型(OUTPUT 产出/INPUT 投入/BYPRODUCT 联副)]
 materialId[物料] skuId[SKU]
 uoMId[计量单位] plannedQuantity[计划数量]
 actualQuantity[实际数量(完工/领用)] scrappedQuantity[报废数量]
 sourceWarehouseId[领料仓库(投入用)] destWarehouseId[入库仓库(产出用)]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 materialName[物料名称] sourceWarehouseName[领料仓库名称]
 destWarehouseName[入库仓库名称] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-工单行" i18n-en:title="Add Work Order Line" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-工单行" i18n-en:title="Edit Work Order Line">
            <layout>
 id[ID] workOrderId[工单ID]
 lineNo[行号] lineType[行类型(OUTPUT 产出/INPUT 投入/BYPRODUCT 联副)]
 materialId[物料] skuId[SKU]
 uoMId[计量单位] plannedQuantity[计划数量]
 actualQuantity[实际数量(完工/领用)] scrappedQuantity[报废数量]
 sourceWarehouseId[领料仓库(投入用)] destWarehouseId[入库仓库(产出用)]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-工单行" i18n-en:title="Update Work Order Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgWorkOrderLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgWorkOrderLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpMfgWorkOrderLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpMfgWorkOrderLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpMfgWorkOrderLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpMfgWorkOrderLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpMfgWorkOrderLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpMfgWorkOrderLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpMfgWorkOrderLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpMfgWorkOrderLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>