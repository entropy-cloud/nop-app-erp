<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpMfgBatchGenealogy" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/mfg/model/ErpMfgBatchGenealogy/ErpMfgBatchGenealogy.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--工单-->
                <col id="workOrderId" mandatory="true" ui:number="true" sortable="true"/>

                <!--作业卡-->
                <col id="jobCardId" ui:number="true" sortable="true"/>

                <!--工序-->
                <col id="operationId" ui:number="true" sortable="true"/>

                <!--输入批次-->
                <col id="inputLotId" mandatory="true" ui:number="true" sortable="true"/>

                <!--输入物料-->
                <col id="inputMaterialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--投入数量-->
                <col id="inputQty" mandatory="true" ui:number="true" sortable="true"/>

                <!--投入计量单位-->
                <col id="inputUoMId" mandatory="true" ui:number="true" sortable="true"/>

                <!--产出批次-->
                <col id="outputLotId" mandatory="true" ui:number="true" sortable="true"/>

                <!--产出物料-->
                <col id="outputMaterialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--产出数量-->
                <col id="outputQty" mandatory="true" ui:number="true" sortable="true"/>

                <!--产出计量单位-->
                <col id="outputUoMId" mandatory="true" ui:number="true" sortable="true"/>

                <!--生产日期-->
                <col id="productionDate" mandatory="true" sortable="true"/>

                <!--生产时间-->
                <col id="productionTime" sortable="true"/>

                <!--行号-->
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--批次状态-->
                <col id="lotStatus" sortable="true"/>

                <!--输入是否已消耗-->
                <col id="isInputConsumed" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-批次追溯" i18n-en:title="View Batch Genealogy">
            <layout>
 id[ID] workOrderId[工单]
 jobCardId[作业卡] operationId[工序]
 inputLotId[输入批次] inputMaterialId[输入物料]
 inputQty[投入数量] inputUoMId[投入计量单位]
 outputLotId[产出批次] outputMaterialId[产出物料]
 outputQty[产出数量] outputUoMId[产出计量单位]
 productionDate[生产日期] productionTime[生产时间]
 lineNo[行号] lotStatus[批次状态]
 isInputConsumed[输入是否已消耗] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-批次追溯" i18n-en:title="Add Batch Genealogy" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-批次追溯" i18n-en:title="Edit Batch Genealogy">
            <layout>
 id[ID] workOrderId[工单]
 jobCardId[作业卡] operationId[工序]
 inputLotId[输入批次] inputMaterialId[输入物料]
 inputQty[投入数量] inputUoMId[投入计量单位]
 outputLotId[产出批次] outputMaterialId[产出物料]
 outputQty[产出数量] outputUoMId[产出计量单位]
 productionDate[生产日期] productionTime[生产时间]
 lineNo[行号] lotStatus[批次状态]
 isInputConsumed[输入是否已消耗] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-批次追溯" i18n-en:title="Update Batch Genealogy"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgBatchGenealogy__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMfgBatchGenealogy__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpMfgBatchGenealogy__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpMfgBatchGenealogy__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpMfgBatchGenealogy__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpMfgBatchGenealogy__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpMfgBatchGenealogy__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpMfgBatchGenealogy__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpMfgBatchGenealogy__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpMfgBatchGenealogy__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>