<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgSubcontractOrderLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="subcontractOrder" label="委外单"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="物料"/>
                <col id="uoMId" label="计量单位"/>
                <col id="quantity" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitProcessingFee" ui:number="true" sortable="true"/>
                <col id="amount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>quantity[数量信息]======
 quantity[数量]
=========>amount[金额信息]======
 unitProcessingFee[单位加工费] amount[金额]
=========>reference[业务关联]======
 subcontractOrderId[委外单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>quantity[数量信息]======
 quantity[数量]
=========>amount[金额信息]======
 unitProcessingFee[单位加工费] amount[金额]
=========>reference[业务关联]======
 subcontractOrderId[委外单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 subcontractOrderId[委外单] uoMId[计量单位]
 quantity[数量]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="subcontractOrderId" filterOp="eq"/>
                <cell id="uoMId" filterOp="eq"/>
                <cell id="quantity" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>