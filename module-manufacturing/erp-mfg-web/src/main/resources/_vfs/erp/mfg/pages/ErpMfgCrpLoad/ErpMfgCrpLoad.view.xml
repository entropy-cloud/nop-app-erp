<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgCrpLoad.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="workcenterId" label="工作中心"/>
                <col id="orgId" label="业务组织"/>
                <col id="workOrderNo" label="工单"/>
                <col id="loadDate" mandatory="true" sortable="true"/>
                <col id="loadHours" ui:number="true" sortable="true"/>
                <col id="setupHours" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>