<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMfgCrpLoad.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="workcenterId" label="工作中心"/>
                <col id="orgId" label="业务组织"/>
                <col id="workOrder" label="工单"/>
                <col id="loadDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="loadHours" ui:number="true" sortable="true"/>
                <col id="setupHours" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 workcenterId[工作中心] orgId[业务组织]
 workOrderId[工单] loadDate[负荷日期]
=========>load[负荷信息]======
 loadHours[负荷工时] setupHours[换型工时]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 workcenterId[工作中心] orgId[业务组织]
 workOrderId[工单] loadDate[负荷日期]
=========>load[负荷信息]======
 loadHours[负荷工时] setupHours[换型工时]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 workcenterId[工作中心] orgId[业务组织]
 workOrderId[工单] loadDate[负荷日期]
 loadHours[负荷工时]
            </layout>
            <cells>
                <cell id="workcenterId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="workOrderId" filterOp="eq"/>
                <cell id="loadDate" filterOp="date-between"/>
                <cell id="loadHours" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>