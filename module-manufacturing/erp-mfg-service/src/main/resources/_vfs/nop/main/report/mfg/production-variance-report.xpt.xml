<?xml version="1.0" encoding="UTF-8" ?>
<!-- 生产差异报表（种子报表）。数据集 ds 由 ErpMfgReportBizModel.buildProductionVarianceDataset 注入，
     每行 {workOrderId, workOrderCode, varianceType, costElement, standardAmount, actualAmount, varianceAmount, businessDate}。
     口径对齐 plan 2026-07-05-1838-2 差异引擎输出与 manufacturing/state-machine.md：按工单×差异类型维度汇总。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="production-variance" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="70.0"/>
                    <col width="100.0"/>
                    <col width="120.0"/>
                    <col width="80.0"/>
                    <col width="80.0"/>
                    <col width="80.0"/>
                    <col width="80.0"/>
                    <col width="80.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="7" styleId="title"><model/><value>生产差异分析表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>工单ID</value></cell>
                            <cell styleId="header"><model/><value>工单编码</value></cell>
                            <cell styleId="header"><model/><value>差异类型</value></cell>
                            <cell styleId="header"><model/><value>成本要素</value></cell>
                            <cell styleId="header"><model/><value>标准成本</value></cell>
                            <cell styleId="header"><model/><value>实际成本</value></cell>
                            <cell styleId="header"><model/><value>差异金额</value></cell>
                            <cell styleId="header"><model/><value>业务日期</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="cell">
                                <model ds="ds" expandType="r" field="workOrderId"/>
                                <value>*=^ds!workOrderId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=workOrderCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=varianceType</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=costElement</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=standardAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=actualAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=varianceAmount</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=businessDate</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="5" styleId="total"><model/><value>差异金额合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(G3)</valueExpr></model>
                            </cell>
                            <cell styleId="cell"/>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
