          class="app.erp.mfg.service.workorder.KitAvailabilityChecker"/>

    <!-- йўҶж–ҷеҮәеә“з§»еҠЁеҚ•иҜ·жұӮжһ„йҖ еҷЁпјҲplan 2026-07-02-2237-1 Phase 3пјүпјҡйўҶж–ҷеҚ•вҶ’StockMoveRequest(MANUFACTURING еҮәеә“) -->
    <bean id="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"
          class="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"/>

    <!-- MRP зӢ¬з«ӢйңҖжұӮж•ҙеҗҲжңҚеҠЎпјҲplan 2026-07-02-2237-2 Phase 1пјүпјҡй”Җе”®и®ўеҚ•/е®үе…Ёеә“еӯҳ/жүӢе·ҘйңҖжұӮ вҶ’ ErpMfgMrpDemand -->
