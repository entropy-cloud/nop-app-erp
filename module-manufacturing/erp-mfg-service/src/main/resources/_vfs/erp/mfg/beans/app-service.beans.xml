          class="app.erp.mfg.service.mrp.DemandAggregator"/>

    <!-- MRP и®Ўз®—еј•ж“ҺпјҲplan 2026-07-02-2237-2 Phase 1пјүпјҡBOM еӨҡзә§еұ•ејҖ + еҮҖйңҖжұӮ + lot sizing + жҸҗеүҚжңҹ вҶ’ ErpMfgMrpPlanLine -->
    <bean id="app.erp.mfg.service.mrp.MrpEngine"
          class="app.erp.mfg.service.mrp.MrpEngine"/>

    <!-- MRP и®ЎеҲ’и®ўеҚ•йҮҠж”ҫжңҚеҠЎпјҲplan 2026-07-02-2237-2 Phase 2пјүпјҡPURCHASE_REQUESTвҶ’йҮҮиҙӯи®ўеҚ• / WORK_ORDER_REQUESTвҶ’е·ҘеҚ• -->
    <bean id="app.erp.mfg.service.mrp.MrpReleaseService"
          class="app.erp.mfg.service.mrp.MrpReleaseService"/>

    <!-- CRP иҙҹиҚ·и®Ўз®—еј•ж“ҺпјҲplan 2026-07-03-1707-1пјүпјҡWorkOrderГ—RoutingOperation еҲҶжҙҫвҶ’workcenterГ—date иҙҹиҚ·еҝ«з…§+жҠҘиЎЁ -->
