    <!-- жҲҗжң¬еҚ·з®—жңҚеҠЎпјҲplan 2026-07-02-1538-2 Phase 3пјүпјҡйҮҮиҙӯд»¶еҹәзЎҖ + еҲ¶йҖ д»¶жқҗж–ҷ+е·Ҙж—¶ вҶ’ ErpMfgCostRollup/Line -->
    <bean id="app.erp.mfg.service.costing.CostRollupService"
          class="app.erp.mfg.service.costing.CostRollupService"/>

    <!-- е·ҘеҚ•йҪҗеҘ—ж ЎйӘҢжңҚеҠЎпјҲplan 2026-07-02-2237-1 Phase 2пјүпјҡBOM еұ•ејҖ Г— plannedQuantity еҜ№з…§ inventory дҪҷйўқеҸҜз”ЁйҮҸ -->
