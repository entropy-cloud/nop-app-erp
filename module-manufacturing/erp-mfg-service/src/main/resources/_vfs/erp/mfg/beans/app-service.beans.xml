<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- BOM 多级展开服务（plan 2026-07-02-1538-2 Phase 2）：phantom/环/深度，供 ErpMfgBomBizModel.explode 调用 -->
    <bean id="app.erp.mfg.service.bom.BomExpander"
          class="app.erp.mfg.service.bom.BomExpander"/>

    <!-- 成本卷算服务（plan 2026-07-02-1538-2 Phase 3）：采购件基础 + 制造件材料+工时 → ErpMfgCostRollup/Line -->
    <bean id="app.erp.mfg.service.costing.CostRollupService"
          class="app.erp.mfg.service.costing.CostRollupService"/>

    <!-- 生产差异计算引擎（plan 2026-07-05-1838-2）：完工触发 / 手动重算 → ErpMfgCostVariance 行 -->
    <bean id="app.erp.mfg.service.costing.ProductionVarianceCalculator"
          class="app.erp.mfg.service.costing.ProductionVarianceCalculator"/>

    <!-- 生产差异过账（plan 2026-07-05-1838-2）：差异计算后按要素汇总净差异 → 凭证 → posted 回写。
          Provider 由 finance ErpFinAcctDocRegistry 跨模块 collect-beans 自动聚合（同 PPV 范式）。 -->
    <bean id="app.erp.mfg.service.posting.MfgPostingExecutor"
          class="app.erp.mfg.service.posting.MfgPostingExecutor"/>
    <bean id="app.erp.mfg.service.posting.ProductionVarianceDispatcher"
          class="app.erp.mfg.service.posting.ProductionVarianceDispatcher"/>
    <bean id="app.erp.mfg.service.posting.ProductionVarianceAcctDocProvider"
          class="app.erp.mfg.service.posting.ProductionVarianceAcctDocProvider"/>

    <!-- 工单齐套校验服务（plan 2026-07-02-2237-1 Phase 2）：BOM 展开 × plannedQuantity 对照 inventory 余额可用量 -->
    <bean id="app.erp.mfg.service.workorder.KitAvailabilityChecker"
          class="app.erp.mfg.service.workorder.KitAvailabilityChecker"/>

    <!-- 领料出库移动单请求构造器（plan 2026-07-02-2237-1 Phase 3）：领料单→StockMoveRequest(MANUFACTURING 出库) -->
    <bean id="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"
          class="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"/>

    <!-- MRP 独立需求整合服务（plan 2026-07-02-2237-2 Phase 1）：销售订单/安全库存/手工需求 → ErpMfgMrpDemand -->
    <bean id="app.erp.mfg.service.mrp.DemandAggregator"
          class="app.erp.mfg.service.mrp.DemandAggregator"/>

    <!-- MRP 计算引擎（plan 2026-07-02-2237-2 Phase 1）：BOM 多级展开 + 净需求 + lot sizing + 提前期 → ErpMfgMrpPlanLine -->
    <bean id="app.erp.mfg.service.mrp.MrpEngine"
          class="app.erp.mfg.service.mrp.MrpEngine"/>

    <!-- MRP 计划订单释放服务（plan 2026-07-02-2237-2 Phase 2）：PURCHASE_REQUEST→采购订单 / WORK_ORDER_REQUEST→工单 -->
    <bean id="app.erp.mfg.service.mrp.MrpReleaseService"
          class="app.erp.mfg.service.mrp.MrpReleaseService"/>

    <!-- CRP 负荷计算引擎（plan 2026-07-03-1707-1）：WorkOrder×RoutingOperation 分派→workcenter×date 负荷快照+报表。
          plan 2026-07-05-0306-2：经 ioc:collect-beans by-type 跨模块收集 aps-service 实现的
          IErpApsLoadSourceProvider（镜像 finance IErpFinAcctDocProvider 跨域 SPI 范式）；
          APS 模块缺失时收集到空 list，CRP 回退 WorkOrder 计划日期（行为不变）。 -->
    <bean id="app.erp.mfg.service.crp.CrpLoadCalculator"
          class="app.erp.mfg.service.crp.CrpLoadCalculator">
        <property name="apsLoadSourceProviders">
            <ioc:collect-beans by-type="app.erp.mfg.biz.IErpApsLoadSourceProvider"
                               only-concrete-classes="true" ioc:ignore-depends="true"/>
        </property>
    </bean>

    <!-- manufacturing 域状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖）。 -->
    <bean id="app.erp.mfg.service.processor.ErpMfgWorkOrderProcessor"
          class="app.erp.mfg.service.processor.ErpMfgWorkOrderProcessor"/>
    <bean id="app.erp.mfg.service.processor.ErpMfgJobCardProcessor"
          class="app.erp.mfg.service.processor.ErpMfgJobCardProcessor"/>

    <!-- APS 排程→工序卡自动生成 Processor（plan 2026-07-05-0427-3）。经 ioc:collect-beans by-type 跨模块收集
           aps-service 实现的 IErpApsLoadSourceProvider（同 CRP SPI 范式）；APS 模块缺失时收集到空 list，
           fetchSlots 返回空、generateJobCardsFromSchedule 抛 ERR_NO_SCHEDULED_OPERATIONS（行为降级）。 -->
    <bean id="app.erp.mfg.service.processor.ErpMfgScheduleToJobCardProcessor"
          class="app.erp.mfg.service.processor.ErpMfgScheduleToJobCardProcessor">
        <property name="apsLoadSourceProviders">
            <ioc:collect-beans by-type="app.erp.mfg.biz.IErpApsLoadSourceProvider"
                               only-concrete-classes="true" ioc:ignore-depends="true"/>
        </property>
    </bean>

    <!-- 定时 CRP 负荷计算 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
           经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-mfg.crp-run-cron 配置门控。 -->
    <bean id="erpMfgCrpRunJob"
          class="app.erp.mfg.service.job.ErpMfgCrpRunJob"/>

    <!-- 定时 APS 排程→工序卡自动生成 Job Bean（plan 2026-07-05-0427-3 Phase 3）。双层门控：
           erp-mfg.jobcard-auto-generate-cron（本 Job cron 空跳过）+ erp-mfg.jobcard-auto-generate-on-schedule
           （Processor 总开关，默认 false）。参照 0306-1 三件套范式。 -->
    <bean id="erpMfgJobCardAutoGenJob"
          class="app.erp.mfg.service.job.ErpMfgJobCardAutoGenJob"/>
</beans>