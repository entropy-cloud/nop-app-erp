<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- BOM 多级展开服务（plan 2026-07-02-1538-2 Phase 2）：phantom/环/深度，供 ErpMfgBomBizModel.explode 调用 -->
    <bean id="app.erp.mfg.service.bom.BomExpander"
          class="app.erp.mfg.service.bom.BomExpander"/>

    <!-- 成本卷算服务（plan 2026-07-02-1538-2 Phase 3）：采购件基础 + 制造件材料+工时 → ErpMfgCostRollup/Line -->
    <bean id="app.erp.mfg.service.costing.CostRollupService"
          class="app.erp.mfg.service.costing.CostRollupService"/>

    <!-- 工单齐套校验服务（plan 2026-07-02-2237-1 Phase 2）：BOM 展开 × plannedQuantity 对照 inventory 余额可用量 -->
    <bean id="app.erp.mfg.service.workorder.KitAvailabilityChecker"
          class="app.erp.mfg.service.workorder.KitAvailabilityChecker"/>

    <!-- 领料出库移动单请求构造器（plan 2026-07-02-2237-1 Phase 3）：领料单→StockMoveRequest(MANUFACTURING 出库) -->
    <bean id="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"
          class="app.erp.mfg.service.entity.MaterialIssueStockMoveBuilder"/>

    <!-- MRP 独立需求整合服务（plan 2026-07-02-2237-2 Phase 1）：销售订单/安全库存/手工需求 → ErpMfgMrpDemand -->
    <bean id="app.erp.mfg.service.mrp.DemandAggregator"
          class="app.erp.mfg.service.mrp.DemandAggregator"/>

    <!-- MRP 计算引擎（plan 2026-07-02-2237-2 Phase 1）：BOM 多级展开 + 净需求 + lot sizing + 提前期 → ErpMfgMrpPlanLine -->
    <bean id="app.erp.mfg.service.mrp.MrpEngine"
          class="app.erp.mfg.service.mrp.MrpEngine"/>

    <!-- MRP 计划订单释放服务（plan 2026-07-02-2237-2 Phase 2）：PURCHASE_REQUEST→采购订单 / WORK_ORDER_REQUEST→工单 -->
    <bean id="app.erp.mfg.service.mrp.MrpReleaseService"
          class="app.erp.mfg.service.mrp.MrpReleaseService"/>

    <!-- manufacturing 域状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖）。 -->
    <bean id="app.erp.mfg.service.processor.ErpMfgWorkOrderProcessor"
          class="app.erp.mfg.service.processor.ErpMfgWorkOrderProcessor"/>
    <bean id="app.erp.mfg.service.processor.ErpMfgJobCardProcessor"
          class="app.erp.mfg.service.processor.ErpMfgJobCardProcessor"/>
</beans>