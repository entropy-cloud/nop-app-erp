<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinFundAccount.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="accountType" mandatory="true" sortable="true"/>
                <col id="subjectId" label="科目"/>
                <col id="bankName" sortable="true"/>
                <col id="bankAccount" sortable="true"/>
                <col id="currencyId" label="币种"/>
                <col id="currentBalance" ui:number="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>