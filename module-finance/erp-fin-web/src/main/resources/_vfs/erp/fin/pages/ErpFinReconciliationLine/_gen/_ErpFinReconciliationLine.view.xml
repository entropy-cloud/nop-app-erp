<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinReconciliationLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinReconciliationLine/ErpFinReconciliationLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--核销单ID-->
                <col id="reconciliationId" mandatory="true" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--付款/收款项(invoice or payment item)-->
                <col id="paymentItemId" mandatory="true" ui:number="true" sortable="true"/>

                <!--被核销发票项-->
                <col id="invoiceItemId" mandatory="true" ui:number="true" sortable="true"/>

                <!--核销金额(源币)-->
                <col id="settledAmountSource" mandatory="true" ui:number="true" sortable="true"/>

                <!--核销金额(本位币)-->
                <col id="settledAmountFunctional" mandatory="true" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-核销单行" i18n-en:title="View Reconciliation Line">
            <layout>
 id[ID] reconciliationId[核销单ID]
 lineNo[行号] paymentItemId[付款/收款项(invoice or payment item)]
 invoiceItemId[被核销发票项] settledAmountSource[核销金额(源币)]
 settledAmountFunctional[核销金额(本位币)] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-核销单行" i18n-en:title="Add Reconciliation Line">
            <layout>
 id[ID]
 reconciliationId[核销单ID]
 lineNo[行号]
 paymentItemId[付款/收款项(invoice or payment item)]
 invoiceItemId[被核销发票项]
 settledAmountSource[核销金额(源币)]
 settledAmountFunctional[核销金额(本位币)]
 remark[备注]
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-核销单行" i18n-en:title="Edit Reconciliation Line">
            <layout>
 id[ID]
 reconciliationId[核销单ID]
 lineNo[行号]
 paymentItemId[付款/收款项(invoice or payment item)]
 invoiceItemId[被核销发票项]
 settledAmountSource[核销金额(源币)]
 settledAmountFunctional[核销金额(本位币)]
 remark[备注]
 delVersion[逻辑删除版本]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-核销单行"
              i18n-en:title="Update Reconciliation Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinReconciliationLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinReconciliationLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinReconciliationLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinReconciliationLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinReconciliationLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinReconciliationLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinReconciliationLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinReconciliationLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinReconciliationLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinReconciliationLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>