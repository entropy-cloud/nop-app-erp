<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinAccountingPeriod.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] name[名称]
 orgId[业务组织] year[年度]
 month[月份] quarter[季度]
 startDate[开始日期] endDate[结束日期]
 isAdjustment[是否调整期]
=========>status[状态信息]======
 status[期间状态] closedBy[关闭人]
 closedAt[关闭时间]
=========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] name[名称]
 orgId[业务组织] year[年度]
 month[月份] quarter[季度]
 startDate[开始日期] endDate[结束日期]
 isAdjustment[是否调整期]
=========>status[状态信息]======
 status[期间状态] closedBy[关闭人]
 closedAt[关闭时间]
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编码] name[名称]
 year[年度] status[期间状态]
 orgId[业务组织]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="year" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-close-period-button" label="结账" level="primary" icon="fa fa-lock">
                    <api url="@mutation:ErpFinAccountingPeriod__closePeriod?periodId=$id"/>
                    <confirmText>确认结账此会计期间？结账后该期间凭证不可修改。</confirmText>
                    <messages>
                        <success>会计期间已结账</success>
                    </messages>
                    <visibleOn>${status == 'OPEN' || status == 'CLOSING'}</visibleOn>
                </action>
                <action id="row-reverse-close-button" label="反结账" level="warning" icon="fa fa-unlock">
                    <api url="@mutation:ErpFinAccountingPeriod__reverseClose?periodId=$id"/>
                    <confirmText>确认反结账此会计期间？</confirmText>
                    <messages>
                        <success>会计期间已反结账</success>
                    </messages>
                    <visibleOn>${status == 'CLOSED' || status == 'CLOSED_FINAL'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>