<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBudgetLine.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="scenario" label="预算方案"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="acctSchema" label="账套"/>
                <col id="period" label="会计期间"/>
                <col id="subjectCode" mandatory="true" sortable="true"/>
                <col id="subjectId" label="科目名称"/>
                <col id="costCenterId" label="成本中心"/>
                <col id="departmentId" label="部门"/>
                <col id="projectId" label="项目"/>
                <col id="partnerId" label="往来单位"/>
                <col id="warehouseId" label="仓库"/>
                <col id="materialId" label="物料"/>
                <col id="budgetAmountSource" ui:number="true" sortable="true"/>
                <col id="budgetAmountFunctional" ui:number="true" sortable="true"/>
                <col id="currencyId" label="币种"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>