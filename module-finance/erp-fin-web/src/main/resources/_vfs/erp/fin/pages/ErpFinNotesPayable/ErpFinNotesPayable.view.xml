<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinNotesPayable.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="notesType" mandatory="true" sortable="true"/>
                <col id="notesNo" sortable="true"/>
                <col id="payeeName" sortable="true"/>
                <col id="issueDate" sortable="true"/>
                <col id="dueDate" sortable="true"/>
                <col id="currencyName" label="币种"/>
                <col id="amountSource" ui:number="true" sortable="true"/>
                <col id="amountFunctional" ui:number="true" sortable="true"/>
                <col id="partnerName" label="收款方"/>
                <col id="creditFacilityCode" label="授信额度"/>
                <col id="status" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>