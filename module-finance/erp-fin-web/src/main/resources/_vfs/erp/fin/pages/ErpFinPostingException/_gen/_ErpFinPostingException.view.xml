<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinPostingException" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinPostingException/ErpFinPostingException.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--追踪ID-->
                <col id="traceId" sortable="true"/>

                <!--单据编号-->
                <col id="billHeadCode" sortable="true"/>

                <!--业务类型-->
                <col id="businessType" sortable="true"/>

                <!--过账类型-->
                <col id="postingType" sortable="true"/>

                <!--错误码-->
                <col id="errorCode" mandatory="true" sortable="true"/>

                <!--错误信息-->
                <col id="errorMessage" sortable="true"/>

                <!--失败阶段-->
                <col id="failedStage" sortable="true"/>

                <!--凭证日期-->
                <col id="voucherDate" sortable="true"/>

                <!--核算组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--账套-->
                <col id="acctSchemaId" ui:number="true" sortable="true"/>

                <!--处置状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--重试次数-->
                <col id="retryCount" ui:number="true" sortable="true"/>

                <!--处置动作-->
                <col id="resolution" sortable="true"/>

                <!--处置说明-->
                <col id="resolutionNote" sortable="true"/>

                <!--处置人-->
                <col id="resolvedBy" sortable="true"/>

                <!--处置时间-->
                <col id="resolvedAt" sortable="true"/>

                <!--关联凭证ID-->
                <col id="voucherId" ui:number="true" sortable="true"/>

                <!--发生时间-->
                <col id="occurrenceTime" mandatory="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" ui:number="true" sortable="true"/>

                <!--原始事件数据(JSON)-->
                <col id="eventData" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-过账异常记录" i18n-en:title="View Posting Exception">
            <layout>
 traceId[追踪ID] billHeadCode[单据编号]
 businessType[业务类型] postingType[过账类型]
 errorCode[错误码] errorMessage[错误信息]
 failedStage[失败阶段] voucherDate[凭证日期]
 orgId[核算组织] acctSchemaId[账套]
 status[处置状态] retryCount[重试次数]
 resolution[处置动作] resolutionNote[处置说明]
 resolvedBy[处置人] resolvedAt[处置时间]
 voucherId[关联凭证ID] occurrenceTime[发生时间]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] currencyId[币种]
 exchangeRate[汇率] eventData[原始事件数据(JSON)]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-过账异常记录" i18n-en:title="Add Posting Exception" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-过账异常记录" i18n-en:title="Edit Posting Exception">
            <layout>
 traceId[追踪ID] billHeadCode[单据编号]
 businessType[业务类型] postingType[过账类型]
 errorCode[错误码] errorMessage[错误信息]
 failedStage[失败阶段] voucherDate[凭证日期]
 orgId[核算组织] acctSchemaId[账套]
 status[处置状态] retryCount[重试次数]
 resolution[处置动作] resolutionNote[处置说明]
 resolvedBy[处置人] resolvedAt[处置时间]
 voucherId[关联凭证ID] occurrenceTime[发生时间]
 currencyId[币种] exchangeRate[汇率]
 eventData[原始事件数据(JSON)] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-过账异常记录"
              i18n-en:title="Update Posting Exception"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinPostingException__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinPostingException__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinPostingException__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinPostingException__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinPostingException__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinPostingException__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinPostingException__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinPostingException__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinPostingException__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinPostingException__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>