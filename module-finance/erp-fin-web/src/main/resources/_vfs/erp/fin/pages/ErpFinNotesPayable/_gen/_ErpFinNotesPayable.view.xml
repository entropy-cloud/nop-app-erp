<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinNotesPayable" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinNotesPayable/ErpFinNotesPayable.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--核算组织-->
                <col id="orgId" mandatory="true" ui:number="true" sortable="true"/>

                <!--票据类型-->
                <col id="notesType" mandatory="true" sortable="true"/>

                <!--票据号-->
                <col id="notesNo" sortable="true"/>

                <!--收款人-->
                <col id="payeeName" sortable="true"/>

                <!--收款行-->
                <col id="payeeBank" sortable="true"/>

                <!--出票日-->
                <col id="issueDate" sortable="true"/>

                <!--到期日-->
                <col id="dueDate" sortable="true"/>

                <!--币种-->
                <col id="currencyId" mandatory="true" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" ui:number="true" sortable="true"/>

                <!--源币种票面金额-->
                <col id="amountSource" ui:number="true" sortable="true"/>

                <!--本位币票面金额-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>

                <!--收款方往来-->
                <col id="partnerId" ui:number="true" sortable="true"/>

                <!--占用授信额度-->
                <col id="creditFacilityId" ui:number="true" sortable="true"/>

                <!--来源单据类型-->
                <col id="sourceBillType" sortable="true"/>

                <!--来源单据号-->
                <col id="sourceBillCode" sortable="true"/>

                <!--票据状态-->
                <col id="status" sortable="true"/>

                <!--是否已过账-->
                <col id="posted" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务组织名称-->
                <col id="orgName"/>

                <!--币种名称-->
                <col id="currencyName"/>

                <!--收款方名称-->
                <col id="partnerName"/>

                <!--授信额度单号-->
                <col id="creditFacilityCode"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-应付票据" i18n-en:title="View Notes Payable">
            <layout>
 code[单号] orgId[核算组织]
 notesType[票据类型] notesNo[票据号]
 payeeName[收款人] payeeBank[收款行]
 issueDate[出票日] dueDate[到期日]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种票面金额] amountFunctional[本位币票面金额]
 partnerId[收款方往来] creditFacilityId[占用授信额度]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 status[票据状态] posted[是否已过账]
 postedBy[过账人] postedAt[过账时间]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 orgName[业务组织名称] currencyName[币种名称]
 partnerName[收款方名称] creditFacilityCode[授信额度单号]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-应付票据" i18n-en:title="Add Notes Payable" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-应付票据" i18n-en:title="Edit Notes Payable">
            <layout>
 code[单号] orgId[核算组织]
 notesType[票据类型] notesNo[票据号]
 payeeName[收款人] payeeBank[收款行]
 issueDate[出票日] dueDate[到期日]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种票面金额] amountFunctional[本位币票面金额]
 partnerId[收款方往来] creditFacilityId[占用授信额度]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 status[票据状态] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-应付票据" i18n-en:title="Update Notes Payable"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinNotesPayable__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinNotesPayable__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinNotesPayable__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinNotesPayable__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinNotesPayable__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinNotesPayable__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinNotesPayable__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinNotesPayable__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinNotesPayable__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinNotesPayable__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>