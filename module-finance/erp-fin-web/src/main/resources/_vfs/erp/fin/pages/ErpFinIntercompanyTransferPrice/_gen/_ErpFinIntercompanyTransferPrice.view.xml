<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinIntercompanyTransferPrice" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinIntercompanyTransferPrice/ErpFinIntercompanyTransferPrice.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--规则编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--规则名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--核算组织-->
                <col id="orgId" mandatory="true" ui:number="true" sortable="true"/>

                <!--调出组织(空=通配)-->
                <col id="fromOrgId" ui:number="true" sortable="true"/>

                <!--调入组织(空=通配)-->
                <col id="toOrgId" ui:number="true" sortable="true"/>

                <!--物料(空=通配)-->
                <col id="materialId" ui:number="true" sortable="true"/>

                <!--物料分类(空=通配)-->
                <col id="materialCategoryId" ui:number="true" sortable="true"/>

                <!--定价方法-->
                <col id="pricingMethod" mandatory="true" sortable="true"/>

                <!--加成率(COST_PLUS)-->
                <col id="markupRate" ui:number="true" sortable="true"/>

                <!--固定单价(NEGOTIATED/MARKET兜底)-->
                <col id="fixedPrice" ui:number="true" sortable="true"/>

                <!--市场价来源说明(MARKET)-->
                <col id="marketRefSource" sortable="true"/>

                <!--生效日期-->
                <col id="validFrom" sortable="true"/>

                <!--失效日期-->
                <col id="validTo" sortable="true"/>

                <!--是否启用-->
                <col id="isActive" mandatory="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-跨法人转移定价规则" i18n-en:title="View Intercompany Transfer Price">
            <layout>
 code[规则编码] name[规则名称]
 orgId[核算组织] fromOrgId[调出组织(空=通配)]
 toOrgId[调入组织(空=通配)] materialId[物料(空=通配)]
 materialCategoryId[物料分类(空=通配)] pricingMethod[定价方法]
 markupRate[加成率(COST_PLUS)] fixedPrice[固定单价(NEGOTIATED/MARKET兜底)]
 marketRefSource[市场价来源说明(MARKET)] validFrom[生效日期]
 validTo[失效日期] isActive[是否启用]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-跨法人转移定价规则" i18n-en:title="Add Intercompany Transfer Price"
              x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-跨法人转移定价规则" i18n-en:title="Edit Intercompany Transfer Price">
            <layout>
 code[规则编码] name[规则名称]
 orgId[核算组织] fromOrgId[调出组织(空=通配)]
 toOrgId[调入组织(空=通配)] materialId[物料(空=通配)]
 materialCategoryId[物料分类(空=通配)] pricingMethod[定价方法]
 markupRate[加成率(COST_PLUS)] fixedPrice[固定单价(NEGOTIATED/MARKET兜底)]
 marketRefSource[市场价来源说明(MARKET)] validFrom[生效日期]
 validTo[失效日期] isActive[是否启用]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-跨法人转移定价规则"
              i18n-en:title="Update Intercompany Transfer Price"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinIntercompanyTransferPrice__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinIntercompanyTransferPrice__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinIntercompanyTransferPrice__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinIntercompanyTransferPrice__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinIntercompanyTransferPrice__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinIntercompanyTransferPrice__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinIntercompanyTransferPrice__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinIntercompanyTransferPrice__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinIntercompanyTransferPrice__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinIntercompanyTransferPrice__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>