<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBankReconciliation.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="fundAccountId" label="资金账户"/>
                <col id="statement" label="对账单"/>
                <col id="reconciliationDate" mandatory="true" sortable="true"/>
                <col id="bookBalance" mandatory="true" ui:number="true" sortable="true"/>
                <col id="statementBalance" mandatory="true" ui:number="true" sortable="true"/>
                <col id="unreconciledDiff" ui:number="true" sortable="true"/>
                <col id="isBalanced" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>