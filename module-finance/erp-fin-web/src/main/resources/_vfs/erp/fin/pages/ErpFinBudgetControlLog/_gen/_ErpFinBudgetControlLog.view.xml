<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinBudgetControlLog" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinBudgetControlLog/ErpFinBudgetControlLog.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--核算组织-->
                <col id="orgId" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--预算方案-->
                <col id="scenarioId" ui:number="true" sortable="true"/>

                <!--预算明细行-->
                <col id="budgetLineId" ui:number="true" sortable="true"/>

                <!--触发单据类型-->
                <col id="sourceBillType" mandatory="true" sortable="true"/>

                <!--触发单据号-->
                <col id="sourceBillCode" mandatory="true" sortable="true"/>

                <!--命中科目-->
                <col id="subjectId" ui:number="true" sortable="true"/>

                <!--命中成本中心-->
                <col id="costCenterId" ui:number="true" sortable="true"/>

                <!--命中项目-->
                <col id="projectId" ui:number="true" sortable="true"/>

                <!--命中期间-->
                <col id="periodId" ui:number="true" sortable="true"/>

                <!--申请占用金额-->
                <col id="requestedAmount" mandatory="true" ui:number="true" sortable="true"/>

                <!--实际占用金额-->
                <col id="committedAmount" ui:number="true" sortable="true"/>

                <!--检查时余量-->
                <col id="availableAmount" ui:number="true" sortable="true"/>

                <!--控制结果-->
                <col id="actionResult" mandatory="true" sortable="true"/>

                <!--操作人-->
                <col id="operatorId" sortable="true"/>

                <!--操作时间-->
                <col id="operatedAt" sortable="true"/>

                <!--原因-->
                <col id="reason" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-预算控制日志" i18n-en:title="View Budget Control Log">
            <layout>
 id[ID] orgId[核算组织]
 businessDate[业务日期] scenarioId[预算方案]
 budgetLineId[预算明细行] sourceBillType[触发单据类型]
 sourceBillCode[触发单据号] subjectId[命中科目]
 costCenterId[命中成本中心] projectId[命中项目]
 periodId[命中期间] requestedAmount[申请占用金额]
 committedAmount[实际占用金额] availableAmount[检查时余量]
 actionResult[控制结果] operatorId[操作人]
 operatedAt[操作时间] reason[原因]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-预算控制日志" i18n-en:title="Add Budget Control Log" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-预算控制日志" i18n-en:title="Edit Budget Control Log">
            <layout>
 id[ID] orgId[核算组织]
 businessDate[业务日期] scenarioId[预算方案]
 budgetLineId[预算明细行] sourceBillType[触发单据类型]
 sourceBillCode[触发单据号] subjectId[命中科目]
 costCenterId[命中成本中心] projectId[命中项目]
 periodId[命中期间] requestedAmount[申请占用金额]
 committedAmount[实际占用金额] availableAmount[检查时余量]
 actionResult[控制结果] operatorId[操作人]
 operatedAt[操作时间] reason[原因]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-预算控制日志"
              i18n-en:title="Update Budget Control Log"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinBudgetControlLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinBudgetControlLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinBudgetControlLog__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinBudgetControlLog__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinBudgetControlLog__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinBudgetControlLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinBudgetControlLog__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinBudgetControlLog__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinBudgetControlLog__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinBudgetControlLog__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>