<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinPostingException.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="traceId" sortable="true"/>
                <col id="billHeadCode" sortable="true"/>
                <col id="businessType" sortable="true"/>
                <col id="postingType" sortable="true"/>
                <col id="errorCode" mandatory="true" sortable="true"/>
                <col id="errorMessage" sortable="true"/>
                <col id="failedStage" sortable="true"/>
                <col id="voucherDate" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="acctSchemaCode" label="账套"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="voucherCode" label="凭证号"/>
                <col id="currencyId" label="币种"/>
                <col id="occurrenceTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>