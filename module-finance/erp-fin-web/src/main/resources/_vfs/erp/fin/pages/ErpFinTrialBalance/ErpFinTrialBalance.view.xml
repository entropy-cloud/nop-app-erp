<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinTrialBalance.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 periodId[期间] subjectId[科目]
 acctSchemaId[账套] __includeUnposted[含未过账]
            </layout>
            <cells>
                <cell id="periodId" filterOp="eq"/>
                <cell id="subjectId" filterOp="eq"/>
                <cell id="acctSchemaId" filterOp="eq"/>
                <cell id="__includeUnposted" custom="true" domain="boolean" defaultValue="false"
                      label="含未过账"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 periodId[期间] subjectCode[科目编码]
            </layout>
            <cells>
                <cell id="periodId" filterOp="eq"/>
                <cell id="subjectCode" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
