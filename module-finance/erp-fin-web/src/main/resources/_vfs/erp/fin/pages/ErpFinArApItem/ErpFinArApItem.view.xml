<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinArApItem.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="acctSchema" label="账套"/>
                <col id="direction" mandatory="true" sortable="true"/>
                <col id="partnerId" label="往来单位"/>
                <col id="sourceBillType" mandatory="true" sortable="true"/>
                <col id="sourceBillCode" mandatory="true" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="dueDate" sortable="true"/>
                <col id="currencyId" label="币种"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="period" label="会计期间"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>