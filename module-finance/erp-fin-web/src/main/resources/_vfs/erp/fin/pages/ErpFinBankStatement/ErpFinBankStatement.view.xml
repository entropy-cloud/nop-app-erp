<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBankStatement.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="fundAccountName" label="资金账户"/>
                <col id="statementDate" mandatory="true" sortable="true"/>
                <col id="beginningBalance" ui:number="true" sortable="true"/>
                <col id="endingBalance" ui:number="true" sortable="true"/>
                <col id="totalDebit" ui:number="true" sortable="true"/>
                <col id="totalCredit" ui:number="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>