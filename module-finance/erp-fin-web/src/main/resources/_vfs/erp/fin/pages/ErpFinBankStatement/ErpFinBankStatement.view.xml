<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBankStatement.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="fundAccountId" label="资金账户"/>
                <col id="statementDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="beginningBalance" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endingBalance" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalDebit" ui:number="true" sortable="true"/>
                <col id="totalCredit" ui:number="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 fundAccountId[资金账户] statementDate[对账单日期]
=========>amount[金额信息]======
 beginningBalance[期初余额] endingBalance[期末余额]
 totalDebit[借方合计] totalCredit[贷方合计]
=========>status[状态信息]======
 docStatus[单据状态] importTime[导入时间]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 fundAccountId[资金账户] statementDate[对账单日期]
=========>amount[金额信息]======
 beginningBalance[期初余额] endingBalance[期末余额]
 totalDebit[借方合计] totalCredit[贷方合计]
=========>status[状态信息]======
 docStatus[单据状态] importTime[导入时间]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] fundAccountId[资金账户]
 docStatus[单据状态] orgId[业务组织]
 statementDate[对账单日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="fundAccountId" filterOp="eq"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="statementDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>