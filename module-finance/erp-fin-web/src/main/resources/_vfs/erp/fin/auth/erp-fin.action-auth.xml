<?xml version="1.0" encoding="UTF-8" ?>
<auth x:extends="_erp-fin.action-auth.xml" x:schema="/nop/schema/action-auth.xdef"
     xmlns:x="/nop/schema/xdsl.xdef" xmlns:i18n-en="i18n-en" xmlns:app="app">

    <site id="main">
        <!-- 删除自动生成的测试菜单根 -->
        <resource id="test-orm-erp-fin" x:override="remove"/>

        <!-- 财务管理:finance域一级菜单 -->
        <resource id="erp-fin" displayName="财务管理" i18n-en:displayName="Finance"
                  icon="landmark" resourceType="TOPM" orderNo="500"
                  routePath="/erp-fin" component="layouts/default/index">
            <children>
                <!-- 凭证 -->
                <resource id="fin-voucher" displayName="凭证" i18n-en:displayName="Voucher"
                          icon="book-up" resourceType="SUBM" orderNo="100">
                    <children>
                        <resource id="ErpFinVoucher-main" app:useCases="UC-FIN-01,UC-FIN-02,UC-FIN-12" displayName="会计凭证"
                                  i18n-en:displayName="Accounting Voucher" icon="book-up"
                                  component="AMIS" resourceType="SUBM" orderNo="100"
                                  url="/erp/fin/pages/ErpFinVoucher/main.page.yaml"/>
                        <resource id="ErpFinVoucherTemplate-main" app:useCases="UC-FIN-01" displayName="凭证模板"
                                  i18n-en:displayName="Voucher Template" icon="book-template"
                                  component="AMIS" resourceType="SUBM" orderNo="110"
                                  url="/erp/fin/pages/ErpFinVoucherTemplate/main.page.yaml"/>
                        <resource id="ErpFinVoucherBillR-main" app:useCases="UC-FIN-01,UC-FIN-02" displayName="业财回链"
                                  i18n-en:displayName="Voucher Business Link" icon="link"
                                  component="AMIS" resourceType="SUBM" orderNo="120"
                                  url="/erp/fin/pages/ErpFinVoucherBillR/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 会计期间 -->
                <resource id="fin-period" displayName="会计期间" i18n-en:displayName="Accounting Period"
                          icon="calendar" resourceType="SUBM" orderNo="200">
                    <children>
                        <resource id="ErpFinAccountingPeriod-main" app:useCases="UC-FIN-06,UC-FIN-07" displayName="会计期间"
                                  i18n-en:displayName="Accounting Period" icon="calendar"
                                  component="AMIS" resourceType="SUBM" orderNo="200"
                                  url="/erp/fin/pages/ErpFinAccountingPeriod/main.page.yaml"/>
                        <resource id="ErpFinAccountingPeriodStatus-main" app:useCases="UC-FIN-06,UC-FIN-07" displayName="期间结账状态"
                                  i18n-en:displayName="Period Close Status" icon="calendar-check"
                                  component="AMIS" resourceType="SUBM" orderNo="210"
                                  url="/erp/fin/pages/ErpFinAccountingPeriodStatus/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 应收应付 -->
                <resource id="fin-arap" displayName="应收应付" i18n-en:displayName="AR/AP"
                          icon="arrow-left-right" resourceType="SUBM" orderNo="300">
                    <children>
                        <resource id="ErpFinArApItem-main" app:useCases="UC-FIN-08" displayName="应收应付明细账"
                                  i18n-en:displayName="AR/AP Subledger" icon="arrow-left-right"
                                  component="AMIS" resourceType="SUBM" orderNo="300"
                                  url="/erp/fin/pages/ErpFinArApItem/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 核销 -->
                <resource id="fin-recon" displayName="核销" i18n-en:displayName="Reconciliation"
                          icon="check-check" resourceType="SUBM" orderNo="400">
                    <children>
                        <resource id="ErpFinReconciliation-main" app:useCases="UC-FIN-08" displayName="核销单"
                                  i18n-en:displayName="Reconciliation" icon="check-check"
                                  component="AMIS" resourceType="SUBM" orderNo="400"
                                  url="/erp/fin/pages/ErpFinReconciliation/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 总账 -->
                <resource id="fin-gl" displayName="总账" i18n-en:displayName="General Ledger"
                          icon="scale" resourceType="SUBM" orderNo="500">
                    <children>
                        <resource id="ErpFinGlBalance-main" app:useCases="UC-FIN-05,UC-FIN-11" displayName="总账余额"
                                  i18n-en:displayName="GL Balance" icon="scale"
                                  component="AMIS" resourceType="SUBM" orderNo="500"
                                  url="/erp/fin/pages/ErpFinGlBalance/main.page.yaml"/>
                        <resource id="ErpFinTrialBalance-main" app:useCases="UC-FIN-01" displayName="试算平衡表"
                                  i18n-en:displayName="Trial Balance" icon="git-compare"
                                  component="AMIS" resourceType="SUBM" orderNo="510"
                                  url="/erp/fin/pages/ErpFinTrialBalance/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 资金 -->
                <resource id="fin-fund" displayName="资金" i18n-en:displayName="Fund"
                          icon="wallet" resourceType="SUBM" orderNo="600">
                    <children>
                        <resource id="ErpFinFundAccount-main" app:useCases="UC-FIN-09" displayName="资金账户"
                                  i18n-en:displayName="Fund Account" icon="wallet"
                                  component="AMIS" resourceType="SUBM" orderNo="600"
                                  url="/erp/fin/pages/ErpFinFundAccount/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 财务报表 -->
                <resource id="fin-report" displayName="财务报表" i18n-en:displayName="Financial Statements"
                          icon="bar-chart-3" resourceType="SUBM" orderNo="700">
                    <children>
                        <resource id="balance-sheet" displayName="资产负债表"
                                  i18n-en:displayName="Balance Sheet" icon="scale"
                                  component="AMIS" resourceType="SUBM" orderNo="7010"
                                  url="/erp/fin/pages/report/balance-sheet.page.yaml"/>
                        <resource id="income-statement" displayName="利润表"
                                  i18n-en:displayName="Income Statement" icon="trending-up"
                                  component="AMIS" resourceType="SUBM" orderNo="7020"
                                  url="/erp/fin/pages/report/income-statement.page.yaml"/>
                        <resource id="cash-flow" displayName="现金流量表"
                                  i18n-en:displayName="Cash Flow Statement" icon="banknote"
                                  component="AMIS" resourceType="SUBM" orderNo="7030"
                                  url="/erp/fin/pages/report/cash-flow.page.yaml"/>
                    </children>
                </resource>
                <!-- 科目分摊 -->
                <resource id="fin-distribution" displayName="科目分摊" i18n-en:displayName="GL Distribution"
                          icon="split" resourceType="SUBM" orderNo="800">
                    <children>
                        <resource id="gl-distribution" displayName="分摊规则"
                                  i18n-en:displayName="Distribution Rule" icon="split"
                                  component="AMIS" resourceType="SUBM" orderNo="8010"
                                  url="/erp/fin/pages/gl-distribution/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 费用报销 -->
                <resource id="fin-expense" displayName="费用报销" i18n-en:displayName="Expense Claim"
                          icon="wallet-receipt" resourceType="SUBM" orderNo="900">
                    <children>
                        <resource id="expense-claim" displayName="费用报销单"
                                  i18n-en:displayName="Expense Claim" icon="wallet-receipt"
                                  component="AMIS" resourceType="SUBM" orderNo="9010"
                                  url="/erp/fin/pages/expense-claim/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 报表看板 -->
                <resource id="fin-dashboard" displayName="财务概览" i18n-en:displayName="Finance Overview"
                          icon="pie-chart" resourceType="SUBM" orderNo="999">
                    <children>
                        <resource id="fin-dashboard-main" displayName="财务概览"
                                  i18n-en:displayName="Finance Overview" icon="pie-chart"
                                  component="AMIS" resourceType="SUBM" orderNo="9990"
                                  url="/erp/fin/pages/dashboard/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 预算管理 -->
                <resource id="fin-budget" displayName="预算管理" i18n-en:displayName="Budget"
                          icon="wallet" resourceType="SUBM" orderNo="1000">
                    <children>
                        <resource id="budget-scenario" displayName="预算方案"
                                  i18n-en:displayName="Budget Scenario" icon="wallet"
                                  component="AMIS" resourceType="SUBM" orderNo="10010"
                                  url="/erp/fin/pages/budget-scenario/main.page.yaml"/>
                        <resource id="budget-control-log" displayName="预算控制日志"
                                  i18n-en:displayName="Budget Control Log" icon="shield-alert"
                                  component="AMIS" resourceType="SUBM" orderNo="10020"
                                  url="/erp/fin/pages/budget-control-log/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 银行对账 -->
                <resource id="fin-bank-recon" displayName="银行对账" i18n-en:displayName="Bank Reconciliation"
                          icon="landmark" resourceType="SUBM" orderNo="1100">
                    <children>
                        <resource id="bank-statement" displayName="银行对账单"
                                  i18n-en:displayName="Bank Statement" icon="receipt"
                                  component="AMIS" resourceType="SUBM" orderNo="11010"
                                  url="/erp/fin/pages/bank-statement/main.page.yaml"/>
                        <resource id="bank-ledger-line" displayName="账面流水"
                                  i18n-en:displayName="Bank Ledger Line" icon="list"
                                  component="AMIS" resourceType="SUBM" orderNo="11020"
                                  url="/erp/fin/pages/bank-ledger-line/main.page.yaml"/>
                        <resource id="bank-reconciliation" displayName="余额调节表"
                                  i18n-en:displayName="Bank Reconciliation" icon="scale"
                                  component="AMIS" resourceType="SUBM" orderNo="11030"
                                  url="/erp/fin/pages/bank-reconciliation/main.page.yaml"/>
                    </children>
                </resource>
            </children>
        </resource>
    </site>
</auth>
