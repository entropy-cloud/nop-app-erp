<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBadDebt.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="acctSchemaCode" label="账套"/>
                <col id="docType" mandatory="true" sortable="true"/>
                <col id="partnerId" label="客户"/>
                <col id="amount" mandatory="true" ui:number="true" sortable="true"/>
                <col id="currencyId" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="approvalStatus" mandatory="true" sortable="true"/>
                <col id="periodCode" label="会计期间"/>
                <col id="voucherCode" label="凭证号"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>