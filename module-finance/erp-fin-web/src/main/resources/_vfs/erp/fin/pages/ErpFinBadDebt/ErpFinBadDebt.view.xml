<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBadDebt.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="acctSchema" label="账套"/>
                <col id="docType" mandatory="true" sortable="true"/>
                <col id="partnerId" label="客户"/>
                <col id="amount" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approvalStatus" mandatory="true" sortable="true"/>
                <col id="period" label="会计期间"/>
                <col id="voucher" label="凭证号"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 acctSchemaId[账套] docType[单据类型]
 partnerId[往来单位] sourceArApItemId[应收应付明细ID]
 businessDate[业务日期] reason[坏账原因]
=========>amount[金额信息]======
 amount[坏账金额] currencyId[币种]
 exchangeRate[汇率]
=========>status[状态信息]======
 approvalStatus[审批状态] periodId[会计期间]
 voucherId[凭证ID]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 acctSchemaId[账套] docType[单据类型]
 partnerId[往来单位] sourceArApItemId[应收应付明细ID]
 businessDate[业务日期] reason[坏账原因]
=========>amount[金额信息]======
 amount[坏账金额] currencyId[币种]
 exchangeRate[汇率]
=========>status[状态信息]======
 approvalStatus[审批状态] periodId[会计期间]
 voucherId[凭证ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] partnerId[往来单位]
 docType[单据类型] approvalStatus[审批状态]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="partnerId" filterOp="eq"/>
                <cell id="docType" filterOp="eq"/>
                <cell id="approvalStatus" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>