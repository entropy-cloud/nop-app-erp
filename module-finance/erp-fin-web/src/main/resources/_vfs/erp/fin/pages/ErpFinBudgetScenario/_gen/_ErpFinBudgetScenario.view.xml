<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpFinBudgetScenario" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/fin/model/ErpFinBudgetScenario/ErpFinBudgetScenario.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--方案编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--方案名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--核算组织-->
                <col id="orgId" mandatory="true" ui:number="true" sortable="true"/>

                <!--账套-->
                <col id="acctSchemaId" mandatory="true" ui:number="true" sortable="true"/>

                <!--预算年度-->
                <col id="fiscalYear" mandatory="true" ui:number="true" sortable="true"/>

                <!--方案类型-->
                <col id="scenarioType" mandatory="true" sortable="true"/>

                <!--源方案(调整预算版本链)-->
                <col id="parentScenarioId" ui:number="true" sortable="true"/>

                <!--生效日期-->
                <col id="validFrom" sortable="true"/>

                <!--失效日期-->
                <col id="validTo" sortable="true"/>

                <!--币种-->
                <col id="currencyId" mandatory="true" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" ui:number="true" sortable="true"/>

                <!--预算金额(源币种)-->
                <col id="amountSource" ui:number="true" sortable="true"/>

                <!--预算金额(本位币)-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>

                <!--控制级别-->
                <col id="controlLevel" mandatory="true" sortable="true"/>

                <!--方案状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" mandatory="true" sortable="true"/>

                <!--关联预算凭证ID-->
                <col id="voucherId" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-预算方案" i18n-en:title="View Budget Scenario">
            <layout>
 code[方案编码] name[方案名称]
 orgId[核算组织] acctSchemaId[账套]
 fiscalYear[预算年度] scenarioType[方案类型]
 parentScenarioId[源方案(调整预算版本链)] validFrom[生效日期]
 validTo[失效日期] currencyId[币种]
 exchangeRate[汇率] amountSource[预算金额(源币种)]
 amountFunctional[预算金额(本位币)] controlLevel[控制级别]
 docStatus[方案状态] approveStatus[审核状态]
 voucherId[关联预算凭证ID] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-预算方案" i18n-en:title="Add Budget Scenario" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-预算方案" i18n-en:title="Edit Budget Scenario">
            <layout>
 code[方案编码] name[方案名称]
 orgId[核算组织] acctSchemaId[账套]
 fiscalYear[预算年度] scenarioType[方案类型]
 parentScenarioId[源方案(调整预算版本链)] validFrom[生效日期]
 validTo[失效日期] currencyId[币种]
 exchangeRate[汇率] amountSource[预算金额(源币种)]
 amountFunctional[预算金额(本位币)] controlLevel[控制级别]
 docStatus[方案状态] approveStatus[审核状态]
 voucherId[关联预算凭证ID] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-预算方案" i18n-en:title="Update Budget Scenario"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinBudgetScenario__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpFinBudgetScenario__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpFinBudgetScenario__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpFinBudgetScenario__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpFinBudgetScenario__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpFinBudgetScenario__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpFinBudgetScenario__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpFinBudgetScenario__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpFinBudgetScenario__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpFinBudgetScenario__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>