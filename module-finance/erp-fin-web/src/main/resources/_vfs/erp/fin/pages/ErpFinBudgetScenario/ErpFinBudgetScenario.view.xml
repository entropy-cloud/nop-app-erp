<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinBudgetScenario.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <!-- 预算方案列表：仅保留业务关键字段（bounded-merge 丢弃生成层冗余列） -->
            <cols x:override="bounded-merge">
                <col id="code" label="方案编码"/>
                <col id="name" label="方案名称"/>
                <col id="fiscalYear" label="预算年度"/>
                <col id="scenarioType" label="方案类型"/>
                <col id="budgetGroupCode" label="预算组"/>
                <col id="amountFunctional" label="预算金额(本位币)"/>
                <col id="controlLevel" label="控制级别"/>
                <col id="docStatus" label="方案状态">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approveStatus" label="审核状态">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'approveStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : "
                                    + valueProp + " == 'REJECTED' ? 'danger' : "
                                    + valueProp + " == 'SUBMITTED' ? 'info' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
========>baseInfo[基本信息]======
 code[方案编码] name[方案名称]
 orgId[核算组织] acctSchemaId[账套]
 fiscalYear[预算年度] scenarioType[方案类型]
 parentScenarioId[源方案] validFrom[生效日期]
 validTo[失效日期]
========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[预算金额(源币种)] amountFunctional[预算金额(本位币)]
========>control[控制信息]======
 controlLevel[控制级别]
========>multiYear[多年度/结转信息(A2)]======
 budgetGroupCode[预算组编码] closedAt[结转时间]
 carryForwardRule[结转规则] rollForwardStrategy[滚动复制策略]
========>status[状态信息]======
 docStatus[方案状态] approveStatus[审核状态]
 voucherId[关联预算凭证ID]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
========>baseInfo[基本信息]======
 code[方案编码] name[方案名称]
 orgId[核算组织] acctSchemaId[账套]
 fiscalYear[预算年度] scenarioType[方案类型]
 parentScenarioId[源方案] validFrom[生效日期]
 validTo[失效日期]
========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[预算金额(源币种)] amountFunctional[预算金额(本位币)]
========>control[控制信息]======
 controlLevel[控制级别]
========>multiYear[多年度/结转信息(A2)]======
 budgetGroupCode[预算组编码] closedAt[结转时间]
 carryForwardRule[结转规则] rollForwardStrategy[滚动复制策略]
========>status[状态信息]======
 docStatus[方案状态] approveStatus[审核状态]
 voucherId[关联预算凭证ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[方案编码] fiscalYear[预算年度]
 scenarioType[方案类型] controlLevel[控制级别]
 budgetGroupCode[预算组编码] docStatus[方案状态]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="fiscalYear" filterOp="eq"/>
                <cell id="scenarioType" filterOp="eq"/>
                <cell id="controlLevel" filterOp="eq"/>
                <cell id="budgetGroupCode" filterOp="eq"/>
                <cell id="docStatus" filterOp="eq"/>
            </cells>
        </form>

        <!-- A2 滚动预算复制参数表单（newFiscalYear + strategy） -->
        <form id="rollForward" editMode="add" title="滚动预算复制" size="md">
            <layout>
 newFiscalYear[目标年度] strategy[复制策略]
</layout>
            <cells>
                <cell id="newFiscalYear" label="目标年度" domain="int" custom="true">
                    <gen-control>
                        <input-number placeholder="目标预算年度"/>
                    </gen-control>
                </cell>
                <cell id="strategy" label="复制策略" domain="string" custom="true">
                    <gen-control>
                        <select>
                            <options j:list="true">
                                <_ label="固定比例复制" value="FIXED_PERCENTAGE"/>
                                <_ label="零基（仅结构）" value="ZERO_BASED"/>
                                <_ label="增量调整" value="INCREMENTAL"/>
                            </options>
                        </select>
                    </gen-control>
                </cell>
            </cells>
        </form>

        <!-- A2 预算结转参数表单（targetScenarioId + rule） -->
        <form id="carryForward" editMode="add" title="预算结转" size="md">
            <layout>
 targetScenarioId[目标方案] rule[结转规则]
</layout>
            <cells>
                <cell id="targetScenarioId" label="目标方案" domain="long" custom="true">
                    <gen-control>
                        <select clearable="@:true">
                            <source>
                                <url>@query:ErpFinBudgetScenario__findList/value:id,label:name</url>
                            </source>
                        </select>
                    </gen-control>
                </cell>
                <cell id="rule" label="结转规则" domain="string" custom="true">
                    <gen-control>
                        <select>
                            <options j:list="true">
                                <_ label="剩余全部结转" value="REMAINING_FULL"/>
                                <_ label="剩余按比例结转" value="REMAINING_RATIO"/>
                                <_ label="已用作为基线" value="USED_FULL"/>
                                <_ label="不结转" value="NONE"/>
                            </options>
                        </select>
                    </gen-control>
                </cell>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main" grid="list">
            <!-- 预算方案审批操作（budget.md 状态机：DRAFT→SUBMITTED→APPROVED / →REJECTED / APPROVED→CANCELLED）
                 + A2 多年度/结转操作（rollForward 滚动复制 / carryForward 结转，需 confirm dialog 收集参数）。 -->
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <api url="@query:ErpFinBudgetScenario__get?id=$id" gql:selection="{@viewSelection}"/>
                </action>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpFinBudgetScenario__submit?id=$id"/>
                </action>
                <action id="row-approve-button" label="审核通过" level="primary" icon="fa fa-check">
                    <api url="@mutation:ErpFinBudgetScenario__approve?id=$id"/>
                </action>
                <action id="row-reject-button" label="驳回" level="danger" icon="fa fa-times">
                    <api url="@mutation:ErpFinBudgetScenario__reject?id=$id"/>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpFinBudgetScenario__cancel?id=$id"/>
                </action>
                <!-- A2 滚动预算复制（budget.md §滚动预算自动复制引擎）：drawer 收集 newFiscalYear + strategy -->
                <action id="row-roll-forward-button" label="滚动复制" level="info" icon="fa fa-copy"
                        actionType="drawer">
                    <dialog page="rollForward" size="md"/>
                </action>
                <!-- A2 预算结转（budget.md §结转规则引擎）：drawer 收集 targetScenarioId + rule -->
                <action id="row-carry-forward-button" label="结转" level="info" icon="fa fa-arrow-right"
                        actionType="drawer">
                    <dialog page="carryForward" size="md"/>
                </action>
            </rowActions>
        </crud>
        <!-- A2 滚动预算复制提交页 -->
        <simple name="rollForward" form="rollForward" useFormActions="true">
            <api url="@mutation:ErpFinBudgetScenario__rollForward/id" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认复制" actionType="submit" level="primary">
                    <messages>
                        <success>预算已滚动复制到新年度</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <!-- A2 预算结转提交页 -->
        <simple name="carryForward" form="carryForward" useFormActions="true">
            <api url="@mutation:ErpFinBudgetScenario__carryForward/id" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认结转" actionType="submit" level="primary">
                    <messages>
                        <success>预算已结转到目标方案</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <picker name="picker"/>
    </pages>
</view>
