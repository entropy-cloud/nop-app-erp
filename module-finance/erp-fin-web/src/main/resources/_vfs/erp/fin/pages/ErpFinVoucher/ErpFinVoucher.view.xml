<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinVoucher.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="voucherType" mandatory="true" sortable="true"/>
                <col id="voucherDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orgId" label="业务组织"/>
                <col id="isReversed" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[凭证号] voucherType[凭证字]
 voucherDate[凭证日期] voucherNo[凭证编号]
 orgId[核算组织] acctSchemaId[账套]
 periodId[会计期间] docStatus[凭证状态]
==========^posting[过账信息]=========
 postingType[过账类型] isReversed[是否红字冲销凭证]
 reversalOfVoucherId[原冲销凭证ID]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[凭证号] voucherType[凭证字]
 voucherDate[凭证日期] voucherNo[凭证编号]
 orgId[核算组织] acctSchemaId[账套]
 periodId[会计期间] docStatus[凭证状态]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[凭证号] voucherType[凭证字]
 voucherDate[凭证日期] docStatus[凭证状态]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="voucherDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-post-button" label="过账" level="success" icon="fa fa-check-circle">
                    <api url="@mutation:ErpFinVoucher__postVoucher?voucherId=$id"/>
                    <confirmText>确认过账此凭证？过账后不可编辑。</confirmText>
                    <messages>
                        <success>凭证已过账</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-reverse-button" label="红冲" level="danger" icon="fa fa-undo">
                    <api url="@mutation:ErpFinVoucher__reverseVoucher?voucherId=$id"/>
                    <confirmText>确认对此凭证执行红字冲销？</confirmText>
                    <messages>
                        <success>凭证已红冲</success>
                    </messages>
                    <visibleOn>${docStatus == 'POSTED' &amp;&amp; !isReversed}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>