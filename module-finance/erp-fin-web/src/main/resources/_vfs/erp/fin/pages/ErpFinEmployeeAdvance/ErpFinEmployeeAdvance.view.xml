<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpFinEmployeeAdvance.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="employeeId" label="员工"/>
                <col id="currencyId" label="币种"/>
                <col id="amountSource" ui:number="true" sortable="true"/>
                <col id="businessDate" sortable="true"/>
                <col id="projectId" label="项目"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 employeeId[员工] advanceType[借款类型]
 businessDate[业务日期] projectId[项目]
=========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[借款金额(源币种)] amountFunctional[借款金额(本位币)]
 settledAmount[已结算金额] outstandingAmount[未还金额]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
=========>posting[过账信息]======
 posted[已过账] postedBy[过账人]
 postedAt[过账时间] approvedBy[审核人]
 approvedAt[审核时间]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 employeeId[员工] advanceType[借款类型]
 businessDate[业务日期] projectId[项目]
=========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[借款金额(源币种)] amountFunctional[借款金额(本位币)]
 settledAmount[已结算金额] outstandingAmount[未还金额]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] employeeId[员工]
 advanceType[借款类型] docStatus[单据状态]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="advanceType" filterOp="eq"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpFinEmployeeAdvance__submitForApproval?id=$id"/>
                    <confirmText>确认提交此员工借款单审批？</confirmText>
                    <messages>
                        <success>员工借款单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpFinEmployeeAdvance__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此员工借款单的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>员工借款单已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpFinEmployeeAdvance__approve?id=$id"/>
                    <confirmText>确认批准此员工借款单？</confirmText>
                    <messages>
                        <success>员工借款单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpFinEmployeeAdvance__reject?id=$id"/>
                    <confirmText>确认驳回此员工借款单？</confirmText>
                    <messages>
                        <success>员工借款单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpFinEmployeeAdvance__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此员工借款单？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>员工借款单已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>