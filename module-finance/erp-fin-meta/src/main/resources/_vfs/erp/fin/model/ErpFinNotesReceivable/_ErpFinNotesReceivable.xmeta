            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="sourceBillCode" displayName="来源单据号" propId="18" i18n-en:displayName="Source Bill Code" tagSet="var"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="discountId" displayName="贴现明细" propId="19" i18n-en:displayName="Discount" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="status" displayName="票据状态" propId="20" i18n-en:displayName="Status" queryable="true" sortable="true"
