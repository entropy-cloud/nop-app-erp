            <schema type="java.lang.Integer"/>
        </prop>
        <prop name="unpostedVouchers" displayName="未过账凭证数" propId="6" i18n-en:displayName="Unposted Vouchers"
              queryable="true" sortable="true" insertable="true" updatable="true" defaultValue="0">
            <schema type="java.lang.Integer"/>
        </prop>
        <prop name="arStatus" displayName="应收模块状态" propId="7" i18n-en:displayName="Ar Status" mandatory="true"
