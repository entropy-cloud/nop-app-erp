            <schema type="java.lang.String" precision="20" dict="erp-fin/module-close-status"/>
        </prop>
        <prop name="glStatus" displayName="总账模块状态" propId="10" i18n-en:displayName="Gl Status" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="20" dict="erp-fin/module-close-status"/>
        </prop>
        <prop name="assetStatus" displayName="资产模块状态" propId="11" i18n-en:displayName="Asset Status" mandatory="true"
