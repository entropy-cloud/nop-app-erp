<?xml version="1.0" encoding="UTF-8" ?>
<!-- AR/AP 账龄报表（种子报表）。数据集 ds 由 ErpFinReportBizModel.buildArApAgingDataset 注入，
     每行 {direction:RECEIVABLE|PAYABLE, partnerId, sourceBillCode, businessDate, dueDate, openAmount, ageDays, bucket}。
     账龄分桶 0-30/31-60/61-90/90+，口径对齐 ar-ap-reconciliation §账龄。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="ar-ap-aging" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="80.0"/>
                    <col width="70.0"/>
                    <col width="120.0"/>
                    <col width="80.0"/>
                    <col width="80.0"/>
                    <col width="90.0"/>
                    <col width="60.0"/>
                    <col width="60.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="7" styleId="title"><model/><value>应收应付账龄分析表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>方向</value></cell>
                            <cell styleId="header"><model/><value>往来单位</value></cell>
                            <cell styleId="header"><model/><value>来源单据</value></cell>
                            <cell styleId="header"><model/><value>业务日期</value></cell>
                            <cell styleId="header"><model/><value>到期日</value></cell>
                            <cell styleId="header"><model/><value>未核销余额</value></cell>
                            <cell styleId="header"><model/><value>账龄(天)</value></cell>
                            <cell styleId="header"><model/><value>账龄区间</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="cell">
                                <model ds="ds" expandType="r" field="direction"/>
                                <value>*=^ds!direction</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=partnerId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=sourceBillCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=businessDate</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=dueDate</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=openAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=ageDays</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=bucket</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="4" styleId="total"><model/><value>未核销余额合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(F3)</valueExpr></model>
                            </cell>
                            <cell styleId="cell"/>
                            <cell styleId="cell"/>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
