<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 业财过账引擎（非 BizModel 编排层）：SPI 注册中心 + 默认模板 Provider + 过账编排 Processor。
         Processor 被凭证聚合根 Facade ErpFinVoucherBizModel 内部调用（见 processor-extension-pattern.md）。 -->
    <bean id="app.erp.fin.service.posting.ErpFinAcctDocRegistry"
          class="app.erp.fin.service.posting.ErpFinAcctDocRegistry">
        <property name="providers">
            <ioc:collect-beans by-type="app.erp.fin.service.posting.IErpFinAcctDocProvider"
                               only-concrete-classes="true" ioc:ignore-depends="true"/>
        </property>
        <property name="validators">
            <ioc:collect-beans by-type="app.erp.fin.service.posting.IErpFinFactsValidator"
                               only-concrete-classes="true" ioc:ignore-depends="true"/>
        </property>
    </bean>

    <bean id="app.erp.fin.service.posting.provider.ErpFinTemplateAcctDocProvider"
          class="app.erp.fin.service.posting.provider.ErpFinTemplateAcctDocProvider"/>

    <bean id="app.erp.fin.service.posting.ErpFinPostingProcessor"
          class="app.erp.fin.service.posting.ErpFinPostingProcessor"/>

    <!-- 过账异常记录器（process()/reverse() 抛 NopException 时以 REQUIRES_NEW 写 PENDING 异常记录，
         独立事务保证不随主过账回滚丢失；被 ErpFinPostingProcessor 调用）。 -->
    <bean id="app.erp.fin.service.posting.ErpFinPostingExceptionRecorder"
          class="app.erp.fin.service.posting.ErpFinPostingExceptionRecorder"/>

    <!-- 应收应付辅助账生成器（过账成功后同事务生成 ErpFinArApItem，被 ErpFinPostingProcessor 调用）。 -->
    <bean id="app.erp.fin.service.posting.ErpFinArApItemGenerator"
          class="app.erp.fin.service.posting.ErpFinArApItemGenerator"/>

    <!-- 核销结算组件（核销单过账/红冲时回写辅助账 + 往来余额缓存，被 ErpFinReconciliationBizModel 调用）。 -->
    <bean id="app.erp.fin.service.reconciliation.ReconciliationSettler"
          class="app.erp.fin.service.reconciliation.ReconciliationSettler"/>
    <bean id="app.erp.fin.service.reconciliation.PartnerBalanceUpdater"
          class="app.erp.fin.service.reconciliation.PartnerBalanceUpdater"/>

    <!-- 报销/借款业财过账 Provider（注册为 Bean 后由 ErpFinAcctDocRegistry 自动聚合，
         处理 EXPENSE_CLAIM / EMPLOYEE_ADVANCE / EMPLOYEE_ADVANCE_SETTLE）。 -->
    <bean id="app.erp.fin.service.posting.provider.ExpenseClaimAcctDocProvider"
          class="app.erp.fin.service.posting.provider.ExpenseClaimAcctDocProvider"/>
    <bean id="app.erp.fin.service.posting.provider.EmployeeAdvanceAcctDocProvider"
          class="app.erp.fin.service.posting.provider.EmployeeAdvanceAcctDocProvider"/>

    <!-- finance 自有域过账执行器（跨域经 IErpFinVoucherBiz Facade，REQUIRES_NEW 由 Facade 承接，自身无 @Transactional）。 -->
    <bean id="app.erp.fin.service.posting.FinPostingExecutor"
          class="app.erp.fin.service.posting.FinPostingExecutor"/>

    <!-- 报销单过账派发器（APPROVED→EXPENSE_CLAIM 凭证 借费用/进项税/贷方按 paymentMode；失败吞异常保持终态 posted=false）。 -->
    <bean id="app.erp.fin.service.posting.ExpenseClaimPostingDispatcher"
          class="app.erp.fin.service.posting.ExpenseClaimPostingDispatcher"/>

    <!-- 借款单过账派发器（APPROVED→EMPLOYEE_ADVANCE 凭证 借其他应收-员工预支/贷银行存款；失败吞异常保持终态 posted=false）。 -->
    <bean id="app.erp.fin.service.posting.EmployeeAdvancePostingDispatcher"
          class="app.erp.fin.service.posting.EmployeeAdvancePostingDispatcher"/>

    <!-- 报销抵扣借款编排器（报销过账后净额抵扣同员工未还借款 + EMPLOYEE_ADVANCE_SETTLE 清算凭证；反审核时反向）。 -->
    <bean id="app.erp.fin.service.posting.AdvanceOffsetOrchestrator"
          class="app.erp.fin.service.posting.AdvanceOffsetOrchestrator"/>

    <!-- 票据业财过账 Provider（注册为 Bean 后由 ErpFinAcctDocRegistry 自动聚合，
         处理 NOTES_RECEIVABLE_RECEIVED/DISCOUNTED/ENDORSED/COLLECTION + NOTES_PAYABLE_ISSUED/HONORED）。 -->
    <bean id="app.erp.fin.service.posting.provider.NotesReceivableAcctDocProvider"
          class="app.erp.fin.service.posting.provider.NotesReceivableAcctDocProvider"/>
    <bean id="app.erp.fin.service.posting.provider.NotesPayableAcctDocProvider"
          class="app.erp.fin.service.posting.provider.NotesPayableAcctDocProvider"/>

    <!-- 票据过账派发器（状态迁移边界触发：收到/贴现/背书/托收/承兑 + 应付开出/兑付；失败吞异常保持原态 posted=false）。 -->
    <bean id="app.erp.fin.service.posting.NotesPostingDispatcher"
          class="app.erp.fin.service.posting.NotesPostingDispatcher"/>

    <!-- 期末结账编排组件（被 ErpFinAccountingPeriodProcessor 调用）：损益结转 + 汇兑重估。 -->
    <bean id="app.erp.fin.service.profitloss.ProfitLossClosingService"
          class="app.erp.fin.service.profitloss.ProfitLossClosingService"/>
    <bean id="app.erp.fin.service.fx.ExchangeRevaluationService"
          class="app.erp.fin.service.fx.ExchangeRevaluationService"/>

    <!-- finance 域审批/状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖）。
         各 Facade BizModel 仅负责入口/事务/委托，编排委托对应 Processor。 -->
    <bean id="app.erp.fin.service.processor.ErpFinEmployeeAdvanceProcessor"
          class="app.erp.fin.service.processor.ErpFinEmployeeAdvanceProcessor"/>
    <bean id="app.erp.fin.service.processor.ErpFinExpenseClaimProcessor"
          class="app.erp.fin.service.processor.ErpFinExpenseClaimProcessor"/>
    <bean id="app.erp.fin.service.processor.ErpFinNotesPayableProcessor"
          class="app.erp.fin.service.processor.ErpFinNotesPayableProcessor"/>
    <bean id="app.erp.fin.service.processor.ErpFinNotesReceivableProcessor"
          class="app.erp.fin.service.processor.ErpFinNotesReceivableProcessor"/>
    <bean id="app.erp.fin.service.processor.ErpFinAccountingPeriodProcessor"
          class="app.erp.fin.service.processor.ErpFinAccountingPeriodProcessor"/>
</beans>