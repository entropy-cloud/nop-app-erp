<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" x:extends="/nop/biz/defaults/service-base.beans.xml"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <bean id="app.erp.aps.service.entity.ErpApsOperationOrderBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsOperationOrder" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsOperationOrderBiz" ioc:force-lazy-property="true" lazy-init="true"
          primary="true">
        <property name="bizObjName" value="ErpApsOperationOrder"/>
    </bean>

    <bean id="app.erp.aps.service.entity.ErpApsScheduleBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsSchedule" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsScheduleBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpApsSchedule"/>
    </bean>

    <bean id="app.erp.aps.service.entity.ErpApsConstraintBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsConstraint" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsConstraintBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpApsConstraint"/>
    </bean>

    <bean id="app.erp.aps.service.entity.ErpApsOpRoutingBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsOpRouting" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsOpRoutingBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpApsOpRouting"/>
    </bean>

    <bean id="app.erp.aps.service.entity.ErpApsDispatchRuleBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsDispatchRule" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsDispatchRuleBiz" ioc:force-lazy-property="true" lazy-init="true"
          primary="true">
        <property name="bizObjName" value="ErpApsDispatchRule"/>
    </bean>

    <bean id="app.erp.aps.service.entity.ErpApsDispatchLogBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpApsDispatchLog" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.aps.biz.IErpApsDispatchLogBiz" ioc:force-lazy-property="true" lazy-init="true"
          primary="true">
        <property name="bizObjName" value="ErpApsDispatchLog"/>
    </bean>
</beans>