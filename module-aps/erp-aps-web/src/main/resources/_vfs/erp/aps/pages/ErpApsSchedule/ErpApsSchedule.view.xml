<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpApsSchedule.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="scheduleDate" mandatory="true" sortable="true"/>
                <col id="schedulingMode" mandatory="true" sortable="true"/>
                <col id="horizonStart" mandatory="true" sortable="true"/>
                <col id="horizonEnd" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[编号] name[方案名称]
 scheduleDate[排产日期] schedulingMode[排产模式]
 horizonStart[展望期开始] horizonEnd[展望期结束]
 status[状态] orgId[业务组织]
 businessDate[业务日期]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[编号] name[方案名称]
 scheduleDate[排产日期] schedulingMode[排产模式]
 horizonStart[展望期开始] horizonEnd[展望期结束]
 status[状态] orgId[业务组织]
 businessDate[业务日期]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编号] status[状态]
 scheduleDate[排产日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="scheduleDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>