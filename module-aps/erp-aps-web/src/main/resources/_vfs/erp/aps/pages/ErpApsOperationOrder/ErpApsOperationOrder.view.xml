<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpApsOperationOrder.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="workOrderId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="operationName" mandatory="true" sortable="true"/>
                <col id="sequence" mandatory="true" ui:number="true" sortable="true"/>
                <col id="machineId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="priority" ui:number="true" sortable="true"/>
                <col id="plannedStartDateT" sortable="true"/>
                <col id="plannedEndDateT" sortable="true"/>
                <col id="realStartDateT" sortable="true"/>
                <col id="realEndDateT" sortable="true"/>
                <col id="setupTime" ui:number="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="runtimePerUnit" ui:number="true" sortable="true"/>
                <col id="qty" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalDuration" ui:number="true" sortable="true"/>
                <col id="assignedToId" sortable="true"/>
                <col id="isOutsourced" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orgId" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="earliestStartDateT" sortable="true"/>
                <col id="latestEndDateT" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] workOrderId[主工单]
 operationName[工序名称] sequence[工序顺序]
 orgId[业务组织] businessDate[业务日期]
=========>assign[分派]======
 machineId[工作中心/设备] assignedToId[操作工]
 isOutsourced[是否外协]
=========>schedule[排程]======
 plannedStartDateT[计划开工时间] plannedEndDateT[计划完工时间]
 realStartDateT[实际开工时间] realEndDateT[实际完工时间]
 setupTime[准备时间(分钟)] runtimePerUnit[每件加工时间(分钟)]
 qty[加工数量] totalDuration[总耗时(分钟)]
 earliestStartDateT[最早开工时间] latestEndDateT[最晚完工时间]
=========>status[状态]======
 priority[优先级] status[状态]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] workOrderId[主工单]
 operationName[工序名称] sequence[工序顺序]
 orgId[业务组织] businessDate[业务日期]
=========>assign[分派]======
 machineId[工作中心/设备] assignedToId[操作工]
 isOutsourced[是否外协]
=========>schedule[排程]======
 plannedStartDateT[计划开工时间] plannedEndDateT[计划完工时间]
 realStartDateT[实际开工时间] realEndDateT[实际完工时间]
 setupTime[准备时间(分钟)] runtimePerUnit[每件加工时间(分钟)]
 qty[加工数量] totalDuration[总耗时(分钟)]
 earliestStartDateT[最早开工时间] latestEndDateT[最晚完工时间]
=========>status[状态]======
 priority[优先级] status[状态]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编号] workOrderId[主工单]
 machineId[工作中心/设备] orgId[业务组织]
 status[状态] businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="workOrderId" filterOp="eq"/>
                <cell id="machineId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-schedule-button" label="排程" level="primary" icon="fa fa-calendar">
                    <api url="@mutation:ErpApsOperationOrder__scheduleForward?scheduleId=0"/>
                    <confirmText>排程操作请在排程方案详情页执行</confirmText>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-start-button" label="开始" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpApsOperationOrder__start?operationOrderId=$id"/>
                    <confirmText>确认开始此工序工单？</confirmText>
                    <messages>
                        <success>工序工单已开始</success>
                    </messages>
                    <visibleOn>${status == 'PLANNED'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpApsOperationOrder__complete?operationOrderId=$id"/>
                    <confirmText>确认完成此工序工单？</confirmText>
                    <messages>
                        <success>工序工单已完成</success>
                    </messages>
                    <visibleOn>${status == 'IN_PROGRESS'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpApsOperationOrder__cancel?operationOrderId=$id"/>
                    <confirmText>确认作废此工序工单？</confirmText>
                    <messages>
                        <success>工序工单已作废</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT' || status == 'PLANNED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>