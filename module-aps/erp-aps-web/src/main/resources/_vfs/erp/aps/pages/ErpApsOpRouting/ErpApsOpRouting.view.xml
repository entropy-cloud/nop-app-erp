<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpApsOpRouting.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="operationId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="machineId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="priority" mandatory="true" ui:number="true" sortable="true"/>
                <col id="setupTimeDelta" ui:number="true" sortable="true"/>
                <col id="runtimePerUnitDelta" ui:number="true" sortable="true"/>
                <col id="isDefault" sortable="true"/>
                <col id="isEnabled" sortable="true"/>
                <col id="effectiveFrom" sortable="true"/>
                <col id="effectiveTo" sortable="true"/>
                <col id="minBatchQty" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="maxBatchQty" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] operationId[工序]
 machineId[工作中心] priority[优先级]
=========>delta[时间差]======
 setupTimeDelta[换模时间差(分钟)] runtimePerUnitDelta[单件加工时间差(分钟)]
=========>validity[生效条件]======
 isDefault[默认路由] isEnabled[启用]
 effectiveFrom[生效日期] effectiveTo[失效日期]
 minBatchQty[最小批量] maxBatchQty[最大批量]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] operationId[工序]
 machineId[工作中心] priority[优先级]
=========>delta[时间差]======
 setupTimeDelta[换模时间差(分钟)] runtimePerUnitDelta[单件加工时间差(分钟)]
=========>validity[生效条件]======
 isDefault[默认路由] isEnabled[启用]
 effectiveFrom[生效日期] effectiveTo[失效日期]
 minBatchQty[最小批量] maxBatchQty[最大批量]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织] operationId[工序]
 machineId[工作中心] isDefault[默认路由]
 isEnabled[启用]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="operationId" filterOp="eq"/>
                <cell id="machineId" filterOp="eq"/>
                <cell id="isDefault" filterOp="eq"/>
                <cell id="isEnabled" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>