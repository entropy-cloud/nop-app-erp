<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpApsDispatchRule.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="workcenterId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="ruleName" mandatory="true" sortable="true"/>
                <col id="enableAuto" sortable="true"/>
                <col id="requireMaterial" sortable="true"/>
                <col id="requireOperator" sortable="true"/>
                <col id="requireTooling" sortable="true"/>
                <col id="maxLookaheadMinutes" ui:number="true" sortable="true"/>
                <col id="dispatchAheadMinutes" ui:number="true" sortable="true"/>
                <col id="autoConfirmMaterial" sortable="true"/>
                <col id="maxConcurrentOps" ui:number="true" sortable="true"/>
                <col id="priorityThreshold" ui:number="true" sortable="true"/>
                <col id="enabledHours" sortable="true"/>
                <col id="holdUntil" sortable="true"/>
                <col id="holdReason" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] workcenterId[工作中心]
 ruleName[规则名称] enableAuto[自动派工启用]
=========>constraint[约束条件]======
 requireMaterial[物料齐套检查] requireOperator[操作工检查]
 requireTooling[工装检查] maxLookaheadMinutes[前瞻窗口(分钟)]
 dispatchAheadMinutes[提前派工(分钟)] autoConfirmMaterial[自动确认物料]
 maxConcurrentOps[最大并行工序数] priorityThreshold[优先级阈值]
 enabledHours[允许时段(JSON)]
=========>action[动作]======
 holdUntil[暂停到] holdReason[暂停原因]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] workcenterId[工作中心]
 ruleName[规则名称] enableAuto[自动派工启用]
=========>constraint[约束条件]======
 requireMaterial[物料齐套检查] requireOperator[操作工检查]
 requireTooling[工装检查] maxLookaheadMinutes[前瞻窗口(分钟)]
 dispatchAheadMinutes[提前派工(分钟)] autoConfirmMaterial[自动确认物料]
 maxConcurrentOps[最大并行工序数] priorityThreshold[优先级阈值]
 enabledHours[允许时段(JSON)]
=========>action[动作]======
 holdUntil[暂停到] holdReason[暂停原因]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织] workcenterId[工作中心]
 ruleName[规则名称] enableAuto[自动派工启用]
 holdUntil[暂停到]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="workcenterId" filterOp="eq"/>
                <cell id="ruleName" filterOp="like"/>
                <cell id="enableAuto" filterOp="eq"/>
                <cell id="holdUntil" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>