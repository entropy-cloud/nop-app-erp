<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpApsDispatchLog.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="operationOrderId" label="工序工单"/>
                <col id="workcenterId" ui:number="true" sortable="true"/>
                <col id="dispatchType" mandatory="true" sortable="true"/>
                <col id="previousStatus" sortable="true"/>
                <col id="newStatus" sortable="true"/>
                <col id="conditionCheckResult" sortable="true"/>
                <col id="dispatchedBy" sortable="true"/>
                <col id="dispatchedAt" sortable="true"/>
                <col id="materialAvailable" sortable="true"/>
                <col id="operatorAvailable" sortable="true"/>
                <col id="toolingAvailable" sortable="true"/>
                <col id="note" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] operationOrderId[工序工单]
 workcenterId[工作中心]
=========>dispatch[派工]======
 dispatchType[派工类型] previousStatus[派工前状态]
 newStatus[派工后状态] dispatchedBy[派工人]
 dispatchedAt[派工时间]
=========>condition[条件检查]======
 conditionCheckResult[条件检查结果(JSON)] materialAvailable[物料齐套]
 operatorAvailable[操作工可用] toolingAvailable[工装可用]
========^audit[审计信息]=========
 note[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 operationOrderId[工序工单] workcenterId[工作中心]
 dispatchType[派工类型] newStatus[派工后状态]
 dispatchedBy[派工人] dispatchedAt[派工时间]
            </layout>
            <cells>
                <cell id="operationOrderId" filterOp="eq"/>
                <cell id="workcenterId" filterOp="eq"/>
                <cell id="dispatchType" filterOp="eq"/>
                <cell id="newStatus" filterOp="eq"/>
                <cell id="dispatchedBy" filterOp="eq"/>
                <cell id="dispatchedAt" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>