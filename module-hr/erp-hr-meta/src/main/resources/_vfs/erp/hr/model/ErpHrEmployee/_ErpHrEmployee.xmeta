<?xml version="1.0" encoding="UTF-8" ?>
<meta x:schema="/nop/schema/xmeta.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:i18n-en="i18n-en" xmlns:ext="ext"
      xmlns:xpl="xpl" ext:model="orm" ext:icon="user" xmlns:c="c" xmlns:graphql="graphql" xmlns:meta-gen="meta-gen"
      xmlns:biz="biz" displayName="员工" i18n-en:displayName="Employee" tagSet="gid,erp.hr" xmlns:ui="ui" xmlns:orm="orm">

    <entityName>app.erp.hr.dao.entity.ErpHrEmployee</entityName>

    <primaryKey>id</primaryKey>

    <x:gen-extends>
        <meta-gen:DefaultMetaGenExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <meta-gen:DefaultMetaPostExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
    </x:post-extends>

    <keys>
        <key name="UK_HR_EMPLOYEE_CODE_ORG" props="code,orgId"/>
    </keys>

    <props>
        <prop name="id" displayName="ID" propId="1" i18n-en:displayName="ID" tagSet="seq-default" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="false" graphql:type="String">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="code" displayName="工号" propId="2" i18n-en:displayName="Code" mandatory="true" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="code" type="java.lang.String" precision="50"/>
        </prop>
        <prop name="firstName" displayName="姓" propId="3" i18n-en:displayName="First Name" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="lastName" displayName="名" propId="4" i18n-en:displayName="Last Name" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="fullName" displayName="全名" propId="5" i18n-en:displayName="Full Name" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="200"/>
        </prop>
        <prop name="gender" displayName="性别" propId="6" i18n-en:displayName="Gender" mandatory="true" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="20" dict="erp-hr/gender"/>
        </prop>
        <prop name="birthDate" displayName="出生日期" propId="7" i18n-en:displayName="Birth Date" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="idCardType" displayName="证件类型" propId="8" i18n-en:displayName="ID Card Type" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="idCardNo" displayName="证件号码" propId="9" i18n-en:displayName="ID Card No" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="idCardNo" type="java.lang.String" precision="50"/>
        </prop>
        <prop name="email" displayName="电子邮箱" propId="10" i18n-en:displayName="Email" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema domain="email" type="java.lang.String" precision="200"/>
        </prop>
        <prop name="mobilePhone" displayName="手机号" propId="11" i18n-en:displayName="Mobile Phone" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="phone" type="java.lang.String" precision="20"/>
        </prop>
        <prop name="maritalStatus" displayName="婚姻状况" propId="12" i18n-en:displayName="Marital Status" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="20" dict="erp-hr/marital-status"/>
        </prop>
        <prop name="nationality" displayName="国籍" propId="13" i18n-en:displayName="Nationality" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="emergencyContact" displayName="紧急联系人" propId="14" i18n-en:displayName="Emergency Contact"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="emergencyPhone" displayName="紧急联系电话" propId="15" i18n-en:displayName="Emergency Phone"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema domain="phone" type="java.lang.String" precision="20"/>
        </prop>
        <prop name="departmentId" displayName="部门" propId="16" i18n-en:displayName="Department" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="department">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="positionId" displayName="职位" propId="17" i18n-en:displayName="Position" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="position">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="jobTitle" displayName="岗位名称" propId="18" i18n-en:displayName="Job Title" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="200"/>
        </prop>
        <prop name="superiorId" displayName="直接上级" propId="19" i18n-en:displayName="Superior" queryable="true"
