            <schema type="java.lang.Long"/>
        </prop>
        <prop name="costCenterId" displayName="默认成本中心" propId="20" i18n-en:displayName="Cost Center" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="costCenter">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="hireDate" displayName="入职日期" propId="21" i18n-en:displayName="Hire Date" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="probationEndDate" displayName="试用期截止" propId="22" i18n-en:displayName="Probation End Date"
