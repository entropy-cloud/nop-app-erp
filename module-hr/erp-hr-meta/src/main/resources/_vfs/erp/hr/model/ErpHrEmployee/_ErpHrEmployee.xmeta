            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="regularDate" displayName="转正日期" propId="23" i18n-en:displayName="Regular Date" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="resignationDate" displayName="离职日期" propId="24" i18n-en:displayName="Resignation Date"
