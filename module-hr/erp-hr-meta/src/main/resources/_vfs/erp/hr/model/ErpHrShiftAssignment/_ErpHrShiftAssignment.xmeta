            <schema bizObjName="ErpHrShift"/>
        </prop>
        <prop name="leaveRequest" i18n-en:displayName="Leave Request" tagSet="pub" ext:kind="to-one" internal="true"
              queryable="true" ext:joinLeftProp="leaveRequestId" ext:joinRightProp="id" insertable="false"
              updatable="false" lazy="true">
            <schema bizObjName="ErpHrLeaveRequest"/>
        </prop>
        <prop name="swapRequest" i18n-en:displayName="Swap Request" tagSet="pub" ext:kind="to-one" internal="true"
