<?xml version="1.0" encoding="UTF-8" ?>
<!-- 薪酬模拟对比报表（种子报表）。数据集 ds 由 ErpHrReportBizModel.buildPayrollSimulationComparisonDataset 注入，
     明细行 {employeeId, employeeName, departmentId, salaryItemCode, originalAmount, adjustedAmount, difference, rowType=DETAIL}，
     部门小计行 {departmentId, employeeName=部门小计, difference, rowType=DEPT_SUBTOTAL}。
     口径对齐 docs/design/human-resource/payroll-simulation.md §3.2：源值 vs 调整值 + 差额（=调整−源）+ 部门小计。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="payroll-sim-cmp" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="80.0"/>
                    <col width="120.0"/>
                    <col width="70.0"/>
                    <col width="110.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="70.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="7" styleId="title"><model/><value>薪酬模拟对比报表（源 vs 模拟）</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>员工ID</value></cell>
                            <cell styleId="header"><model/><value>姓名/标识</value></cell>
                            <cell styleId="header"><model/><value>部门</value></cell>
                            <cell styleId="header"><model/><value>薪酬项目</value></cell>
                            <cell styleId="header"><model/><value>源值</value></cell>
                            <cell styleId="header"><model/><value>调整值</value></cell>
                            <cell styleId="header"><model/><value>差异</value></cell>
                            <cell styleId="header"><model/><value>行类型</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="employeeId"/>
                                <value>*=^ds!employeeId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=employeeName</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=departmentId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=salaryItemCode</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=originalAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=adjustedAmount</value>
                            </cell>
                            <cell styleId="alert">
                                <model rowParent="A3"/>
                                <value>*=difference</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=rowType</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="alert" fillPattern="solid" fillBgColor="FFFFF9C4" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
