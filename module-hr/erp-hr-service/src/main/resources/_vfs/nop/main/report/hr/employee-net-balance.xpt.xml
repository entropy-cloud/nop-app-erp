<?xml version="1.0" encoding="UTF-8" ?>
<!-- 员工净余额报表（种子报表）。数据集 ds 由 ErpHrReportBizModel.buildEmployeeNetBalanceDataset 注入，
     每行 {partnerId, partnerName, advanceBalance, expenseBalance, netBalance, netDirection}。
     口径对齐 docs/design/finance/expense-claim.md：净额 = 预支应收 − 报销应付（员工预支=其他应收资产方向，
     报销=应付方向）。净额正=员工欠公司，负=公司欠员工，零=结平。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="emp-net-balance" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="90.0"/>
                    <col width="140.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="100.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="5" styleId="title"><model/><value>员工净余额报表（预支 − 报销）</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>往来单位ID</value></cell>
                            <cell styleId="header"><model/><value>员工/往来单位</value></cell>
                            <cell styleId="header"><model/><value>预支余额(应收)</value></cell>
                            <cell styleId="header"><model/><value>报销余额(应付)</value></cell>
                            <cell styleId="header"><model/><value>净余额</value></cell>
                            <cell styleId="header"><model/><value>方向</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="partnerId"/>
                                <value>*=^ds!partnerId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=partnerName</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=advanceBalance</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=expenseBalance</value>
                            </cell>
                            <cell styleId="alert">
                                <model rowParent="A3"/>
                                <value>*=netBalance</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=netDirection</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="alert" fillPattern="solid" fillBgColor="FFFFF9C4" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
