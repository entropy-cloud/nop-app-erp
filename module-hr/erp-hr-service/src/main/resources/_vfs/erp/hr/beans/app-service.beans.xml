<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- HR 薪酬核算引擎组件（payroll.md §五/§六/§七）。BizModel 逻辑挂在 ErpHrSalaryBizModel（实体绑定，
         由 _service.beans.xml 自动注册 BizProxy），此处仅注册核算/过账辅助组件。 -->
    <bean id="app.erp.hr.service.payroll.TaxBracketParser"
          class="app.erp.hr.service.payroll.TaxBracketParser"/>
    <bean id="app.erp.hr.service.payroll.SocialInsuranceCalculator"
          class="app.erp.hr.service.payroll.SocialInsuranceCalculator"/>
    <bean id="app.erp.hr.service.payroll.IncomeTaxCalculator"
          class="app.erp.hr.service.payroll.IncomeTaxCalculator"/>
    <bean id="app.erp.hr.service.payroll.PayrollCalculator"
          class="app.erp.hr.service.payroll.PayrollCalculator"/>

    <!-- HR 业财过账：执行器 + 派发器 + Provider（Registry 容器级 collect-by-type 自动收录） -->
    <bean id="app.erp.hr.service.posting.SalaryPostingExecutor"
          class="app.erp.hr.service.posting.SalaryPostingExecutor"/>
    <bean id="app.erp.hr.service.posting.SalaryPostingDispatcher"
          class="app.erp.hr.service.posting.SalaryPostingDispatcher"/>
    <bean id="app.erp.hr.service.posting.SalaryPostingProvider"
          class="app.erp.hr.service.posting.SalaryPostingProvider"/>

    <!-- HR 胜任力管理引擎组件（competency-management.md §评估流程/§差距分析）。
         纯函数式 + 注入加载函数便于单测；BizModel 经 @Inject 引用。 -->
    <bean id="app.erp.hr.service.competency.AssessmentAggregator"
          class="app.erp.hr.service.competency.AssessmentAggregator"/>
    <bean id="app.erp.hr.service.competency.GapAnalysisCalculator"
          class="app.erp.hr.service.competency.GapAnalysisCalculator"/>

    <!-- HR 域报表渲染入口（plan 2026-07-06-1247-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。@BizModel 注解由 bizObject 管理器自动识别。
          镜像 finance ErpFinReportBizModel / manufacturing ErpMfgReportBizModel / inventory ErpInvReportBizModel
          （域隔离 /hr/ vs /fin/ vs /mfg/ vs /inv/）。员工净余额跨域只读经 IErpFinArApItemBiz 聚合。 -->
    <bean id="app.erp.hr.service.report.ErpHrReportBizModel" ioc:type="@bean:id"/>

    <!-- HR 合同到期扫描 Job Bean（UC-HR-07），由 scheduler.yaml 经 BeanMethodJobInvoker 反射调用 -->
    <bean id="erpHrContractExpiryJob" class="app.erp.hr.service.job.ErpHrContractExpiryJob"/>
</beans>
