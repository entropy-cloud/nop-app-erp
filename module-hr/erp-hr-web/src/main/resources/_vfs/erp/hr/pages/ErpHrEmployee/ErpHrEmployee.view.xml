<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrEmployee.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:i18n-en="i18n-en">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="fullName" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="departmentId" label="部门"/>
                <col id="positionId" label="职位"/>
                <col id="jobTitle" sortable="true"/>
                <col id="costCenterId" label="默认成本中心"/>
                <col id="bankAccountId" label="工资卡账户"/>
                <col id="employmentStatus" mandatory="true" sortable="true"/>
                <col id="employeeType" mandatory="true" sortable="true"/>
                <col id="hireDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="userAccountId" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
        <!-- Drawer 相关 crud grids：仅展示直接字段（避免跨实体 to-one 关联）。
             custom="true" 因为这些字段属于关联实体（ErpHrEmploymentContract 等），不在 ErpHrEmployee 的 objMeta 中。 -->
        <grid id="archive-contract-list">
            <cols>
                <col id="id" custom="true" mandatory="true" ui:number="true" sortable="true" domain="long"/>
                <col id="code" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="contractType" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="signDate" custom="true" mandatory="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="startDate" custom="true" mandatory="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" custom="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" custom="true" mandatory="true" sortable="true" domain="string">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="archive-attendance-list">
            <cols>
                <col id="id" custom="true" mandatory="true" ui:number="true" sortable="true" domain="long"/>
                <col id="date" custom="true" mandatory="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="clockIn" custom="true" sortable="true" domain="string"/>
                <col id="clockOut" custom="true" sortable="true" domain="string"/>
                <col id="workHours" custom="true" ui:number="true" sortable="true" domain="long"/>
                <col id="lateMinutes" custom="true" ui:number="true" sortable="true" domain="long"/>
                <col id="earlyLeaveMinutes" custom="true" ui:number="true" sortable="true" domain="long"/>
                <col id="isAbsent" custom="true" sortable="true" domain="boolean"/>
            </cols>
        </grid>
        <grid id="archive-leave-list">
            <cols>
                <col id="id" custom="true" mandatory="true" ui:number="true" sortable="true" domain="long"/>
                <col id="code" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="leaveType" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="startDate" custom="true" mandatory="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" custom="true" mandatory="true" sortable="true" align="center" domain="date">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="durationDays" custom="true" ui:number="true" sortable="true" domain="long"/>
                <col id="status" custom="true" mandatory="true" sortable="true" domain="string">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="archive-timesheet-list">
            <cols>
                <col id="id" custom="true" mandatory="true" ui:number="true" sortable="true" domain="long"/>
                <col id="code" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="periodFrom" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="periodTo" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="totalHours" custom="true" ui:number="true" sortable="true" domain="long"/>
                <col id="status" custom="true" mandatory="true" sortable="true" domain="string">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg" layoutControl="tabs">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[工号] firstName[姓]
 lastName[名] fullName[全名]
 gender[性别] birthDate[出生日期]
 orgId[业务组织] employmentStatus[雇佣状态]
 employeeType[员工类型]
==========>contact[联系方式]======
 email[电子邮箱] mobilePhone[手机号]
 emergencyContact[紧急联系人] emergencyPhone[紧急联系电话]
==========^idCard[证件信息]=========
 idCardType[证件类型] idCardNo[证件号码]
 maritalStatus[婚姻状况] nationality[国籍]
==========>employment[雇佣信息]======
 departmentId[部门] positionId[职位]
 jobTitle[岗位名称] superiorId[直接上级]
 costCenterId[默认成本中心] hireDate[入职日期]
 probationEndDate[试用期截止] regularDate[转正日期]
 resignationDate[离职日期] resignationReason[离职原因]
==========^payroll[薪酬信息（脱敏待落地，敏感字段隐藏）]=========
 userAccountId[系统用户ID]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="idCardNo">
                    <visibleOn>${false}</visibleOn>
                </cell>
            </cells>
        </form>
        <form id="edit" size="lg" layoutControl="tabs">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[工号] firstName[姓]
 lastName[名] fullName[全名]
 gender[性别] birthDate[出生日期]
 orgId[业务组织] employmentStatus[雇佣状态]
 employeeType[员工类型]
==========>contact[联系方式]======
 email[电子邮箱] mobilePhone[手机号]
 emergencyContact[紧急联系人] emergencyPhone[紧急联系电话]
==========^idCard[证件信息]=========
 idCardType[证件类型] idCardNo[证件号码]
 maritalStatus[婚姻状况] nationality[国籍]
==========>employment[雇佣信息]======
 departmentId[部门] positionId[职位]
 jobTitle[岗位名称] superiorId[直接上级]
 costCenterId[默认成本中心] hireDate[入职日期]
 probationEndDate[试用期截止] regularDate[转正日期]
 resignationDate[离职日期] resignationReason[离职原因]
==========^payroll[薪酬信息（脱敏待落地，敏感字段隐藏）]=========
 userAccountId[系统用户ID]
 remark[备注](2)
            </layout>
            <cells>
                <cell id="idCardNo">
                    <visibleOn>${false}</visibleOn>
                </cell>
                <cell id="bankAccountId">
                    <visibleOn>${false}</visibleOn>
                </cell>
                <cell id="socialSecurityNo">
                    <visibleOn>${false}</visibleOn>
                </cell>
                <cell id="taxFileNo">
                    <visibleOn>${false}</visibleOn>
                </cell>
            </cells>
        </form>
        <form id="add"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 departmentId[部门] positionId[职位]
 employmentStatus[雇佣状态] employeeType[员工类型]
 orgId[业务组织] hireDate[入职日期]
            </layout>
            <cells>
                <cell id="departmentId" filterOp="eq"/>
                <cell id="positionId" filterOp="eq"/>
                <cell id="employmentStatus" filterOp="eq"/>
                <cell id="employeeType" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="hireDate" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[工号] fullName[全名]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="fullName" filterOp="like"/>
            </cells>
        </form>

        <!-- UC-HR-08 部门调动表单（自定义参数，非实体属性。cell id 与 transferEmployee 入参一致） -->
        <form id="transfer" editMode="add" title="部门调动" i18n-en:title="Transfer Employee">
            <layout>
  employeeId[员工ID] targetDepartmentId[目标部门]
  targetPositionId[目标职位] targetSuperiorId[直接上级]
  effectiveDate[生效日期] handleContract[合同处理]
</layout>
            <cells>
                <cell id="employeeId" label="员工ID" domain="long" custom="true">
                    <gen-control>
                        <input-number hidden="true"/>
                    </gen-control>
                </cell>
                <cell id="targetDepartmentId" label="目标部门" domain="long" custom="true">
                    <gen-control>
                        <input-number placeholder="目标部门ID（必填）"/>
                    </gen-control>
                </cell>
                <cell id="targetPositionId" label="目标职位" domain="long" custom="true">
                    <gen-control>
                        <input-number placeholder="目标职位ID（可空）"/>
                    </gen-control>
                </cell>
                <cell id="targetSuperiorId" label="直接上级" domain="long" custom="true">
                    <gen-control>
                        <input-number placeholder="直接上级员工ID（可空）"/>
                    </gen-control>
                </cell>
                <cell id="effectiveDate" label="生效日期" domain="date" custom="true">
                    <gen-control>
                        <input-date format="YYYY-MM-DD" placeholder="调动生效日期"/>
                    </gen-control>
                </cell>
                <cell id="handleContract" label="合同处理" domain="string" custom="true">
                    <gen-control>
                        <select>
                            <options j:list="true">
                                <_ label="AUTO（按配置，存在生效合同时处理）" value="AUTO"/>
                                <_ label="YES（强制处理：终止原合同+新建）" value="YES"/>
                                <_ label="NO（跳过合同处理）" value="NO"/>
                            </options>
                        </select>
                    </gen-control>
                </cell>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-view-employee-archive-button" label="完整档案" level="info" icon="fa fa-id-card-o"
                        actionType="drawer">
                    <dialog page="employeeArchive" size="xl">
                        <data>
                            <id>${'$'}{id}</id>
                        </data>
                    </dialog>
                </action>
                <action id="row-transfer-button" label="调动" level="primary" icon="fa fa-exchange"
                        actionType="drawer">
                    <dialog page="transfer" size="lg">
                        <data>
                            <employeeId>$id</employeeId>
                        </data>
                    </dialog>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <!-- 完整档案 drawer（机制 B）：headerForm simple + 4 跨实体 crud tab -->
        <simple name="employeeHeader" form="view">
            <initApi url="@query:ErpHrEmployee__get?id=${'$'}{id}" gql:selection="{@formSelection}"/>
        </simple>

        <crud name="employeeContracts" grid="archive-contract-list">
            <table noOperations="true">
                <api url="@query:ErpHrEmploymentContract__findPage/{@pageSelection}?filter_employeeId=${'$'}{id}"/>
            </table>
        </crud>

        <crud name="employeeAttendance" grid="archive-attendance-list">
            <table noOperations="true">
                <api url="@query:ErpHrAttendance__findPage/{@pageSelection}?filter_employeeId=${'$'}{id}"/>
            </table>
        </crud>

        <crud name="employeeLeaves" grid="archive-leave-list">
            <table noOperations="true">
                <api url="@query:ErpHrLeaveRequest__findPage/{@pageSelection}?filter_employeeId=${'$'}{id}"/>
            </table>
        </crud>

        <crud name="employeeTimesheets" grid="archive-timesheet-list">
            <table noOperations="true">
                <api url="@query:ErpHrTimesheet__findPage/{@pageSelection}?filter_employeeId=${'$'}{id}"/>
            </table>
        </crud>

        <tabs name="employeeArchive" mountOnEnter="true" unmountOnExit="false">
            <tab name="header" page="employeeHeader" title="基本信息"/>
            <tab name="contracts" page="employeeContracts" title="合同"/>
            <tab name="attendance" page="employeeAttendance" title="考勤"/>
            <tab name="leaves" page="employeeLeaves" title="休假"/>
            <tab name="timesheets" page="employeeTimesheets" title="工时"/>
        </tabs>

        <!-- 调动页面：表单提交调 transferEmployee mutation，employeeId 由 dialog data 预填 -->
        <simple name="transfer" form="transfer" useFormActions="true">
            <api url="@mutation:ErpHrEmployee__transferEmployee" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认调动" actionType="submit" level="primary">
                    <messages>
                        <success>员工调动已提交</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <picker name="picker"/>
    </pages>
</view>
