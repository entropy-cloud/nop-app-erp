<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrLeaveRequest.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="leaveType" mandatory="true" sortable="true"/>
                <col id="startDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="durationDays" ui:number="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approver" label="审批人"/>
                <col id="approvedAt" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] employeeId[员工]
 orgId[业务组织] businessDate[业务日期]
=========>detail[休假明细]======
 leaveType[休假类型] startDate[开始日期]
 endDate[结束日期] durationDays[天数]
 reason[请假原因] 
=========>approval[审批信息]======
 status[状态] approverId[审批人]
 approvedAt[审批时间] 
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] employeeId[员工]
 orgId[业务组织] businessDate[业务日期]
=========>detail[休假明细]======
 leaveType[休假类型] startDate[开始日期]
 endDate[结束日期] durationDays[天数]
 reason[请假原因] 
=========>approval[审批信息]======
 status[状态] approverId[审批人]
 approvedAt[审批时间] 
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 employeeId[员工] leaveType[休假类型]
 status[状态] approverId[审批人]
 orgId[业务组织] startDate[开始日期]
            </layout>
            <cells>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="leaveType" filterOp="eq"/>
                <cell id="status" filterOp="in"/>
                <cell id="approverId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="startDate" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpHrLeaveRequest__submit?id=$id"/>
                    <confirmText>确认提交此休假申请？</confirmText>
                    <messages>
                        <success>休假申请已提交</success>
                    </messages>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpHrLeaveRequest__approve?id=$id"/>
                    <confirmText>确认批准此休假申请？</confirmText>
                    <messages>
                        <success>休假申请已批准</success>
                    </messages>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpHrLeaveRequest__reject?id=$id"/>
                    <confirmText>确认驳回此休假申请？</confirmText>
                    <messages>
                        <success>休假申请已驳回</success>
                    </messages>
                </action>
                <action id="row-cancel-button" label="取消" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpHrLeaveRequest__cancel?id=$id"/>
                    <confirmText>确认取消此已批准的休假？将回退排班联动。</confirmText>
                    <messages>
                        <success>休假申请已取消</success>
                    </messages>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <picker name="picker"/>
    </pages>
</view>
