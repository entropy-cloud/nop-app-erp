<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpHrEmploymentContract" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/hr/model/ErpHrEmploymentContract/ErpHrEmploymentContract.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--合同编号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--员工-->
                <col id="employeeId" mandatory="true" ui:number="true" sortable="true"/>

                <!--合同类型-->
                <col id="contractType" mandatory="true" sortable="true"/>

                <!--签订日期-->
                <col id="signDate" mandatory="true" sortable="true"/>

                <!--生效日期-->
                <col id="startDate" mandatory="true" sortable="true"/>

                <!--到期日期-->
                <col id="endDate" sortable="true"/>

                <!--试用期月数-->
                <col id="probationMonths" ui:number="true" sortable="true"/>

                <!--每周工时-->
                <col id="workingHoursPerWeek" ui:number="true" sortable="true"/>

                <!--薪资币种-->
                <col id="salaryCurrencyId" ui:number="true" sortable="true"/>

                <!--发薪方式-->
                <col id="salaryPayMethod" sortable="true"/>

                <!--合同状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--合同文件-->
                <col id="attachmentFileId" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-劳动合同" i18n-en:title="View Employment Contract">
            <layout>
 id[ID] code[合同编号]
 employeeId[员工] contractType[合同类型]
 signDate[签订日期] startDate[生效日期]
 endDate[到期日期] probationMonths[试用期月数]
 workingHoursPerWeek[每周工时] salaryCurrencyId[薪资币种]
 salaryPayMethod[发薪方式] status[合同状态]
 attachmentFileId[合同文件] orgId[业务组织]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 businessDate[业务日期] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-劳动合同" i18n-en:title="Add Employment Contract" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-劳动合同" i18n-en:title="Edit Employment Contract">
            <layout>
 id[ID] code[合同编号]
 employeeId[员工] contractType[合同类型]
 signDate[签订日期] startDate[生效日期]
 endDate[到期日期] probationMonths[试用期月数]
 workingHoursPerWeek[每周工时] salaryCurrencyId[薪资币种]
 salaryPayMethod[发薪方式] status[合同状态]
 attachmentFileId[合同文件] orgId[业务组织]
 remark[备注] businessDate[业务日期]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-劳动合同"
              i18n-en:title="Update Employment Contract"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrEmploymentContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrEmploymentContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpHrEmploymentContract__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpHrEmploymentContract__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpHrEmploymentContract__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpHrEmploymentContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpHrEmploymentContract__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpHrEmploymentContract__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpHrEmploymentContract__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpHrEmploymentContract__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>