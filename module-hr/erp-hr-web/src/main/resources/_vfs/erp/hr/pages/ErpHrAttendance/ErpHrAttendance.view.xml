<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrAttendance.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="date" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="clockIn" sortable="true"/>
                <col id="clockOut" sortable="true"/>
                <col id="workHours" ui:number="true" sortable="true"/>
                <col id="lateMinutes" ui:number="true" sortable="true"/>
                <col id="earlyLeaveMinutes" ui:number="true" sortable="true"/>
                <col id="isAbsent" sortable="true"/>
                <col id="source" sortable="true"/>
                <col id="leaveRequest" label="请假申请"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 employeeId[员工] date[考勤日期]
 businessDate[业务日期] orgId[业务组织]
=========>clock[打卡信息]======
 clockIn[签到时间] clockOut[签退时间]
 workHours[出勤时长] 
=========>exception[异常信息]======
 lateMinutes[迟到分钟数] earlyLeaveMinutes[早退分钟数]
 isAbsent[是否旷工] source[来源]
 leaveRequestId[关联休假] 
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 employeeId[员工] date[考勤日期]
 businessDate[业务日期] orgId[业务组织]
=========>clock[打卡信息]======
 clockIn[签到时间] clockOut[签退时间]
 workHours[出勤时长] 
=========>exception[异常信息]======
 lateMinutes[迟到分钟数] earlyLeaveMinutes[早退分钟数]
 isAbsent[是否旷工] source[来源]
 leaveRequestId[关联休假] 
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 employeeId[员工] date[考勤日期]
 orgId[业务组织] source[来源]
 isAbsent[是否旷工] 
            </layout>
            <cells>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="date" filterOp="date-between"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="source" filterOp="eq"/>
                <cell id="isAbsent" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge">
                <action id="list-clock-in-button" label="签到" level="primary" icon="fa fa-sign-in"
                        actionType="ajax">
                    <api url="@mutation:ErpHrAttendance__clockIn?employeeId=$employeeId" dataType="raw"/>
                    <confirmText>确认签到？</confirmText>
                    <messages>
                        <success>签到成功</success>
                    </messages>
                </action>
                <action id="list-clock-out-button" label="签退" level="info" icon="fa fa-sign-out"
                        actionType="ajax">
                    <api url="@mutation:ErpHrAttendance__clockOut?employeeId=$employeeId" dataType="raw"/>
                    <confirmText>确认签退？</confirmText>
                    <messages>
                        <success>签退成功</success>
                    </messages>
                </action>
            </listActions>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <picker name="picker"/>
    </pages>
</view>
