<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrRecruitment.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="positionId" label="职位"/>
                <col id="departmentId" label="部门"/>
                <col id="headcount" ui:number="true" sortable="true"/>
                <col id="candidateName" mandatory="true" sortable="true"/>
                <col id="source" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="interviewer" label="面试官"/>
                <col id="interviewDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="offerSalary" ui:number="true" sortable="true"/>
                <col id="hiredDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="employee" label="员工"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] positionId[招聘职位]
 departmentId[招聘部门] orgId[业务组织]
 businessDate[业务日期] 
=========>headcount[编制与候选人]======
 headcount[招聘人数] candidateName[应聘者姓名]
 candidatePhone[联系电话] candidateEmail[电子邮箱]
 source[来源] 
=========>pipeline[招聘管线]======
 status[状态] interviewerId[面试官]
 interviewDate[面试日期] offerSalary[Offer薪资]
 hiredDate[入职日期] employeeId[关联员工]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] positionId[招聘职位]
 departmentId[招聘部门] orgId[业务组织]
 businessDate[业务日期] 
=========>headcount[编制与候选人]======
 headcount[招聘人数] candidateName[应聘者姓名]
 candidatePhone[联系电话] candidateEmail[电子邮箱]
 source[来源] 
=========>pipeline[招聘管线]======
 status[状态] interviewerId[面试官]
 interviewDate[面试日期] offerSalary[Offer薪资]
 hiredDate[入职日期] employeeId[关联员工]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编号] positionId[招聘职位]
 departmentId[招聘部门] status[状态]
 businessDate[业务日期] 
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="positionId" filterOp="eq"/>
                <cell id="departmentId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>

        <!-- UC-HR-05 安排面试表单 -->
        <form id="scheduleInterview" editMode="add" title="安排面试">
            <layout>
  interviewerId[面试官ID] interviewDate[面试日期]
</layout>
            <cells>
                <cell id="interviewerId" label="面试官ID" domain="long" custom="true">
                    <gen-control>
                        <input-number placeholder="面试官员工ID"/>
                    </gen-control>
                </cell>
                <cell id="interviewDate" label="面试日期" domain="date" custom="true">
                    <gen-control>
                        <input-date format="YYYY-MM-DD" placeholder="面试日期"/>
                    </gen-control>
                </cell>
            </cells>
        </form>

        <!-- UC-HR-05 发放Offer表单 -->
        <form id="makeOffer" editMode="add" title="发放Offer">
            <layout>
  offerSalary[Offer薪资]
</layout>
            <cells>
                <cell id="offerSalary" label="Offer薪资(月薪)" domain="decimal" custom="true">
                    <gen-control>
                        <input-number placeholder="月薪金额"/>
                    </gen-control>
                </cell>
            </cells>
        </form>

        <!-- UC-HR-05 入职表单 -->
        <form id="hire" editMode="add" title="入职">
            <layout>
  hiredDate[入职日期]
</layout>
            <cells>
                <cell id="hiredDate" label="入职日期" domain="date" custom="true">
                    <gen-control>
                        <input-date format="YYYY-MM-DD" placeholder="入职日期"/>
                    </gen-control>
                </cell>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-screening-button" label="筛选" level="primary" icon="fa fa-filter">
                    <api url="@mutation:ErpHrRecruitment__moveToScreening?id=$id"/>
                    <confirmText>确认推进到简历筛选？</confirmText>
                    <messages>
                        <success>已推进到筛选阶段</success>
                    </messages>
                </action>
                <action id="row-interview-button" label="面试" level="info" icon="fa fa-calendar"
                        actionType="drawer">
                    <dialog page="scheduleInterview" size="md"/>
                </action>
                <action id="row-offer-button" label="Offer" level="success" icon="fa fa-file-text-o"
                        actionType="drawer">
                    <dialog page="makeOffer" size="md"/>
                </action>
                <action id="row-hire-button" label="入职" level="success" icon="fa fa-user-plus"
                        actionType="drawer">
                    <dialog page="hire" size="md"/>
                </action>
                <action id="row-reject-button" label="拒绝" level="danger" icon="fa fa-times">
                    <api url="@mutation:ErpHrRecruitment__reject?id=$id"/>
                    <confirmText>确认拒绝此候选人？</confirmText>
                    <messages>
                        <success>已拒绝此候选人</success>
                    </messages>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <!-- 安排面试提交页 -->
        <simple name="scheduleInterview" form="scheduleInterview" useFormActions="true">
            <api url="@mutation:ErpHrRecruitment__scheduleInterview/id" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认安排" actionType="submit" level="primary">
                    <messages>
                        <success>面试已安排</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <!-- 发放Offer提交页 -->
        <simple name="makeOffer" form="makeOffer" useFormActions="true">
            <api url="@mutation:ErpHrRecruitment__makeOffer/id" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认发放" actionType="submit" level="primary">
                    <messages>
                        <success>Offer已发放</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <!-- 入职提交页 -->
        <simple name="hire" form="hire" useFormActions="true">
            <api url="@mutation:ErpHrRecruitment__hire/id" withFormData="true"/>
            <actions>
                <action id="cancel" label="取消" actionType="cancel"/>
                <action id="confirm" label="确认入职" actionType="submit" level="primary">
                    <messages>
                        <success>入职已确认，员工档案已创建</success>
                    </messages>
                </action>
            </actions>
        </simple>

        <picker name="picker"/>
    </pages>
</view>
