<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrEmploymentContract.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="employeeDisplayName" label="员工"/>
                <col id="contractType" mandatory="true" sortable="true"/>
                <col id="signDate" mandatory="true" sortable="true"/>
                <col id="startDate" mandatory="true" sortable="true"/>
                <col id="endDate" sortable="true"/>
                <col id="currencyId" label="币种"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>