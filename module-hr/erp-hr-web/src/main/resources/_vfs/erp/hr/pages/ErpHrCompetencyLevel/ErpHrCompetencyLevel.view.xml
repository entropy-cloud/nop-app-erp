<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrCompetencyLevel.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="competencyId" label="胜任力"/>
                <col id="levelNumber" mandatory="true" ui:number="true" sortable="true"/>
                <col id="levelName" sortable="true"/>
                <col id="behavioralAnchor" sortable="true"/>
                <col id="sortOrder" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="levelNumber" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'levelNumber',
                                required: true,
                                step: 1,
                                validations: { minimum: 1 },
                                validationErrors: { minimum: '等级编号必须 ≥ 1' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="levelName"/>
                <col id="behavioralAnchor"/>
                <col id="sortOrder">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-number', name: 'sortOrder', step: 10 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="levelNumber" mandatory="true" ui:number="true"/>
                <col id="levelName"/>
                <col id="behavioralAnchor"/>
                <col id="sortOrder" ui:number="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>