<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrDevelopmentPlanItem.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="planId" label="发展计划"/>
                <col id="competencyId" label="胜任力"/>
                <col id="gapId" ui:number="true" sortable="true"/>
                <col id="targetLevel" mandatory="true" ui:number="true" sortable="true"/>
                <col id="developmentAction" sortable="true"/>
                <col id="mentor" label="导师"/>
                <col id="startDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="competencyId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'competencyId',
                                source: '/erp/hr/pages/ErpHrCompetency/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="targetLevel" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'targetLevel',
                                required: true,
                                step: 1,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '目标等级不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="developmentAction"/>
                <col id="mentorId"/>
                <col id="startDate">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-date', name: 'startDate', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-date', name: 'endDate', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" mandatory="true"/>
                <col id="progressNote"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="competencyId"/>
                <col id="targetLevel" mandatory="true" ui:number="true"/>
                <col id="developmentAction"/>
                <col id="mentorId"/>
                <col id="startDate">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" mandatory="true"/>
                <col id="progressNote"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 planId[发展计划] competencyId[目标胜任力]
 gapId[关联差距分析] 
=========>detail[明细]======
 targetLevel[目标等级] developmentAction[发展行动]
 mentorId[导师] startDate[开始日期]
 endDate[预计完成日期] status[状态]
 progressNote[进度说明] 
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 planId[发展计划] competencyId[目标胜任力]
 gapId[关联差距分析] 
=========>detail[明细]======
 targetLevel[目标等级] developmentAction[发展行动]
 mentorId[导师] startDate[开始日期]
 endDate[预计完成日期] status[状态]
 progressNote[进度说明] 
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 planId[发展计划] competencyId[目标胜任力]
 mentorId[导师] status[状态]
 startDate[开始日期] 
            </layout>
            <cells>
                <cell id="planId" filterOp="eq"/>
                <cell id="competencyId" filterOp="eq"/>
                <cell id="mentorId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="startDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>