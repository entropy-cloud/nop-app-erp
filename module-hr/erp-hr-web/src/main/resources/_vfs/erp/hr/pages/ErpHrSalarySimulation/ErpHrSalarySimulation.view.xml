<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSalarySimulation.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="sourceSalaryId" ui:number="true" sortable="true"/>
                <col id="simulationPeriodYear" mandatory="true" ui:number="true" sortable="true"/>
                <col id="simulationPeriodMonth" mandatory="true" ui:number="true" sortable="true"/>
                <col id="simulationName" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="reviewerDisplayName" label="审核人"/>
                <col id="reviewedAt" sortable="true"/>
                <col id="convertedAt" sortable="true"/>
                <col id="convertedSalaryId" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>