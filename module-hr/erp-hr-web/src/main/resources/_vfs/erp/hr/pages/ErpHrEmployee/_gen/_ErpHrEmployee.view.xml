<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpHrEmployee" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/hr/model/ErpHrEmployee/ErpHrEmployee.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--工号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--姓-->
                <col id="firstName" mandatory="true" sortable="true"/>

                <!--名-->
                <col id="lastName" mandatory="true" sortable="true"/>

                <!--全名-->
                <col id="fullName" sortable="true"/>

                <!--性别-->
                <col id="gender" mandatory="true" sortable="true"/>

                <!--出生日期-->
                <col id="birthDate" sortable="true"/>

                <!--证件类型-->
                <col id="idCardType" sortable="true"/>

                <!--证件号码-->
                <col id="idCardNo" sortable="true"/>

                <!--电子邮箱-->
                <col id="email" sortable="true"/>

                <!--手机号-->
                <col id="mobilePhone" sortable="true"/>

                <!--婚姻状况-->
                <col id="maritalStatus" sortable="true"/>

                <!--国籍-->
                <col id="nationality" sortable="true"/>

                <!--紧急联系人-->
                <col id="emergencyContact" sortable="true"/>

                <!--紧急联系电话-->
                <col id="emergencyPhone" sortable="true"/>

                <!--部门-->
                <col id="departmentId" ui:number="true" sortable="true"/>

                <!--职位-->
                <col id="positionId" ui:number="true" sortable="true"/>

                <!--岗位名称-->
                <col id="jobTitle" sortable="true"/>

                <!--直接上级-->
                <col id="superiorId" ui:number="true" sortable="true"/>

                <!--默认成本中心-->
                <col id="costCenterId" ui:number="true" sortable="true"/>

                <!--入职日期-->
                <col id="hireDate" mandatory="true" sortable="true"/>

                <!--试用期截止-->
                <col id="probationEndDate" sortable="true"/>

                <!--转正日期-->
                <col id="regularDate" sortable="true"/>

                <!--离职日期-->
                <col id="resignationDate" sortable="true"/>

                <!--离职原因-->
                <col id="resignationReason" sortable="true"/>

                <!--雇佣状态-->
                <col id="employmentStatus" mandatory="true" sortable="true"/>

                <!--员工类型-->
                <col id="employeeType" mandatory="true" sortable="true"/>

                <!--工资卡账户-->
                <col id="bankAccountId" ui:number="true" sortable="true"/>

                <!--社保号-->
                <col id="socialSecurityNo" sortable="true"/>

                <!--个税档案号-->
                <col id="taxFileNo" sortable="true"/>

                <!--系统用户ID-->
                <col id="userAccountId" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgName"/>

                <!--部门-->
                <col id="departmentName"/>

                <!--职位-->
                <col id="positionName"/>

                <!--直接上级-->
                <col id="superiorDisplayName"/>

                <!--默认成本中心-->
                <col id="costCenterName"/>

                <!--工资卡账户-->
                <col id="bankAccountName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-员工" i18n-en:title="View Employee">
            <layout>
 code[工号] firstName[姓]
 lastName[名] fullName[全名]
 gender[性别] birthDate[出生日期]
 idCardType[证件类型] idCardNo[证件号码]
 email[电子邮箱] mobilePhone[手机号]
 maritalStatus[婚姻状况] nationality[国籍]
 emergencyContact[紧急联系人] emergencyPhone[紧急联系电话]
 departmentId[部门] positionId[职位]
 jobTitle[岗位名称] superiorId[直接上级]
 costCenterId[默认成本中心] hireDate[入职日期]
 probationEndDate[试用期截止] regularDate[转正日期]
 resignationDate[离职日期] resignationReason[离职原因]
 employmentStatus[雇佣状态] employeeType[员工类型]
 bankAccountId[工资卡账户] socialSecurityNo[社保号]
 taxFileNo[个税档案号] userAccountId[系统用户ID]
 orgId[业务组织] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] orgName[业务组织]
 departmentName[部门] positionName[职位]
 superiorDisplayName[直接上级] costCenterName[默认成本中心]
 bankAccountName[工资卡账户] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-员工" i18n-en:title="Add Employee" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-员工" i18n-en:title="Edit Employee">
            <layout>
 code[工号] firstName[姓]
 lastName[名] fullName[全名]
 gender[性别] birthDate[出生日期]
 idCardType[证件类型] idCardNo[证件号码]
 email[电子邮箱] mobilePhone[手机号]
 maritalStatus[婚姻状况] nationality[国籍]
 emergencyContact[紧急联系人] emergencyPhone[紧急联系电话]
 departmentId[部门] positionId[职位]
 jobTitle[岗位名称] superiorId[直接上级]
 costCenterId[默认成本中心] hireDate[入职日期]
 probationEndDate[试用期截止] regularDate[转正日期]
 resignationDate[离职日期] resignationReason[离职原因]
 employmentStatus[雇佣状态] employeeType[员工类型]
 bankAccountId[工资卡账户] socialSecurityNo[社保号]
 taxFileNo[个税档案号] userAccountId[系统用户ID]
 orgId[业务组织] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-员工" i18n-en:title="Update Employee"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrEmployee__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrEmployee__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpHrEmployee__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpHrEmployee__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpHrEmployee__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpHrEmployee__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpHrEmployee__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpHrEmployee__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpHrEmployee__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpHrEmployee__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>