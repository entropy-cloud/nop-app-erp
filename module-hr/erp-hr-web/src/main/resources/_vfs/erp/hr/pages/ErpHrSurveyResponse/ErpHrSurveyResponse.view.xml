<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSurveyResponse.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="surveyId" label="问卷"/>
                <col id="employee" label="员工"/>
                <col id="submittedAt" sortable="true"/>
                <col id="isComplete" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="employeeId"/>
                <col id="submittedAt">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-datetime', name: 'submittedAt', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isComplete"/>
                <col id="timeSpentSeconds">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'timeSpentSeconds',
                                step: 1,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '耗时不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="employeeId"/>
                <col id="submittedAt"/>
                <col id="isComplete"/>
                <col id="timeSpentSeconds" ui:number="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>