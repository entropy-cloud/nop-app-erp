<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSalarySimulationItemAdjustment.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="simulation" label="薪资模拟"/>
                <col id="employee" label="员工"/>
                <col id="salaryItemCode" mandatory="true" sortable="true"/>
                <col id="originalAmount" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="adjustedAmount" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="adjustmentReason" sortable="true"/>
                <col id="adjustedBy" sortable="true"/>
                <col id="adjustedAt" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 simulationId[模拟] employeeId[员工]
 orgId[业务组织] 
=========>detail[调整明细]======
 salaryItemCode[薪酬项目编码] originalAmount[源值]
 adjustedAmount[调整后值] adjustmentReason[调整原因]
========^audit[审计信息]=========
 adjustedBy[调整人] adjustedAt[调整时间]
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 simulationId[模拟] employeeId[员工]
 orgId[业务组织] 
=========>detail[调整明细]======
 salaryItemCode[薪酬项目编码] originalAmount[源值]
 adjustedAmount[调整后值] adjustmentReason[调整原因]
========^audit[审计信息]=========
 adjustedBy[调整人] adjustedAt[调整时间]
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 simulationId[模拟] employeeId[员工]
 salaryItemCode[薪酬项目编码] adjustedBy[调整人]
 adjustmentReason[调整原因] 
            </layout>
            <cells>
                <cell id="simulationId" filterOp="eq"/>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="salaryItemCode" filterOp="like"/>
                <cell id="adjustedBy" filterOp="eq"/>
                <cell id="adjustmentReason" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>