<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSurveyResult.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="surveyId" label="问卷"/>
                <col id="departmentId" label="部门"/>
                <col id="totalResponses" ui:number="true" sortable="true"/>
                <col id="avgScore" ui:number="true" sortable="true"/>
                <col id="eNpsScore" ui:number="true" sortable="true"/>
                <col id="lastCalculatedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 surveyId[问卷] departmentId[部门]
 lastCalculatedAt[最后计算时间]
            </layout>
            <cells>
                <cell id="surveyId" filterOp="eq"/>
                <cell id="departmentId" filterOp="eq"/>
                <cell id="lastCalculatedAt" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 surveyId[问卷]
            </layout>
            <cells>
                <cell id="surveyId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
