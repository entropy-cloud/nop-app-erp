<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSalary.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="year" mandatory="true" ui:number="true" sortable="true"/>
                <col id="month" mandatory="true" ui:number="true" sortable="true"/>
                <col id="paymentStatus" mandatory="true" sortable="true"/>
                <col id="paymentDate" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
                <col id="bankFileId" label="银行代发文件"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpHrSalary__submitForApproval?id=$id"/>
                    <confirmText>确认提交此薪酬记录审批？</confirmText>
                    <messages>
                        <success>薪酬记录已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpHrSalary__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此薪酬记录的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>薪酬记录已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpHrSalary__approve?id=$id"/>
                    <confirmText>确认批准此薪酬记录？</confirmText>
                    <messages>
                        <success>薪酬记录已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpHrSalary__reject?id=$id"/>
                    <confirmText>确认驳回此薪酬记录？</confirmText>
                    <messages>
                        <success>薪酬记录已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpHrSalary__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此薪酬记录？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>薪酬记录已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>