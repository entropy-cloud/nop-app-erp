<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSurveyQuestion.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="surveyId" label="问卷"/>
                <col id="sortOrder" ui:number="true" sortable="true"/>
                <col id="questionText" mandatory="true" sortable="true"/>
                <col id="questionType" mandatory="true" sortable="true"/>
                <col id="driverCategory" sortable="true"/>
                <col id="isRequired" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="sortOrder" ui:number="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-number', name: 'sortOrder', step: 10 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="questionText" mandatory="true"/>
                <col id="questionType" mandatory="true"/>
                <col id="driverCategory"/>
                <col id="isRequired"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="sortOrder" ui:number="true"/>
                <col id="questionText" mandatory="true"/>
                <col id="questionType" mandatory="true"/>
                <col id="driverCategory"/>
                <col id="isRequired"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>