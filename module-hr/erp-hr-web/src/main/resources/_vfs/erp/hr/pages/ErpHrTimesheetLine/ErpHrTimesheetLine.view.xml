<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrTimesheetLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="timesheet" label="工时表"/>
                <col id="employee" label="员工"/>
                <col id="workDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="projectId" label="项目"/>
                <col id="taskId" label="任务"/>
                <col id="activityType" sortable="true"/>
                <col id="hours" mandatory="true" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>