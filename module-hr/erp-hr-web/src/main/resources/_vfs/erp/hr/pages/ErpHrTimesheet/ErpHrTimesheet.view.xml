<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrTimesheet.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="periodFrom" mandatory="true" sortable="true"/>
                <col id="periodTo" mandatory="true" sortable="true"/>
                <col id="totalHours" ui:number="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpHrTimesheet__submit?timesheetId=$id"/>
                    <confirmText>确认提交此工时表？</confirmText>
                    <messages>
                        <success>工时表已提交</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>