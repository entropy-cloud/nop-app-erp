<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpHrSurveyQuestion" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/hr/model/ErpHrSurveyQuestion/ErpHrSurveyQuestion.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--所属问卷-->
                <col id="surveyId" mandatory="true" ui:number="true" sortable="true"/>

                <!--排序号-->
                <col id="sortOrder" ui:number="true" sortable="true"/>

                <!--题目内容-->
                <col id="questionText" mandatory="true" sortable="true"/>

                <!--题型-->
                <col id="questionType" mandatory="true" sortable="true"/>

                <!--评分最低分-->
                <col id="ratingScaleMin" ui:number="true" sortable="true"/>

                <!--评分最高分-->
                <col id="ratingScaleMax" ui:number="true" sortable="true"/>

                <!--最低分标签-->
                <col id="ratingLabelMin" sortable="true"/>

                <!--最高分标签-->
                <col id="ratingLabelMax" sortable="true"/>

                <!--选项列表-->
                <col id="options" sortable="true"/>

                <!--驱动因子分类-->
                <col id="driverCategory" sortable="true"/>

                <!--是否必填-->
                <col id="isRequired" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-问卷题目" i18n-en:title="View Survey Question">
            <layout>
 surveyId[所属问卷] sortOrder[排序号]
 questionText[题目内容] questionType[题型]
 ratingScaleMin[评分最低分] ratingScaleMax[评分最高分]
 ratingLabelMin[最低分标签] ratingLabelMax[最高分标签]
 options[选项列表] driverCategory[驱动因子分类]
 isRequired[是否必填] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-问卷题目" i18n-en:title="Add Survey Question" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-问卷题目" i18n-en:title="Edit Survey Question">
            <layout>
 surveyId[所属问卷] sortOrder[排序号]
 questionText[题目内容] questionType[题型]
 ratingScaleMin[评分最低分] ratingScaleMax[评分最高分]
 ratingLabelMin[最低分标签] ratingLabelMax[最高分标签]
 options[选项列表] driverCategory[驱动因子分类]
 isRequired[是否必填] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-问卷题目" i18n-en:title="Update Survey Question"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrSurveyQuestion__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrSurveyQuestion__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpHrSurveyQuestion__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpHrSurveyQuestion__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpHrSurveyQuestion__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpHrSurveyQuestion__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpHrSurveyQuestion__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpHrSurveyQuestion__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpHrSurveyQuestion__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpHrSurveyQuestion__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>