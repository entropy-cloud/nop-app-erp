<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrLeaveBalance.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="leaveType" mandatory="true" sortable="true"/>
                <col id="fiscalYear" mandatory="true" ui:number="true" sortable="true"/>
                <col id="entitledDays" mandatory="true" ui:number="true" sortable="true"/>
                <col id="carriedForwardDays" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 employeeId[员工] leaveType[休假类型]
 fiscalYear[财政年度] orgId[业务组织]
            </layout>
            <cells>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="leaveType" filterOp="eq"/>
                <cell id="fiscalYear" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 employeeId[员工] fiscalYear[财政年度]
            </layout>
            <cells>
                <cell id="employeeId" filterOp="eq"/>
                <cell id="fiscalYear" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
