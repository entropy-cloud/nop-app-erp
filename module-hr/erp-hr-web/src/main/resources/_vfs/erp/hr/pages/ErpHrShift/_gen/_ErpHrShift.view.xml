<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpHrShift" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/hr/model/ErpHrShift/ErpHrShift.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--班次名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--班次类型-->
                <col id="shiftType" mandatory="true" ui:number="true" sortable="true"/>

                <!--上班时间-->
                <col id="startTime" mandatory="true" sortable="true"/>

                <!--下班时间-->
                <col id="endTime" mandatory="true" sortable="true"/>

                <!--迟到宽容分钟数-->
                <col id="graceLateMinutes" ui:number="true" sortable="true"/>

                <!--早退宽容分钟数-->
                <col id="graceEarlyLeaveMinutes" ui:number="true" sortable="true"/>

                <!--需签到-->
                <col id="requireClockIn" sortable="true"/>

                <!--需签退-->
                <col id="requireClockOut" sortable="true"/>

                <!--休息开始-->
                <col id="restStartTime" sortable="true"/>

                <!--休息结束-->
                <col id="restEndTime" sortable="true"/>

                <!--标准工时(分钟)-->
                <col id="totalWorkMinutes" ui:number="true" sortable="true"/>

                <!--允许加班-->
                <col id="allowOvertime" sortable="true"/>

                <!--显示颜色-->
                <col id="colorHex" sortable="true"/>

                <!--说明-->
                <col id="description" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-班次模板" i18n-en:title="View Shift">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] name[班次名称]
 shiftType[班次类型] startTime[上班时间]
 endTime[下班时间] graceLateMinutes[迟到宽容分钟数]
 graceEarlyLeaveMinutes[早退宽容分钟数] requireClockIn[需签到]
 requireClockOut[需签退] restStartTime[休息开始]
 restEndTime[休息结束] totalWorkMinutes[标准工时(分钟)]
 allowOvertime[允许加班] colorHex[显示颜色]
 description[说明] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-班次模板" i18n-en:title="Add Shift">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] name[班次名称]
 shiftType[班次类型] startTime[上班时间]
 endTime[下班时间] graceLateMinutes[迟到宽容分钟数]
 graceEarlyLeaveMinutes[早退宽容分钟数] requireClockIn[需签到]
 requireClockOut[需签退] restStartTime[休息开始]
 restEndTime[休息结束] totalWorkMinutes[标准工时(分钟)]
 allowOvertime[允许加班] colorHex[显示颜色]
 description[说明] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-班次模板" i18n-en:title="Edit Shift">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] name[班次名称]
 shiftType[班次类型] startTime[上班时间]
 endTime[下班时间] graceLateMinutes[迟到宽容分钟数]
 graceEarlyLeaveMinutes[早退宽容分钟数] requireClockIn[需签到]
 requireClockOut[需签退] restStartTime[休息开始]
 restEndTime[休息结束] totalWorkMinutes[标准工时(分钟)]
 allowOvertime[允许加班] colorHex[显示颜色]
 description[说明] delVersion[逻辑删除版本]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-班次模板" i18n-en:title="Update Shift"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrShift__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpHrShift__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpHrShift__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpHrShift__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpHrShift__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpHrShift__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpHrShift__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpHrShift__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpHrShift__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpHrShift__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>