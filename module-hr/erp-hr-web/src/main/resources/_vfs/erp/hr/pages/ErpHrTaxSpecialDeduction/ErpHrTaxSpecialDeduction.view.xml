<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrTaxSpecialDeduction.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="employee" label="员工"/>
                <col id="year" mandatory="true" ui:number="true" sortable="true"/>
                <col id="month" mandatory="true" ui:number="true" sortable="true"/>
                <col id="deductionType" mandatory="true" sortable="true"/>
                <col id="monthlyAmount" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="verified" sortable="true"/>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>