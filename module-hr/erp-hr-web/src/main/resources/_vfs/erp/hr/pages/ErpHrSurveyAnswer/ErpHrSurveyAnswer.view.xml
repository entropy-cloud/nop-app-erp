<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpHrSurveyAnswer.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="responseId" mandatory="true" ui:number="true" sortable="true"/>
                <col id="question" label="题目"/>
                <col id="ratingValue" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="selectedOption" sortable="true"/>
                <col id="openText" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="questionId" mandatory="true"/>
                <col id="ratingValue">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'ratingValue',
                                step: 1,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '评分不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="selectedOption"/>
                <col id="openText"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="questionId" mandatory="true"/>
                <col id="ratingValue" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="selectedOption"/>
                <col id="openText"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>