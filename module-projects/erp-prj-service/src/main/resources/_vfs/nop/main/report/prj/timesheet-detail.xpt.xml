<?xml version="1.0" encoding="UTF-8" ?>
<!-- 工时明细报表（种子报表）。数据集 ds 由 ErpPrjReportBizModel.buildTimesheetDetailDataset 注入，
     每行 {projectId, userId, hours, costAmount}。口径对齐 docs/design/projects/cost-collection.md：
     按项目×员工聚合工时与工时成本。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="timesheet-detail" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="100.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="3" styleId="title"><model/><value>工时明细表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>项目ID</value></cell>
                            <cell styleId="header"><model/><value>员工ID</value></cell>
                            <cell styleId="header"><model/><value>工时(小时)</value></cell>
                            <cell styleId="header"><model/><value>工时成本</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="projectId"/>
                                <value>*=^ds!projectId</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=userId</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=hours</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=costAmount</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="1" styleId="total"><model/><value>合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(C3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(D3)</valueExpr></model>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
