<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 项目业财过账：执行器 + 工时派发器 + PROJECT_COST_COLLECTION Provider（Registry 容器级 collect-by-type 自动收录） -->
    <bean id="app.erp.prj.service.posting.ProjectPostingExecutor"
          class="app.erp.prj.service.posting.ProjectPostingExecutor"/>
    <bean id="app.erp.prj.service.posting.TimesheetPostingDispatcher"
          class="app.erp.prj.service.posting.TimesheetPostingDispatcher"/>
    <bean id="app.erp.prj.service.posting.ProjectCostCollectionProvider"
          class="app.erp.prj.service.posting.ProjectCostCollectionProvider"/>

    <!-- 项目结算过账：PROJECT_SETTLEMENT(430) 派发器 + Provider（plan 2026-07-07-0305-1 Phase 3） -->
    <bean id="app.erp.prj.service.posting.ProjectSettlementPostingDispatcher"
          class="app.erp.prj.service.posting.ProjectSettlementPostingDispatcher"/>
    <bean id="app.erp.prj.service.posting.ProjectSettlementAcctDocProvider"
          class="app.erp.prj.service.posting.ProjectSettlementAcctDocProvider"/>

    <!-- 工时成本率解析器 -->
    <bean id="app.erp.prj.service.cost.CostRateResolver"
          class="app.erp.prj.service.cost.CostRateResolver"/>

    <!-- 项目预算检查器（WARNING/STRICT，按 erp-prj.budget-control-mode） -->
    <bean id="app.erp.prj.service.cost.BudgetChecker"
          class="app.erp.prj.service.cost.BudgetChecker"/>

    <!-- 项目成本归集聚合器（工时 APPROVED → 归集行 + actualCost 回写） -->
    <bean id="app.erp.prj.service.cost.ProjectCostAggregator"
          class="app.erp.prj.service.cost.ProjectCostAggregator"/>

    <!-- 费用报销归集聚合器（projects 驱动只读聚合，config-gated） -->
    <bean id="app.erp.prj.service.cost.ExpenseCostAggregator"
          class="app.erp.prj.service.cost.ExpenseCostAggregator"/>

    <!-- 项目看板聚合入口（plan 2026-07-06-1606-1）：非实体 BizModel，注入 IDaoProvider/IOrmTemplate，
          经 @BizQuery 暴露 getDashboardKpi/getProjectStatusDistribution/findCostOverrunAlert/findDelayedProjectAlert。 -->
    <bean id="app.erp.prj.service.dashboard.ErpPrjDashboardBizModel" ioc:type="@bean:id"/>

    <!-- 项目域报表渲染入口（plan 2026-07-06-1815-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。镜像 finance ErpFinReportBizModel（域隔离 /prj/）。 -->
    <bean id="app.erp.prj.service.report.ErpPrjReportBizModel" ioc:type="@bean:id"/>

    <!-- 项目损益汇总计算引擎（plan 2026-07-07-0305-1 Phase 2）：聚合 Billing 收入 + CostCollection 四类成本 → ErpPrjProjectPnl -->
    <bean id="app.erp.prj.service.pnl.ProjectPnlCalculator"
          class="app.erp.prj.service.pnl.ProjectPnlCalculator"/>

    <!-- 项目结算单编排 Processor（plan 2026-07-07-0305-1 Phase 3）：三轴状态机 + CLOSE 转固 + 过账委托 -->
    <bean id="app.erp.prj.service.processor.ErpPrjProjectSettlementProcessor"
          class="app.erp.prj.service.processor.ErpPrjProjectSettlementProcessor"/>

</beans>
