            <schema type="java.lang.String" precision="20" dict="erp-prj/settlement-type"/>
        </prop>
        <prop name="pnlSnapshotId" displayName="关联损益汇总" propId="8" i18n-en:displayName="PnL Snapshot" queryable="true"
