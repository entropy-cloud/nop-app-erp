        </prop>
        <prop name="exchangeRate" displayName="汇率" propId="10" i18n-en:displayName="Exchange Rate" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true" defaultValue="1">
            <schema domain="exchangeRate" type="java.math.BigDecimal" precision="20" scale="8"/>
        </prop>
        <prop name="amountSource" displayName="源币种金额" propId="11" i18n-en:displayName="Amt (Source)" queryable="true"
