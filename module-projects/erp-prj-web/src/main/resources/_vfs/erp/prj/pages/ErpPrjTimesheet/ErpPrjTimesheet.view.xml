<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjTimesheet.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="projectId" label="项目"/>
                <col id="taskId" label="任务"/>
                <col id="userId" label="用户"/>
                <col id="workDate" mandatory="true" sortable="true"/>
                <col id="hours" mandatory="true" sortable="true"/>
                <col id="activityTypeId" label="活动类型"/>
                <col id="currencyId" label="币种"/>
                <col id="costRate" sortable="true"/>
                <col id="costAmount" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpPrjTimesheet__submit?timesheetId=$id"/>
                    <confirmText>确认提交此工时单？</confirmText>
                    <messages>
                        <success>工时单已提交</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpPrjTimesheet__approve?timesheetId=$id"/>
                    <confirmText>确认批准此工时单？</confirmText>
                    <messages>
                        <success>工时单已批准</success>
                    </messages>
                    <visibleOn>${status == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpPrjTimesheet__reject?timesheetId=$id"/>
                    <confirmText>确认驳回此工时单？</confirmText>
                    <messages>
                        <success>工时单已驳回</success>
                    </messages>
                    <visibleOn>${status == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpPrjTimesheet__cancel?timesheetId=$id"/>
                    <confirmText>确认作废此工时单？</confirmText>
                    <messages>
                        <success>工时单已作废</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>