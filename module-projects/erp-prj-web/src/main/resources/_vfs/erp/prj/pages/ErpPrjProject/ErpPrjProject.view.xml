<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjProject.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="projectTypeId" label="项目类型"/>
                <col id="customerId" label="客户"/>
                <col id="currencyId" label="币种"/>
                <col id="managerId" label="项目经理"/>
                <col id="startDate" sortable="true"/>
                <col id="endDate" sortable="true"/>
                <col id="budget" sortable="true"/>
                <col id="actualCost" sortable="true"/>
                <col id="billedAmount" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[项目编码] name[项目名称]
 orgId[业务组织] projectTypeId[项目类型]
 customerId[客户] status[状态]
==========>schedule[进度信息]======
 startDate[开始日期] endDate[结束日期]
 managerId[项目经理(职员)]
==========>finance[财务信息]======
 currencyId[币种] budget[预算总额]
 committedCost[已承诺成本] actualCost[实际成本]
 billedAmount[已开票金额]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[项目编码] name[项目名称]
 orgId[业务组织] projectTypeId[项目类型]
 customerId[客户] status[状态]
==========>schedule[进度信息]======
 startDate[开始日期] endDate[结束日期]
 managerId[项目经理(职员)]
==========>finance[财务信息]======
 currencyId[币种] budget[预算总额]
 committedCost[已承诺成本] actualCost[实际成本]
 billedAmount[已开票金额]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[项目编码] name[项目名称]
 status[状态] customerId[客户]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-start-button" label="启动" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpPrjProject__startProject?projectId=$id"/>
                    <confirmText>确认启动此项目？</confirmText>
                    <messages>
                        <success>项目已启动</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-hold-button" label="暂停" level="warning" icon="fa fa-pause">
                    <api url="@mutation:ErpPrjProject__holdProject?projectId=$id"/>
                    <confirmText>确认暂停此项目？</confirmText>
                    <messages>
                        <success>项目已暂停</success>
                    </messages>
                    <visibleOn>${status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-resume-button" label="恢复" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpPrjProject__resumeProject?projectId=$id"/>
                    <confirmText>确认恢复此项目？</confirmText>
                    <messages>
                        <success>项目已恢复</success>
                    </messages>
                    <visibleOn>${status == 'ON_HOLD'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpPrjProject__closeProject?projectId=$id"/>
                    <confirmText>确认完成此项目？</confirmText>
                    <messages>
                        <success>项目已完成</success>
                    </messages>
                    <visibleOn>${status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpPrjProject__cancelProject?projectId=$id"/>
                    <confirmText>确认作废此项目？</confirmText>
                    <messages>
                        <success>项目已作废</success>
                    </messages>
                    <visibleOn>${status != 'COMPLETED' &amp;&amp; status != 'CANCELLED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>