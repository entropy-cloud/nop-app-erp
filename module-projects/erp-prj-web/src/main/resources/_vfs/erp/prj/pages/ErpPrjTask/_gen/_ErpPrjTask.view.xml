<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpPrjTask" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/prj/model/ErpPrjTask/ErpPrjTask.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--项目-->
                <col id="projectId" mandatory="true" ui:number="true" sortable="true"/>

                <!--父任务-->
                <col id="parentTaskId" ui:number="true" sortable="true"/>

                <!--任务标题-->
                <col id="title" mandatory="true" sortable="true"/>

                <!--负责人-->
                <col id="assigneeId" ui:number="true" sortable="true"/>

                <!--计划开始日期-->
                <col id="plannedStartDate" sortable="true"/>

                <!--计划结束日期-->
                <col id="plannedEndDate" sortable="true"/>

                <!--实际开始日期-->
                <col id="actualStartDate" sortable="true"/>

                <!--实际结束日期-->
                <col id="actualEndDate" sortable="true"/>

                <!--预估工时-->
                <col id="estimatedHours" ui:number="true" sortable="true"/>

                <!--实际工时-->
                <col id="actualHours" ui:number="true" sortable="true"/>

                <!--依赖任务-->
                <col id="dependsOnId" ui:number="true" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--优先级-->
                <col id="priority" sortable="true"/>

                <!--阻塞原因-->
                <col id="blockReason" sortable="true"/>

                <!--排序号-->
                <col id="sortNum" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-任务" i18n-en:title="View Task">
            <layout>
 id[ID] projectId[项目]
 parentTaskId[父任务] title[任务标题]
 assigneeId[负责人] plannedStartDate[计划开始日期]
 plannedEndDate[计划结束日期] actualStartDate[实际开始日期]
 actualEndDate[实际结束日期] estimatedHours[预估工时]
 actualHours[实际工时] dependsOnId[依赖任务]
 status[状态] priority[优先级]
 blockReason[阻塞原因] sortNum[排序号]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-任务" i18n-en:title="Add Task">
            <layout>
 id[ID] projectId[项目]
 parentTaskId[父任务] title[任务标题]
 assigneeId[负责人] plannedStartDate[计划开始日期]
 plannedEndDate[计划结束日期] actualStartDate[实际开始日期]
 actualEndDate[实际结束日期] estimatedHours[预估工时]
 actualHours[实际工时] dependsOnId[依赖任务]
 status[状态] priority[优先级]
 blockReason[阻塞原因] sortNum[排序号]
 remark[备注] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-任务" i18n-en:title="Edit Task">
            <layout>
 id[ID] projectId[项目]
 parentTaskId[父任务] title[任务标题]
 assigneeId[负责人] plannedStartDate[计划开始日期]
 plannedEndDate[计划结束日期] actualStartDate[实际开始日期]
 actualEndDate[实际结束日期] estimatedHours[预估工时]
 actualHours[实际工时] dependsOnId[依赖任务]
 status[状态] priority[优先级]
 blockReason[阻塞原因] sortNum[排序号]
 remark[备注] delVersion[逻辑删除版本]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-任务" i18n-en:title="Update Task"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpPrjTask__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpPrjTask__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpPrjTask__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpPrjTask__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpPrjTask__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpPrjTask__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpPrjTask__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpPrjTask__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>