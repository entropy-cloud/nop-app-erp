<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjProjectUser.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="projectId" label="项目"/>
                <col id="userId" label="用户"/>
                <col id="role" sortable="true"/>
                <col id="startDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 projectId[项目] userId[用户]
 role[角色] startDate[开始日期]
 endDate[结束日期]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 projectId[项目] userId[用户]
 role[角色] startDate[开始日期]
 endDate[结束日期]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 projectId[项目] userId[用户]
 role[角色] startDate[开始日期]
 endDate[结束日期]
            </layout>
            <cells>
                <cell id="projectId" filterOp="eq"/>
                <cell id="userId" filterOp="eq"/>
                <cell id="role" filterOp="eq"/>
                <cell id="startDate" filterOp="date-between"/>
                <cell id="endDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>