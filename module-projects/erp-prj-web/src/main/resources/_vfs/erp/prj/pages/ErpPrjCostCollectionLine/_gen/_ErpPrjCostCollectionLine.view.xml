<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpPrjCostCollectionLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/prj/model/ErpPrjCostCollectionLine/ErpPrjCostCollectionLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--归集单ID-->
                <col id="costCollectionId" mandatory="true" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--成本类别(人工/材料/费用/分包)-->
                <col id="costCategory" mandatory="true" sortable="true"/>

                <!--来源单据类型(TIMESHEET/PURCHASE/EXPENSE)-->
                <col id="sourceBillType" sortable="true"/>

                <!--来源单据号-->
                <col id="sourceBillCode" sortable="true"/>

                <!--科目-->
                <col id="subjectId" ui:number="true" sortable="true"/>

                <!--任务-->
                <col id="taskId" ui:number="true" sortable="true"/>

                <!--金额-->
                <col id="amount" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-项目成本归集行" i18n-en:title="View Project Cost Collection Line">
            <layout>
 id[ID] costCollectionId[归集单ID]
 lineNo[行号] costCategory[成本类别(人工/材料/费用/分包)]
 sourceBillType[来源单据类型(TIMESHEET/PURCHASE/EXPENSE)] sourceBillCode[来源单据号]
 subjectId[科目] taskId[任务]
 amount[金额] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-项目成本归集行" i18n-en:title="Add Project Cost Collection Line">
            <layout>
 id[ID] costCollectionId[归集单ID]
 lineNo[行号] costCategory[成本类别(人工/材料/费用/分包)]
 sourceBillType[来源单据类型(TIMESHEET/PURCHASE/EXPENSE)] sourceBillCode[来源单据号]
 subjectId[科目] taskId[任务]
 amount[金额] remark[备注]
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-项目成本归集行" i18n-en:title="Edit Project Cost Collection Line">
            <layout>
 id[ID] costCollectionId[归集单ID]
 lineNo[行号] costCategory[成本类别(人工/材料/费用/分包)]
 sourceBillType[来源单据类型(TIMESHEET/PURCHASE/EXPENSE)] sourceBillCode[来源单据号]
 subjectId[科目] taskId[任务]
 amount[金额] remark[备注]
 delVersion[逻辑删除版本] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-项目成本归集行"
              i18n-en:title="Update Project Cost Collection Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjCostCollectionLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjCostCollectionLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpPrjCostCollectionLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpPrjCostCollectionLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpPrjCostCollectionLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpPrjCostCollectionLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpPrjCostCollectionLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpPrjCostCollectionLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpPrjCostCollectionLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpPrjCostCollectionLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>