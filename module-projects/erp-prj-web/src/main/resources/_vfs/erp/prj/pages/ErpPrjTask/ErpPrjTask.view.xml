<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjTask.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="projectId" label="项目"/>
                <col id="parentTaskId" label="父任务"/>
                <col id="title" mandatory="true" sortable="true"/>
                <col id="assigneeId" label="负责人"/>
                <col id="dependsOnTaskName" label="依赖任务"/>
                <col id="plannedStartDate" sortable="true"/>
                <col id="plannedEndDate" sortable="true"/>
                <col id="estimatedHours" sortable="true"/>
                <col id="actualHours" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="priority" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>