<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjTask.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="projectId" label="项目"/>
                <col id="parentTaskId" label="父任务"/>
                <col id="title" mandatory="true" sortable="true"/>
                <col id="assigneeId" label="负责人"/>
                <col id="dependsOn" label="依赖任务"/>
                <col id="plannedStartDate" sortable="true"/>
                <col id="plannedEndDate" sortable="true"/>
                <col id="estimatedHours" sortable="true"/>
                <col id="actualHours" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="priority" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-start-button" label="开始" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpPrjTask__startTask?taskId=$id"/>
                    <confirmText>确认开始此任务？</confirmText>
                    <messages>
                        <success>任务已开始</success>
                    </messages>
                    <visibleOn>${status == 'TODO'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpPrjTask__completeTask?taskId=$id"/>
                    <confirmText>确认完成此任务？</confirmText>
                    <messages>
                        <success>任务已完成</success>
                    </messages>
                    <visibleOn>${status == 'IN_PROGRESS' || status == 'BLOCKED'}</visibleOn>
                </action>
                <action id="row-block-button" label="阻塞" level="warning" icon="fa fa-exclamation-triangle">
                    <api url="@mutation:ErpPrjTask__blockTask?taskId=$id&amp;reason=blocked"/>
                    <confirmText>确认标记此任务为阻塞？</confirmText>
                    <messages>
                        <success>任务已标记为阻塞</success>
                    </messages>
                    <visibleOn>${status == 'TODO' || status == 'IN_PROGRESS'}</visibleOn>
                </action>
                <action id="row-unblock-button" label="解除阻塞" level="primary" icon="fa fa-unlock">
                    <api url="@mutation:ErpPrjTask__unblockTask?taskId=$id"/>
                    <confirmText>确认解除此任务阻塞？</confirmText>
                    <messages>
                        <success>任务已解除阻塞</success>
                    </messages>
                    <visibleOn>${status == 'BLOCKED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>