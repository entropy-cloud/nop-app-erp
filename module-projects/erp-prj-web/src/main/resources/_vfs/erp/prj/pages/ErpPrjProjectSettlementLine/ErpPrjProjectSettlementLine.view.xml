<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPrjProjectSettlementLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="settlement" label="结算单号"/>
                <col id="lineNo" mandatory="true" sortable="true"/>
                <col id="lineType" mandatory="true" sortable="true"/>
                <col id="sourceBillType" sortable="true"/>
                <col id="sourceBillCode" sortable="true"/>
                <col id="subjectId" label="科目"/>
                <col id="amount" mandatory="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] lineType[行类型]
 sourceBillType[源单据类型] sourceBillCode[源单据号]
 subjectId[科目]
=========>amount[金额信息]======
 amount[金额]
=========>reference[业务关联]======
 settlementId[结算单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] lineType[行类型]
 sourceBillType[源单据类型] sourceBillCode[源单据号]
 subjectId[科目]
=========>amount[金额信息]======
 amount[金额]
=========>reference[业务关联]======
 settlementId[结算单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] lineType[行类型]
 sourceBillType[源单据类型] subjectId[科目]
 settlementId[结算单]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="lineType" filterOp="eq"/>
                <cell id="sourceBillType" filterOp="eq"/>
                <cell id="subjectId" filterOp="eq"/>
                <cell id="settlementId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>