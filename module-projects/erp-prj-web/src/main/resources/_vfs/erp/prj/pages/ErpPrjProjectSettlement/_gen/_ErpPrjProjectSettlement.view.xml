<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpPrjProjectSettlement" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/prj/model/ErpPrjProjectSettlement/ErpPrjProjectSettlement.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--项目-->
                <col id="projectId" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--客户-->
                <col id="customerId" ui:number="true" sortable="true"/>

                <!--结算日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--结算类型-->
                <col id="settlementType" mandatory="true" sortable="true"/>

                <!--关联损益汇总-->
                <col id="pnlSnapshotId" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" mandatory="true" ui:number="true" sortable="true"/>

                <!--源币种金额-->
                <col id="amountSource" ui:number="true" sortable="true"/>

                <!--本位币金额-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>

                <!--最终结算收入-->
                <col id="finalRevenue" ui:number="true" sortable="true"/>

                <!--最终结算成本-->
                <col id="finalCost" ui:number="true" sortable="true"/>

                <!--最终损益-->
                <col id="finalProfit" ui:number="true" sortable="true"/>

                <!--质保金/保留款-->
                <col id="retentionAmount" ui:number="true" sortable="true"/>

                <!--质保金到期-->
                <col id="retentionDueDate" sortable="true"/>

                <!--是否转固定资产-->
                <col id="transferToAsset" sortable="true"/>

                <!--转固资产卡片-->
                <col id="assetCardId" ui:number="true" sortable="true"/>

                <!--结算凭证号-->
                <col id="settlementVoucherCode" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" mandatory="true" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--审核人-->
                <col id="approvedBy" sortable="true"/>

                <!--审核时间-->
                <col id="approvedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-项目结算单" i18n-en:title="View Project Settlement">
            <layout>
 id[ID] code[单号]
 projectId[项目] orgId[业务组织]
 customerId[客户] businessDate[结算日期]
 settlementType[结算类型] pnlSnapshotId[关联损益汇总]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
 finalRevenue[最终结算收入] finalCost[最终结算成本]
 finalProfit[最终损益] retentionAmount[质保金/保留款]
 retentionDueDate[质保金到期] transferToAsset[是否转固定资产]
 assetCardId[转固资产卡片] settlementVoucherCode[结算凭证号]
 docStatus[单据状态] approveStatus[审核状态]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] approvedBy[审核人]
 approvedAt[审核时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-项目结算单" i18n-en:title="Add Project Settlement">
            <layout>
 id[ID] code[单号]
 projectId[项目] orgId[业务组织]
 customerId[客户] businessDate[结算日期]
 settlementType[结算类型] pnlSnapshotId[关联损益汇总]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
 finalRevenue[最终结算收入] finalCost[最终结算成本]
 finalProfit[最终损益] retentionAmount[质保金/保留款]
 retentionDueDate[质保金到期] transferToAsset[是否转固定资产]
 assetCardId[转固资产卡片] settlementVoucherCode[结算凭证号]
 docStatus[单据状态] approveStatus[审核状态]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 approvedBy[审核人] approvedAt[审核时间]
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-项目结算单" i18n-en:title="Edit Project Settlement">
            <layout>
 id[ID] code[单号]
 projectId[项目] orgId[业务组织]
 customerId[客户] businessDate[结算日期]
 settlementType[结算类型] pnlSnapshotId[关联损益汇总]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
 finalRevenue[最终结算收入] finalCost[最终结算成本]
 finalProfit[最终损益] retentionAmount[质保金/保留款]
 retentionDueDate[质保金到期] transferToAsset[是否转固定资产]
 assetCardId[转固资产卡片] settlementVoucherCode[结算凭证号]
 docStatus[单据状态] approveStatus[审核状态]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] remark[备注]
 delVersion[逻辑删除版本] approvedBy[审核人]
 approvedAt[审核时间] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-项目结算单"
              i18n-en:title="Update Project Settlement"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjProjectSettlement__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPrjProjectSettlement__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpPrjProjectSettlement__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpPrjProjectSettlement__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpPrjProjectSettlement__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpPrjProjectSettlement__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpPrjProjectSettlement__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpPrjProjectSettlement__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpPrjProjectSettlement__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpPrjProjectSettlement__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>