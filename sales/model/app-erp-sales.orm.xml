<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-sales ORM 模型 — 销售域（权威数据模型来源）
  ==================================================
  业务范围：销售订单（头/行）、销售出库单（头/行）、销售发票（头/行）、
            收款单（头/行）、收款核销明细

  三轴状态分离：
    - docStatus: 草稿/已生效/已作废（单据生命周期）
    - approveStatus: 未提交/已提交/已审核/已驳回（审核流程）
    - receivedStatus: 未收款/部分收款/已收清（收付款进度）

  命名约定：
    - appName:        app-erp-sal
    - entityPackage:  app.erp.sal.dao.entity
    - 实体类名:        ErpSal<Entity>
    - 表名:           erp_sal_<entity>
    - 字典命名空间:    erp-sal/<dict-name>
-->
<orm ext:registerShortName="true" ext:appName="app-erp-sal" ext:entityPackageName="app.erp.sal.dao.entity"
     ext:basePackageName="app.erp.sal" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-sales"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="单据状态" name="erp-sal/doc-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="ACTIVE" label="已生效" value="1"/>
            <option code="CANCELLED" label="已作废" value="2"/>
        </dict>
        <dict label="审核状态" name="erp-sal/approve-status" valueType="int">
            <option code="UNSUBMITTED" label="未提交" value="0"/>
            <option code="SUBMITTED" label="已提交" value="1"/>
            <option code="APPROVED" label="已审核" value="2"/>
            <option code="REJECTED" label="已驳回" value="3"/>
        </dict>
        <dict label="收款进度" name="erp-sal/received-status" valueType="int">
            <option code="UNRECEIVED" label="未收款" value="0"/>
            <option code="PARTIAL" label="部分收款" value="1"/>
            <option code="RECEIVED" label="已收清" value="2"/>
        </dict>
        <dict label="销售单据类型" name="erp-sal/biz-type" valueType="int">
            <option code="ORDER" label="销售订单" value="0"/>
            <option code="DELIVERY" label="销售出库" value="1"/>
            <option code="INVOICE" label="销售发票" value="2"/>
            <option code="RECEIPT" label="收款单" value="3"/>
            <option code="RETURN" label="销售退货" value="4"/>
        </dict>
    </dicts>

    <domains>
        <domain name="orderCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="taxRate" stdSqlType="DECIMAL" precision="10" scale="4"/>
        <domain name="quantity" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="unitPrice" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="taxAmount" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="discountRate" stdSqlType="DECIMAL" precision="10" scale="4"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <!-- 销售订单头 -->
        <entity className="app.erp.sal.dao.entity.ErpSalOrder"
                displayName="销售订单" name="app.erp.sal.dao.entity.ErpSalOrder"
                tableName="erp_sal_order" tag="erp.sales">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="单号" domainName="orderCode" mandatory="true"/>
                <column name="customerId" displayName="客户" stdSqlType="BIGINT" mandatory="true"/>
                <column name="warehouseId" displayName="发货仓库" stdSqlType="BIGINT"/>
                <column name="orderDate" displayName="订单日期" stdSqlType="DATE" mandatory="true"/>
                <column name="deliveryDate" displayName="交货日期" stdSqlType="DATE"/>
                <column name="currencyId" displayName="币种" stdSqlType="BIGINT" mandatory="true"/>
                <column name="exchangeRate" displayName="汇率" stdSqlType="DECIMAL" precision="20" scale="8" defaultValue="1"/>
                <column name="totalAmount" displayName="合计金额(不含税)" domainName="amount" defaultValue="0"/>
                <column name="totalTaxAmount" displayName="合计税额" domainName="taxAmount" defaultValue="0"/>
                <column name="totalAmountWithTax" displayName="合计金额(含税)" domainName="amount" defaultValue="0"/>
                <column name="discountRate" displayName="整单折扣率(%)" domainName="discountRate"/>
                <column name="discountAmount" displayName="折扣金额" domainName="amount" defaultValue="0"/>
                <column name="receivedAmount" displayName="已收金额" domainName="amount" defaultValue="0"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-sal/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-sal/approve-status" mandatory="true"/>
                <column name="receivedStatus" displayName="收款进度" dictName="erp-sal/received-status"/>
                <column name="approvedBy" displayName="审核人" stdSqlType="BIGINT"/>
                <column name="approvedAt" displayName="审核时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="customer" refEntityName="app.erp.md.dao.entity.ErpMdPartner" joinColumnName="customerId"/>
                <to-one name="warehouse" refEntityName="app.erp.md.dao.entity.ErpMdWarehouse" joinColumnName="warehouseId"/>
                <to-one name="currency" refEntityName="app.erp.md.dao.entity.ErpMdCurrency" joinColumnName="currencyId"/>
                <to-many name="lines" refEntityName="app.erp.sal.dao.entity.ErpSalOrderLine" myFieldName="id" refFieldName="orderId"/>
            </relations>
        </entity>

        <!-- 销售订单行 -->
        <entity className="app.erp.sal.dao.entity.ErpSalOrderLine"
                displayName="销售订单行" name="app.erp.sal.dao.entity.ErpSalOrderLine"
                tableName="erp_sal_order_line" tag="erp.sales">
