                <column name="quantity" displayName="数量" domainName="quantity" mandatory="true"/>
                <column name="unitPrice" displayName="单价(不含税)" domainName="unitPrice" mandatory="true"/>
                <column name="taxRate" displayName="税率(%)" domainName="taxRate"/>
                <column name="taxAmount" displayName="税额" domainName="taxAmount" defaultValue="0"/>
                <column name="amount" displayName="金额(不含税)" domainName="amount" mandatory="true"/>
                <column name="amountWithTax" displayName="金额(含税)" domainName="amount"/>
                <column name="deliveredQuantity" displayName="已出库数量" domainName="quantity" defaultValue="0"/>
                <column name="invoicedQuantity" displayName="已开票数量" domainName="quantity" defaultValue="0"/>
                <column name="warehouseId" displayName="发货仓库" stdSqlType="BIGINT"/>
                <column name="projectId" displayName="项目" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
