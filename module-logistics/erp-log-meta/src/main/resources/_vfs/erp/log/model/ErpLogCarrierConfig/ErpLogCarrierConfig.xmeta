<?xml version="1.0" encoding="UTF-8" ?>
<meta x:schema="/nop/schema/xmeta.xdef" xmlns:x="/nop/schema/xdsl.xdef" x:extends="_ErpLogCarrierConfig.xmeta">

    <props>
        <!-- 安全：凭证字段从 GraphQL schema 移除并禁止查询/排序，防止密钥明文泄露。请勿删除此屏蔽。 -->
        <prop name="apiKey" published="false" queryable="false" sortable="false" x:override="merge"/>
        <prop name="apiSecret" published="false" queryable="false" sortable="false" x:override="merge"/>
        <prop name="credentials" published="false" queryable="false" sortable="false" x:override="merge"/>
    </props>
</meta>