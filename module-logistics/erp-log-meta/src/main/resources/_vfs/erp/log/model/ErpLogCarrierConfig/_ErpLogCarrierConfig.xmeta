            <schema domain="orderCode" type="java.lang.String" precision="50"/>
        </prop>
        <prop name="serviceType" displayName="服务类型" propId="5" i18n-en:displayName="Service Type" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="apiEndpoint" displayName="接口地址" propId="6" i18n-en:displayName="API Endpoint" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="apiKey" displayName="API密钥" propId="7" i18n-en:displayName="API Key" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="apiSecret" displayName="API密钥" propId="8" i18n-en:displayName="API Secret" queryable="true"
