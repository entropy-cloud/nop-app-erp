            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="credentials" displayName="完整凭证" propId="9" i18n-en:displayName="Credentials" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="jsonText" type="java.lang.String"/>
        </prop>
        <prop name="trackingUrlTemplate" displayName="追踪URL模板" propId="10" i18n-en:displayName="Tracking URL Template"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="printFormat" displayName="面单打印格式" propId="11" i18n-en:displayName="Print Format" queryable="true"
