            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="signedBy" displayName="签收人" propId="30" i18n-en:displayName="Signed By" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="shipperId" displayName="发货员(职员)" propId="31" i18n-en:displayName="Shipper" queryable="true"
