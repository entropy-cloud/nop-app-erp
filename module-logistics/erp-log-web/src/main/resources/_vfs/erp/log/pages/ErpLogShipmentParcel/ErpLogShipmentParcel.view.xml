<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpLogShipmentParcel.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="shipmentId" label="发运单"/>
                <col id="parcelNo" mandatory="true" sortable="true"/>
                <col id="trackingNo" sortable="true"/>
                <col id="labelUrl" sortable="true"/>
                <col id="weight" ui:number="true" sortable="true"/>
                <col id="length" ui:number="true" sortable="true"/>
                <col id="width" ui:number="true" sortable="true"/>
                <col id="height" ui:number="true" sortable="true"/>
                <col id="declaredValue" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isActive" mandatory="true" ui:number="true" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 shipmentId[发运单ID] parcelNo[包裹编号]
 trackingNo[运单号]
=========>dimension[尺寸]======
 weight[重量(kg)] length[长(cm)]
 width[宽(cm)] height[高(cm)]
=========>value[价值与面单]======
 declaredValue[申报价值] labelUrl[面单URL]
 isActive[是否有效]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 shipmentId[发运单ID] parcelNo[包裹编号]
 trackingNo[运单号]
=========>dimension[尺寸]======
 weight[重量(kg)] length[长(cm)]
 width[宽(cm)] height[高(cm)]
=========>value[价值与面单]======
 declaredValue[申报价值] labelUrl[面单URL]
 isActive[是否有效]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 shipmentId[发运单ID] parcelNo[包裹编号]
 trackingNo[运单号] isActive[是否有效]
            </layout>
            <cells>
                <cell id="shipmentId" filterOp="eq"/>
                <cell id="parcelNo" filterOp="like"/>
                <cell id="trackingNo" filterOp="like"/>
                <cell id="isActive" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>