<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpLogShipmentLog.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="shipmentId" label="发运单"/>
                <col id="orgId" label="业务组织"/>
                <col id="gatewayId" mandatory="true" sortable="true"/>
                <col id="actionType" mandatory="true" sortable="true"/>
                <col id="requestBody" sortable="true"/>
                <col id="responseBody" sortable="true"/>
                <col id="httpStatus" ui:number="true" sortable="true"/>
                <col id="errorCode" sortable="true"/>
                <col id="errorMessage" sortable="true"/>
                <col id="isSuccess" sortable="true"/>
                <col id="executedAt" mandatory="true" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="actionType" mandatory="true"/>
                <col id="gatewayId" mandatory="true"/>
                <col id="httpStatus" ui:number="true"/>
                <col id="isSuccess"/>
                <col id="errorCode"/>
                <col id="errorMessage"/>
                <col id="executedAt" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 shipmentId[发运单ID] orgId[业务组织]
 gatewayId[网关标识] actionType[操作类型]
=========>request[请求]======
 requestBody[请求报文] responseBody[响应报文]
 httpStatus[HTTP状态码]
=========>result[结果]======
 errorCode[错误码] errorMessage[错误信息]
 isSuccess[是否成功] executedAt[执行时间]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 shipmentId[发运单ID] gatewayId[网关标识]
 actionType[操作类型] isSuccess[是否成功]
 orgId[业务组织] executedAt[执行时间]
            </layout>
            <cells>
                <cell id="shipmentId" filterOp="eq"/>
                <cell id="gatewayId" filterOp="eq"/>
                <cell id="actionType" filterOp="eq"/>
                <cell id="isSuccess" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="executedAt" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 errorCode[错误码]
            </layout>
            <cells>
                <cell id="errorCode" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>