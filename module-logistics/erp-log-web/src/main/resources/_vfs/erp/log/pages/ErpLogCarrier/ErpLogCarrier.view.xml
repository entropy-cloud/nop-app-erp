<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpLogCarrier.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="carrierName" mandatory="true" sortable="true"/>
                <col id="carrierType" mandatory="true" sortable="true"/>
                <col id="gatewayId" mandatory="true" sortable="true"/>
                <col id="partnerId" label="承运商往来单位"/>
                <col id="isActive" mandatory="true" ui:number="true" sortable="true"/>
                <col id="trackingUrlTemplate" sortable="true"/>
                <col id="maxParcelWeight" ui:number="true" sortable="true"/>
                <col id="supportedServiceTypes" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="carrierName" mandatory="true" sortable="true"/>
                <col id="carrierType" mandatory="true" sortable="true"/>
                <col id="partnerId" label="承运商往来单位"/>
                <col id="isActive" mandatory="true" ui:number="true" sortable="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 carrierName[承运商名称] carrierType[承运商类型]
 partnerId[承运商往来单位ID] isActive[是否启用]
=========>gateway[网关]======
 gatewayId[网关标识] trackingUrlTemplate[追踪URL模板]
=========>capability[能力]======
 maxParcelWeight[最大包裹重量(kg)] supportedServiceTypes[支持服务类型]
=========>configs[配置项]======
 configs[配置项](2)
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="configs">
                    <view path="/erp/log/pages/ErpLogCarrierConfig/ErpLogCarrierConfig.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 carrierName[承运商名称] carrierType[承运商类型]
 partnerId[承运商往来单位ID] isActive[是否启用]
=========>gateway[网关]======
 gatewayId[网关标识] trackingUrlTemplate[追踪URL模板]
=========>capability[能力]======
 maxParcelWeight[最大包裹重量(kg)] supportedServiceTypes[支持服务类型]
=========>configs[配置项]======
 configs[配置项](2)
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="configs">
                    <view path="/erp/log/pages/ErpLogCarrierConfig/ErpLogCarrierConfig.view.xml" grid="sub-grid-edit"/>
                </cell>
            </cells>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 carrierType[承运商类型] gatewayId[网关标识]
 partnerId[承运商往来单位ID] isActive[是否启用]
 orgId[业务组织]
            </layout>
            <cells>
                <cell id="carrierType" filterOp="eq"/>
                <cell id="gatewayId" filterOp="eq"/>
                <cell id="partnerId" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编码] carrierName[承运商名称]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="carrierName" filterOp="like"/>
            </cells>
        </form>
        <form id="pick-query" editMode="query" title="查询条件">
            <layout>
 code[编码] carrierName[承运商名称]
 carrierType[承运商类型] isActive[是否启用]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="carrierName" filterOp="like"/>
                <cell id="carrierType" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker" filterForm="pick-query"/>
    </pages>
</view>