<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpLogCarrier.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="carrierName" mandatory="true" sortable="true"/>
                <col id="carrierType" mandatory="true" sortable="true"/>
                <col id="gatewayId" mandatory="true" sortable="true"/>
                <col id="partnerId" label="承运商往来单位"/>
                <col id="isActive" mandatory="true" ui:number="true" sortable="true"/>
                <col id="trackingUrlTemplate" sortable="true"/>
                <col id="maxParcelWeight" ui:number="true" sortable="true"/>
                <col id="supportedServiceTypes" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>