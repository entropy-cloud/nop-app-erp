<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpLogDeliveryWindow.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="partnerId" label="客户"/>
                <col id="orgId" label="业务组织"/>
                <col id="weekday" mandatory="true" ui:number="true" sortable="true"/>
                <col id="startTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="maxCapacity" mandatory="true" ui:number="true" sortable="true"/>
                <col id="currentBooked" mandatory="true" ui:number="true" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="effectiveFrom" sortable="true"/>
                <col id="effectiveTo" sortable="true"/>
                <col id="allowedShipmentTypes" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerId[客户] orgId[业务组织]
 weekday[星期] startTime[开始时间]
 endTime[结束时间]
=========>capacity[容量]======
 maxCapacity[最大预约数] currentBooked[当前已预约]
 isActive[是否启用] effectiveFrom[生效日期]
 effectiveTo[失效日期] allowedShipmentTypes[允许发运类型]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerId[客户] orgId[业务组织]
 weekday[星期] startTime[开始时间]
 endTime[结束时间]
=========>capacity[容量]======
 maxCapacity[最大预约数] currentBooked[当前已预约]
 isActive[是否启用] effectiveFrom[生效日期]
 effectiveTo[失效日期] allowedShipmentTypes[允许发运类型]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 partnerId[客户] orgId[业务组织]
 weekday[星期] isActive[是否启用]
 effectiveFrom[生效日期]
            </layout>
            <cells>
                <cell id="partnerId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="weekday" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
                <cell id="effectiveFrom" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>