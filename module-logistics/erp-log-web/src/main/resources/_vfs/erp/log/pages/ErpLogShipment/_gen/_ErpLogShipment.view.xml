<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpLogShipment" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/log/model/ErpLogShipment/ErpLogShipment.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--承运商ID-->
                <col id="carrierId" mandatory="true" ui:number="true" sortable="true"/>

                <!--承运商配置ID-->
                <col id="carrierConfigId" ui:number="true" sortable="true"/>

                <!--关联单据类型-->
                <col id="relatedBillType" sortable="true"/>

                <!--关联单据号-->
                <col id="relatedBillCode" sortable="true"/>

                <!--发运日期-->
                <col id="shipmentDate" sortable="true"/>

                <!--运单号-->
                <col id="trackingNo" sortable="true"/>

                <!--面单URL-->
                <col id="labelUrl" sortable="true"/>

                <!--运费-->
                <col id="freightAmount" ui:number="true" sortable="true"/>

                <!--运费币种-->
                <col id="freightCurrencyId" ui:number="true" sortable="true"/>

                <!--运费条款-->
                <col id="freightTerms" sortable="true"/>

                <!--运费结算状态-->
                <col id="freightSettlementStatus" sortable="true"/>

                <!--总重量(kg)-->
                <col id="totalWeight" ui:number="true" sortable="true"/>

                <!--总体积(m³)-->
                <col id="totalVolume" ui:number="true" sortable="true"/>

                <!--总包裹数-->
                <col id="totalParcels" ui:number="true" sortable="true"/>

                <!--收货人-->
                <col id="receiverName" sortable="true"/>

                <!--收货人电话-->
                <col id="receiverPhone" sortable="true"/>

                <!--收货地址-->
                <col id="receiverAddress" sortable="true"/>

                <!--国家-->
                <col id="receiverCountry" sortable="true"/>

                <!--省份-->
                <col id="receiverProvince" sortable="true"/>

                <!--城市-->
                <col id="receiverCity" sortable="true"/>

                <!--区县-->
                <col id="receiverDistrict" sortable="true"/>

                <!--发货人-->
                <col id="senderName" sortable="true"/>

                <!--发货人电话-->
                <col id="senderPhone" sortable="true"/>

                <!--发货地址-->
                <col id="senderAddress" sortable="true"/>

                <!--预计送达日期-->
                <col id="estimatedDeliveryDate" sortable="true"/>

                <!--实际送达日期-->
                <col id="actualDeliveryDate" sortable="true"/>

                <!--签收人-->
                <col id="signedBy" sortable="true"/>

                <!--发货员(职员)-->
                <col id="shipperId" ui:number="true" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-发运单" i18n-en:title="View Shipment">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] carrierId[承运商ID]
 carrierConfigId[承运商配置ID] relatedBillType[关联单据类型]
 relatedBillCode[关联单据号] shipmentDate[发运日期]
 trackingNo[运单号] labelUrl[面单URL]
 freightAmount[运费] freightCurrencyId[运费币种]
 freightTerms[运费条款] freightSettlementStatus[运费结算状态]
 totalWeight[总重量(kg)] totalVolume[总体积(m³)]
 totalParcels[总包裹数] receiverName[收货人]
 receiverPhone[收货人电话] receiverAddress[收货地址]
 receiverCountry[国家] receiverProvince[省份]
 receiverCity[城市] receiverDistrict[区县]
 senderName[发货人] senderPhone[发货人电话]
 senderAddress[发货地址] estimatedDeliveryDate[预计送达日期]
 actualDeliveryDate[实际送达日期] signedBy[签收人]
 shipperId[发货员(职员)] status[状态]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 businessDate[业务日期] posted[已过账]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-发运单" i18n-en:title="Add Shipment" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-发运单" i18n-en:title="Edit Shipment">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] carrierId[承运商ID]
 carrierConfigId[承运商配置ID] relatedBillType[关联单据类型]
 relatedBillCode[关联单据号] shipmentDate[发运日期]
 trackingNo[运单号] labelUrl[面单URL]
 freightAmount[运费] freightCurrencyId[运费币种]
 freightTerms[运费条款] freightSettlementStatus[运费结算状态]
 totalWeight[总重量(kg)] totalVolume[总体积(m³)]
 totalParcels[总包裹数] receiverName[收货人]
 receiverPhone[收货人电话] receiverAddress[收货地址]
 receiverCountry[国家] receiverProvince[省份]
 receiverCity[城市] receiverDistrict[区县]
 senderName[发货人] senderPhone[发货人电话]
 senderAddress[发货地址] estimatedDeliveryDate[预计送达日期]
 actualDeliveryDate[实际送达日期] signedBy[签收人]
 shipperId[发货员(职员)] status[状态]
 remark[备注] businessDate[业务日期]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-发运单" i18n-en:title="Update Shipment"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpLogShipment__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpLogShipment__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpLogShipment__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpLogShipment__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpLogShipment__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpLogShipment__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpLogShipment__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpLogShipment__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpLogShipment__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpLogShipment__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>