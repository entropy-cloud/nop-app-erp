<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-logistics ORM 模型 — 物流/运输管理域（权威数据模型来源）
  ======================================================
  业务范围：发运单（关联采购入库/销售出库）、承运商主数据与配置、
            承运商网关 SPI 对接、包裹管理、运费双路径过账

  命名约定：
    - appName:        app-erp-log
    - entityPackage:  app.erp.log.dao.entity
    - 实体类名:        ErpLog<Entity>     （如 ErpLogCarrier、ErpLogShipment）
    - 表名:           erp_log_<entity>   （如 erp_log_carrier、erp_log_shipment）
    - 字典命名空间:    erp-log/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（物料、往来单位、业务组织）
    - 被 app-erp-sales 引用（销售出库触发发运）
    - 被 app-erp-purchase 引用（采购入库触发发运）
    - finance 运费过账通过 I*Biz 引用 logistics 发运单
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="erp-log" ext:entityPackageName="app.erp.log.dao.entity"
