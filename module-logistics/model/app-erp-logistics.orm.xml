            <option code="DISPATCHED" label="已派发" value="DISPATCHED" i18n-en:label='Dispatched'/>
            <option code="IN_TRANSIT" label="运输中" value="IN_TRANSIT" i18n-en:label='In Transit'/>
            <option code="DELIVERED" label="已签收" value="DELIVERED" i18n-en:label='Delivered'/>
            <option code="CANCELLED" label="已取消" value="CANCELLED" i18n-en:label='Cancelled'/>
