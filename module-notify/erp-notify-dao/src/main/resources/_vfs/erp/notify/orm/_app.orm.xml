<?xml version="1.0" encoding="UTF-8" ?>
<orm ext:registerShortName="true" ext:appName="erp-notify" ext:entityPackageName="app.erp.notify.dao.entity"
     ext:basePackageName="app.erp.notify" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-notify"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" ext:icon="bell" xmlns:i18n-en="i18n-en" xmlns:biz="biz"
     x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ref-i18n-en="ref-i18n-en" xmlns:ext="ext"
     xmlns:orm-gen="orm-gen" xmlns:xpl="xpl" xmlns:ui="ui">

    <x:post-extends x:override="replace">
        <orm-gen:DefaultPostExtends xpl:lib="/nop/orm/xlib/orm-gen.xlib"/>
    </x:post-extends>

    <x:gen-extends x:override="replace">
        <orm-gen:DefaultGenExtends xpl:lib="/nop/orm/xlib/orm-gen.xlib"/>
    </x:gen-extends>

    <dicts>
        <dict label="通知渠道" name="erp-notify/notification-channel" valueType="string"
              i18n-en:label="Notification Channel">
            <option code="IN_APP" label="站内消息" value="IN_APP" i18n-en:label="In-App"/>
            <option code="EMAIL" label="邮件" value="EMAIL" i18n-en:label="Email"/>
            <option code="SMS" label="短信" value="SMS" i18n-en:label="SMS"/>
        </dict>
        <dict label="通知实例状态" name="erp-notify/notification-status" valueType="string"
              i18n-en:label="Notification Status">
            <option code="PENDING" label="待发送" value="PENDING" i18n-en:label="Pending"/>
            <option code="SENT" label="已发送" value="SENT" i18n-en:label="Sent"/>
            <option code="MERGED" label="已合并" value="MERGED" i18n-en:label="Merged"/>
            <option code="FAILED" label="发送失败" value="FAILED" i18n-en:label="Failed"/>
        </dict>
        <dict label="接收人解析器" name="erp-notify/recipient-resolver" valueType="string" i18n-en:label="Recipient Resolver">
            <option code="ROLE" label="按角色" value="ROLE" i18n-en:label="By Role"/>
            <option code="ORG" label="按部门" value="ORG" i18n-en:label="By Dept"/>
            <option code="PARTNER" label="按业务伙伴" value="PARTNER" i18n-en:label="By Partner"/>
            <option code="USER_LIST" label="用户列表" value="USER_LIST" i18n-en:label="User List"/>
        </dict>
        <dict label="频控合并策略" name="erp-notify/merge-strategy" valueType="string" i18n-en:label="Merge Strategy">
            <option code="NONE" label="不合并" value="NONE" i18n-en:label="None"/>
            <option code="MERGE_BY_USER_TYPE" label="按用户与类型合并" value="MERGE_BY_USER_TYPE"
                    i18n-en:label="Merge By User+Type"/>
        </dict>
        <dict label="模板状态" name="erp-notify/template-status" valueType="string" i18n-en:label="Template Status">
            <option code="DRAFT" label="草稿" value="DRAFT" i18n-en:label="Draft"/>
            <option code="ACTIVE" label="启用" value="ACTIVE" i18n-en:label="Active"/>
        </dict>
    </dicts>

    <domains>
        <domain name="boolFlag" stdDataType="boolean" stdSqlType="BOOLEAN"/>
        <domain name="delVersion" stdSqlType="BIGINT"/>
        <domain name="version" stdSqlType="INTEGER"/>
        <domain name="createTime" stdSqlType="TIMESTAMP"/>
        <domain name="createdBy" precision="50" stdSqlType="VARCHAR"/>
        <domain name="updateTime" stdSqlType="TIMESTAMP"/>
        <domain name="updatedBy" precision="50" stdSqlType="VARCHAR"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="code" precision="50" stdSqlType="VARCHAR"/>
        <domain name="name" precision="200" stdSqlType="VARCHAR"/>
        <domain name="payloadJson" precision="4000" stdSqlType="VARCHAR"/>
        <domain name="templateText" precision="2000" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <entity className="app.erp.notify.dao.entity.ErpSysNotificationTemplate" createTimeProp="createTime"
                createrProp="createdBy" deleteFlagProp="delVersion" deleteVersionProp="delVersion" displayName="通知模板"
                name="app.erp.notify.dao.entity.ErpSysNotificationTemplate" registerShortName="true"
                tableName="erp_sys_notification_template" tagSet="gid,erp.notify" updateTimeProp="updateTime"
                updaterProp="updatedBy" useLogicalDelete="true" versionProp="version" ext:icon="bell"
                i18n-en:displayName="Notification Template">
            <columns>
                <column code="ID" displayName="ID" mandatory="true" name="id" primary="true" propId="1"
                        stdDataType="long" stdSqlType="BIGINT" tagSet="seq-default" i18n-en:displayName="ID"/>
                <column code="NOTIFICATION_TYPE" displayName="业务事件键" mandatory="true" name="notificationType"
                        precision="100" propId="2" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Notification Type"/>
                <column code="NAME" displayName="模板名称" domain="name" mandatory="true" name="name" precision="200"
                        propId="3" stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Name"/>
                <column code="CHANNEL_SET" defaultValue="IN_APP" displayName="渠道集合" mandatory="true" name="channelSet"
                        precision="100" propId="4" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Channel Set"/>
                <column code="SUBJECT_TPL" displayName="标题模板" domain="templateText" name="subjectTpl" precision="2000"
                        propId="5" stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Subject Template"/>
                <column code="BODY_TPL" displayName="正文模板" name="bodyTpl" precision="4000" propId="6"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Body Template"/>
                <column code="RECIPIENT_RESOLVER" defaultValue="ROLE" displayName="接收人解析器" mandatory="true"
                        name="recipientResolver" precision="20" propId="7" stdDataType="string" stdSqlType="VARCHAR"
                        ext:dict="erp-notify/recipient-resolver" i18n-en:displayName="Recipient Resolver"/>
                <column code="RECIPIENT_CONFIG" displayName="接收人配置(JSON)" name="recipientConfig" precision="2000"
                        propId="8" stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Recipient Config"/>
                <column code="MERGE_WINDOW_SECONDS" defaultValue="300" displayName="合并窗口(秒)" name="mergeWindowSeconds"
                        propId="9" stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Merge Window Seconds"/>
                <column code="MERGE_STRATEGY" defaultValue="MERGE_BY_USER_TYPE" displayName="合并策略" mandatory="true"
                        name="mergeStrategy" precision="30" propId="10" stdDataType="string" stdSqlType="VARCHAR"
                        ext:dict="erp-notify/merge-strategy" i18n-en:displayName="Merge Strategy"/>
                <column code="STATUS" defaultValue="DRAFT" displayName="模板状态" mandatory="true" name="status"
                        precision="20" propId="11" stdDataType="string" stdSqlType="VARCHAR"
                        ext:dict="erp-notify/template-status" i18n-en:displayName="Status"/>
                <column code="REMARK" displayName="备注" domain="remark" name="remark" precision="1000" propId="12"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Remark"/>
                <column code="DEL_VERSION" defaultValue="0" displayName="逻辑删除版本" domain="delVersion" mandatory="true"
                        name="delVersion" propId="13" stdDataType="long" stdSqlType="BIGINT"
                        i18n-en:displayName="Del Flag" ui:show="R"/>
                <column code="VERSION" defaultValue="0" displayName="数据版本" domain="version" mandatory="true"
                        name="version" propId="14" stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Version"/>
                <column code="CREATED_BY" displayName="创建人" domain="createdBy" mandatory="true" name="createdBy"
                        precision="50" propId="15" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Created By"/>
                <column code="CREATE_TIME" displayName="创建时间" domain="createTime" mandatory="true" name="createTime"
                        propId="16" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Create Time"/>
                <column code="UPDATED_BY" displayName="修改人" domain="updatedBy" mandatory="true" name="updatedBy"
                        precision="50" propId="17" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Updated By"/>
                <column code="UPDATE_TIME" displayName="修改时间" domain="updateTime" mandatory="true" name="updateTime"
                        propId="18" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Update Time"/>
            </columns>
            <indexes>
                <index name="IDX_SYS_NOTIFY_TPL_STATUS" unique="false">
                    <column name="status"/>
                </index>
            </indexes>
            <unique-keys>
                <unique-key columns="notificationType" name="UK_SYS_NOTIFY_TPL_TYPE"/>
            </unique-keys>
        </entity>
        <entity className="app.erp.notify.dao.entity.ErpSysNotification" createTimeProp="createTime"
                createrProp="createdBy" deleteFlagProp="delVersion" deleteVersionProp="delVersion" displayName="通知实例"
                name="app.erp.notify.dao.entity.ErpSysNotification" registerShortName="true"
                tableName="erp_sys_notification" tagSet="gid,erp.notify" updateTimeProp="updateTime"
                updaterProp="updatedBy" useLogicalDelete="true" versionProp="version" ext:icon="envelope"
                i18n-en:displayName="Notification">
            <columns>
                <column code="ID" displayName="ID" mandatory="true" name="id" primary="true" propId="1"
                        stdDataType="long" stdSqlType="BIGINT" tagSet="seq-default" i18n-en:displayName="ID"/>
                <column code="TEMPLATE_ID" displayName="模板ID" name="templateId" propId="2" stdDataType="long"
                        stdSqlType="BIGINT" i18n-en:displayName="Template"/>
                <column code="NOTIFICATION_TYPE" displayName="业务事件键" mandatory="true" name="notificationType"
                        precision="100" propId="3" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Notification Type"/>
                <column code="RECIPIENT_USER_ID" displayName="接收用户" name="recipientUserId" precision="36" propId="4"
                        stdDataType="string" stdDomain="userId" stdSqlType="VARCHAR"
                        i18n-en:displayName="Recipient User"/>
                <column code="RECIPIENT_PARTNER_ID" displayName="接收业务伙伴" name="recipientPartnerId" propId="5"
                        stdDataType="long" stdSqlType="BIGINT" i18n-en:displayName="Recipient Partner"/>
                <column code="RECIPIENT_DEPT_ID" displayName="接收部门" name="recipientDeptId" propId="6" stdDataType="long"
                        stdSqlType="BIGINT" i18n-en:displayName="Recipient Dept"/>
                <column code="CHANNEL" defaultValue="IN_APP" displayName="渠道" mandatory="true" name="channel"
                        precision="20" propId="7" stdDataType="string" stdSqlType="VARCHAR"
                        ext:dict="erp-notify/notification-channel" i18n-en:displayName="Channel"/>
                <column code="SUBJECT" displayName="标题" name="subject" precision="500" propId="8" stdDataType="string"
                        stdSqlType="VARCHAR" i18n-en:displayName="Subject"/>
                <column code="BODY" displayName="正文" name="body" precision="4000" propId="9" stdDataType="string"
                        stdSqlType="VARCHAR" i18n-en:displayName="Body"/>
                <column code="PAYLOAD_JSON" displayName="负载JSON" domain="payloadJson" name="payloadJson"
                        precision="4000" propId="10" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Payload Json"/>
                <column code="STATUS" defaultValue="PENDING" displayName="状态" mandatory="true" name="status"
                        precision="20" propId="11" stdDataType="string" stdSqlType="VARCHAR"
                        ext:dict="erp-notify/notification-status" i18n-en:displayName="Status"/>
                <column code="MERGE_GROUP_ID" displayName="合并组ID" name="mergeGroupId" precision="200" propId="12"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Merge Group"/>
                <column code="MERGE_COUNT" defaultValue="1" displayName="合并次数" name="mergeCount" propId="13"
                        stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Merge Count"/>
                <column code="SENT_AT" displayName="发送时间" name="sentAt" propId="14" stdDataType="timestamp"
                        stdSqlType="TIMESTAMP" tagSet="clock" i18n-en:displayName="Sent At"/>
                <column code="ERROR_MSG" displayName="错误信息" name="errorMsg" precision="1000" propId="15"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Error Msg"/>
                <column code="DEL_VERSION" defaultValue="0" displayName="逻辑删除版本" domain="delVersion" mandatory="true"
                        name="delVersion" propId="16" stdDataType="long" stdSqlType="BIGINT"
                        i18n-en:displayName="Del Flag" ui:show="R"/>
                <column code="VERSION" defaultValue="0" displayName="数据版本" domain="version" mandatory="true"
                        name="version" propId="17" stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Version"/>
                <column code="CREATED_BY" displayName="创建人" domain="createdBy" mandatory="true" name="createdBy"
                        precision="50" propId="18" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Created By"/>
                <column code="CREATE_TIME" displayName="创建时间" domain="createTime" mandatory="true" name="createTime"
                        propId="19" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Create Time"/>
                <column code="UPDATED_BY" displayName="修改人" domain="updatedBy" mandatory="true" name="updatedBy"
                        precision="50" propId="20" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Updated By"/>
                <column code="UPDATE_TIME" displayName="修改时间" domain="updateTime" mandatory="true" name="updateTime"
                        propId="21" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Update Time"/>
            </columns>
            <indexes>
                <index name="IDX_SYS_NOTIFY_USER_STATUS" unique="false">
                    <column name="recipientUserId"/>
                    <column name="status"/>
                </index>
                <index name="IDX_SYS_NOTIFY_MERGE_GROUP" unique="false">
                    <column name="mergeGroupId"/>
                </index>
                <index name="IDX_SYS_NOTIFY_TYPE_USER" unique="false">
                    <column name="notificationType"/>
                    <column name="recipientUserId"/>
                </index>
            </indexes>
            <relations>
                <to-one name="template" refEntityName="app.erp.notify.dao.entity.ErpSysNotificationTemplate"
                        tagSet="pub" i18n-en:displayName="Template">
                    <join>
                        <on leftProp="templateId" rightProp="id"/>
                    </join>
                </to-one>
            </relations>
        </entity>
        <entity className="app.erp.notify.dao.entity.ErpSysNotificationRead" createTimeProp="createTime"
                createrProp="createdBy" deleteFlagProp="delVersion" deleteVersionProp="delVersion" displayName="通知已读记录"
                name="app.erp.notify.dao.entity.ErpSysNotificationRead" registerShortName="true"
                tableName="erp_sys_notification_read" tagSet="gid,erp.notify" updateTimeProp="updateTime"
                updaterProp="updatedBy" useLogicalDelete="true" versionProp="version" ext:icon="check-square"
                i18n-en:displayName="Notification Read">
            <columns>
                <column code="ID" displayName="ID" mandatory="true" name="id" primary="true" propId="1"
                        stdDataType="long" stdSqlType="BIGINT" tagSet="seq-default" i18n-en:displayName="ID"/>
                <column code="NOTIFICATION_ID" displayName="通知ID" mandatory="true" name="notificationId" propId="2"
                        stdDataType="long" stdSqlType="BIGINT" i18n-en:displayName="Notification"/>
                <column code="USER_ID" displayName="用户" mandatory="true" name="userId" precision="36" propId="3"
                        stdDataType="string" stdDomain="userId" stdSqlType="VARCHAR" i18n-en:displayName="User"/>
                <column code="READ_TIME" displayName="阅读时间" mandatory="true" name="readTime" propId="4"
                        stdDataType="timestamp" stdSqlType="TIMESTAMP" tagSet="clock" i18n-en:displayName="Read Time"/>
                <column code="DEL_VERSION" defaultValue="0" displayName="逻辑删除版本" domain="delVersion" mandatory="true"
                        name="delVersion" propId="5" stdDataType="long" stdSqlType="BIGINT"
                        i18n-en:displayName="Del Flag" ui:show="R"/>
                <column code="VERSION" defaultValue="0" displayName="数据版本" domain="version" mandatory="true"
                        name="version" propId="6" stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Version"/>
                <column code="CREATED_BY" displayName="创建人" domain="createdBy" mandatory="true" name="createdBy"
                        precision="50" propId="7" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Created By"/>
                <column code="CREATE_TIME" displayName="创建时间" domain="createTime" mandatory="true" name="createTime"
                        propId="8" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Create Time"/>
                <column code="UPDATED_BY" displayName="修改人" domain="updatedBy" mandatory="true" name="updatedBy"
                        precision="50" propId="9" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Updated By"/>
                <column code="UPDATE_TIME" displayName="修改时间" domain="updateTime" mandatory="true" name="updateTime"
                        propId="10" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Update Time"/>
            </columns>
            <indexes>
                <index name="IDX_SYS_NOTIFY_READ_USER" unique="false">
                    <column name="userId"/>
                </index>
            </indexes>
            <relations>
                <to-one name="notification" refEntityName="app.erp.notify.dao.entity.ErpSysNotification" tagSet="pub"
                        i18n-en:displayName="Notification">
                    <join>
                        <on leftProp="notificationId" rightProp="id"/>
                    </join>
                </to-one>
            </relations>
            <unique-keys>
                <unique-key columns="notificationId,userId" name="UK_SYS_NOTIFY_READ_NOTIF_USER"/>
            </unique-keys>
        </entity>
    </entities>
</orm>