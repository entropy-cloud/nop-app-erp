<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpSysNotificationTemplate" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/notify/model/ErpSysNotificationTemplate/ErpSysNotificationTemplate.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务事件键-->
                <col id="notificationType" mandatory="true" sortable="true"/>

                <!--模板名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--渠道集合-->
                <col id="channelSet" mandatory="true" sortable="true"/>

                <!--标题模板-->
                <col id="subjectTpl" sortable="true"/>

                <!--正文模板-->
                <col id="bodyTpl" sortable="true"/>

                <!--接收人解析器-->
                <col id="recipientResolver" mandatory="true" sortable="true"/>

                <!--接收人配置(JSON)-->
                <col id="recipientConfig" sortable="true"/>

                <!--合并窗口(秒)-->
                <col id="mergeWindowSeconds" ui:number="true" sortable="true"/>

                <!--合并策略-->
                <col id="mergeStrategy" mandatory="true" sortable="true"/>

                <!--模板状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-通知模板" i18n-en:title="View Notification Template">
            <layout>
 id[ID] notificationType[业务事件键]
 name[模板名称] channelSet[渠道集合]
 subjectTpl[标题模板] bodyTpl[正文模板]
 recipientResolver[接收人解析器] recipientConfig[接收人配置(JSON)]
 mergeWindowSeconds[合并窗口(秒)] mergeStrategy[合并策略]
 status[模板状态] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-通知模板" i18n-en:title="Add Notification Template" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-通知模板" i18n-en:title="Edit Notification Template">
            <layout>
 id[ID] notificationType[业务事件键]
 name[模板名称] channelSet[渠道集合]
 subjectTpl[标题模板] bodyTpl[正文模板]
 recipientResolver[接收人解析器] recipientConfig[接收人配置(JSON)]
 mergeWindowSeconds[合并窗口(秒)] mergeStrategy[合并策略]
 status[模板状态] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-通知模板"
              i18n-en:title="Update Notification Template"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpSysNotificationTemplate__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpSysNotificationTemplate__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpSysNotificationTemplate__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpSysNotificationTemplate__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpSysNotificationTemplate__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpSysNotificationTemplate__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpSysNotificationTemplate__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpSysNotificationTemplate__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpSysNotificationTemplate__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpSysNotificationTemplate__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>