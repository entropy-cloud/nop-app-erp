<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtContract.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="contractType" mandatory="true" sortable="true"/>
                <col id="contractDirection" mandatory="true" sortable="true"/>
                <col id="partnerId" label="合作方"/>
                <col id="currencyId" label="币种"/>
                <col id="totalAmount" ui:number="true" sortable="true"/>
                <col id="startDate" mandatory="true" sortable="true"/>
                <col id="endDate" mandatory="true" sortable="true"/>
                <col id="signDate" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="templateId" label="合同模板"/>
                <col id="parentContractId" label="父合同"/>
                <col id="description" sortable="true"/>
                <col id="attachmentFileId" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[合同编号] contractName[合同名称]
 contractType[合同类型] contractDirection[合同方向]
 orgId[业务组织] status[合同状态]
 businessDate[业务日期]
==========>parties[合同方信息]======
 partnerId[合作方] parentContractId[父合同]
 templateId[合同模板]
==========>finance[财务信息]======
 currencyId[币种] totalAmount[合同总额]
==========>schedule[日期信息]======
 startDate[生效日期] endDate[到期日期]
 signDate[签署日期]
==========^audit[审计信息]=========
 description[描述] attachmentFileId[合同附件]
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[合同编号] contractName[合同名称]
 contractType[合同类型] contractDirection[合同方向]
 orgId[业务组织] status[合同状态]
 businessDate[业务日期]
==========>parties[合同方信息]======
 partnerId[合作方] parentContractId[父合同]
 templateId[合同模板]
==========>finance[财务信息]======
 currencyId[币种] totalAmount[合同总额]
==========>schedule[日期信息]======
 startDate[生效日期] endDate[到期日期]
 signDate[签署日期]
 description[描述](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[合同编号] contractName[合同名称]
 status[合同状态] contractType[合同类型]
 partnerId[合作方]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="contractName" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>