<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCtDocument" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ct/model/ErpCtDocument/ErpCtDocument.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--关联合同-->
                <col id="contractId" ui:number="true" sortable="true"/>

                <!--文档编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--文档名称-->
                <col id="docName" mandatory="true" sortable="true"/>

                <!--文档类型-->
                <col id="docType" mandatory="true" sortable="true"/>

                <!--附件-->
                <col id="attachmentFileId" sortable="true"/>

                <!--文件大小(字节)-->
                <col id="fileSize" ui:number="true" sortable="true"/>

                <!--文件哈希-->
                <col id="fileHash" sortable="true"/>

                <!--MIME类型-->
                <col id="mimeType" sortable="true"/>

                <!--OCR文本-->
                <col id="ocrText" sortable="true"/>

                <!--OCR状态-->
                <col id="ocrStatus" sortable="true"/>

                <!--全文检索-->
                <col id="fullTextSearch" sortable="true"/>

                <!--元数据标签(JSON)-->
                <col id="metadataTags" sortable="true"/>

                <!--保留截止日期-->
                <col id="retentionDate" sortable="true"/>

                <!--归档日期-->
                <col id="archiveDate" sortable="true"/>

                <!--销毁日期-->
                <col id="purgeDate" sortable="true"/>

                <!--已归档-->
                <col id="isArchived" sortable="true"/>

                <!--文档版本-->
                <col id="versionNo" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-合同文档" i18n-en:title="View Contract Document">
            <layout>
 id[ID] orgId[业务组织]
 contractId[关联合同] code[文档编码]
 docName[文档名称] docType[文档类型]
 attachmentFileId[附件] fileSize[文件大小(字节)]
 fileHash[文件哈希] mimeType[MIME类型]
 ocrText[OCR文本] ocrStatus[OCR状态]
 fullTextSearch[全文检索] metadataTags[元数据标签(JSON)]
 retentionDate[保留截止日期] archiveDate[归档日期]
 purgeDate[销毁日期] isArchived[已归档]
 versionNo[文档版本] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-合同文档" i18n-en:title="Add Contract Document" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-合同文档" i18n-en:title="Edit Contract Document">
            <layout>
 id[ID] orgId[业务组织]
 contractId[关联合同] code[文档编码]
 docName[文档名称] docType[文档类型]
 attachmentFileId[附件] fileSize[文件大小(字节)]
 fileHash[文件哈希] mimeType[MIME类型]
 ocrText[OCR文本] ocrStatus[OCR状态]
 fullTextSearch[全文检索] metadataTags[元数据标签(JSON)]
 retentionDate[保留截止日期] archiveDate[归档日期]
 purgeDate[销毁日期] isArchived[已归档]
 versionNo[文档版本] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-合同文档"
              i18n-en:title="Update Contract Document"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCtDocument__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCtDocument__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCtDocument__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCtDocument__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCtDocument__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCtDocument__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCtDocument__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCtDocument__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCtDocument__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCtDocument__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>