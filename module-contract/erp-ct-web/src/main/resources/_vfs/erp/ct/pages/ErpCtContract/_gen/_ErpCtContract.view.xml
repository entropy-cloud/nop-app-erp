<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCtContract" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ct/model/ErpCtContract/ErpCtContract.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--合同编号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--合同名称-->
                <col id="contractName" mandatory="true" sortable="true"/>

                <!--合同类型-->
                <col id="contractType" mandatory="true" sortable="true"/>

                <!--合同方向-->
                <col id="contractDirection" mandatory="true" sortable="true"/>

                <!--合作方-->
                <col id="partnerId" mandatory="true" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--合同总额-->
                <col id="totalAmount" ui:number="true" sortable="true"/>

                <!--生效日期-->
                <col id="startDate" mandatory="true" sortable="true"/>

                <!--到期日期-->
                <col id="endDate" mandatory="true" sortable="true"/>

                <!--签署日期-->
                <col id="signDate" sortable="true"/>

                <!--合同状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--合同模板-->
                <col id="templateId" ui:number="true" sortable="true"/>

                <!--父合同-->
                <col id="parentContractId" ui:number="true" sortable="true"/>

                <!--描述-->
                <col id="description" sortable="true"/>

                <!--合同附件-->
                <col id="attachmentFileId" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-合同" i18n-en:title="View Contract">
            <layout>
 id[ID] code[合同编号]
 orgId[业务组织] contractName[合同名称]
 contractType[合同类型] contractDirection[合同方向]
 partnerId[合作方] currencyId[币种]
 totalAmount[合同总额] startDate[生效日期]
 endDate[到期日期] signDate[签署日期]
 status[合同状态] templateId[合同模板]
 parentContractId[父合同] description[描述]
 attachmentFileId[合同附件] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] businessDate[业务日期]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-合同" i18n-en:title="Add Contract" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-合同" i18n-en:title="Edit Contract">
            <layout>
 id[ID] code[合同编号]
 orgId[业务组织] contractName[合同名称]
 contractType[合同类型] contractDirection[合同方向]
 partnerId[合作方] currencyId[币种]
 totalAmount[合同总额] startDate[生效日期]
 endDate[到期日期] signDate[签署日期]
 status[合同状态] templateId[合同模板]
 parentContractId[父合同] description[描述]
 attachmentFileId[合同附件] remark[备注]
 businessDate[业务日期] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-合同" i18n-en:title="Update Contract"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCtContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCtContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCtContract__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCtContract__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCtContract__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCtContract__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCtContract__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCtContract__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCtContract__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCtContract__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>