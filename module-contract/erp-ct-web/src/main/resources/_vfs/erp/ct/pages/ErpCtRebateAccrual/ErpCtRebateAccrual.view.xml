<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtRebateAccrual.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="rebateAgreementId" label="返利协议"/>
                <col id="orgId" label="业务组织"/>
                <col id="sourceBillType" sortable="true"/>
                <col id="sourceBillCode" sortable="true"/>
                <col id="billAmountSource" ui:number="true" sortable="true"/>
                <col id="accruedRebate" ui:number="true" sortable="true"/>
                <col id="accrualDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isSettled" sortable="true"/>
                <col id="settledDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 rebateAgreementId[返利协议] orgId[业务组织]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 accrualDate[计提日期]
=========>amount[金额信息]======
 billAmountSource[单据金额(源币种)] accruedRebate[计提返利金额]
=========>settle[结算状态]======
 isSettled[已结算] settledDate[结算日期]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 rebateAgreementId[返利协议] orgId[业务组织]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 accrualDate[计提日期]
=========>amount[金额信息]======
 billAmountSource[单据金额(源币种)] accruedRebate[计提返利金额]
=========>settle[结算状态]======
 isSettled[已结算] settledDate[结算日期]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 rebateAgreementId[返利协议] orgId[业务组织]
 sourceBillType[来源单据类型] isSettled[已结算]
 accrualDate[计提日期]
            </layout>
            <cells>
                <cell id="rebateAgreementId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="sourceBillType" filterOp="eq"/>
                <cell id="isSettled" filterOp="eq"/>
                <cell id="accrualDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>