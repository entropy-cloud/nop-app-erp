<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtConsumptionLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="contractLineId" label="合同行"/>
                <col id="consumptionDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="quantity" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="sourceBillType" sortable="true"/>
                <col id="sourceBillCode" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="consumptionDate" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'input-date', name: 'consumptionDate', required: true, format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="quantity" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'quantity',
                                required: true,
                                step: 1,
                                validations: { minimum: 0.0001 },
                                validationErrors: { minimum: '消耗数量必须大于 0' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        amount: '${ROUND(quantity * unitPrice, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'unitPrice',
                                required: true,
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '单价不能为负' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        amount: '${ROUND(quantity * unitPrice, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount"/>
                <col id="sourceBillType"/>
                <col id="sourceBillCode"/>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="consumptionDate" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="quantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="sourceBillType"/>
                <col id="sourceBillCode"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractLineId[合同行ID] consumptionDate[消耗日期]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
=========>quantity[数量金额]======
 quantity[消耗数量] unitPrice[单价]
 amount[金额]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractLineId[合同行ID] consumptionDate[消耗日期]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
=========>quantity[数量金额]======
 quantity[消耗数量] unitPrice[单价]
 amount[金额]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 contractLineId[合同行ID] sourceBillType[来源单据类型]
 sourceBillCode[来源单据号] consumptionDate[消耗日期]
            </layout>
            <cells>
                <cell id="contractLineId" filterOp="eq"/>
                <cell id="sourceBillType" filterOp="eq"/>
                <cell id="sourceBillCode" filterOp="like"/>
                <cell id="consumptionDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>