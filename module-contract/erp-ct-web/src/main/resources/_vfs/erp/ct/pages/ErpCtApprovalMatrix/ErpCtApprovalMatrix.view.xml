<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtApprovalMatrix.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="minAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="maxAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approverRole" mandatory="true" sortable="true"/>
                <col id="approvalOrder" mandatory="true" ui:number="true" sortable="true"/>
                <col id="contractType" sortable="true"/>
                <col id="allowSkip" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 contractType[适用合同类型] isActive[启用]
=========>range[金额范围]======
 minAmount[最小金额] maxAmount[最大金额]
=========>rule[审批规则]======
 approverRole[审批角色] approvalOrder[审批顺序]
 allowSkip[可跳过]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 contractType[适用合同类型] isActive[启用]
=========>range[金额范围]======
 minAmount[最小金额] maxAmount[最大金额]
=========>rule[审批规则]======
 approverRole[审批角色] approvalOrder[审批顺序]
 allowSkip[可跳过]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编码] orgId[业务组织]
 contractType[适用合同类型] isActive[启用]
 approverRole[审批角色]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="contractType" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
                <cell id="approverRole" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>