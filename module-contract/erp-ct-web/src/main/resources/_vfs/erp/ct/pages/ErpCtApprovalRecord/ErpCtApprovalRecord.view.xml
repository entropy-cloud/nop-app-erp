<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtApprovalRecord.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="contractId" label="合同"/>
                <col id="orgId" label="业务组织"/>
                <col id="approvalMatrixId" label="审批矩阵"/>
                <col id="approvalOrder" ui:number="true" sortable="true"/>
                <col id="approverId" sortable="true"/>
                <col id="approvalStatus" mandatory="true" sortable="true"/>
                <col id="comment" sortable="true"/>
                <col id="approvedAt" sortable="true"/>
                <col id="rejectedAt" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>