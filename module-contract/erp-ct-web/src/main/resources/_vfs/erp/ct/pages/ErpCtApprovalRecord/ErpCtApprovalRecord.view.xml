<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtApprovalRecord.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="contractId" label="合同"/>
                <col id="orgId" label="业务组织"/>
                <col id="approvalMatrixId" label="审批矩阵"/>
                <col id="approvalOrder" ui:number="true" sortable="true"/>
                <col id="approverId" sortable="true"/>
                <col id="approvalStatus" mandatory="true" sortable="true"/>
                <col id="comment" sortable="true"/>
                <col id="approvedAt" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="rejectedAt" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractId[合同] orgId[业务组织]
 approvalMatrixId[审批矩阵] approvalOrder[顺序号]
 approverId[审批人]
=========>result[审批结果]======
 approvalStatus[审批状态] comment[审批意见]
 approvedAt[通过时间] rejectedAt[驳回时间]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractId[合同] orgId[业务组织]
 approvalMatrixId[审批矩阵] approvalOrder[顺序号]
 approverId[审批人]
=========>result[审批结果]======
 approvalStatus[审批状态] comment[审批意见]
 approvedAt[通过时间] rejectedAt[驳回时间]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 contractId[合同] orgId[业务组织]
 approvalMatrixId[审批矩阵] approvalStatus[审批状态]
 approverId[审批人]
            </layout>
            <cells>
                <cell id="contractId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="approvalMatrixId" filterOp="eq"/>
                <cell id="approvalStatus" filterOp="eq"/>
                <cell id="approverId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>