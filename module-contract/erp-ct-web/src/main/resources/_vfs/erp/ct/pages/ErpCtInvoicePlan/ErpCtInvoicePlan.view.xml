<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtInvoicePlan.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="contractLineId" label="合同行"/>
                <col id="planDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isInvoiced" sortable="true"/>
                <col id="invoiceBillCode" sortable="true"/>
                <col id="invoiceDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="invoiceTerm" mandatory="true" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractLineId[合同行ID] planDate[计划开票日期]
 invoiceTerm[开票条款]
=========>amount[金额信息]======
 amount[开票金额]
=========>status[开票状态]======
 isInvoiced[是否已开票] invoiceBillCode[关联发票号]
 invoiceDate[实际开票日期]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 contractLineId[合同行ID] planDate[计划开票日期]
 invoiceTerm[开票条款]
=========>amount[金额信息]======
 amount[开票金额]
=========>status[开票状态]======
 isInvoiced[是否已开票] invoiceBillCode[关联发票号]
 invoiceDate[实际开票日期]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 contractLineId[合同行ID] invoiceTerm[开票条款]
 isInvoiced[是否已开票] planDate[计划开票日期]
            </layout>
            <cells>
                <cell id="contractLineId" filterOp="eq"/>
                <cell id="invoiceTerm" filterOp="eq"/>
                <cell id="isInvoiced" filterOp="eq"/>
                <cell id="planDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>