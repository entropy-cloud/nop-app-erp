<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCtDocument.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="contractId" label="关联合同"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="docName" mandatory="true" sortable="true"/>
                <col id="docType" mandatory="true" sortable="true"/>
                <col id="attachmentFileId" sortable="true"/>
                <col id="fileSize" ui:number="true" sortable="true"/>
                <col id="fileHash" sortable="true"/>
                <col id="mimeType" sortable="true"/>
                <col id="ocrText" sortable="true"/>
                <col id="ocrStatus" sortable="true"/>
                <col id="fullTextSearch" sortable="true"/>
                <col id="metadataTags" sortable="true"/>
                <col id="retentionDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="archiveDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="purgeDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isArchived" sortable="true"/>
                <col id="versionNo" ui:number="true" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] contractId[关联合同]
 code[文档编码] docName[文档名称]
 docType[文档类型]
=========>file[文件信息]======
 attachmentFileId[附件] fileSize[文件大小(字节)]
 fileHash[文件哈希] mimeType[MIME类型]
=========>ocr[OCR信息]======
 ocrText[OCR文本] ocrStatus[OCR状态]
 fullTextSearch[全文检索]
=========>retention[保留策略]======
 metadataTags[元数据标签(JSON)] retentionDate[保留截止日期]
 archiveDate[归档日期] purgeDate[销毁日期]
 isArchived[已归档] versionNo[文档版本]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] contractId[关联合同]
 code[文档编码] docName[文档名称]
 docType[文档类型]
=========>file[文件信息]======
 attachmentFileId[附件] fileSize[文件大小(字节)]
 fileHash[文件哈希] mimeType[MIME类型]
=========>ocr[OCR信息]======
 ocrText[OCR文本] ocrStatus[OCR状态]
 fullTextSearch[全文检索]
=========>retention[保留策略]======
 metadataTags[元数据标签(JSON)] retentionDate[保留截止日期]
 archiveDate[归档日期] purgeDate[销毁日期]
 isArchived[已归档] versionNo[文档版本]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[文档编码] docName[文档名称]
 orgId[业务组织] contractId[关联合同]
 docType[文档类型] isArchived[已归档]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="docName" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="contractId" filterOp="eq"/>
                <cell id="docType" filterOp="eq"/>
                <cell id="isArchived" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>