<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpSalInvoice.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="customerName" label="客户"/>
                <col id="invoiceNo"/>
                <col id="invoiceType"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="currencyName" label="币种"/>
                <col id="totalAmountWithTax" ui:number="true" sortable="true"/>
                <col id="receivedAmount" ui:number="true" sortable="true"/>
                <col id="receivedStatus"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
                <col id="posted"/>
                <col id="orgName" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="customerName" label="客户"/>
                <col id="totalAmountWithTax" ui:number="true" sortable="true"/>
                <col id="receivedAmount" ui:number="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>