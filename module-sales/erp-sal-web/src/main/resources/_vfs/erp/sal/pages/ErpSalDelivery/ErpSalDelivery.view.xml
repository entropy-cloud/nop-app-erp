<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpSalDelivery.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="customerName" label="客户"/>
                <col id="warehouseName" label="出库仓库"/>
                <col id="currencyName" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="totalAmountWithTax" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 orderId[销售订单] customerId[客户]
 warehouseId[出库仓库] businessDate[出库日期]
 currencyId[币种] exchangeRate[汇率]
 docStatus[单据状态] approveStatus[审核状态]
==========>amount[金额信息]======
 amountSource[合计金额(源币)] amountFunctional[合计金额(本位币)]
 totalAmount[合计金额(不含税)] totalTaxAmount[合计税额]
 totalAmountWithTax[合计金额(含税)]
==========^approval[审批与过账]=========
 approvedBy[审核人] approvedAt[审核时间]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 orderId[销售订单] customerId[客户]
 warehouseId[出库仓库] businessDate[出库日期]
 currencyId[币种] exchangeRate[汇率]
 docStatus[单据状态] approveStatus[审核状态]
==========>amount[金额信息]======
 amountSource[合计金额(源币)] amountFunctional[合计金额(本位币)]
 totalAmount[合计金额(不含税)] totalTaxAmount[合计税额]
 totalAmountWithTax[合计金额(含税)]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] docStatus[单据状态]
 customerId[客户] approveStatus[审核状态]
 businessDate[出库日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpSalDelivery__submitForApproval?id=$id"/>
                    <confirmText>确认提交此销售出库单审批？</confirmText>
                    <messages>
                        <success>销售出库单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpSalDelivery__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此销售出库单的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>销售出库单已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpSalDelivery__approve?id=$id"/>
                    <confirmText>确认批准此销售出库单？</confirmText>
                    <messages>
                        <success>销售出库单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpSalDelivery__reject?id=$id"/>
                    <confirmText>确认驳回此销售出库单？</confirmText>
                    <messages>
                        <success>销售出库单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpSalDelivery__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此销售出库单？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>销售出库单已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>