<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpSalOrder.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="customerName" label="客户"/>
                <col id="warehouseName" label="仓库"/>
                <col id="currencyName" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="deliveryDate" sortable="true"/>
                <col id="totalAmountWithTax" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
                <col id="deliveryStatus" sortable="true"/>
                <col id="receivedStatus" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpSalOrder__submitForApproval?id=$id"/>
                    <confirmText>确认提交此销售订单审批？</confirmText>
                    <messages>
                        <success>销售订单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpSalOrder__approve?id=$id"/>
                    <confirmText>确认批准此销售订单？</confirmText>
                    <messages>
                        <success>销售订单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpSalOrder__reject?id=$id"/>
                    <confirmText>确认驳回此销售订单？</confirmText>
                    <messages>
                        <success>销售订单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpSalOrder__cancel?orderId=$id"/>
                    <confirmText>确认作废此销售订单？</confirmText>
                    <messages>
                        <success>销售订单已作废</success>
                    </messages>
                    <visibleOn>${docStatus != 'CANCELLED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <picker name="picker"/>
    </pages>
</view>
