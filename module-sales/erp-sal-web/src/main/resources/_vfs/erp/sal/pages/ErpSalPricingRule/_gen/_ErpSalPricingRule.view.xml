<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpSalPricingRule" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/sal/model/ErpSalPricingRule/ErpSalPricingRule.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--规则名称-->
                <col id="ruleName" mandatory="true" sortable="true"/>

                <!--规则编码-->
                <col id="ruleCode" mandatory="true" sortable="true"/>

                <!--规则类型-->
                <col id="ruleType" mandatory="true" sortable="true"/>

                <!--目标-->
                <col id="targetType" mandatory="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" ui:number="true" sortable="true"/>

                <!--物料分类-->
                <col id="materialCategoryId" ui:number="true" sortable="true"/>

                <!--客户组-->
                <col id="customerGroupCode" sortable="true"/>

                <!--指定客户-->
                <col id="partnerId" ui:number="true" sortable="true"/>

                <!--满减门槛-->
                <col id="minOrderAmount" ui:number="true" sortable="true"/>

                <!--折扣率(%)-->
                <col id="discountPercent" ui:number="true" sortable="true"/>

                <!--折扣金额-->
                <col id="discountAmount" ui:number="true" sortable="true"/>

                <!--赠品物料-->
                <col id="giftMaterialId" ui:number="true" sortable="true"/>

                <!--赠品SKU-->
                <col id="giftSkuId" ui:number="true" sortable="true"/>

                <!--赠品数量-->
                <col id="giftQuantity" ui:number="true" sortable="true"/>

                <!--覆盖单价-->
                <col id="priceOverride" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--优先级-->
                <col id="priority" ui:number="true" sortable="true"/>

                <!--可叠加-->
                <col id="stackable" sortable="true"/>

                <!--生效时间-->
                <col id="validFrom" sortable="true"/>

                <!--失效时间-->
                <col id="validTo" sortable="true"/>

                <!--启用-->
                <col id="isActive" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-销售促销规则" i18n-en:title="View Sales Pricing Rule">
            <layout>
 ruleName[规则名称] ruleCode[规则编码]
 ruleType[规则类型] targetType[目标]
 materialId[物料] materialCategoryId[物料分类]
 customerGroupCode[客户组] partnerId[指定客户]
 minOrderAmount[满减门槛] discountPercent[折扣率(%)]
 discountAmount[折扣金额] giftMaterialId[赠品物料]
 giftSkuId[赠品SKU] giftQuantity[赠品数量]
 priceOverride[覆盖单价] currencyId[币种]
 priority[优先级] stackable[可叠加]
 validFrom[生效时间] validTo[失效时间]
 isActive[启用] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-销售促销规则" i18n-en:title="Add Sales Pricing Rule" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-销售促销规则" i18n-en:title="Edit Sales Pricing Rule">
            <layout>
 ruleName[规则名称] ruleCode[规则编码]
 ruleType[规则类型] targetType[目标]
 materialId[物料] materialCategoryId[物料分类]
 customerGroupCode[客户组] partnerId[指定客户]
 minOrderAmount[满减门槛] discountPercent[折扣率(%)]
 discountAmount[折扣金额] giftMaterialId[赠品物料]
 giftSkuId[赠品SKU] giftQuantity[赠品数量]
 priceOverride[覆盖单价] currencyId[币种]
 priority[优先级] stackable[可叠加]
 validFrom[生效时间] validTo[失效时间]
 isActive[启用] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-销售促销规则"
              i18n-en:title="Update Sales Pricing Rule"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpSalPricingRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpSalPricingRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpSalPricingRule__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpSalPricingRule__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpSalPricingRule__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpSalPricingRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpSalPricingRule__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpSalPricingRule__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpSalPricingRule__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpSalPricingRule__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>