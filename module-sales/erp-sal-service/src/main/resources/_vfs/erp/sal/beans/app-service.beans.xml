<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 销售域服务（非 BizModel）：出库移动单请求构造器 -->
    <bean id="app.erp.sal.service.entity.DeliveryStockMoveBuilder"
          class="app.erp.sal.service.entity.DeliveryStockMoveBuilder"/>

    <!-- 销售域服务（非 BizModel）：客户信用额度校验器（订单审核时调用）。
         notificationBiz 注入标记为 optional：单域测试（如 crm 引入 sales-service 但无 notify-service）时降级跳过通知。 -->
    <bean id="app.erp.sal.service.entity.CreditLimitChecker"
          class="app.erp.sal.service.entity.CreditLimitChecker">
        <property name="notificationBiz">
            <ioc:inject type="app.erp.notify.biz.IErpSysNotificationBiz" ioc:optional="true"/>
        </property>
    </bean>

    <!-- 销售域服务（非 BizModel）：报价→订单域内转化组装器 -->
    <bean id="app.erp.sal.service.entity.QuotationToOrderConverter"
          class="app.erp.sal.service.entity.QuotationToOrderConverter"/>

    <!-- 销售域服务（非 BizModel）：退货入库移动单请求构造器（INCOMING，destWarehouse=退货仓库） -->
    <bean id="app.erp.sal.service.entity.ReturnStockMoveBuilder"
          class="app.erp.sal.service.entity.ReturnStockMoveBuilder"/>

    <!-- 销售域服务（非 BizModel）：退货数量上限校验器（按出库行聚合已审核退货量） -->
    <bean id="app.erp.sal.service.entity.ReturnQtyValidator"
          class="app.erp.sal.service.entity.ReturnQtyValidator"/>

    <!-- 销售业财过账 Provider（注册为 Bean 后由 ErpFinAcctDocRegistry 自动聚合，处理 AR_INVOICE/RECEIPT） -->
    <bean id="app.erp.sal.service.posting.SalAcctDocProvider"
          class="app.erp.sal.service.posting.SalAcctDocProvider"/>

    <!-- 销售过账执行器（跨域经 IErpFinVoucherBiz Facade，REQUIRES_NEW 由 Facade 承接，自身无 @Transactional） -->
    <bean id="app.erp.sal.service.posting.SalPostingExecutor"
          class="app.erp.sal.service.posting.SalPostingExecutor"/>

    <!-- 销售发票过账派发器（APPROVED→AR_INVOICE 凭证 借应收/贷收入+销项税；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.sal.service.posting.SalInvoicePostingDispatcher"
          class="app.erp.sal.service.posting.SalInvoicePostingDispatcher"/>

    <!-- 收款单过账派发器（APPROVED→RECEIPT 凭证 借银行存款/贷应收；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.sal.service.posting.SalReceiptPostingDispatcher"
          class="app.erp.sal.service.posting.SalReceiptPostingDispatcher"/>

    <!-- 销售退货过账派发器（APPROVED→SALES_RETURN 反向 SALES_OUTPUT 凭证 借存货/贷成本；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.sal.service.posting.SalReturnPostingDispatcher"
          class="app.erp.sal.service.posting.SalReturnPostingDispatcher"/>

    <!-- 销售域凭证红冲监听者（业财闭环方向二：财务侧红冲→销售单据回退 posted=false + approveStatus→REJECTED）。
         注册为 Bean 后由 finance ErpFinReversalListenerRegistry 自动聚合，处理 AR_INVOICE/RECEIPT/SALES_RETURN/SALES_OUTPUT。 -->
    <bean id="app.erp.sal.service.posting.SalReversalListener"
          class="app.erp.sal.service.posting.SalReversalListener"/>

    <!-- 收款→发票域级核销器（ErpSalReceiptLine 多对多，回写 receivedStatus/receivedAmount/writtenOffStatus） -->
    <bean id="app.erp.sal.service.entity.ReceiptSettler"
          class="app.erp.sal.service.entity.ReceiptSettler"/>

    <!-- 退货退款编排器（已收款退货→反向收款核销行 + 发票 receivedStatus 回写；复用 ReceiptSettler） -->
    <bean id="app.erp.sal.service.entity.ReturnRefundOrchestrator"
          class="app.erp.sal.service.entity.ReturnRefundOrchestrator"/>

    <!-- 销售域审批状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖） -->
    <bean id="app.erp.sal.service.processor.ErpSalOrderProcessor"
          class="app.erp.sal.service.processor.ErpSalOrderProcessor"/>
    <bean id="app.erp.sal.service.processor.ErpSalQuotationProcessor"
          class="app.erp.sal.service.processor.ErpSalQuotationProcessor"/>
    <bean id="app.erp.sal.service.processor.ErpSalDeliveryProcessor"
          class="app.erp.sal.service.processor.ErpSalDeliveryProcessor"/>
    <bean id="app.erp.sal.service.processor.ErpSalReturnProcessor"
          class="app.erp.sal.service.processor.ErpSalReturnProcessor"/>
    <bean id="app.erp.sal.service.processor.ErpSalInvoiceProcessor"
          class="app.erp.sal.service.processor.ErpSalInvoiceProcessor"/>
    <bean id="app.erp.sal.service.processor.ErpSalReceiptProcessor"
          class="app.erp.sal.service.processor.ErpSalReceiptProcessor"/>

    <!-- 销售看板聚合入口（plan 2026-07-06-0935-1）：非实体 BizModel，注入 IDaoProvider/IOrmTemplate/IErpFinArApItemBiz，
         经 @BizQuery 暴露 getDashboardKpi/getDashboardTrend/findCustomerTopN/findArOverdueAlert。 -->
    <bean id="app.erp.sal.service.dashboard.ErpSalDashboardBizModel" ioc:type="@bean:id"/>

    <!-- UC-SAL-11 定价引擎：客户价格清单解析器（实现 IErpMdCustomerPriceResolver SPI，由 master-data 注入） -->
    <bean id="app.erp.sal.service.support.ErpSalCustomerPriceResolver"
          class="app.erp.sal.service.support.ErpSalCustomerPriceResolver">
        <property name="daoProvider">
            <ioc:inject type="io.nop.dao.api.IDaoProvider"/>
        </property>
        <property name="mdPartnerBiz">
            <ioc:inject type="app.erp.md.biz.IErpMdPartnerBiz"/>
        </property>
    </bean>

    <!-- UC-SAL-11 定价引擎：促销规则引擎（纯函数式，无 IoC 状态） -->
    <bean id="app.erp.sal.service.support.ErpSalPricingRuleEngine"
          class="app.erp.sal.service.support.ErpSalPricingRuleEngine"/>
</beans>