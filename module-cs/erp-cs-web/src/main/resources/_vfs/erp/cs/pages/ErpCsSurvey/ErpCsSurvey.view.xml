<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsSurvey.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="ticketCode" label="工单"/>
                <col id="csatScore" ui:number="true" sortable="true"/>
                <col id="npsScore" ui:number="true" sortable="true"/>
                <col id="cesScore" ui:number="true" sortable="true"/>
                <col id="respondedAt" sortable="true"/>
                <col id="surveySentAt" sortable="true"/>
                <col id="surveyChannel" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>