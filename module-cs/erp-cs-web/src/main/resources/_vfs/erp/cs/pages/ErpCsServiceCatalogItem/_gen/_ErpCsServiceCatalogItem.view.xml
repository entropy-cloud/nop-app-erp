<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCsServiceCatalogItem" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/cs/model/ErpCsServiceCatalogItem/ErpCsServiceCatalogItem.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--目录分类-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--父项-->
                <col id="parentId" ui:number="true" sortable="true"/>

                <!--简短描述-->
                <col id="shortDescription" sortable="true"/>

                <!--详细说明-->
                <col id="fullDescription" sortable="true"/>

                <!--关联工单类型-->
                <col id="ticketTypeId" ui:number="true" sortable="true"/>

                <!--默认SLA策略-->
                <col id="slaPolicyId" ui:number="true" sortable="true"/>

                <!--履行流程标识-->
                <col id="fulfillmentProcessId" sortable="true"/>

                <!--请求表单配置-->
                <col id="requestFormConfig" sortable="true"/>

                <!--是否上架-->
                <col id="isActive" sortable="true"/>

                <!--是否客户可见-->
                <col id="isPublic" sortable="true"/>

                <!--排序-->
                <col id="sequence" ui:number="true" sortable="true"/>

                <!--预计解决时间-->
                <col id="estimatedResolution" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-服务目录项" i18n-en:title="View Service Catalog Item">
            <layout>
 id[ID] code[编码]
 name[名称] orgId[业务组织]
 categoryId[目录分类] parentId[父项]
 shortDescription[简短描述] fullDescription[详细说明]
 ticketTypeId[关联工单类型] slaPolicyId[默认SLA策略]
 fulfillmentProcessId[履行流程标识] requestFormConfig[请求表单配置]
 isActive[是否上架] isPublic[是否客户可见]
 sequence[排序] estimatedResolution[预计解决时间]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-服务目录项" i18n-en:title="Add Service Catalog Item" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-服务目录项" i18n-en:title="Edit Service Catalog Item">
            <layout>
 id[ID] code[编码]
 name[名称] orgId[业务组织]
 categoryId[目录分类] parentId[父项]
 shortDescription[简短描述] fullDescription[详细说明]
 ticketTypeId[关联工单类型] slaPolicyId[默认SLA策略]
 fulfillmentProcessId[履行流程标识] requestFormConfig[请求表单配置]
 isActive[是否上架] isPublic[是否客户可见]
 sequence[排序] estimatedResolution[预计解决时间]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-服务目录项"
              i18n-en:title="Update Service Catalog Item"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsServiceCatalogItem__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsServiceCatalogItem__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCsServiceCatalogItem__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCsServiceCatalogItem__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCsServiceCatalogItem__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCsServiceCatalogItem__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCsServiceCatalogItem__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCsServiceCatalogItem__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCsServiceCatalogItem__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCsServiceCatalogItem__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>