<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsTicket.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="subject" sortable="true"/>
                <col id="customerId" label="客户"/>
                <col id="contactId" label="联系人"/>
                <col id="ticketTypeId" label="工单类型"/>
                <col id="slaPolicyId" label="SLA策略"/>
                <col id="catalogItemId" label="目录项"/>
                <col id="priority" sortable="true"/>
                <col id="status" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="docStatus" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approveStatus" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'approveStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : "
                                    + valueProp + " == 'REJECTED' ? 'danger' : "
                                    + valueProp + " == 'SUBMITTED' ? 'info' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="deadlineDateTime" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isSlaCompleted" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 subject[工单主题] customerId[客户]
 ticketTypeId[工单类型] priority[优先级]
 source[来源] status[工单状态]
 docStatus[单据状态] approveStatus[审核状态]
 contactId[联系人] catalogItemId[服务目录项]
 description[问题描述](2)
=========>sla[SLA与处理]======
 assignedToId[分配处理人] slaPolicyId[SLA 策略]
 deadlineDateTime[SLA 截止时间] isSlaCompleted[SLA 是否完成]
 startDateTime[开始处理时间] endDateTime[关闭时间]
 duration[处理时长(分钟)] progress[进度(%)]
=========>actions[操作历史]======
 actions[操作历史](2)
==========^audit[审计信息]=========
 remark[备注] businessDate[业务日期]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="actions">
                    <view path="/erp/cs/pages/ErpCsTicketAction/ErpCsTicketAction.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="add" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 subject[工单主题] customerId[客户]
 ticketTypeId[工单类型] priority[优先级]
 source[来源] assignedToId[分配处理人]
 status[工单状态] docStatus[单据状态]
 approveStatus[审核状态] contactId[联系人]
 catalogItemId[服务目录项]
 description[问题描述](2)
=========>sla[SLA与处理]======
 slaPolicyId[SLA 策略] deadlineDateTime[SLA 截止时间]
 isSlaCompleted[SLA 是否完成] startDateTime[开始处理时间]
 endDateTime[关闭时间] duration[处理时长(分钟)]
 progress[进度(%)]
=========>actions[操作历史]======
 actions[操作历史](2)
==========^audit[审计信息]=========
 remark[备注]
 __kbSuggestion[相关知识库文章]
            </layout>
            <cells>
                <cell id="actions">
                    <view path="/erp/cs/pages/ErpCsTicketAction/ErpCsTicketAction.view.xml" grid="sub-grid-view"/>
                </cell>
                <cell id="__kbSuggestion" custom="true" notSubmit="true">
                    <gen-control>
                        <wrapper className="m-t-sm">
                            <body j:list="true">
                                <service name="kbSuggestion">
                                    <api method="post" url="/graphql" dataType="raw"
                                         sendOn="${'$'}{subject &amp;&amp; subject.length >= 2}">
                                        <data>
                                            <query><![CDATA[query($subject:String,$limit:Int){ ErpCsKnowledgeBase__suggestForTicket(subject:$subject,limit:$limit) }]]></query>
                                            <variables>
                                                <subject>${'$'}{subject}</subject>
                                                <limit>5</limit>
                                            </variables>
                                        </data>
                                        <adaptor><![CDATA[var d=payload.data||{};var g=d.data?d.data:d;var it=(g.ErpCsKnowledgeBase__suggestForTicket||[]).map(function(i){return{kbId:i.id,code:i.code,title:i.title,contentSummary:i.contentSummary};});return{status:0,msg:'',data:{items:it}};]]></adaptor>
                                    </api>
                                    <body j:list="true">
                                        <list source="${'$'}{items}" placeholder="输入工单主题后将显示相关知识库文章">
                                            <listItem>
                                                <body j:list="true">
                                                    <tpl tpl="&lt;strong&gt;${'$'}{title}&lt;/strong&gt;&lt;br/&gt;&lt;span class='text-muted text-sm'&gt;${'$'}{contentSummary}&lt;/span&gt;"/>
                                                </body>
                                                <actions j:list="true">
                                                    <button label="采纳并参考" level="primary" size="sm" actionType="ajax"
                                                            visibleOn="${'$'}{!!id}"
                                                            confirmText="确认采纳此知识库文章作为工单处理参考？">
                                                        <api method="post" url="/graphql" dataType="raw">
                                                            <data>
                                                                <query><![CDATA[mutation($ticketId:BigDecimal,$knowledgeBaseId:BigDecimal){ ErpCsTicket__adoptKnowledge(ticketId:$ticketId,knowledgeBaseId:$knowledgeBaseId) }]]></query>
                                                                <variables>
                                                                    <ticketId>${'$'}{id}</ticketId>
                                                                    <knowledgeBaseId>${'$'}{kbId}</knowledgeBaseId>
                                                                </variables>
                                                            </data>
                                                        </api>
                                                    </button>
                                                </actions>
                                            </listItem>
                                        </list>
                                    </body>
                                </service>
                            </body>
                        </wrapper>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 subject[工单主题] customerId[客户]
 ticketTypeId[工单类型] priority[优先级]
 source[来源] assignedToId[分配处理人]
 status[工单状态] docStatus[单据状态]
 approveStatus[审核状态] contactId[联系人]
 catalogItemId[服务目录项]
 description[问题描述](2)
=========>sla[SLA与处理]======
 slaPolicyId[SLA 策略] deadlineDateTime[SLA 截止时间]
 isSlaCompleted[SLA 是否完成] startDateTime[开始处理时间]
 endDateTime[关闭时间] duration[处理时长(分钟)]
 progress[进度(%)]
=========>actions[操作历史]======
 actions[操作历史](2)
==========^audit[审计信息]=========
 remark[备注]
 __kbSuggestion[相关知识库文章]
            </layout>
            <cells>
                <cell id="actions">
                    <view path="/erp/cs/pages/ErpCsTicketAction/ErpCsTicketAction.view.xml" grid="sub-grid-view"/>
                </cell>
                <cell id="__kbSuggestion" custom="true" notSubmit="true">
                    <gen-control>
                        <wrapper className="m-t-sm">
                            <body j:list="true">
                                <service name="kbSuggestion">
                                    <api method="post" url="/graphql" dataType="raw"
                                         sendOn="${'$'}{subject &amp;&amp; subject.length >= 2}">
                                        <data>
                                            <query><![CDATA[query($subject:String,$limit:Int){ ErpCsKnowledgeBase__suggestForTicket(subject:$subject,limit:$limit) }]]></query>
                                            <variables>
                                                <subject>${'$'}{subject}</subject>
                                                <limit>5</limit>
                                            </variables>
                                        </data>
                                        <adaptor><![CDATA[var d=payload.data||{};var g=d.data?d.data:d;var it=(g.ErpCsKnowledgeBase__suggestForTicket||[]).map(function(i){return{kbId:i.id,code:i.code,title:i.title,contentSummary:i.contentSummary};});return{status:0,msg:'',data:{items:it}};]]></adaptor>
                                    </api>
                                    <body j:list="true">
                                        <list source="${'$'}{items}" placeholder="输入工单主题后将显示相关知识库文章">
                                            <listItem>
                                                <body j:list="true">
                                                    <tpl tpl="&lt;strong&gt;${'$'}{title}&lt;/strong&gt;&lt;br/&gt;&lt;span class='text-muted text-sm'&gt;${'$'}{contentSummary}&lt;/span&gt;"/>
                                                </body>
                                                <actions j:list="true">
                                                    <button label="采纳并参考" level="primary" size="sm" actionType="ajax"
                                                            visibleOn="${'$'}{!!id}"
                                                            confirmText="确认采纳此知识库文章作为工单处理参考？">
                                                        <api method="post" url="/graphql" dataType="raw">
                                                            <data>
                                                                <query><![CDATA[mutation($ticketId:BigDecimal,$knowledgeBaseId:BigDecimal){ ErpCsTicket__adoptKnowledge(ticketId:$ticketId,knowledgeBaseId:$knowledgeBaseId) }]]></query>
                                                                <variables>
                                                                    <ticketId>${'$'}{id}</ticketId>
                                                                    <knowledgeBaseId>${'$'}{kbId}</knowledgeBaseId>
                                                                </variables>
                                                            </data>
                                                        </api>
                                                    </button>
                                                </actions>
                                            </listItem>
                                        </list>
                                    </body>
                                </service>
                            </body>
                        </wrapper>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] status[工单状态]
 customerId[客户] priority[优先级]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-assign-button" label="分派" level="primary" icon="fa fa-user">
                    <api url="@mutation:ErpCsTicket__assign?ticketId=$id&amp;assignedToId=0"/>
                    <confirmText>确认分派此工单？</confirmText>
                    <messages>
                        <success>工单已分派</success>
                    </messages>
                </action>
                <action id="row-start-button" label="开始处理" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpCsTicket__start?ticketId=$id"/>
                    <confirmText>确认开始处理此工单？</confirmText>
                    <messages>
                        <success>工单已开始处理</success>
                    </messages>
                </action>
                <action id="row-resolve-button" label="解决" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpCsTicket__resolve?ticketId=$id&amp;resolution="/>
                    <confirmText>确认解决此工单？</confirmText>
                    <messages>
                        <success>工单已解决</success>
                    </messages>
                </action>
                <action id="row-close-button" label="关闭" level="info" icon="fa fa-archive">
                    <api url="@mutation:ErpCsTicket__close?ticketId=$id"/>
                    <confirmText>确认关闭此工单？</confirmText>
                    <messages>
                        <success>工单已关闭</success>
                    </messages>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpCsTicket__cancel?ticketId=$id"/>
                    <confirmText>确认作废此工单？</confirmText>
                    <messages>
                        <success>工单已作废</success>
                    </messages>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
