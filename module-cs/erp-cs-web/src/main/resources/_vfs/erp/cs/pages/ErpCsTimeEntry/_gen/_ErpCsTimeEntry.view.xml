<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCsTimeEntry" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/cs/model/ErpCsTimeEntry/ErpCsTimeEntry.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--关联工单-->
                <col id="ticketId" mandatory="true" ui:number="true" sortable="true"/>

                <!--处理人-->
                <col id="agentId" mandatory="true" ui:number="true" sortable="true"/>

                <!--开始时间-->
                <col id="startTime" sortable="true"/>

                <!--结束时间-->
                <col id="endTime" sortable="true"/>

                <!--时长(分钟)-->
                <col id="duration" ui:number="true" sortable="true"/>

                <!--是否可计费-->
                <col id="isBillable" sortable="true"/>

                <!--计费费率-->
                <col id="billingRate" ui:number="true" sortable="true"/>

                <!--计费金额-->
                <col id="billableAmount" ui:number="true" sortable="true"/>

                <!--工作内容描述-->
                <col id="description" sortable="true"/>

                <!--审批状态-->
                <col id="approvalStatus" sortable="true"/>

                <!--审批人-->
                <col id="approvedById" sortable="true"/>

                <!--审批时间-->
                <col id="approvedAt" sortable="true"/>

                <!--关联项目-->
                <col id="projectId" ui:number="true" sortable="true"/>

                <!--关联任务-->
                <col id="taskId" ui:number="true" sortable="true"/>

                <!--来源-->
                <col id="source" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgName"/>

                <!--工单-->
                <col id="ticketCode"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-工单计时条目" i18n-en:title="View Time Entry">
            <layout>
 orgId[业务组织] ticketId[关联工单]
 agentId[处理人] startTime[开始时间]
 endTime[结束时间] duration[时长(分钟)]
 isBillable[是否可计费] billingRate[计费费率]
 billableAmount[计费金额] description[工作内容描述]
 approvalStatus[审批状态] approvedById[审批人]
 approvedAt[审批时间] projectId[关联项目]
 taskId[关联任务] source[来源]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] orgName[业务组织]
 ticketCode[工单] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-工单计时条目" i18n-en:title="Add Time Entry" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-工单计时条目" i18n-en:title="Edit Time Entry">
            <layout>
 orgId[业务组织] ticketId[关联工单]
 agentId[处理人] startTime[开始时间]
 endTime[结束时间] duration[时长(分钟)]
 isBillable[是否可计费] billingRate[计费费率]
 billableAmount[计费金额] description[工作内容描述]
 approvalStatus[审批状态] approvedById[审批人]
 projectId[关联项目] taskId[关联任务]
 source[来源] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-工单计时条目" i18n-en:title="Update Time Entry"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsTimeEntry__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsTimeEntry__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCsTimeEntry__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCsTimeEntry__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCsTimeEntry__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCsTimeEntry__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCsTimeEntry__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCsTimeEntry__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCsTimeEntry__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCsTimeEntry__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>