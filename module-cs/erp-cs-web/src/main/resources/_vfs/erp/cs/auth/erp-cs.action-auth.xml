                    <children>
                        <resource id="ErpCsTicketType-main" displayName="工单类型"
                                  i18n-en:displayName="Ticket Type" icon="tag"
                                  component="AMIS" resourceType="SUBM" orderNo="900"
                                  url="/erp/cs/pages/ErpCsTicketType/main.page.yaml"/>
                        <resource id="ErpCsSlaPolicy-main" app:useCases="UC-CS-04"
                                  displayName="SLA策略" i18n-en:displayName="SLA Policy" icon="clock"
                                  component="AMIS" resourceType="SUBM" orderNo="910"
                                  url="/erp/cs/pages/ErpCsSlaPolicy/main.page.yaml"/>
