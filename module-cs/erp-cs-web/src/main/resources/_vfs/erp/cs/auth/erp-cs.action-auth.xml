                                  component="AMIS" resourceType="SUBM" orderNo="300"
                                  url="/erp/cs/pages/ErpCsSurvey/main.page.yaml"/>
                    </children>
                </resource>
                <resource id="cs-entitlement" displayName="服务权益" i18n-en:displayName="Entitlements"
                          icon="shield" resourceType="SUBM" orderNo="400">
