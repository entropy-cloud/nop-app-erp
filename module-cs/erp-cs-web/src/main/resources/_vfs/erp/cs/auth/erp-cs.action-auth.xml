                                  component="AMIS" resourceType="SUBM" orderNo="50"
                                  url="/erp/cs/pages/ErpCsQualityDashboard/main.page.yaml"/>
                    </children>
                </resource>
                <resource id="cs-ticket" displayName="客服工单" i18n-en:displayName="Tickets"
