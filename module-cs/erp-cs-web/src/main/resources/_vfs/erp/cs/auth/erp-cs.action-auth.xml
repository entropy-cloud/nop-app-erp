<?xml version="1.0" encoding="UTF-8" ?>
<auth x:schema="/nop/schema/action-auth.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      xmlns:i18n-en="i18n-en" xmlns:app="app">
    <site id="main">
        <resource id="erp-cs" displayName="售后服务" i18n-en:displayName="Customer Service"
