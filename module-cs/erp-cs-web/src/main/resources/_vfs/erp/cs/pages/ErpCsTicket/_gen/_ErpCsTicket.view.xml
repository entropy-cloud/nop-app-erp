<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCsTicket" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/cs/model/ErpCsTicket/ErpCsTicket.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--工单主题-->
                <col id="subject" mandatory="true" sortable="true"/>

                <!--问题描述-->
                <col id="description" sortable="true"/>

                <!--客户-->
                <col id="customerId" mandatory="true" ui:number="true" sortable="true"/>

                <!--联系人-->
                <col id="contactId" ui:number="true" sortable="true"/>

                <!--工单类型-->
                <col id="ticketTypeId" mandatory="true" ui:number="true" sortable="true"/>

                <!--优先级-->
                <col id="priority" mandatory="true" sortable="true"/>

                <!--来源-->
                <col id="source" sortable="true"/>

                <!--分配处理人-->
                <col id="assignedToId" sortable="true"/>

                <!--SLA 策略-->
                <col id="slaPolicyId" ui:number="true" sortable="true"/>

                <!--SLA 截止时间-->
                <col id="deadlineDateTime" sortable="true"/>

                <!--SLA 是否完成-->
                <col id="isSlaCompleted" sortable="true"/>

                <!--开始处理时间-->
                <col id="startDateTime" sortable="true"/>

                <!--关闭时间-->
                <col id="endDateTime" sortable="true"/>

                <!--处理时长(分钟)-->
                <col id="duration" ui:number="true" sortable="true"/>

                <!--进度(%)-->
                <col id="progress" ui:number="true" sortable="true"/>

                <!--工单状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--服务目录项-->
                <col id="catalogItemId" ui:number="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-客服工单" i18n-en:title="View Ticket">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] subject[工单主题]
 description[问题描述] customerId[客户]
 contactId[联系人] ticketTypeId[工单类型]
 priority[优先级] source[来源]
 assignedToId[分配处理人] slaPolicyId[SLA 策略]
 deadlineDateTime[SLA 截止时间] isSlaCompleted[SLA 是否完成]
 startDateTime[开始处理时间] endDateTime[关闭时间]
 duration[处理时长(分钟)] progress[进度(%)]
 status[工单状态] docStatus[单据状态]
 approveStatus[审核状态] remark[备注]
 catalogItemId[服务目录项] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-客服工单" i18n-en:title="Add Ticket">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] subject[工单主题]
 description[问题描述] customerId[客户]
 contactId[联系人] ticketTypeId[工单类型]
 priority[优先级] source[来源]
 assignedToId[分配处理人] slaPolicyId[SLA 策略]
 deadlineDateTime[SLA 截止时间] isSlaCompleted[SLA 是否完成]
 startDateTime[开始处理时间] endDateTime[关闭时间]
 duration[处理时长(分钟)] progress[进度(%)]
 status[工单状态] docStatus[单据状态]
 approveStatus[审核状态] remark[备注]
 catalogItemId[服务目录项] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-客服工单" i18n-en:title="Edit Ticket">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] subject[工单主题]
 description[问题描述] customerId[客户]
 contactId[联系人] ticketTypeId[工单类型]
 priority[优先级] source[来源]
 assignedToId[分配处理人] slaPolicyId[SLA 策略]
 deadlineDateTime[SLA 截止时间] isSlaCompleted[SLA 是否完成]
 startDateTime[开始处理时间] endDateTime[关闭时间]
 duration[处理时长(分钟)] progress[进度(%)]
 status[工单状态] docStatus[单据状态]
 approveStatus[审核状态] remark[备注]
 catalogItemId[服务目录项] delVersion[逻辑删除版本]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-客服工单" i18n-en:title="Update Ticket"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsTicket__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCsTicket__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCsTicket__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCsTicket__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCsTicket__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCsTicket__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCsTicket__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCsTicket__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCsTicket__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCsTicket__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>