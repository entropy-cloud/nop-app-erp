<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsEntitlement.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="partnerId" label="客户"/>
                <col id="contractId" label="合同"/>
                <col id="slaPolicyId" label="SLA策略"/>
                <col id="serviceType" sortable="true"/>
                <col id="startDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="maxTickets" ui:number="true" sortable="true"/>
                <col id="usedTickets" ui:number="true" sortable="true"/>
                <col id="isActive" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 partnerId[客户] contractId[支持合同]
 slaPolicyId[SLA策略]
=========>service[服务周期]======
 serviceType[服务类型] startDate[生效日期]
 endDate[失效日期]
=========>quota[配额与承诺]======
 maxTickets[最大工单数] usedTickets[已用工单数]
 maxResponseTime[承诺响应时限(分钟)] maxResolutionTime[承诺解决时限(分钟)]
 isActive[是否启用]
========^audit[审计信息]=========
 notes[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编码] orgId[业务组织]
 partnerId[客户] contractId[支持合同]
 slaPolicyId[SLA策略]
=========>service[服务周期]======
 serviceType[服务类型] startDate[生效日期]
 endDate[失效日期]
=========>quota[配额与承诺]======
 maxTickets[最大工单数] usedTickets[已用工单数]
 maxResponseTime[承诺响应时限(分钟)] maxResolutionTime[承诺解决时限(分钟)]
 isActive[是否启用]
========^audit[审计信息]=========
 notes[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编码] orgId[业务组织]
 partnerId[客户] contractId[支持合同]
 serviceType[服务类型] isActive[是否启用]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="partnerId" filterOp="eq"/>
                <cell id="contractId" filterOp="eq"/>
                <cell id="serviceType" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>