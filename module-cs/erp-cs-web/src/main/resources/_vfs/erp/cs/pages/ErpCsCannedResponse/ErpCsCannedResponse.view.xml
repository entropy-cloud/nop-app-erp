<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsCannedResponse.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="title" sortable="true"/>
                <col id="categoryName" label="分类"/>
                <col id="ticketTypeName" label="工单类型"/>
                <col id="macroPriority" sortable="true"/>
                <col id="sequence" ui:number="true" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="usageCount" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>