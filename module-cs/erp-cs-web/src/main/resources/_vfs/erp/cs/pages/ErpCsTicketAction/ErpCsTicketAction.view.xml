<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsTicketAction.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="ticket" label="工单"/>
                <col id="actionType" sortable="true"/>
                <col id="fromStatus" sortable="true"/>
                <col id="toStatus" sortable="true"/>
                <col id="operatorId" sortable="true"/>
                <col id="content" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 ticketId[工单ID] actionType[操作类型]
=========>transition[状态迁移]======
 fromStatus[起始状态] toStatus[目标状态]
 operatorId[操作人] content[操作内容]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 ticketId[工单ID] actionType[操作类型]
=========>transition[状态迁移]======
 fromStatus[起始状态] toStatus[目标状态]
 operatorId[操作人] content[操作内容]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 ticketId[工单ID] actionType[操作类型]
 fromStatus[起始状态] toStatus[目标状态]
 operatorId[操作人]
            </layout>
            <cells>
                <cell id="ticketId" filterOp="eq"/>
                <cell id="actionType" filterOp="eq"/>
                <cell id="fromStatus" filterOp="eq"/>
                <cell id="toStatus" filterOp="eq"/>
                <cell id="operatorId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>