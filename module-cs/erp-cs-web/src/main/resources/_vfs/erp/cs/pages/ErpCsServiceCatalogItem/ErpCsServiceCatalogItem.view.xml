<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsServiceCatalogItem.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="categoryId" label="分类"/>
                <col id="parentId" label="上级项"/>
                <col id="ticketTypeId" label="工单类型"/>
                <col id="slaPolicyId" label="SLA策略"/>
                <col id="shortDescription" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="isPublic" sortable="true"/>
                <col id="sequence" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="tree-list" x:prototype="list">
            <selection>children @TreeChildren(max:5)</selection>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit">
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpCsServiceCatalogItem__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="add">
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpCsServiceCatalogItem__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main" grid="tree-list">
            <table loadDataOnce="true" sortable="false" pager="none">
                <api url="@query:ErpCsServiceCatalogItem__findList?filter_parentId=__null"
                     gql:selection="{@listSelection}"/>
            </table>
            <rowActions>
                <action id="row-add-child-button" level="primary" label="新增子节点">
                    <dialog page="add-child"/>
                </action>
            </rowActions>
        </crud>
        <simple name="add-child" form="add">
            <data>
                <parentId>$id</parentId>
            </data>
        </simple>
        <picker name="picker">
            <table loadDataOnce="true" sortable="false" pager="none">
                <api url="@query:ErpCsServiceCatalogItem__findList?filter_parentId=__null"
                     gql:selection="{@listSelection}"/>
            </table>
        </picker>
    </pages>
</view>
