<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCsTimeEntry.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="ticket" label="工单"/>
                <col id="agentId" sortable="true"/>
                <col id="startTime" sortable="true"/>
                <col id="endTime" sortable="true"/>
                <col id="duration" ui:number="true" sortable="true"/>
                <col id="isBillable" sortable="true"/>
                <col id="projectId" ui:number="true" sortable="true"/>
                <col id="taskId" ui:number="true" sortable="true"/>
                <col id="approvalStatus" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>