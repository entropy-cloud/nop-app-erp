<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ioc="ioc"
       xmlns="http://www.springframework.org/schema/beans" x:extends="/nop/biz/defaults/service-base.beans.xml"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <bean id="app.erp.cs.service.entity.ErpCsTicketTypeBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsTicketType" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.cs.biz.IErpCsTicketTypeBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpCsTicketType"/>
    </bean>

    <bean id="app.erp.cs.service.entity.ErpCsKnowledgeBaseBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsKnowledgeBase" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.cs.biz.IErpCsKnowledgeBaseBiz" ioc:force-lazy-property="true" lazy-init="true"
          primary="true">
        <property name="bizObjName" value="ErpCsKnowledgeBase"/>
    </bean>

    <bean id="app.erp.cs.service.entity.ErpCsTeamBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsTeam" class="io.nop.biz.proxy.BizProxyFactoryBean" ioc:type="app.erp.cs.biz.IErpCsTeamBiz"
          ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpCsTeam"/>
    </bean>

    <bean id="app.erp.cs.service.entity.ErpCsSlaPolicyBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsSlaPolicy" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.cs.biz.IErpCsSlaPolicyBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpCsSlaPolicy"/>
    </bean>

    <bean id="app.erp.cs.service.entity.ErpCsTicketBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsTicket" class="io.nop.biz.proxy.BizProxyFactoryBean" ioc:type="app.erp.cs.biz.IErpCsTicketBiz"
          ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpCsTicket"/>
    </bean>

    <bean id="app.erp.cs.service.entity.ErpCsTicketActionBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpCsTicketAction" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.cs.biz.IErpCsTicketActionBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpCsTicketAction"/>
    </bean>
</beans>