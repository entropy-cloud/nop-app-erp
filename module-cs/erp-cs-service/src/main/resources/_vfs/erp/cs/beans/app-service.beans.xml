<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 定时 SLA 超时扫描 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-cs.sla-scan-cron 配置门控。 -->
    <bean id="erpCsSlaScanJob"
          class="app.erp.cs.service.job.ErpCsSlaScanJob"/>

    <!-- 定时 CSAT 调查到期提醒 Job Bean（plan 2026-07-06-0642-1 §Phase 2）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-cs.csat-reminder-cron 配置门控。 -->
    <bean id="erpCsCsatReminderJob"
          class="app.erp.cs.service.job.ErpCsCsatReminderJob"/>

    <!-- 客服域报表渲染入口（plan 2026-07-06-1815-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。镜像 finance ErpFinReportBizModel（域隔离 /cs/）。 -->
    <bean id="app.erp.cs.service.report.ErpCsReportBizModel" ioc:type="@bean:id"/>
</beans>