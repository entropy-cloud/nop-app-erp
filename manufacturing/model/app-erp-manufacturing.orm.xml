<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-manufacturing ORM 模型 — 制造域（权威数据模型来源）
  ==================================================
  业务范围：BOM（头/行/工艺/联副产品）、工艺路线（Routing）、工作中心（Workcenter）、
            工单（WorkOrder）、工序作业卡（Job Card）

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-mfg
    - entityPackage:  app.erp.mfg.dao.entity
    - 实体类名:        ErpMfg<Entity>     （如 ErpMfgBom、ErpMfgWorkOrder、ErpMfgJobCard、ErpMfgRouting）
    - 表名:           erp_mfg_<entity>   （如 erp_mfg_bom、erp_mfg_work_order、erp_mfg_job_card）
    - 字典命名空间:    erp-mfg/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（物料/SKU、计量单位主数据）
    - 被 app-erp-finance 引用（生产订单触发存货估值凭证、成本结转）
    - 可被 app-erp-quality 引用（工单完工触发质检）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-mfg" ext:entityPackageName="app.erp.mfg.dao.entity"
     ext:basePackageName="app.erp.mfg" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-manufacturing"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="工单状态" name="erp-mfg/work-order-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="SUBMITTED" label="已提交" value="1"/>
            <option code="NOT_STARTED" label="未开始" value="2"/>
            <option code="IN_PROCESS" label="生产中" value="3"/>
            <option code="STOCK_RESERVED" label="已齐套" value="4"/>
            <option code="STOCK_PARTIAL" label="部分齐套" value="5"/>
            <option code="COMPLETED" label="已完工" value="6"/>
            <option code="STOPPED" label="已停工" value="7"/>
            <option code="CLOSED" label="已关闭" value="8"/>
            <option code="CANCELLED" label="已取消" value="9"/>
        </dict>
        <dict label="作业卡状态" name="erp-mfg/job-card-status" valueType="int">
            <option code="OPEN" label="待开始" value="0"/>
            <option code="WORK_IN_PROGRESS" label="作业中" value="1"/>
            <option code="PARTIALLY_TRANSFERRED" label="部分转序" value="2"/>
            <option code="MATERIAL_TRANSFERRED" label="已转序" value="3"/>
            <option code="ON_HOLD" label="暂停" value="4"/>
            <option code="SUBMITTED" label="已提交" value="5"/>
            <option code="COMPLETED" label="已完成" value="6"/>
            <option code="CANCELLED" label="已取消" value="7"/>
        </dict>
        <dict label="BOM 类型" name="erp-mfg/bom-type" valueType="int">
            <option code="NORMAL" label="制造" value="0"/>
            <option code="PHANTOM" label="虚拟件/Kit" value="1"/>
        </dict>
        <dict label="消耗控制" name="erp-mfg/consumption" valueType="int">
            <option code="FLEXIBLE" label="允许超耗" value="0"/>
            <option code="WARNING" label="超耗警告" value="1"/>
            <option code="STRICT" label="严格按 BOM" value="2"/>
        </dict>
        <dict label="审核状态" name="erp-mfg/approve-status" valueType="int">
            <option code="UNSUBMITTED" label="未提交" value="0"/>
            <option code="SUBMITTED" label="已提交" value="1"/>
            <option code="APPROVED" label="已审核" value="2"/>
            <option code="REJECTED" label="已驳回" value="3"/>
        </dict>
        <dict label="工单优先级" name="erp-mfg/priority" valueType="int">
            <option code="LOW" label="低" value="0"/>
            <option code="NORMAL" label="普通" value="1"/>
            <option code="HIGH" label="高" value="2"/>
            <option code="URGENT" label="紧急" value="3"/>
        </dict>
    </dicts>

    <domains>
        <domain name="bomCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="routingCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="workcenterCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="workOrderCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="quantity" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="unitPrice" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="timeInMins" stdSqlType="DECIMAL" precision="12" scale="2"/>
        <domain name="rate" stdSqlType="DECIMAL" precision="10" scale="4"/>
        <domain name="capacity" stdSqlType="DECIMAL" precision="16" scale="4"/>
        <domain name="hourlyRate" stdSqlType="DECIMAL" precision="16" scale="4"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <!-- BOM 头 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgBom"
                displayName="BOM" name="app.erp.mfg.dao.entity.ErpMfgBom"
                tableName="erp_mfg_bom" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="BOM编码" domainName="bomCode" mandatory="true"/>
                <column name="productId" displayName="产品" stdSqlType="BIGINT" mandatory="true"/>
                <column name="version" displayName="版本" stdSqlType="INT" defaultValue="1"/>
                <column name="bomType" displayName="BOM类型" dictName="erp-mfg/bom-type" mandatory="true"/>
                <column name="consumption" displayName="消耗控制" dictName="erp-mfg/consumption"/>
                <column name="isActive" displayName="是否有效" stdSqlType="BOOLEAN" defaultValue="true"/>
                <column name="isDefault" displayName="是否默认" stdSqlType="BOOLEAN" defaultValue="false"/>
                <column name="useMultiLevelBom" displayName="展开多层BOM" stdSqlType="BOOLEAN" defaultValue="false"/>
                <column name="inspectionRequired" displayName="需要质检" stdSqlType="BOOLEAN" defaultValue="false"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="product" refEntityName="app.erp.md.dao.entity.ErpMdMaterial" joinColumnName="productId"/>
                <to-many name="lines" refEntityName="app.erp.mfg.dao.entity.ErpMfgBomLine" myFieldName="id" refFieldName="bomId"/>
                <to-many name="operations" refEntityName="app.erp.mfg.dao.entity.ErpMfgBomOperation" myFieldName="id" refFieldName="bomId"/>
                <to-many name="byproducts" refEntityName="app.erp.mfg.dao.entity.ErpMfgBomByproduct" myFieldName="id" refFieldName="bomId"/>
            </relations>
        </entity>

        <!-- BOM 行 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgBomLine"
                displayName="BOM行" name="app.erp.mfg.dao.entity.ErpMfgBomLine"
                tableName="erp_mfg_bom_line" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="bomId" displayName="BOM ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="materialId" displayName="物料" stdSqlType="BIGINT" mandatory="true"/>
                <column name="skuId" displayName="SKU" stdSqlType="BIGINT"/>
                <column name="uoMId" displayName="计量单位" stdSqlType="BIGINT" mandatory="true"/>
                <column name="quantity" displayName="数量" domainName="quantity" mandatory="true"/>
                <column name="operationId" displayName="工序ID" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="bom" refEntityName="app.erp.mfg.dao.entity.ErpMfgBom" joinColumnName="bomId"/>
                <to-one name="material" refEntityName="app.erp.md.dao.entity.ErpMdMaterial" joinColumnName="materialId"/>
                <to-one name="sku" refEntityName="app.erp.md.dao.entity.ErpMdMaterialSku" joinColumnName="skuId"/>
                <to-one name="uoM" refEntityName="app.erp.md.dao.entity.ErpMdUoM" joinColumnName="uoMId"/>
            </relations>
        </entity>

        <!-- BOM 工艺 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgBomOperation"
                displayName="BOM工艺" name="app.erp.mfg.dao.entity.ErpMfgBomOperation"
                tableName="erp_mfg_bom_operation" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="bomId" displayName="BOM ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="operationId" displayName="工序ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="workcenterId" displayName="工作中心" stdSqlType="BIGINT"/>
                <column name="standardTime" displayName="标准工时" domainName="timeInMins"/>
                <column name="timeUnit" displayName="时间单位" stdSqlType="VARCHAR" precision="20"/>
                <column name="rate" displayName="效率系数" domainName="rate" defaultValue="1"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="bom" refEntityName="app.erp.mfg.dao.entity.ErpMfgBom" joinColumnName="bomId"/>
                <to-one name="workcenter" refEntityName="app.erp.mfg.dao.entity.ErpMfgWorkcenter" joinColumnName="workcenterId"/>
            </relations>
        </entity>

        <!-- BOM 联副产品 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgBomByproduct"
                displayName="BOM联副产品" name="app.erp.mfg.dao.entity.ErpMfgBomByproduct"
                tableName="erp_mfg_bom_byproduct" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="bomId" displayName="BOM ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="materialId" displayName="物料" stdSqlType="BIGINT" mandatory="true"/>
                <column name="skuId" displayName="SKU" stdSqlType="BIGINT"/>
                <column name="uoMId" displayName="计量单位" stdSqlType="BIGINT" mandatory="true"/>
                <column name="quantity" displayName="数量" domainName="quantity" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="bom" refEntityName="app.erp.mfg.dao.entity.ErpMfgBom" joinColumnName="bomId"/>
                <to-one name="material" refEntityName="app.erp.md.dao.entity.ErpMdMaterial" joinColumnName="materialId"/>
                <to-one name="sku" refEntityName="app.erp.md.dao.entity.ErpMdMaterialSku" joinColumnName="skuId"/>
                <to-one name="uoM" refEntityName="app.erp.md.dao.entity.ErpMdUoM" joinColumnName="uoMId"/>
            </relations>
        </entity>

        <!-- 工艺路线 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgRouting"
                displayName="工艺路线" name="app.erp.mfg.dao.entity.ErpMfgRouting"
                tableName="erp_mfg_routing" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="工艺路线编码" domainName="routingCode" mandatory="true"/>
                <column name="name" displayName="工艺路线名称" stdSqlType="VARCHAR" precision="200"/>
                <column name="isActive" displayName="是否有效" stdSqlType="BOOLEAN" defaultValue="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-many name="operations" refEntityName="app.erp.mfg.dao.entity.ErpMfgRoutingOperation" myFieldName="id" refFieldName="routingId"/>
            </relations>
        </entity>

        <!-- 工艺路线工序 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgRoutingOperation"
                displayName="工艺路线工序" name="app.erp.mfg.dao.entity.ErpMfgRoutingOperation"
                tableName="erp_mfg_routing_operation" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="routingId" displayName="工艺路线ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="operationCode" displayName="工序编码" stdSqlType="VARCHAR" precision="50"/>
                <column name="operationName" displayName="工序名称" stdSqlType="VARCHAR" precision="200"/>
                <column name="workcenterId" displayName="工作中心" stdSqlType="BIGINT"/>
                <column name="standardTime" displayName="标准工时" domainName="timeInMins"/>
                <column name="timeUnit" displayName="时间单位" stdSqlType="VARCHAR" precision="20"/>
                <column name="setupTime" displayName="准备时间" domainName="timeInMins"/>
                <column name="runTime" displayName="加工时间" domainName="timeInMins"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="routing" refEntityName="app.erp.mfg.dao.entity.ErpMfgRouting" joinColumnName="routingId"/>
                <to-one name="workcenter" refEntityName="app.erp.mfg.dao.entity.ErpMfgWorkcenter" joinColumnName="workcenterId"/>
            </relations>
        </entity>

        <!-- 工作中心 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgWorkcenter"
                displayName="工作中心" name="app.erp.mfg.dao.entity.ErpMfgWorkcenter"
                tableName="erp_mfg_workcenter" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="工作中心编码" domainName="workcenterCode" mandatory="true"/>
                <column name="name" displayName="工作中心名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="capacity" displayName="产能" domainName="capacity"/>
                <column name="capacityUnit" displayName="产能单位" stdSqlType="VARCHAR" precision="20"/>
                <column name="hourlyRate" displayName="小时费率" domainName="hourlyRate"/>
                <column name="workHoursPerDay" displayName="日工时" stdSqlType="DECIMAL" precision="8" scale="2"/>
                <column name="isExternal" displayName="是否外协" stdSqlType="BOOLEAN" defaultValue="false"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
        </entity>

        <!-- 工单 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgWorkOrder"
                displayName="工单" name="app.erp.mfg.dao.entity.ErpMfgWorkOrder"
                tableName="erp_mfg_work_order" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="工单号" domainName="workOrderCode" mandatory="true"/>
                <column name="bomId" displayName="BOM" stdSqlType="BIGINT" mandatory="true"/>
                <column name="productId" displayName="产品" stdSqlType="BIGINT" mandatory="true"/>
                <column name="plannedQuantity" displayName="计划数量" domainName="quantity" mandatory="true"/>
                <column name="completedQuantity" displayName="完工数量" domainName="quantity" defaultValue="0"/>
                <column name="scrappedQuantity" displayName="报废数量" domainName="quantity" defaultValue="0"/>
                <column name="plannedStartDate" displayName="计划开工日期" stdSqlType="DATE"/>
                <column name="plannedEndDate" displayName="计划完工日期" stdSqlType="DATE"/>
                <column name="actualStartDate" displayName="实际开工日期" stdSqlType="DATE"/>
                <column name="actualEndDate" displayName="实际完工日期" stdSqlType="DATE"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-mfg/work-order-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-mfg/approve-status"/>
                <column name="priority" displayName="优先级" dictName="erp-mfg/priority"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="bom" refEntityName="app.erp.mfg.dao.entity.ErpMfgBom" joinColumnName="bomId"/>
                <to-one name="product" refEntityName="app.erp.md.dao.entity.ErpMdMaterial" joinColumnName="productId"/>
                <to-many name="jobCards" refEntityName="app.erp.mfg.dao.entity.ErpMfgJobCard" myFieldName="id" refFieldName="workOrderId"/>
            </relations>
        </entity>

        <!-- 作业卡 -->
        <entity className="app.erp.mfg.dao.entity.ErpMfgJobCard"
                displayName="作业卡" name="app.erp.mfg.dao.entity.ErpMfgJobCard"
                tableName="erp_mfg_job_card" tag="erp.manufacturing">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="workOrderId" displayName="工单ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="operationId" displayName="工序ID" stdSqlType="BIGINT"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="plannedQuantity" displayName="计划数量" domainName="quantity" mandatory="true"/>
                <column name="completedQuantity" displayName="完工数量" domainName="quantity" defaultValue="0"/>
                <column name="scrappedQuantity" displayName="报废数量" domainName="quantity" defaultValue="0"/>
                <column name="status" displayName="状态" dictName="erp-mfg/job-card-status" mandatory="true"/>
                <column name="workcenterId" displayName="工作中心" stdSqlType="BIGINT"/>
                <column name="actualStartTime" displayName="实际开始时间" stdSqlType="DATETIME"/>
                <column name="actualEndTime" displayName="实际结束时间" stdSqlType="DATETIME"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="workOrder" refEntityName="app.erp.mfg.dao.entity.ErpMfgWorkOrder" joinColumnName="workOrderId"/>
                <to-one name="workcenter" refEntityName="app.erp.mfg.dao.entity.ErpMfgWorkcenter" joinColumnName="workcenterId"/>
            </relations>
        </entity>
    </entities>
</orm>
