<?xml version="1.0" encoding="UTF-8" ?>
<!-- 聚合 app 的菜单入口:合并全部 18 业务域 + 跨域通知派发子系统(notify) + 系统模块(nop-auth/sys/wf/report/job)的菜单。
     x:extends 用逗号分隔多个 action-auth,合并到同一 site。各业务域菜单定义在各自 erp-{short}.action-auth.xml,
     系统模块菜单在 nop-{module}/auth/ 下。-->
<auth x:extends="/erp/md/auth/erp-md.action-auth.xml,
                 /erp/pur/auth/erp-pur.action-auth.xml,
                 /erp/sal/auth/erp-sal.action-auth.xml,
                 /erp/inv/auth/erp-inv.action-auth.xml,
                 /erp/fin/auth/erp-fin.action-auth.xml,
                 /erp/ast/auth/erp-ast.action-auth.xml,
                 /erp/prj/auth/erp-prj.action-auth.xml,
                 /erp/mfg/auth/erp-mfg.action-auth.xml,
                 /erp/qa/auth/erp-qa.action-auth.xml,
                 /erp/mnt/auth/erp-mnt.action-auth.xml,
                 /erp/crm/auth/erp-crm.action-auth.xml,
                 /erp/cs/auth/erp-cs.action-auth.xml,
                 /erp/hr/auth/erp-hr.action-auth.xml,
                 /erp/aps/auth/erp-aps.action-auth.xml,
                 /erp/ct/auth/erp-ct.action-auth.xml,
                 /erp/drp/auth/erp-drp.action-auth.xml,
                 /erp/log/auth/erp-log.action-auth.xml,
                 /erp/b2b/auth/erp-b2b.action-auth.xml,
                 /erp/notify/auth/erp-notify.action-auth.xml,
                 /nop/auth/auth/nop-auth.action-auth.xml,
                 /nop/sys/auth/nop-sys.action-auth.xml,
                 /nop/wf/auth/nop-wf.action-auth.xml,
                 /nop/report/auth/nop-report.action-auth.xml"
     x:schema="/nop/schema/action-auth.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:i18n-en="i18n-en">

    <site id="main">
        <!-- 删除各系统模块的测试菜单根(它们各带 test-orm-nop-* TOPM) -->
        <resource id="test-orm-nop-auth" x:override="remove"/>
        <resource id="test-orm-nop-sys" x:override="remove"/>
        <resource id="test-orm-nop-wf" x:override="remove"/>
        <resource id="test-orm-nop-report" x:override="remove"/>

        <!-- 中国本地化:金税接口(L10N CN,独立 module-l10n-cn 工程,设计阶段) -->
        <resource id="erp-l10n-cn" displayName="中国本地化" i18n-en:displayName="L10N CN"
                  icon="map-pin" resourceType="TOPM" orderNo="3000"
                  routePath="/erp-l10n-cn" component="layouts/default/index">
            <children>
                <resource id="l10n-cn-invoice" displayName="增值税发票" i18n-en:displayName="VAT Invoice"
                          icon="receipt" resourceType="SUBM" orderNo="100">
                    <children>
                        <resource id="l10n-cn-vat-invoice" displayName="增值税发票"
                                  i18n-en:displayName="VAT Invoice" icon="receipt"
                                  component="AMIS" resourceType="SUBM" orderNo="100"
                                  url="/erp/l10n-cn/pages/ErpL10nCnVatInvoice/main.page.yaml"/>
                    </children>
                </resource>
                <resource id="l10n-cn-config" displayName="金税配置" i18n-en:displayName="Config"
                          icon="sliders-horizontal" resourceType="SUBM" orderNo="200">
                    <children>
                        <resource id="l10n-cn-golden-tax-log" displayName="金税接口日志"
                                  i18n-en:displayName="Golden Tax Log" icon="list"
                                  component="AMIS" resourceType="SUBM" orderNo="200"
                                  url="/erp/l10n-cn/pages/ErpL10nCnGoldenTaxLog/main.page.yaml"/>
                        <resource id="l10n-cn-tax-rate" displayName="税率配置"
                                  i18n-en:displayName="Tax Rate" icon="percent"
                                  component="AMIS" resourceType="SUBM" orderNo="210"
                                  url="/erp/l10n-cn/pages/ErpL10nCnTaxRate/main.page.yaml"/>
                    </children>
                </resource>
            </children>
        </resource>
        <!-- 系统管理:聚合系统级功能的顶层菜单 -->
        <resource id="erp-sys" displayName="系统管理" i18n-en:displayName="System"
                  icon="settings" resourceType="TOPM" orderNo="2000"
                  routePath="/erp-sys" component="layouts/default/index">
            <children>
                <!-- 用户权限 -->
                <resource id="sys-user" displayName="用户权限" i18n-en:displayName="User &amp; Role"
                          icon="users" resourceType="SUBM" orderNo="100">
                    <children>
                        <resource id="sys-user-main" displayName="用户管理"
                                  i18n-en:displayName="User" icon="user-round"
                                  component="AMIS" resourceType="SUBM" orderNo="100"
                                  url="/nop/auth/pages/NopAuthUser/main.page.yaml"/>
                        <resource id="sys-role-main" displayName="角色管理"
                                  i18n-en:displayName="Role" icon="shield"
                                  component="AMIS" resourceType="SUBM" orderNo="110"
                                  url="/nop/auth/pages/NopAuthRole/main.page.yaml"/>
                        <resource id="sys-dept-main" displayName="部门管理"
                                  i18n-en:displayName="Department" icon="git-branch"
                                  component="AMIS" resourceType="SUBM" orderNo="120"
                                  url="/nop/auth/pages/NopAuthDept/main.page.yaml"/>
                        <resource id="sys-position-main" displayName="岗位管理"
                                  i18n-en:displayName="Position" icon="briefcase"
                                  component="AMIS" resourceType="SUBM" orderNo="130"
                                  url="/nop/auth/pages/NopAuthPosition/main.page.yaml"/>
                        <resource id="sys-group-main" displayName="用户组"
                                  i18n-en:displayName="User Group" icon="users"
                                  component="AMIS" resourceType="SUBM" orderNo="140"
                                  url="/nop/auth/pages/NopAuthGroup/main.page.yaml"/>
                        <resource id="sys-role-data-auth-main" displayName="数据权限"
                                  i18n-en:displayName="Data Auth" icon="database"
                                  component="AMIS" resourceType="SUBM" orderNo="150"
                                  url="/nop/auth/pages/NopAuthRoleDataAuth/main.page.yaml"/>
                    </children>
                </resource>

                <!-- 资源菜单 -->
                <resource id="sys-resource" displayName="资源菜单" i18n-en:displayName="Resource"
                          icon="menu" resourceType="SUBM" orderNo="200">
                    <children>
                        <resource id="sys-resource-main" displayName="菜单资源"
                                  i18n-en:displayName="Menu Resource" icon="panels-top-left"
                                  component="AMIS" resourceType="SUBM" orderNo="200"
                                  url="/nop/auth/pages/NopAuthResource/main.page.yaml"/>
                        <resource id="sys-site-main" displayName="站点管理"
                                  i18n-en:displayName="Site" icon="globe-2"
                                  component="AMIS" resourceType="SUBM" orderNo="210"
                                  url="/nop/auth/pages/NopAuthSite/main.page.yaml"/>
                    </children>
                </resource>

                <!-- 系统配置 -->
                <resource id="sys-config" displayName="系统配置" i18n-en:displayName="Config"
                          icon="sliders-horizontal" resourceType="SUBM" orderNo="300">
                    <children>
                        <resource id="sys-dict-main" displayName="数据字典"
                                  i18n-en:displayName="Dict" icon="book"
                                  component="AMIS" resourceType="SUBM" orderNo="300"
                                  url="/nop/sys/pages/NopSysDict/main.page.yaml"/>
                        <resource id="sys-dict-option-main" displayName="字典选项"
                                  i18n-en:displayName="Dict Option" icon="list"
                                  component="AMIS" resourceType="SUBM" orderNo="310"
                                  url="/nop/sys/pages/NopSysDictOption/main.page.yaml"/>
                        <resource id="sys-sequence-main" displayName="序列号规则"
                                  i18n-en:displayName="Sequence" icon="hash"
                                  component="AMIS" resourceType="SUBM" orderNo="320"
                                  url="/nop/sys/pages/NopSysSequence/main.page.yaml"/>
                        <resource id="sys-i18n-main" displayName="国际化"
                                  i18n-en:displayName="I18n" icon="languages"
                                  component="AMIS" resourceType="SUBM" orderNo="330"
                                  url="/nop/sys/pages/NopSysI18n/main.page.yaml"/>
                    </children>
                </resource>

                <!-- 工作流 -->
                <resource id="sys-workflow" displayName="工作流" i18n-en:displayName="Workflow"
                          icon="git-branch" resourceType="SUBM" orderNo="400">
                    <children>
                        <resource id="sys-wf-definition-main" displayName="流程定义"
                                  i18n-en:displayName="Process Definition" icon="workflow"
                                  component="AMIS" resourceType="SUBM" orderNo="400"
                                  url="/nop/wf/pages/NopWfDefinition/main.page.yaml"/>
                        <resource id="sys-wf-instance-main" displayName="流程实例"
                                  i18n-en:displayName="Process Instance" icon="git-branch"
                                  component="AMIS" resourceType="SUBM" orderNo="410"
                                  url="/nop/wf/pages/NopWfInstance/main.page.yaml"/>
                        <resource id="sys-wf-workflow-main" displayName="我的待办"
                                  i18n-en:displayName="My Todo" icon="list-checks"
                                  component="AMIS" resourceType="SUBM" orderNo="420"
                                  url="/nop/wf/pages/WorkflowService/main.page.yaml"/>
                    </children>
                </resource>

                <!-- 报表中心 -->
                <resource id="sys-report" displayName="报表中心" i18n-en:displayName="Report"
                          icon="bar-chart-3" resourceType="SUBM" orderNo="500">
                    <children>
                        <resource id="sys-report-definition-main" displayName="报表定义"
                                  i18n-en:displayName="Report Definition" icon="file-bar-chart"
                                  component="AMIS" resourceType="SUBM" orderNo="500"
                                  url="/nop/report/pages/NopReportDefinition/main.page.yaml"/>
                        <resource id="sys-report-datasource-main" displayName="报表数据源"
                                  i18n-en:displayName="Report Datasource" icon="database"
                                  component="AMIS" resourceType="SUBM" orderNo="510"
                                  url="/nop/report/pages/NopReportDatasource/main.page.yaml"/>
                    </children>
                </resource>

                <!-- 系统监控 -->
                <resource id="sys-monitor" displayName="系统监控" i18n-en:displayName="Monitor"
                          icon="activity" resourceType="SUBM" orderNo="700">
                    <children>
                        <resource id="sys-oplog-main" displayName="操作日志"
                                  i18n-en:displayName="Operation Log" icon="list"
                                  component="AMIS" resourceType="SUBM" orderNo="700"
                                  url="/nop/auth/pages/NopAuthOpLog/main.page.yaml"/>
                        <resource id="sys-session-main" displayName="在线会话"
                                  i18n-en:displayName="Session" icon="monitor"
                                  component="AMIS" resourceType="SUBM" orderNo="710"
                                  url="/nop/auth/pages/NopAuthSession/main.page.yaml"/>
                        <resource id="sys-extfield-main" displayName="扩展字段"
                                  i18n-en:displayName="Ext Field" icon="columns"
                                  component="AMIS" resourceType="SUBM" orderNo="720"
                                  url="/nop/sys/pages/NopSysExtField/main.page.yaml"/>
                    </children>
                </resource>
            </children>
        </resource>
    </site>
</auth>
