    <bean id="app.erp.b2b.service.entity.ErpB2bCodeMappingBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpB2bCodeMapping" class="io.nop.biz.proxy.BizProxyFactoryBean"
