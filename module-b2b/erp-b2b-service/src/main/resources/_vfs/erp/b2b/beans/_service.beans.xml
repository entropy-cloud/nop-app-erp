       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <bean id="app.erp.b2b.service.entity.ErpB2bEdiFormatBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpB2bEdiFormat" class="io.nop.biz.proxy.BizProxyFactoryBean"
          ioc:type="app.erp.b2b.biz.IErpB2bEdiFormatBiz" ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpB2bEdiFormat"/>
