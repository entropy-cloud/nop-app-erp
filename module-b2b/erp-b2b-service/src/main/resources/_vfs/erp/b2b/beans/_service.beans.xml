    <bean id="app.erp.b2b.service.entity.ErpB2bAsnBizModel" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="biz_ErpB2bAsn" class="io.nop.biz.proxy.BizProxyFactoryBean" ioc:type="app.erp.b2b.biz.IErpB2bAsnBiz"
          ioc:force-lazy-property="true" lazy-init="true" primary="true">
        <property name="bizObjName" value="ErpB2bAsn"/>
