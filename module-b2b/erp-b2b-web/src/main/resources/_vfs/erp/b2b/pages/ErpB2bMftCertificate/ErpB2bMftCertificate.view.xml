<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bMftCertificate.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="partnerId" label="合作伙伴"/>
                <col id="certName" mandatory="true" sortable="true"/>
                <col id="certType" mandatory="true" sortable="true"/>
                <col id="algorithm" mandatory="true" sortable="true"/>
                <col id="keySize" ui:number="true" sortable="true"/>
                <col id="issuerName" sortable="true"/>
                <col id="subjectName" sortable="true"/>
                <col id="serialNo" sortable="true"/>
                <col id="fingerprintSha256" sortable="true"/>
                <col id="issuedAt" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="expiresAt" mandatory="true" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] partnerId[合作伙伴]
 certName[证书名称] certType[证书类型]
=========>detail[证书详情]======
 algorithm[算法] keySize[密钥长度]
 issuerName[颁发者] subjectName[主题]
 serialNo[序列号] fingerprintSha256[SHA-256指纹]
=========>validity[有效期]======
 issuedAt[颁发日期] expiresAt[过期日期]
 isActive[启用]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] partnerId[合作伙伴]
 certName[证书名称] certType[证书类型]
=========>detail[证书详情]======
 algorithm[算法] keySize[密钥长度]
 issuerName[颁发者] subjectName[主题]
 serialNo[序列号] fingerprintSha256[SHA-256指纹]
=========>validity[有效期]======
 issuedAt[颁发日期] expiresAt[过期日期]
 isActive[启用]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织] partnerId[合作伙伴]
 certName[证书名称] certType[证书类型]
 isActive[启用]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="partnerId" filterOp="eq"/>
                <cell id="certName" filterOp="like"/>
                <cell id="certType" filterOp="eq"/>
                <cell id="isActive" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>