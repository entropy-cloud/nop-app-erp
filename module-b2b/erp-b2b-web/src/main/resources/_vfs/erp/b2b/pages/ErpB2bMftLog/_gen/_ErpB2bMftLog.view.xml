<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpB2bMftLog" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/b2b/model/ErpB2bMftLog/ErpB2bMftLog.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--MFT配置-->
                <col id="configId" mandatory="true" ui:number="true" sortable="true"/>

                <!--关联单据类型-->
                <col id="relatedBillType" sortable="true"/>

                <!--关联单据号-->
                <col id="relatedBillCode" sortable="true"/>

                <!--方向-->
                <col id="direction" mandatory="true" sortable="true"/>

                <!--文件名-->
                <col id="fileName" sortable="true"/>

                <!--文件大小(字节)-->
                <col id="fileSize" ui:number="true" sortable="true"/>

                <!--文件哈希-->
                <col id="fileHash" sortable="true"/>

                <!--AS2 Message-ID-->
                <col id="messageId" sortable="true"/>

                <!--MDN状态-->
                <col id="mdnStatus" sortable="true"/>

                <!--传输协议-->
                <col id="protocol" mandatory="true" sortable="true"/>

                <!--传输状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--开始时间-->
                <col id="startTime" sortable="true"/>

                <!--结束时间-->
                <col id="endTime" sortable="true"/>

                <!--耗时(毫秒)-->
                <col id="durationMs" ui:number="true" sortable="true"/>

                <!--错误码-->
                <col id="errorCode" sortable="true"/>

                <!--错误消息-->
                <col id="errorMsg" sortable="true"/>

                <!--重试次数-->
                <col id="retryCount" ui:number="true" sortable="true"/>

                <!--压缩-->
                <col id="isCompressed" sortable="true"/>

                <!--加密-->
                <col id="isEncrypted" sortable="true"/>

                <!--签名-->
                <col id="isSigned" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-MFT 传输日志" i18n-en:title="View MFT Log">
            <layout>
 id[ID] orgId[业务组织]
 configId[MFT配置] relatedBillType[关联单据类型]
 relatedBillCode[关联单据号] direction[方向]
 fileName[文件名] fileSize[文件大小(字节)]
 fileHash[文件哈希] messageId[AS2 Message-ID]
 mdnStatus[MDN状态] protocol[传输协议]
 status[传输状态] startTime[开始时间]
 endTime[结束时间] durationMs[耗时(毫秒)]
 errorCode[错误码] errorMsg[错误消息]
 retryCount[重试次数] isCompressed[压缩]
 isEncrypted[加密] isSigned[签名]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-MFT 传输日志" i18n-en:title="Add MFT Log" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-MFT 传输日志" i18n-en:title="Edit MFT Log">
            <layout>
 id[ID] orgId[业务组织]
 configId[MFT配置] relatedBillType[关联单据类型]
 relatedBillCode[关联单据号] direction[方向]
 fileName[文件名] fileSize[文件大小(字节)]
 fileHash[文件哈希] messageId[AS2 Message-ID]
 mdnStatus[MDN状态] protocol[传输协议]
 status[传输状态] startTime[开始时间]
 endTime[结束时间] durationMs[耗时(毫秒)]
 errorCode[错误码] errorMsg[错误消息]
 retryCount[重试次数] isCompressed[压缩]
 isEncrypted[加密] isSigned[签名]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-MFT 传输日志" i18n-en:title="Update MFT Log"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpB2bMftLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpB2bMftLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpB2bMftLog__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpB2bMftLog__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpB2bMftLog__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpB2bMftLog__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpB2bMftLog__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpB2bMftLog__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpB2bMftLog__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpB2bMftLog__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>