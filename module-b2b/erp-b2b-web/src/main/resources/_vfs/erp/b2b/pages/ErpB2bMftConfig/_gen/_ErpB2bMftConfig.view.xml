<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpB2bMftConfig" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/b2b/model/ErpB2bMftConfig/ErpB2bMftConfig.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--合作伙伴-->
                <col id="partnerId" mandatory="true" ui:number="true" sortable="true"/>

                <!--传输协议-->
                <col id="protocol" mandatory="true" sortable="true"/>

                <!--传输端点-->
                <col id="transportEndpoint" mandatory="true" sortable="true"/>

                <!--本地AS2 ID-->
                <col id="localAs2Id" sortable="true"/>

                <!--对方AS2 ID-->
                <col id="remoteAs2Id" sortable="true"/>

                <!--SFTP用户名-->
                <col id="sftpUsername" sortable="true"/>

                <!--SFTP端口-->
                <col id="sftpPort" ui:number="true" sortable="true"/>

                <!--FTPS端口-->
                <col id="ftpsPort" ui:number="true" sortable="true"/>

                <!--隐式TLS-->
                <col id="ftpsImplicitTls" sortable="true"/>

                <!--启用压缩-->
                <col id="compression" sortable="true"/>

                <!--启用加密-->
                <col id="encryption" sortable="true"/>

                <!--加密算法-->
                <col id="encryptionAlgo" sortable="true"/>

                <!--启用签名-->
                <col id="signature" sortable="true"/>

                <!--签名算法-->
                <col id="signatureAlgo" sortable="true"/>

                <!--关联证书-->
                <col id="certId" ui:number="true" sortable="true"/>

                <!--启用-->
                <col id="active" sortable="true"/>

                <!--最大重试次数-->
                <col id="maxRetries" ui:number="true" sortable="true"/>

                <!--重试间隔(分钟)-->
                <col id="retryIntervalMin" ui:number="true" sortable="true"/>

                <!--启用死信队列-->
                <col id="deadLetterEnabled" sortable="true"/>

                <!--监控目录-->
                <col id="monitorDirectory" sortable="true"/>

                <!--监控间隔(秒)-->
                <col id="monitorIntervalSec" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--合作伙伴-->
                <col id="partnerName"/>

                <!--业务组织-->
                <col id="orgName"/>

                <!--关联证书-->
                <col id="certName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-MFT 配置" i18n-en:title="View MFT Config">
            <layout>
 orgId[业务组织] partnerId[合作伙伴]
 protocol[传输协议] transportEndpoint[传输端点]
 localAs2Id[本地AS2 ID] remoteAs2Id[对方AS2 ID]
 sftpUsername[SFTP用户名] sftpPort[SFTP端口]
 ftpsPort[FTPS端口] ftpsImplicitTls[隐式TLS]
 compression[启用压缩] encryption[启用加密]
 encryptionAlgo[加密算法] signature[启用签名]
 signatureAlgo[签名算法] certId[关联证书]
 active[启用] maxRetries[最大重试次数]
 retryIntervalMin[重试间隔(分钟)] deadLetterEnabled[启用死信队列]
 monitorDirectory[监控目录] monitorIntervalSec[监控间隔(秒)]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 partnerName[合作伙伴] orgName[业务组织]
 certName[关联证书] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-MFT 配置" i18n-en:title="Add MFT Config" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-MFT 配置" i18n-en:title="Edit MFT Config">
            <layout>
 orgId[业务组织] partnerId[合作伙伴]
 protocol[传输协议] transportEndpoint[传输端点]
 localAs2Id[本地AS2 ID] remoteAs2Id[对方AS2 ID]
 sftpUsername[SFTP用户名] sftpPort[SFTP端口]
 ftpsPort[FTPS端口] ftpsImplicitTls[隐式TLS]
 compression[启用压缩] encryption[启用加密]
 encryptionAlgo[加密算法] signature[启用签名]
 signatureAlgo[签名算法] certId[关联证书]
 active[启用] maxRetries[最大重试次数]
 retryIntervalMin[重试间隔(分钟)] deadLetterEnabled[启用死信队列]
 monitorDirectory[监控目录] monitorIntervalSec[监控间隔(秒)]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-MFT 配置" i18n-en:title="Update MFT Config"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpB2bMftConfig__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpB2bMftConfig__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpB2bMftConfig__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpB2bMftConfig__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpB2bMftConfig__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpB2bMftConfig__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpB2bMftConfig__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpB2bMftConfig__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpB2bMftConfig__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpB2bMftConfig__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>