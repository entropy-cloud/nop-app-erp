<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bEdiDoc.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="formatName" label="EDI 格式"/>
                <col id="relatedBillType" sortable="true"/>
                <col id="relatedBillCode" sortable="true"/>
                <col id="state" mandatory="true" sortable="true"/>
                <col id="blockingLevel" mandatory="true" sortable="true"/>
                <col id="error" sortable="true"/>
                <col id="retryCount" mandatory="true" ui:number="true" sortable="true"/>
                <col id="attachmentFileId" sortable="true"/>
                <col id="sentAt" sortable="true"/>
                <col id="acknowledgedAt" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[事务编码] orgId[业务组织]
 formatId[EDI 格式] state[状态]
 blockingLevel[阻断级别] businessDate[业务日期]
==========>transaction[事务信息]======
 relatedBillType[关联单据类型] relatedBillCode[关联单据号]
 attachmentFileId[附件（EDI 报文文件）] retryCount[重试次数]
 error[错误信息]
==========>timing[时间信息]======
 sentAt[发送时间] acknowledgedAt[确认时间]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[事务编码] orgId[业务组织]
 formatId[EDI 格式] state[状态]
 blockingLevel[阻断级别] businessDate[业务日期]
==========>transaction[事务信息]======
 relatedBillType[关联单据类型] relatedBillCode[关联单据号]
 attachmentFileId[附件（EDI 报文文件）] retryCount[重试次数]
 error[错误信息]
==========>timing[时间信息]======
 sentAt[发送时间] acknowledgedAt[确认时间]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[事务编码] state[状态]
 relatedBillCode[关联单据号]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>