<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bTestExchange.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="partnerProfileId" label="伙伴档案"/>
                <col id="direction" mandatory="true" sortable="true"/>
                <col id="formatCode" mandatory="true" sortable="true"/>
                <col id="testCaseCode" sortable="true"/>
                <col id="sentPayload" sortable="true"/>
                <col id="receivedPayload" sortable="true"/>
                <col id="expectedResult" sortable="true"/>
                <col id="actualResult" sortable="true"/>
                <col id="passed" sortable="true"/>
                <col id="testedBy" sortable="true"/>
                <col id="testedAt" sortable="true"/>
                <col id="notes" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerProfileId[伙伴档案] direction[方向]
 formatCode[EDI格式] testCaseCode[测试用例编号]
=========>payload[报文]======
 sentPayload[发送报文] receivedPayload[接收报文]
=========>result[测试结果]======
 expectedResult[预期结果] actualResult[实际结果]
 passed[测试通过] testedBy[测试人]
 testedAt[测试时间]
========^audit[审计信息]=========
 notes[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerProfileId[伙伴档案] direction[方向]
 formatCode[EDI格式] testCaseCode[测试用例编号]
=========>payload[报文]======
 sentPayload[发送报文] receivedPayload[接收报文]
=========>result[测试结果]======
 expectedResult[预期结果] actualResult[实际结果]
 passed[测试通过] testedBy[测试人]
 testedAt[测试时间]
========^audit[审计信息]=========
 notes[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 partnerProfileId[伙伴档案] direction[方向]
 formatCode[EDI格式] testCaseCode[测试用例编号]
 passed[测试通过]
            </layout>
            <cells>
                <cell id="partnerProfileId" filterOp="eq"/>
                <cell id="direction" filterOp="eq"/>
                <cell id="formatCode" filterOp="like"/>
                <cell id="testCaseCode" filterOp="like"/>
                <cell id="passed" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>