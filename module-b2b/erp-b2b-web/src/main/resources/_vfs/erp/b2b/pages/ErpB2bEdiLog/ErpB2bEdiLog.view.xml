<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bEdiLog.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="ediDocId" label="EDI 事务"/>
                <col id="orgId" label="业务组织"/>
                <col id="direction" mandatory="true" sortable="true"/>
                <col id="requestPayload" sortable="true"/>
                <col id="responsePayload" sortable="true"/>
                <col id="resultCode" sortable="true"/>
                <col id="resultMsg" sortable="true"/>
                <col id="logTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 ediDocId[EDI 事务 ID] orgId[业务组织]
 direction[方向] logTime[日志时间]
=========>payload[报文]======
 requestPayload[请求报文] responsePayload[响应报文]
=========>result[结果]======
 resultCode[结果码] resultMsg[结果消息]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 ediDocId[EDI 事务 ID] direction[方向]
 resultCode[结果码] orgId[业务组织]
 logTime[日志时间]
            </layout>
            <cells>
                <cell id="ediDocId" filterOp="eq"/>
                <cell id="direction" filterOp="eq"/>
                <cell id="resultCode" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="logTime" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 resultMsg[结果消息]
            </layout>
            <cells>
                <cell id="resultMsg" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>