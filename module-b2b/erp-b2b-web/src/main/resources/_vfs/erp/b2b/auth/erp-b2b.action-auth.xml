<?xml version="1.0" encoding="UTF-8" ?>
<auth x:schema="/nop/schema/action-auth.xdef" xmlns:x="/nop/schema/xdsl.xdef"
      xmlns:i18n-en="i18n-en" xmlns:app="app">
    <site id="main">
        <resource id="erp-b2b" displayName="B2B集成" i18n-en:displayName="B2B Integration"
                  icon="refresh-cw" resourceType="TOPM" orderNo="1400"
                  routePath="/erp-b2b" component="layouts/default/index">
            <children>
                <resource id="b2b-edi" displayName="EDI管理" i18n-en:displayName="EDI Management"
                          icon="refresh-cw" resourceType="SUBM" orderNo="100">
                    <children>
                        <resource id="ErpB2bEdiFormat-main" app:useCases="UC-B2B-001"
                                  displayName="EDI格式" i18n-en:displayName="EDI Format" icon="file-type"
                                  component="AMIS" resourceType="SUBM" orderNo="100"
                                  url="/erp/b2b/pages/ErpB2bEdiFormat/main.page.yaml"/>
                        <resource id="ErpB2bEdiDoc-main" app:useCases="UC-B2B-002,UC-B2B-006"
                                  displayName="EDI事务" i18n-en:displayName="EDI Document" icon="file"
                                  component="AMIS" resourceType="SUBM" orderNo="110"
                                  url="/erp/b2b/pages/ErpB2bEdiDoc/main.page.yaml"/>
                    </children>
                </resource>
                <resource id="b2b-asn" displayName="ASN管理" i18n-en:displayName="ASN Management"
                          icon="truck" resourceType="SUBM" orderNo="200">
                    <children>
                        <resource id="ErpB2bAsn-main" app:useCases="UC-B2B-003"
                                  displayName="提前发货通知" i18n-en:displayName="Advanced Shipping Notice" icon="truck"
                                  component="AMIS" resourceType="SUBM" orderNo="200"
                                  url="/erp/b2b/pages/ErpB2bAsn/main.page.yaml"/>
                        <resource id="ErpB2bAsnLine-main" displayName="ASN明细"
