<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bPartnerProfile.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="partnerName" label="关联伙伴"/>
                <col id="partnerName" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="protocol" mandatory="true" sortable="true"/>
                <col id="transportEndpoint" sortable="true"/>
                <col id="authMethod" mandatory="true" sortable="true"/>
                <col id="certExpiry" sortable="true"/>
                <col id="certFingerprint" sortable="true"/>
                <col id="allowedFormats" sortable="true"/>
                <col id="timezone" sortable="true"/>
                <col id="contactName" sortable="true"/>
                <col id="contactEmail" sortable="true"/>
                <col id="contactPhone" sortable="true"/>
                <col id="notes" sortable="true"/>
                <col id="goLiveDate" sortable="true"/>
                <col id="archivedAt" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>