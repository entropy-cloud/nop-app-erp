<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bPartnerProfile.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="partnerId" label="关联伙伴"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="protocol" mandatory="true" sortable="true"/>
                <col id="transportEndpoint" sortable="true"/>
                <col id="authMethod" mandatory="true" sortable="true"/>
                <col id="certExpiry" sortable="true"/>
                <col id="certFingerprint" sortable="true"/>
                <col id="allowedFormats" sortable="true"/>
                <col id="timezone" sortable="true"/>
                <col id="contactName" sortable="true"/>
                <col id="contactEmail" sortable="true"/>
                <col id="contactPhone" sortable="true"/>
                <col id="notes" sortable="true"/>
                <col id="goLiveDate" sortable="true"/>
                <col id="archivedAt" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-activate-button" label="上线" level="success" icon="fa fa-power-off">
                    <api url="@mutation:ErpB2bPartnerProfile__activate?profileId=$id"/>
                    <confirmText>确认将此合作伙伴上线到生产环境？</confirmText>
                    <messages>
                        <success>合作伙伴已上线</success>
                    </messages>
                    <visibleOn>${status == 'CERTIFIED' || status == 'TESTING'}</visibleOn>
                </action>
                <action id="row-suspend-button" label="暂停" level="warning" icon="fa fa-pause">
                    <api url="@mutation:ErpB2bPartnerProfile__suspend?profileId=$id"/>
                    <confirmText>确认暂停此合作伙伴？</confirmText>
                    <messages>
                        <success>合作伙伴已暂停</success>
                    </messages>
                    <visibleOn>${status == 'PRODUCTION'}</visibleOn>
                </action>
                <action id="row-deactivate-button" label="终止" level="danger" icon="fa fa-stop">
                    <api url="@mutation:ErpB2bPartnerProfile__deactivate?profileId=$id"/>
                    <confirmText>确认终止此合作伙伴？</confirmText>
                    <messages>
                        <success>合作伙伴已终止</success>
                    </messages>
                    <visibleOn>${status != 'TERMINATED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>