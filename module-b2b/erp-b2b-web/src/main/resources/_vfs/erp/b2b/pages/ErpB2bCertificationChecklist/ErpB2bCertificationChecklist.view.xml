<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpB2bCertificationChecklist.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="partnerProfileId" label="伙伴档案"/>
                <col id="checklistItem" mandatory="true" sortable="true"/>
                <col id="requiredDocType" sortable="true"/>
                <col id="isMandatory" sortable="true"/>
                <col id="isPassed" sortable="true"/>
                <col id="checkedBy" sortable="true"/>
                <col id="checkedAt" sortable="true"/>
                <col id="evidence" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerProfileId[伙伴档案]
=========>detail[检查项详情]======
 checklistItem[检查项] requiredDocType[对应文档类型]
 isMandatory[必检]
=========>result[检查结果]======
 isPassed[通过] checkedBy[检查人]
 checkedAt[检查时间] evidence[检查证据]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 partnerProfileId[伙伴档案]
=========>detail[检查项详情]======
 checklistItem[检查项] requiredDocType[对应文档类型]
 isMandatory[必检]
=========>result[检查结果]======
 isPassed[通过] checkedBy[检查人]
 checkedAt[检查时间] evidence[检查证据]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 partnerProfileId[伙伴档案] checklistItem[检查项]
 isMandatory[必检] isPassed[通过]
            </layout>
            <cells>
                <cell id="partnerProfileId" filterOp="eq"/>
                <cell id="checklistItem" filterOp="like"/>
                <cell id="isMandatory" filterOp="eq"/>
                <cell id="isPassed" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>