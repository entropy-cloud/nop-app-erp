<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 采购域服务（非 BizModel）：入库移动单请求构造器 -->
    <bean id="app.erp.pur.service.entity.ReceiveStockMoveBuilder"
          class="app.erp.pur.service.entity.ReceiveStockMoveBuilder"/>

    <!-- 采购域服务（非 BizModel）：退货出库移动单请求构造器（OUTGOING，sourceWarehouse=退货仓库） -->
    <bean id="app.erp.pur.service.entity.ReturnStockMoveBuilder"
          class="app.erp.pur.service.entity.ReturnStockMoveBuilder"/>

    <!-- 采购域服务（非 BizModel）：退货数量上限校验器（按入库行聚合已审核退货量） -->
    <bean id="app.erp.pur.service.entity.ReturnQtyValidator"
          class="app.erp.pur.service.entity.ReturnQtyValidator"/>

    <!-- 采购域服务（非 BizModel）：请购→订单转化组装器 -->
    <bean id="app.erp.pur.service.entity.RequisitionToOrderConverter"
          class="app.erp.pur.service.entity.RequisitionToOrderConverter"/>

    <!-- 采购域服务（非 BizModel）：三单匹配器（发票审核校验 订单↔入库↔发票） -->
    <bean id="app.erp.pur.service.entity.ThreeWayMatcher"
          class="app.erp.pur.service.entity.ThreeWayMatcher"/>

    <!-- 采购业财过账 Provider（注册为 Bean 后由 ErpFinAcctDocRegistry 自动聚合，处理 AP_INVOICE/PAYMENT） -->
    <bean id="app.erp.pur.service.posting.PurAcctDocProvider"
          class="app.erp.pur.service.posting.PurAcctDocProvider"/>

    <!-- 采购过账执行器（跨域经 IErpFinVoucherBiz Facade，REQUIRES_NEW 由 Facade 承接，自身无 @Transactional） -->
    <bean id="app.erp.pur.service.posting.PurPostingExecutor"
          class="app.erp.pur.service.posting.PurPostingExecutor"/>

    <!-- 采购发票过账派发器（APPROVED→AP_INVOICE 凭证；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.pur.service.posting.PurInvoicePostingDispatcher"
          class="app.erp.pur.service.posting.PurInvoicePostingDispatcher"/>

    <!-- 采购退货过账派发器（APPROVED→PURCHASE_RETURN 红字冲减凭证 借暂估应付/贷存货；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.pur.service.posting.PurReturnPostingDispatcher"
          class="app.erp.pur.service.posting.PurReturnPostingDispatcher"/>

    <!-- 付款单过账派发器（APPROVED→PAYMENT 凭证 借应付/贷银行存款；失败吞异常保持终态 posted=false） -->
    <bean id="app.erp.pur.service.posting.PurPaymentPostingDispatcher"
          class="app.erp.pur.service.posting.PurPaymentPostingDispatcher"/>

    <!-- 付款→发票域级核销器（ErpPurPaymentLine 多对多，回写 paidStatus/paidAmount/writtenOffStatus） -->
    <bean id="app.erp.pur.service.entity.PaymentSettler"
          class="app.erp.pur.service.entity.PaymentSettler"/>

    <!-- 采购域审批状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖） -->
    <bean id="app.erp.pur.service.processor.ErpPurOrderProcessor"
          class="app.erp.pur.service.processor.ErpPurOrderProcessor"/>
    <bean id="app.erp.pur.service.processor.ErpPurRequisitionProcessor"
          class="app.erp.pur.service.processor.ErpPurRequisitionProcessor"/>
    <bean id="app.erp.pur.service.processor.ErpPurReceiveProcessor"
          class="app.erp.pur.service.processor.ErpPurReceiveProcessor"/>
    <bean id="app.erp.pur.service.processor.ErpPurReturnProcessor"
          class="app.erp.pur.service.processor.ErpPurReturnProcessor"/>
    <bean id="app.erp.pur.service.processor.ErpPurInvoiceProcessor"
          class="app.erp.pur.service.processor.ErpPurInvoiceProcessor"/>
    <bean id="app.erp.pur.service.processor.ErpPurPaymentProcessor"
          class="app.erp.pur.service.processor.ErpPurPaymentProcessor"/>

    <!-- 供应商评分卡周期评分计算器（criteria×formula×weight→totalScore→standing，公式经 XLang 表达式） -->
    <bean id="app.erp.pur.service.entity.ScorecardCalculator"
          class="app.erp.pur.service.entity.ScorecardCalculator"/>

    <!-- 评分卡 standing=RED → AVL SUSPENDED 跨域联动桥（purchase→master-data I*Biz，下游可派生覆盖联动策略） -->
    <bean id="app.erp.pur.service.ScorecardStandingLinker"
          class="app.erp.pur.service.ScorecardStandingLinker"/>

    <!-- 供应商询价/报价准入资格校验器（AVL 准入状态 + 评分 standing 三档联动 prevent/warn/allow） -->
    <bean id="app.erp.pur.service.SupplierEligibilityChecker"
          class="app.erp.pur.service.SupplierEligibilityChecker"/>
</beans>