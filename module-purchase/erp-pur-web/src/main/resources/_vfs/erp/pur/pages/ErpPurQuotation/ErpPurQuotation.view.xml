<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPurQuotation.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 rfqId[询价单] supplierId[供应商]
 businessDate[报价日期] validFrom[生效日]
 validTo[失效日]
=========>amount[币种与汇率]======
 currencyId[币种] exchangeRate[汇率]
=========>status[状态信息]======
 isAccepted[是否中标] docStatus[单据状态]
 approveStatus[审核状态]
=========^audit[审计信息]=========
 remark[备注]
 approvedBy[审核人] approvedAt[审核时间]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 rfqId[询价单] supplierId[供应商]
 businessDate[报价日期] validFrom[生效日]
 validTo[失效日]
=========>amount[币种与汇率]======
 currencyId[币种] exchangeRate[汇率]
=========>status[状态信息]======
 isAccepted[是否中标] docStatus[单据状态]
 approveStatus[审核状态]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] supplierId[供应商]
 docStatus[单据状态] approveStatus[审核状态]
 businessDate[报价日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="supplierId" filterOp="eq"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="approveStatus" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpPurQuotation__submitForApproval?id=$id"/>
                    <confirmText>确认提交此报价单？</confirmText>
                    <messages>
                        <success>报价单已提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-accept-button" label="中标" level="success" icon="fa fa-trophy">
                    <api url="@mutation:ErpPurQuotation__approve?id=$id"/>
                    <confirmText>确认此报价单中标？</confirmText>
                    <messages>
                        <success>报价单已标记为中标</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="未中标" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpPurQuotation__reject?id=$id"/>
                    <confirmText>确认此报价单未中标？</confirmText>
                    <messages>
                        <success>报价单已标记为未中标</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpPurQuotation__cancel?quotationId=$id"/>
                    <confirmText>确认作废此报价单？</confirmText>
                    <messages>
                        <success>报价单已作废</success>
                    </messages>
                    <visibleOn>${docStatus != 'CANCELLED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>