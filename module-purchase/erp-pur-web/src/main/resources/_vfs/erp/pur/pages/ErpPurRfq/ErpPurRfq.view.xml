<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPurRfq.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 requisitionId[请购单] businessDate[询价日期]
 validUntil[报价截止日]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
=========^audit[审计信息]=========
 remark[备注]
 approvedBy[审核人] approvedAt[审核时间]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 requisitionId[请购单] businessDate[询价日期]
 validUntil[报价截止日]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] docStatus[单据状态]
 approveStatus[审核状态] businessDate[询价日期]
 orgId[业务组织]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="approveStatus" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="发布" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpPurRfq__submitForApproval?id=$id"/>
                    <confirmText>确认发布此询价单？</confirmText>
                    <messages>
                        <success>询价单已发布</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="比价完成" level="success" icon="fa fa-trophy">
                    <api url="@mutation:ErpPurRfq__approve?id=$id"/>
                    <confirmText>确认完成此询价单比价？</confirmText>
                    <messages>
                        <success>询价单比价已完成</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="流标" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpPurRfq__reject?id=$id"/>
                    <confirmText>确认流标此询价单？</confirmText>
                    <messages>
                        <success>询价单已流标</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpPurRfq__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此询价单？</confirmText>
                    <messages>
                        <success>询价单已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpPurRfq__cancel?id=$id"/>
                    <confirmText>确认作废此询价单？</confirmText>
                    <messages>
                        <success>询价单已作废</success>
                    </messages>
                    <visibleOn>${docStatus != 'CANCELLED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>