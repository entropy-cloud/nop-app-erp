<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPurReturnLine.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="物料名称"/>
                <col id="quantity" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="taxAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="reason" sortable="true"/>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'materialId',
                                label: '物料',
                                required: true,
                                source: '/erp/md/pages/ErpMdMaterial/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="uoMId" mandatory="true"/>
                <col id="quantity" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'quantity',
                                required: true,
                                step: 1,
                                validations: { minimum: 0.0001 },
                                validationErrors: { minimum: '数量必须大于 0' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        amount: '${ROUND(quantity * unitPrice, 4)}',
                                                        taxAmount: '${ROUND(quantity * unitPrice * taxRate / 100, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'unitPrice',
                                required: true,
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '单价不能为负' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        amount: '${ROUND(quantity * unitPrice, 4)}',
                                                        taxAmount: '${ROUND(quantity * unitPrice * taxRate / 100, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount"/>
                <col id="taxRate">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'taxRate',
                                step: 0.01,
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        taxAmount: '${ROUND(quantity * unitPrice * taxRate / 100, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="taxAmount"/>
                <col id="reason"/>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId"/>
                <col id="uoMId"/>
                <col id="quantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitPrice" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="amount" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="taxRate" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="taxAmount" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="reason"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
=========>quantity[数量与价格]======
 quantity[数量] unitPrice[单价]
 amount[金额(不含税)] reason[退货原因]
=========>tax[税务信息]======
 taxRate[税率(%)] taxAmount[税额]
=========>reference[业务关联]======
 returnId[退货单ID] receiveLineId[入库行ID]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
=========>quantity[数量与价格]======
 quantity[数量] unitPrice[单价]
 amount[金额(不含税)] reason[退货原因]
=========>tax[税务信息]======
 taxRate[税率(%)] taxAmount[税额]
=========>reference[业务关联]======
 returnId[退货单ID] receiveLineId[入库行ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 returnId[退货单ID] receiveLineId[入库行ID]
 reason[退货原因]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="returnId" filterOp="eq"/>
                <cell id="receiveLineId" filterOp="eq"/>
                <cell id="reason" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>