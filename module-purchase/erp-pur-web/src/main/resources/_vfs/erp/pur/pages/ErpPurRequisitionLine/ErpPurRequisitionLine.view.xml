<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPurRequisitionLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="物料名称"/>
                <col id="quantity" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="requiredDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>quantity[数量与需求]======
 quantity[数量] requiredDate[需求日期]
 suggestedSupplierId[建议供应商] projectId[项目]
=========>reference[业务关联]======
 requisitionId[请购单ID]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 uoMId[计量单位]
=========>quantity[数量与需求]======
 quantity[数量] requiredDate[需求日期]
 suggestedSupplierId[建议供应商] projectId[项目]
=========>reference[业务关联]======
 requisitionId[请购单ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 requisitionId[请购单ID] suggestedSupplierId[建议供应商]
 requiredDate[需求日期]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="requisitionId" filterOp="eq"/>
                <cell id="suggestedSupplierId" filterOp="eq"/>
                <cell id="requiredDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>