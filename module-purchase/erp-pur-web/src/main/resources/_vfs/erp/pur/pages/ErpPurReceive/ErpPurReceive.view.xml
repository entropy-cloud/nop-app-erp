<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpPurReceive.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="supplierName" label="供应商"/>
                <col id="warehouseName" label="入库仓库"/>
                <col id="currencyName" label="币种"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="totalAmountWithTax" sortable="true"/>
                <col id="receiveStatus" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpPurReceive__submitForApproval?id=$id"/>
                    <confirmText>确认提交此采购入库单审批？</confirmText>
                    <messages>
                        <success>采购入库单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpPurReceive__approve?id=$id"/>
                    <confirmText>确认批准此采购入库单？</confirmText>
                    <messages>
                        <success>采购入库单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpPurReceive__reject?id=$id"/>
                    <confirmText>确认驳回此采购入库单？</confirmText>
                    <messages>
                        <success>采购入库单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>