<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpPurReceive" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/pur/model/ErpPurReceive/ErpPurReceive.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--采购订单-->
                <col id="orderId" ui:number="true" sortable="true"/>

                <!--供应商-->
                <col id="supplierId" mandatory="true" ui:number="true" sortable="true"/>

                <!--入库仓库-->
                <col id="warehouseId" mandatory="true" ui:number="true" sortable="true"/>

                <!--入库日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" mandatory="true" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" ui:number="true" sortable="true"/>

                <!--合计金额(源币)-->
                <col id="amountSource" ui:number="true" sortable="true"/>

                <!--合计金额(本位币)-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>

                <!--合计金额(不含税)-->
                <col id="totalAmount" ui:number="true" sortable="true"/>

                <!--合计税额-->
                <col id="totalTaxAmount" ui:number="true" sortable="true"/>

                <!--合计金额(含税)-->
                <col id="totalAmountWithTax" ui:number="true" sortable="true"/>

                <!--收货状态-->
                <col id="receiveStatus" sortable="true"/>

                <!--入库类型-->
                <col id="receiveType" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" mandatory="true" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--审核人-->
                <col id="approvedBy" sortable="true"/>

                <!--审核时间-->
                <col id="approvedAt" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--供应商名称-->
                <col id="supplierName"/>

                <!--入库仓库名称-->
                <col id="warehouseName"/>

                <!--币种名称-->
                <col id="currencyName"/>

                <!--业务组织名称-->
                <col id="orgName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-采购入库单" i18n-en:title="View Purchase Receipt">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] orderId[采购订单]
 supplierId[供应商] warehouseId[入库仓库]
 businessDate[入库日期] currencyId[币种]
 exchangeRate[汇率] amountSource[合计金额(源币)]
 amountFunctional[合计金额(本位币)] totalAmount[合计金额(不含税)]
 totalTaxAmount[合计税额] totalAmountWithTax[合计金额(含税)]
 receiveStatus[收货状态] receiveType[入库类型]
 docStatus[单据状态] approveStatus[审核状态]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] approvedBy[审核人]
 approvedAt[审核时间] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] supplierName[供应商名称]
 warehouseName[入库仓库名称] currencyName[币种名称]
 orgName[业务组织名称] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-采购入库单" i18n-en:title="Add Purchase Receipt" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-采购入库单" i18n-en:title="Edit Purchase Receipt">
            <layout>
 id[ID] code[单号]
 orgId[业务组织] orderId[采购订单]
 supplierId[供应商] warehouseId[入库仓库]
 businessDate[入库日期] currencyId[币种]
 exchangeRate[汇率] amountSource[合计金额(源币)]
 amountFunctional[合计金额(本位币)] totalAmount[合计金额(不含税)]
 totalTaxAmount[合计税额] totalAmountWithTax[合计金额(含税)]
 receiveStatus[收货状态] receiveType[入库类型]
 docStatus[单据状态] approveStatus[审核状态]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-采购入库单"
              i18n-en:title="Update Purchase Receipt"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPurReceive__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpPurReceive__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpPurReceive__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpPurReceive__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpPurReceive__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpPurReceive__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpPurReceive__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpPurReceive__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpPurReceive__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpPurReceive__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>