        </prop>
        <prop name="batchNo" displayName="批号" propId="8" i18n-en:displayName="Batch No" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="reservedQuantity" displayName="预留数量" propId="9" i18n-en:displayName="Reserved Quantity"
              mandatory="true" queryable="true" sortable="true" insertable="true" updatable="true">
            <schema domain="quantity" type="java.math.BigDecimal" precision="20" scale="4"/>
        </prop>
        <prop name="consumedQuantity" displayName="已消耗数量" propId="10" i18n-en:displayName="Consumed Quantity"
              queryable="true" sortable="true" insertable="true" updatable="true" defaultValue="0">
            <schema domain="quantity" type="java.math.BigDecimal" precision="20" scale="4"/>
        </prop>
        <prop name="uomId" displayName="计量单位" propId="11" i18n-en:displayName="Uom" mandatory="true" queryable="true"
