<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvStockMove.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="moveType" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="sourceWarehouseId" label="源仓库"/>
                <col id="destWarehouseId" label="目标仓库"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] moveType[作业类型]
 orgId[业务组织] businessDate[业务日期]
 docStatus[单据状态] approveStatus[审核状态]
==========>warehouse[仓库信息]======
 sourceWarehouseId[源仓库] sourceLocationId[源库位]
 destWarehouseId[目标仓库] destLocationId[目标库位]
==========>reference[关联信息]======
 relatedBillType[关联单据类型] relatedBillCode[关联单据号]
 originMoveId[上游移动单] originReturnedMoveId[原退货移动单]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] moveType[作业类型]
 orgId[业务组织] businessDate[业务日期]
 docStatus[单据状态] approveStatus[审核状态]
==========>warehouse[仓库信息]======
 sourceWarehouseId[源仓库] sourceLocationId[源库位]
 destWarehouseId[目标仓库] destLocationId[目标库位]
==========>reference[关联信息]======
 relatedBillType[关联单据类型] relatedBillCode[关联单据号]
 originMoveId[上游移动单] originReturnedMoveId[原退货移动单]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] moveType[作业类型]
 docStatus[单据状态] businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-confirm-button" label="提交确认" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpInvStockMove__confirm?moveId=$id"/>
                    <confirmText>确认提交此库存移动单？</confirmText>
                    <messages>
                        <success>库存移动单已确认</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-complete-button" label="执行完成" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpInvStockMove__complete?moveId=$id"/>
                    <confirmText>确认完成此库存移动单？</confirmText>
                    <messages>
                        <success>库存移动单已完成</success>
                    </messages>
                    <visibleOn>${docStatus == 'CONFIRMED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpInvStockMove__cancel?moveId=$id"/>
                    <confirmText>确认作废此库存移动单？</confirmText>
                    <messages>
                        <success>库存移动单已作废</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT' || docStatus == 'CONFIRMED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>