<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpInvStockLedger" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/inv/model/ErpInvStockLedger/ErpInvStockLedger.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--流水号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--移动单ID-->
                <col id="moveId" mandatory="true" ui:number="true" sortable="true"/>

                <!--移动单行ID-->
                <col id="moveLineId" mandatory="true" ui:number="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--SKU-->
                <col id="skuId" ui:number="true" sortable="true"/>

                <!--仓库-->
                <col id="warehouseId" mandatory="true" ui:number="true" sortable="true"/>

                <!--库位-->
                <col id="locationId" ui:number="true" sortable="true"/>

                <!--数量-->
                <col id="quantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--单位成本-->
                <col id="unitCost" ui:number="true" sortable="true"/>

                <!--总成本-->
                <col id="totalCost" ui:number="true" sortable="true"/>

                <!--结存数量-->
                <col id="balanceQuantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--结存总成本-->
                <col id="balanceTotalCost" mandatory="true" ui:number="true" sortable="true"/>

                <!--计价方法-->
                <col id="costMethod" sortable="true"/>

                <!--账套-->
                <col id="acctSchemaId" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" sortable="true"/>

                <!--批号-->
                <col id="batchNo" sortable="true"/>

                <!--序列号-->
                <col id="serialNo" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--所有权往来单位-->
                <col id="ownerId" ui:number="true" sortable="true"/>

                <!--所有权类型-->
                <col id="ownershipType" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-库存流水" i18n-en:title="View Stock Ledger">
            <layout>
 id[ID] code[流水号]
 orgId[业务组织] moveId[移动单ID]
 moveLineId[移动单行ID] materialId[物料]
 skuId[SKU] warehouseId[仓库]
 locationId[库位] quantity[数量]
 unitCost[单位成本] totalCost[总成本]
 balanceQuantity[结存数量] balanceTotalCost[结存总成本]
 costMethod[计价方法] acctSchemaId[账套]
 currencyId[币种] businessDate[业务日期]
 batchNo[批号] serialNo[序列号]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] ownerId[所有权往来单位]
 ownershipType[所有权类型] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-库存流水" i18n-en:title="Add Stock Ledger" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-库存流水" i18n-en:title="Edit Stock Ledger">
            <layout>
 id[ID] code[流水号]
 orgId[业务组织] moveId[移动单ID]
 moveLineId[移动单行ID] materialId[物料]
 skuId[SKU] warehouseId[仓库]
 locationId[库位] quantity[数量]
 unitCost[单位成本] totalCost[总成本]
 balanceQuantity[结存数量] balanceTotalCost[结存总成本]
 costMethod[计价方法] acctSchemaId[账套]
 currencyId[币种] businessDate[业务日期]
 batchNo[批号] serialNo[序列号]
 ownerId[所有权往来单位] ownershipType[所有权类型]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-库存流水" i18n-en:title="Update Stock Ledger"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvStockLedger__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvStockLedger__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpInvStockLedger__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpInvStockLedger__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpInvStockLedger__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpInvStockLedger__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpInvStockLedger__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpInvStockLedger__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpInvStockLedger__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpInvStockLedger__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>