<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvSerialNumber.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 serialNo[序列号] materialId[物料]
 status[状态] warehouseId[当前仓库]
            </layout>
            <cells>
                <cell id="serialNo" filterOp="like"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="warehouseId" filterOp="eq"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 serialNo[序列号]
            </layout>
            <cells>
                <cell id="serialNo" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
