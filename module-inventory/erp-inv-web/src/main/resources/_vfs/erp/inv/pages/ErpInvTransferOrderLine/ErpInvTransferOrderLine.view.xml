<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvTransferOrderLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'materialId',
                                label: '物料',
                                required: true,
                                source: '/erp/md/pages/ErpMdMaterial/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="uoMId" mandatory="true"/>
                <col id="quantity" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'quantity',
                                required: true,
                                step: 1,
                                validations: { minimum: 0.0001 },
                                validationErrors: { minimum: '数量必须大于 0' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="batchNo"/>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId"/>
                <col id="uoMId"/>
                <col id="quantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="batchNo"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
 batchNo[批号]
=========>quantity[数量]======
 quantity[数量]
=========>reference[业务关联]======
 transferId[调拨单ID]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
 batchNo[批号]
=========>quantity[数量]======
 quantity[数量]
=========>reference[业务关联]======
 transferId[调拨单ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 transferId[调拨单ID] batchNo[批号]
 quantity[数量]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="transferId" filterOp="eq"/>
                <cell id="batchNo" filterOp="like"/>
                <cell id="quantity" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>