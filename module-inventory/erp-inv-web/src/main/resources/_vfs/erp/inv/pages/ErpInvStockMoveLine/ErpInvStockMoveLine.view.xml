<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvStockMoveLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="物料名称"/>
                <col id="quantity" mandatory="true" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="batchNo" sortable="true"/>
                <col id="serialNo" sortable="true"/>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'materialId',
                                label: '物料',
                                required: true,
                                source: '/erp/md/pages/ErpMdMaterial/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="uoMId" mandatory="true"/>
                <col id="quantity" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'quantity',
                                required: true,
                                step: 1,
                                validations: { minimum: 0.0001 },
                                validationErrors: { minimum: '数量必须大于 0' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        totalCost: '${ROUND(quantity * unitCost, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitCost">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'unitCost',
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '单位成本不能为负' },
                                onEvent: {
                                    change: {
                                        actions: [
                                            {
                                                actionType: 'setValue',
                                                args: {
                                                    value: {
                                                        totalCost: '${ROUND(quantity * unitCost, 4)}'
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalCost">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'currencyId',
                                label: '币种',
                                source: '/erp/md/pages/ErpMdCurrency/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="sourceLocationId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'sourceLocationId',
                                label: '源库位',
                                source: '/erp/md/pages/ErpMdLocation/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="destLocationId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'destLocationId',
                                label: '目标库位',
                                source: '/erp/md/pages/ErpMdLocation/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="materialId"/>
                <col id="uoMId"/>
                <col id="quantity" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="unitCost" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalCost" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId"/>
                <col id="sourceLocationId"/>
                <col id="destLocationId"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
 batchNo[批号] serialNo[序列号]
=========>quantity[数量与成本]======
 quantity[数量] unitCost[单位成本]
 totalCost[总成本] currencyId[币种]
=========>location[库位信息]======
 sourceLocationId[源库位] destLocationId[目标库位]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] materialId[物料]
 skuId[SKU] uoMId[计量单位]
 batchNo[批号] serialNo[序列号]
=========>quantity[数量与成本]======
 quantity[数量] unitCost[单位成本]
 totalCost[总成本] currencyId[币种]
=========>location[库位信息]======
 sourceLocationId[源库位] destLocationId[目标库位]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] materialId[物料]
 moveId[移动单ID] batchNo[批号]
 sourceLocationId[源库位]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="moveId" filterOp="eq"/>
                <cell id="batchNo" filterOp="like"/>
                <cell id="sourceLocationId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>