<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvStockTake.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 businessDate[业务日期] takeType[盘点类型]
 warehouseId[仓库]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
=========>posting[过账信息]======
 posted[已过账] postedAt[过账时间]
 postedBy[过账人]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 businessDate[业务日期] takeType[盘点类型]
 warehouseId[仓库]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] docStatus[单据状态]
 approveStatus[审核状态] warehouseId[仓库]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="approveStatus" filterOp="eq"/>
                <cell id="warehouseId" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-start-take-button" label="开始盘点" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpInvStockTake__startTake?takeId=$id"/>
                    <confirmText>确认开始此盘点单？</confirmText>
                    <messages>
                        <success>盘点单已开始</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-complete-take-button" label="完成盘点" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpInvStockTake__completeTake?takeId=$id"/>
                    <confirmText>确认完成此盘点单？</confirmText>
                    <messages>
                        <success>盘点单已完成</success>
                    </messages>
                    <visibleOn>${docStatus == 'CONFIRMED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpInvStockTake__cancelTake?takeId=$id"/>
                    <confirmText>确认作废此盘点单？</confirmText>
                    <messages>
                        <success>盘点单已作废</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT' || docStatus == 'CONFIRMED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>