<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvTransferOrder.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 businessDate[业务日期] docStatus[单据状态]
 approveStatus[审核状态]
==========>transfer[调拨信息]======
 fromWarehouseId[调出仓库] toWarehouseId[调入仓库]
 inTransitWarehouseId[在途仓库]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[单号] orgId[业务组织]
 businessDate[业务日期] docStatus[单据状态]
 approveStatus[审核状态]
==========>transfer[调拨信息]======
 fromWarehouseId[调出仓库] toWarehouseId[调入仓库]
 inTransitWarehouseId[在途仓库]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[单号] docStatus[单据状态]
 approveStatus[审核状态] businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-confirm-button" label="确认" level="primary" icon="fa fa-check">
                    <api url="@mutation:ErpInvTransferOrder__confirm?transferOrderId=$id"/>
                    <confirmText>确认审核此调拨单？</confirmText>
                    <messages>
                        <success>调拨单已确认</success>
                    </messages>
                    <visibleOn>${docStatus == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>