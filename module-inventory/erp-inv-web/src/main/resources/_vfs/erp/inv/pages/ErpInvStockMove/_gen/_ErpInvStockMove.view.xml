<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpInvStockMove" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/inv/model/ErpInvStockMove/ErpInvStockMove.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--单号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--作业类型-->
                <col id="moveType" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--源仓库-->
                <col id="sourceWarehouseId" ui:number="true" sortable="true"/>

                <!--源库位-->
                <col id="sourceLocationId" ui:number="true" sortable="true"/>

                <!--目标仓库-->
                <col id="destWarehouseId" ui:number="true" sortable="true"/>

                <!--目标库位-->
                <col id="destLocationId" ui:number="true" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--审核状态-->
                <col id="approveStatus" mandatory="true" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--关联单据类型-->
                <col id="relatedBillType" sortable="true"/>

                <!--关联单据号-->
                <col id="relatedBillCode" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--上游移动单-->
                <col id="originMoveId" ui:number="true" sortable="true"/>

                <!--原退货移动单-->
                <col id="originReturnedMoveId" ui:number="true" sortable="true"/>

                <!--源仓库名称-->
                <col id="sourceWarehouseName"/>

                <!--目标仓库名称-->
                <col id="destWarehouseName"/>

                <!--业务组织名称-->
                <col id="orgName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-库存移动单" i18n-en:title="View Stock Move">
            <layout>
 id[ID] code[单号]
 moveType[作业类型] orgId[业务组织]
 businessDate[业务日期] sourceWarehouseId[源仓库]
 sourceLocationId[源库位] destWarehouseId[目标仓库]
 destLocationId[目标库位] docStatus[单据状态]
 approveStatus[审核状态] posted[已过账]
 postedAt[过账时间] postedBy[过账人]
 relatedBillType[关联单据类型] relatedBillCode[关联单据号]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 originMoveId[上游移动单] originReturnedMoveId[原退货移动单]
 sourceWarehouseName[源仓库名称] destWarehouseName[目标仓库名称]
 orgName[业务组织名称] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-库存移动单" i18n-en:title="Add Stock Move" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-库存移动单" i18n-en:title="Edit Stock Move">
            <layout>
 id[ID] code[单号]
 moveType[作业类型] orgId[业务组织]
 businessDate[业务日期] sourceWarehouseId[源仓库]
 sourceLocationId[源库位] destWarehouseId[目标仓库]
 destLocationId[目标库位] docStatus[单据状态]
 approveStatus[审核状态] relatedBillType[关联单据类型]
 relatedBillCode[关联单据号] remark[备注]
 originMoveId[上游移动单] originReturnedMoveId[原退货移动单]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-库存移动单" i18n-en:title="Update Stock Move"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvStockMove__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvStockMove__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpInvStockMove__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpInvStockMove__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpInvStockMove__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpInvStockMove__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpInvStockMove__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpInvStockMove__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpInvStockMove__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpInvStockMove__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>