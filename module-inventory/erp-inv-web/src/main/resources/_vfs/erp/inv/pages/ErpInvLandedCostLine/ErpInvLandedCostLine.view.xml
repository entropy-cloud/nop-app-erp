<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvLandedCostLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>

        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="costElement" mandatory="true"/>
                <col id="amount" mandatory="true">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-number',
                                name: 'amount',
                                required: true,
                                step: 0.0001,
                                validations: { minimum: 0 },
                                validationErrors: { minimum: '金额不能为负' }
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="apPartnerId">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'picker',
                                name: 'apPartnerId',
                                label: '应付往来',
                                source: '/erp/md/pages/ErpMdPartner/picker.page.yaml',
                                valueField: 'id',
                                labelField: 'name',
                                joinValues: false,
                                extractValue: true
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark"/>
            </cols>
        </grid>

        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols x:override="bounded-merge">
                <col id="lineNo" mandatory="true" ui:number="true"/>
                <col id="costElement"/>
                <col id="amount" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="apPartnerId"/>
                <col id="remark"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] costElement[成本要素]
=========>amount[金额信息]======
 amount[金额] apPartnerId[应付往来]
=========>reference[业务关联]======
 landedCostId[到岸成本单ID]
=========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] costElement[成本要素]
=========>amount[金额信息]======
 amount[金额] apPartnerId[应付往来]
=========>reference[业务关联]======
 landedCostId[到岸成本单ID]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] costElement[成本要素]
 landedCostId[到岸成本单ID] apPartnerId[应付往来]
 amount[金额]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="costElement" filterOp="eq"/>
                <cell id="landedCostId" filterOp="eq"/>
                <cell id="apPartnerId" filterOp="eq"/>
                <cell id="amount" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>