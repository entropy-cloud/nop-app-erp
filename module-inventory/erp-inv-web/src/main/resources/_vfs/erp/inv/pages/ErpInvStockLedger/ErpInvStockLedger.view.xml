<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvStockLedger.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 materialId[物料] warehouseId[仓库]
 costMethod[计价方法] ownershipType[所有权类型]
 businessDate[业务日期] batchNo[批号]
            </layout>
            <cells>
                <cell id="materialId" filterOp="eq"/>
                <cell id="warehouseId" filterOp="eq"/>
                <cell id="costMethod" filterOp="eq"/>
                <cell id="ownershipType" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
                <cell id="batchNo" filterOp="like"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[流水号]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
