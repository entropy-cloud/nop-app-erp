<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 库存域服务（非 BizModel）：记账器 + 存货过账派发器/执行器 + 存货估值 Provider -->
    <bean id="app.erp.inv.service.stock.StockMoveBookkeeper"
          class="app.erp.inv.service.stock.StockMoveBookkeeper"/>

    <!-- 成本方法策略分派（plan 2026-07-02-1538-1） -->
    <bean id="app.erp.inv.service.costing.CostMethodResolver"
          class="app.erp.inv.service.costing.CostMethodResolver"/>
    <bean id="app.erp.inv.service.costing.MovingAverageCostingStrategy"
          class="app.erp.inv.service.costing.MovingAverageCostingStrategy"/>
    <bean id="app.erp.inv.service.costing.FifoCostingStrategy"
          class="app.erp.inv.service.costing.FifoCostingStrategy"/>
    <!-- STANDARD 计价（plan 2026-07-05-0427-2） -->
    <bean id="app.erp.inv.service.costing.StandardCostResolver"
          class="app.erp.inv.service.costing.StandardCostResolver"/>
    <bean id="app.erp.inv.service.costing.StandardCostingStrategy"
          class="app.erp.inv.service.costing.StandardCostingStrategy"/>

    <!-- 存货成本核算服务 BizModel（plan 2026-07-02-1538-1 Phase 3）：期末成本兜底重算，经 IBizObjectManager 跨模块调用 -->
    <bean id="app.erp.inv.service.costing.ErpInvCostingBizModel"
          class="app.erp.inv.service.costing.ErpInvCostingBizModel"/>

    <bean id="app.erp.inv.service.posting.InvPostingDispatcher"
          class="app.erp.inv.service.posting.InvPostingDispatcher"/>

    <bean id="app.erp.inv.service.posting.InvPostingExecutor"
          class="app.erp.inv.service.posting.InvPostingExecutor"/>

    <bean id="app.erp.inv.service.posting.InvAcctDocProvider"
          class="app.erp.inv.service.posting.InvAcctDocProvider"/>

    <!-- 采购价差 Provider（STANDARD 计价，plan 2026-07-05-0427-2） -->
    <bean id="app.erp.inv.service.posting.PurchasePriceVarianceAcctDocProvider"
          class="app.erp.inv.service.posting.PurchasePriceVarianceAcctDocProvider"/>

    <!-- 成本调整（plan 2026-07-05-2352-3）：引擎 + 派发器 + Provider + Processor -->
    <bean id="app.erp.inv.service.costing.CostAdjustmentService"
          class="app.erp.inv.service.costing.CostAdjustmentService"/>
    <bean id="app.erp.inv.service.posting.CostAdjustmentPostingDispatcher"
          class="app.erp.inv.service.posting.CostAdjustmentPostingDispatcher"/>
    <bean id="app.erp.inv.service.posting.CostAdjustmentAcctDocProvider"
          class="app.erp.inv.service.posting.CostAdjustmentAcctDocProvider"/>
    <bean id="app.erp.inv.service.processor.ErpInvCostAdjustProcessor"
          class="app.erp.inv.service.processor.ErpInvCostAdjustProcessor"/>

    <!-- 到岸成本（plan 2026-07-10-1100-3）：分摊引擎 + Processor -->
    <bean id="app.erp.inv.service.costing.LandedCostAllocationEngine"
          class="app.erp.inv.service.costing.LandedCostAllocationEngine"/>
    <bean id="app.erp.inv.service.processor.ErpInvLandedCostProcessor"
          class="app.erp.inv.service.processor.ErpInvLandedCostProcessor"/>

    <!-- 到岸成本过账（plan 2026-07-10-1100-3）：派发器 + Provider -->
    <bean id="app.erp.inv.service.posting.LandedCostPostingDispatcher"
          class="app.erp.inv.service.posting.LandedCostPostingDispatcher"/>
    <bean id="app.erp.inv.service.posting.LandedCostAcctDocProvider"
          class="app.erp.inv.service.posting.LandedCostAcctDocProvider"/>

    <!-- 所有权转移过账（consignment.md §业财过账，plan 2026-07-04-0549-1） -->
    <bean id="app.erp.inv.service.posting.OwnershipTransferPostingDispatcher"
          class="app.erp.inv.service.posting.OwnershipTransferPostingDispatcher"/>

    <bean id="app.erp.inv.service.posting.InvOwnershipTransferProvider"
          class="app.erp.inv.service.posting.InvOwnershipTransferProvider"/>

    <!-- 库存域凭证红冲监听者（业财闭环方向二：财务侧红冲→库存单据回退 posted=false）。
         注册为 Bean 后由 finance ErpFinReversalListenerRegistry 自动聚合，处理 OWNERSHIP_TRANSFER/INTER_TRANSFER。 -->
    <bean id="app.erp.inv.service.posting.InvReversalListener"
          class="app.erp.inv.service.posting.InvReversalListener"/>

    <!-- 所有权转移单状态机/同库位调账编排 Processor -->
    <bean id="app.erp.inv.service.processor.ErpInvOwnershipTransferProcessor"
          class="app.erp.inv.service.processor.ErpInvOwnershipTransferProcessor"/>

    <!-- 库存追溯链查询助手（只读，基于移动单自追溯上链） -->
    <bean id="app.erp.inv.service.trace.TraceChainQuery"
          class="app.erp.inv.service.trace.TraceChainQuery"/>

    <!-- 库存移动单状态机/跨域契约编排 Processor（processor-extension-pattern Facade + Processor） -->
    <bean id="app.erp.inv.service.processor.ErpInvStockMoveProcessor"
          class="app.erp.inv.service.processor.ErpInvStockMoveProcessor"/>

    <!-- 库存看板聚合入口（plan 2026-07-06-0935-1）：非实体 BizModel，注入 IDaoProvider/IOrmTemplate，
         经 @BizQuery 暴露 getDashboardKpi/getDashboardTrend/findWarehouseDistribution/findShortageAlert/
         findSlowMovingAlert/findBatchExpiryAlert。 -->
    <bean id="app.erp.inv.service.dashboard.ErpInvDashboardBizModel" ioc:type="@bean:id"/>

    <!-- 库存域报表渲染入口（plan 2026-07-06-1247-1）：非实体 BizModel，注入平台 IReportEngine，
         经 @BizQuery 暴露 renderHtml/download。@BizModel 注解由 bizObject 管理器自动识别。
         镜像 finance ErpFinReportBizModel / manufacturing ErpMfgReportBizModel（域隔离 /inv/ vs /fin/ vs /mfg/）。 -->
    <bean id="app.erp.inv.service.report.ErpInvReportBizModel" ioc:type="@bean:id"/>
</beans>
