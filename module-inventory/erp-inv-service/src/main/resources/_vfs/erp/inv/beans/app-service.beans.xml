<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 库存域服务（非 BizModel）：记账器 + 存货过账派发器/执行器 + 存货估值 Provider -->
    <bean id="app.erp.inv.service.stock.StockMoveBookkeeper"
          class="app.erp.inv.service.stock.StockMoveBookkeeper"/>

    <!-- 成本方法策略分派（plan 2026-07-02-1538-1） -->
    <bean id="app.erp.inv.service.costing.CostMethodResolver"
          class="app.erp.inv.service.costing.CostMethodResolver"/>
    <bean id="app.erp.inv.service.costing.MovingAverageCostingStrategy"
          class="app.erp.inv.service.costing.MovingAverageCostingStrategy"/>
    <bean id="app.erp.inv.service.costing.FifoCostingStrategy"
          class="app.erp.inv.service.costing.FifoCostingStrategy"/>

    <!-- 存货成本核算服务 BizModel（plan 2026-07-02-1538-1 Phase 3）：期末成本兜底重算，经 IBizObjectManager 跨模块调用 -->
    <bean id="app.erp.inv.service.costing.ErpInvCostingBizModel"
          class="app.erp.inv.service.costing.ErpInvCostingBizModel"/>

    <bean id="app.erp.inv.service.posting.InvPostingDispatcher"
          class="app.erp.inv.service.posting.InvPostingDispatcher"/>

    <bean id="app.erp.inv.service.posting.InvPostingExecutor"
          class="app.erp.inv.service.posting.InvPostingExecutor"/>

    <bean id="app.erp.inv.service.posting.InvAcctDocProvider"
          class="app.erp.inv.service.posting.InvAcctDocProvider"/>

    <!-- 库存追溯链查询助手（只读，基于移动单自追溯上链） -->
    <bean id="app.erp.inv.service.trace.TraceChainQuery"
          class="app.erp.inv.service.trace.TraceChainQuery"/>

    <!-- 库存移动单状态机/跨域契约编排 Processor（processor-extension-pattern Facade + Processor） -->
    <bean id="app.erp.inv.service.processor.ErpInvStockMoveProcessor"
          class="app.erp.inv.service.processor.ErpInvStockMoveProcessor"/>
</beans>
