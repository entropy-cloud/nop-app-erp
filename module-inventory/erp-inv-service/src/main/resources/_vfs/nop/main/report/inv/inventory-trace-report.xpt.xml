<?xml version="1.0" encoding="UTF-8" ?>
<!-- 库存追溯可视化报表（种子报表）。数据集 ds 由 ErpInvReportBizModel.buildInventoryTraceDataset 注入，
     每行 {moveId, moveCode, moveType, businessDate, sourceWarehouseId, destWarehouseId, docStatus,
          originMoveId, originReturnedMoveId, isReturn, materialId, batchNos, quantity, traceType}。
     口径对齐 docs/design/inventory/trace-chain.md §追溯链查询：移动单自追溯链（originMoveId 正向 +
     originReturnedMoveId 退货），退货行高亮。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="inv-trace" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="90.0"/>
                    <col width="110.0"/>
                    <col width="70.0"/>
                    <col width="80.0"/>
                    <col width="70.0"/>
                    <col width="70.0"/>
                    <col width="60.0"/>
                    <col width="80.0"/>
                    <col width="90.0"/>
                    <col width="80.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="9" styleId="title"><model/><value>库存追溯链可视化报表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>移动单号</value></cell>
                            <cell styleId="header"><model/><value>作业类型</value></cell>
                            <cell styleId="header"><model/><value>业务日期</value></cell>
                            <cell styleId="header"><model/><value>源仓库</value></cell>
                            <cell styleId="header"><model/><value>目标仓库</value></cell>
                            <cell styleId="header"><model/><value>状态</value></cell>
                            <cell styleId="header"><model/><value>数量</value></cell>
                            <cell styleId="header"><model/><value>批次号</value></cell>
                            <cell styleId="header"><model/><value>上游移动单</value></cell>
                            <cell styleId="header"><model/><value>退货</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="cell">
                                <model ds="ds" expandType="r" field="moveCode"/>
                                <value>*=^ds!moveCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=moveType</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=businessDate</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=sourceWarehouseId</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=destWarehouseId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=docStatus</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=quantity</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=batchNos</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=originMoveId</value>
                            </cell>
                            <cell styleId="alert">
                                <model rowParent="A3"/>
                                <value>*=isReturn</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="alert" fillPattern="solid" fillBgColor="FFFFCDD2" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
