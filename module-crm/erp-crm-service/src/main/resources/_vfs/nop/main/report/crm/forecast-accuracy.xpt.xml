<?xml version="1.0" encoding="UTF-8" ?>
<!-- 销售预测准确率报表（种子报表）。数据集 ds 由 ErpCrmReportBizModel.buildForecastAccuracyDataset 注入，
     每行 {forecastId, periodId, commitAmount, weightedAmount, bestCaseAmount, expectedClosedRevenue,
     opportunityCount, lineCount, lineWeightedRevenue}。口径对齐 docs/design/crm/sales-forecast.md：
     预测 commit/weighted/bestCase vs 行级加权收入合计。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="forecast-accuracy" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="90.0"/>
                    <col width="80.0"/>
                    <col width="100.0"/>
                    <col width="100.0"/>
                    <col width="100.0"/>
                    <col width="120.0"/>
                    <col width="80.0"/>
                    <col width="70.0"/>
                    <col width="120.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="8" styleId="title"><model/><value>销售预测准确率表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>预测ID</value></cell>
                            <cell styleId="header"><model/><value>期间ID</value></cell>
                            <cell styleId="header"><model/><value>承诺金额</value></cell>
                            <cell styleId="header"><model/><value>加权金额</value></cell>
                            <cell styleId="header"><model/><value>最佳案例</value></cell>
                            <cell styleId="header"><model/><value>期望结转收入</value></cell>
                            <cell styleId="header"><model/><value>机会数</value></cell>
                            <cell styleId="header"><model/><value>预测行数</value></cell>
                            <cell styleId="header"><model/><value>行加权收入合计</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="forecastId"/>
                                <value>*=^ds!forecastId</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=periodId</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=commitAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=weightedAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=bestCaseAmount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=expectedClosedRevenue</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=opportunityCount</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=lineCount</value>
                            </cell>
                            <cell styleId="alert">
                                <model rowParent="A3"/>
                                <value>*=lineWeightedRevenue</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="1" styleId="total"><model/><value>合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(C3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(D3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(E3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(F3)</valueExpr></model>
                            </cell>
                            <cell styleId="cell"/>
                            <cell styleId="num">
                                <model><valueExpr>SUM(H3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(I3)</valueExpr></model>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="alert" fillPattern="solid" fillBgColor="FFFFF9C4" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
