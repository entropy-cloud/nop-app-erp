<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- CRM 线索/商机 docStatus 状态机 + 漏斗阶段流转编排 Processor（Facade + Processor 两层，protected step 方法供下游覆盖） -->
    <bean id="app.erp.crm.service.processor.ErpCrmLeadProcessor"
          class="app.erp.crm.service.processor.ErpCrmLeadProcessor"/>

    <!-- CRM 线索查重器（companyName/contactEmail/contactPhone 命中既有非终态线索，默认仅提示不阻断） -->
    <bean id="app.erp.crm.service.support.LeadDuplicateChecker"
          class="app.erp.crm.service.support.LeadDuplicateChecker"/>

    <!-- CRM 转化闭环 Processor（LEAD→客户+商机、OPPORTUNITY→报价单，跨域经 IErpMdPartnerBiz/IErpSalQuotationBiz） -->
    <bean id="app.erp.crm.service.processor.ErpCrmConversionProcessor"
          class="app.erp.crm.service.processor.ErpCrmConversionProcessor"/>

    <!-- CRM 活动派生字段回写器（Event 状态变更即时回写 Lead.lastContactDate/nextActivityDate，推模式） -->
    <bean id="app.erp.crm.service.support.LeadActivityDerivationHelper"
          class="app.erp.crm.service.support.LeadActivityDerivationHelper"/>

    <!-- CRM 线索活动时间线聚合器（Event + Activity 合并按时间倒序返回只读聚合视图） -->
    <bean id="app.erp.crm.service.support.EventTimelineAggregator"
          class="app.erp.crm.service.support.EventTimelineAggregator"/>

    <!-- CRM 线索评分引擎（config 驱动 LOOKUP/FORMULA/BOOLEAN 准则 → 归一化 totalScore → append-only 评分记录 + auto-qualify） -->
    <bean id="app.erp.crm.service.support.LeadScoringEngine"
          class="app.erp.crm.service.support.LeadScoringEngine"/>

    <!-- CRM 销售预测聚合引擎（commit/upside/best-case/weighted 分类 + 商机级 ForecastLine 快照 + 团队→公司层级 rollup + 准确率） -->
    <bean id="app.erp.crm.service.support.ForecastAggregator"
          class="app.erp.crm.service.support.ForecastAggregator"/>

    <!-- 定时销售预测重算 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-crm.forecast.recalc-cron 配置门控。 -->
    <bean id="erpCrmForecastRecalcJob"
          class="app.erp.crm.service.job.ErpCrmForecastRecalcJob"/>

    <!-- 定时线索评分批量重算 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-crm.lead-scoring.schedule-cron 配置门控。 -->
    <bean id="erpCrmLeadScoringRecalcJob"
          class="app.erp.crm.service.job.ErpCrmLeadScoringRecalcJob"/>

    <!-- 定时活动到期提醒 Job Bean（plan 2026-07-06-0642-1 §Phase 2）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-crm.event-reminder-cron 配置门控。 -->
    <bean id="erpCrmEventReminderJob"
          class="app.erp.crm.service.job.ErpCrmEventReminderJob"/>

    <!-- CRM 域报表渲染入口（plan 2026-07-06-1815-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。镜像 finance ErpFinReportBizModel（域隔离 /crm/）。 -->
    <bean id="app.erp.crm.service.report.ErpCrmReportBizModel" ioc:type="@bean:id"/>
</beans>