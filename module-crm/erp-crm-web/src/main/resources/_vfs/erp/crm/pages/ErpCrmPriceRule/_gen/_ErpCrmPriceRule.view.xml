<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCrmPriceRule" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/crm/model/ErpCrmPriceRule/ErpCrmPriceRule.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--规则类型-->
                <col id="ruleType" mandatory="true" sortable="true"/>

                <!--优先级-->
                <col id="priority" ui:number="true" sortable="true"/>

                <!--适用产品-->
                <col id="productId" ui:number="true" sortable="true"/>

                <!--适用产品品类-->
                <col id="productCategory" sortable="true"/>

                <!--适用客户-->
                <col id="customerId" ui:number="true" sortable="true"/>

                <!--适用客户类别-->
                <col id="customerCategory" sortable="true"/>

                <!--最小数量-->
                <col id="minQuantity" ui:number="true" sortable="true"/>

                <!--最大数量-->
                <col id="maxQuantity" ui:number="true" sortable="true"/>

                <!--覆盖单价-->
                <col id="priceOverride" ui:number="true" sortable="true"/>

                <!--折扣百分比-->
                <col id="discountPercent" ui:number="true" sortable="true"/>

                <!--折扣固定金额-->
                <col id="discountAmount" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--生效开始日期-->
                <col id="effectiveFrom" sortable="true"/>

                <!--生效结束日期-->
                <col id="effectiveTo" sortable="true"/>

                <!--是否启用-->
                <col id="isActive" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgName"/>

                <!--产品-->
                <col id="materialName"/>

                <!--客户-->
                <col id="customerName"/>

                <!--币种-->
                <col id="currencyName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-价格规则" i18n-en:title="View Price Rule">
            <layout>
 code[编码] name[名称]
 orgId[业务组织] ruleType[规则类型]
 priority[优先级] productId[适用产品]
 productCategory[适用产品品类] customerId[适用客户]
 customerCategory[适用客户类别] minQuantity[最小数量]
 maxQuantity[最大数量] priceOverride[覆盖单价]
 discountPercent[折扣百分比] discountAmount[折扣固定金额]
 currencyId[币种] effectiveFrom[生效开始日期]
 effectiveTo[生效结束日期] isActive[是否启用]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 orgName[业务组织] materialName[产品]
 customerName[客户] currencyName[币种]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-价格规则" i18n-en:title="Add Price Rule" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-价格规则" i18n-en:title="Edit Price Rule">
            <layout>
 code[编码] name[名称]
 orgId[业务组织] ruleType[规则类型]
 priority[优先级] productId[适用产品]
 productCategory[适用产品品类] customerId[适用客户]
 customerCategory[适用客户类别] minQuantity[最小数量]
 maxQuantity[最大数量] priceOverride[覆盖单价]
 discountPercent[折扣百分比] discountAmount[折扣固定金额]
 currencyId[币种] effectiveFrom[生效开始日期]
 effectiveTo[生效结束日期] isActive[是否启用]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-价格规则" i18n-en:title="Update Price Rule"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmPriceRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmPriceRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCrmPriceRule__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCrmPriceRule__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCrmPriceRule__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCrmPriceRule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCrmPriceRule__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCrmPriceRule__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCrmPriceRule__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCrmPriceRule__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>