<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmForecastAccuracy.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="forecastId" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="period" label="预测期间"/>
                <col id="teamId" label="销售团队"/>
                <col id="territoryId" label="销售区域"/>
                <col id="commitAccuracy" ui:number="true" sortable="true"/>
                <col id="upsideAccuracy" ui:number="true" sortable="true"/>
                <col id="calculatedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 forecastId[预测主表] periodId[预测期间]
 ownerId[负责人] teamId[销售团队]
 territoryId[销售区域] calculatedAt[计算时间]
            </layout>
            <cells>
                <cell id="forecastId" filterOp="eq"/>
                <cell id="periodId" filterOp="eq"/>
                <cell id="ownerId" filterOp="eq"/>
                <cell id="teamId" filterOp="eq"/>
                <cell id="territoryId" filterOp="eq"/>
                <cell id="calculatedAt" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 forecastId[预测主表]
            </layout>
            <cells>
                <cell id="forecastId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
