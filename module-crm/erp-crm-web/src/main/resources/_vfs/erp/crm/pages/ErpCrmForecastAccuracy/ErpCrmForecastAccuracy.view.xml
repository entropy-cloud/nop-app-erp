<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmForecastAccuracy.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="forecastId" ui:number="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="periodCode" label="预测期间"/>
                <col id="teamName" label="销售团队"/>
                <col id="territoryName" label="销售区域"/>
                <col id="commitAccuracy" ui:number="true" sortable="true"/>
                <col id="upsideAccuracy" ui:number="true" sortable="true"/>
                <col id="calculatedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>