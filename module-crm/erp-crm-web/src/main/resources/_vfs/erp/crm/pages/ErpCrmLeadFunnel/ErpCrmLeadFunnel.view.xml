<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmLeadFunnel.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="funnelName" sortable="true"/>
                <col id="periodStart" sortable="true"/>
                <col id="periodEnd" sortable="true"/>
                <col id="territoryId" label="销售区域"/>
                <col id="teamId" label="销售团队"/>
                <col id="sourceId" label="线索来源"/>
                <col id="totalLeadsAtTop" ui:number="true" sortable="true"/>
                <col id="totalOpportunities" ui:number="true" sortable="true"/>
                <col id="totalWon" ui:number="true" sortable="true"/>
                <col id="totalRevenue" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>