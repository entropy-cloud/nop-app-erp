<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCrmLeadFunnel" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/crm/model/ErpCrmLeadFunnel/ErpCrmLeadFunnel.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--漏斗名称-->
                <col id="funnelName" mandatory="true" sortable="true"/>

                <!--分析期间开始-->
                <col id="periodStart" mandatory="true" sortable="true"/>

                <!--分析期间结束-->
                <col id="periodEnd" mandatory="true" sortable="true"/>

                <!--区域维度-->
                <col id="territoryId" ui:number="true" sortable="true"/>

                <!--团队维度-->
                <col id="teamId" ui:number="true" sortable="true"/>

                <!--来源维度-->
                <col id="sourceId" ui:number="true" sortable="true"/>

                <!--漏斗顶部线索量-->
                <col id="totalLeadsAtTop" ui:number="true" sortable="true"/>

                <!--商机总量-->
                <col id="totalOpportunities" ui:number="true" sortable="true"/>

                <!--赢单总量-->
                <col id="totalWon" ui:number="true" sortable="true"/>

                <!--丢单总量-->
                <col id="totalLost" ui:number="true" sortable="true"/>

                <!--赢单总收入-->
                <col id="totalRevenue" ui:number="true" sortable="true"/>

                <!--丢失金额合计-->
                <col id="lostRevenue" ui:number="true" sortable="true"/>

                <!--加权收入合计-->
                <col id="weightedRevenue" ui:number="true" sortable="true"/>

                <!--平均赢单金额-->
                <col id="avgDealSize" ui:number="true" sortable="true"/>

                <!--平均销售周期天数-->
                <col id="avgSalesCycleDays" ui:number="true" sortable="true"/>

                <!--聚合计算时间-->
                <col id="calculatedAt" sortable="true"/>

                <!--聚合计算人-->
                <col id="calculatedBy" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-线索漏斗" i18n-en:title="View Lead Funnel">
            <layout>
 orgId[业务组织] funnelName[漏斗名称]
 periodStart[分析期间开始] periodEnd[分析期间结束]
 territoryId[区域维度] teamId[团队维度]
 sourceId[来源维度] totalLeadsAtTop[漏斗顶部线索量]
 totalOpportunities[商机总量] totalWon[赢单总量]
 totalLost[丢单总量] totalRevenue[赢单总收入]
 lostRevenue[丢失金额合计] weightedRevenue[加权收入合计]
 avgDealSize[平均赢单金额] avgSalesCycleDays[平均销售周期天数]
 calculatedAt[聚合计算时间] calculatedBy[聚合计算人]
 remark[备注] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-线索漏斗" i18n-en:title="Add Lead Funnel" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-线索漏斗" i18n-en:title="Edit Lead Funnel">
            <layout>
 orgId[业务组织] funnelName[漏斗名称]
 periodStart[分析期间开始] periodEnd[分析期间结束]
 territoryId[区域维度] teamId[团队维度]
 sourceId[来源维度] totalLeadsAtTop[漏斗顶部线索量]
 totalOpportunities[商机总量] totalWon[赢单总量]
 totalLost[丢单总量] totalRevenue[赢单总收入]
 lostRevenue[丢失金额合计] weightedRevenue[加权收入合计]
 avgDealSize[平均赢单金额] avgSalesCycleDays[平均销售周期天数]
 calculatedAt[聚合计算时间] calculatedBy[聚合计算人]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-线索漏斗" i18n-en:title="Update Lead Funnel"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmLeadFunnel__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmLeadFunnel__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCrmLeadFunnel__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCrmLeadFunnel__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCrmLeadFunnel__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCrmLeadFunnel__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCrmLeadFunnel__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCrmLeadFunnel__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCrmLeadFunnel__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCrmLeadFunnel__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>