<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpCrmLead" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/crm/model/ErpCrmLead/ErpCrmLead.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--线索/商机类型-->
                <col id="leadType" mandatory="true" sortable="true"/>

                <!--客户-->
                <col id="partnerId" ui:number="true" sortable="true"/>

                <!--联系人姓名-->
                <col id="contactName" sortable="true"/>

                <!--联系电话-->
                <col id="contactPhone" sortable="true"/>

                <!--联系邮箱-->
                <col id="contactEmail" sortable="true"/>

                <!--公司名称-->
                <col id="companyName" sortable="true"/>

                <!--职位-->
                <col id="jobTitle" sortable="true"/>

                <!--部门-->
                <col id="department" sortable="true"/>

                <!--线索来源-->
                <col id="sourceId" ui:number="true" sortable="true"/>

                <!--线索状态-->
                <col id="leadStatusId" ui:number="true" sortable="true"/>

                <!--漏斗阶段-->
                <col id="stageId" ui:number="true" sortable="true"/>

                <!--预期收入-->
                <col id="expectedRevenue" ui:number="true" sortable="true"/>

                <!--乐观预期-->
                <col id="bestCaseAmount" ui:number="true" sortable="true"/>

                <!--悲观预期-->
                <col id="worstCaseAmount" ui:number="true" sortable="true"/>

                <!--周期性收入-->
                <col id="recurringRevenue" ui:number="true" sortable="true"/>

                <!--周期性计划-->
                <col id="recurringPlan" sortable="true"/>

                <!--预期签单日-->
                <col id="expectedCloseDate" sortable="true"/>

                <!--成交概率-->
                <col id="probability" ui:number="true" sortable="true"/>

                <!--营销活动-->
                <col id="campaignId" ui:number="true" sortable="true"/>

                <!--UTM Medium-->
                <col id="utmMedium" sortable="true"/>

                <!--UTM Source-->
                <col id="utmSource" sortable="true"/>

                <!--负责人-->
                <col id="ownerId" sortable="true"/>

                <!--销售团队-->
                <col id="teamId" ui:number="true" sortable="true"/>

                <!--丢单原因-->
                <col id="lostReasonId" ui:number="true" sortable="true"/>

                <!--丢单描述-->
                <col id="lostReasonDesc" sortable="true"/>

                <!--最后联系日期-->
                <col id="lastContactDate" sortable="true"/>

                <!--下次活动日期-->
                <col id="nextActivityDate" sortable="true"/>

                <!--转化结果单据类型-->
                <col id="relatedBillType" sortable="true"/>

                <!--转化结果单据号-->
                <col id="relatedBillCode" sortable="true"/>

                <!--单据状态-->
                <col id="docStatus" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--销售区域-->
                <col id="territoryId" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-线索/商机" i18n-en:title="View Lead / Opportunity">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] leadType[线索/商机类型]
 partnerId[客户] contactName[联系人姓名]
 contactPhone[联系电话] contactEmail[联系邮箱]
 companyName[公司名称] jobTitle[职位]
 department[部门] sourceId[线索来源]
 leadStatusId[线索状态] stageId[漏斗阶段]
 expectedRevenue[预期收入] bestCaseAmount[乐观预期]
 worstCaseAmount[悲观预期] recurringRevenue[周期性收入]
 recurringPlan[周期性计划] expectedCloseDate[预期签单日]
 probability[成交概率] campaignId[营销活动]
 utmMedium[UTM Medium] utmSource[UTM Source]
 ownerId[负责人] teamId[销售团队]
 lostReasonId[丢单原因] lostReasonDesc[丢单描述]
 lastContactDate[最后联系日期] nextActivityDate[下次活动日期]
 relatedBillType[转化结果单据类型] relatedBillCode[转化结果单据号]
 docStatus[单据状态] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] territoryId[销售区域]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-线索/商机" i18n-en:title="Add Lead / Opportunity">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] leadType[线索/商机类型]
 partnerId[客户] contactName[联系人姓名]
 contactPhone[联系电话] contactEmail[联系邮箱]
 companyName[公司名称] jobTitle[职位]
 department[部门] sourceId[线索来源]
 leadStatusId[线索状态] stageId[漏斗阶段]
 expectedRevenue[预期收入] bestCaseAmount[乐观预期]
 worstCaseAmount[悲观预期] recurringRevenue[周期性收入]
 recurringPlan[周期性计划] expectedCloseDate[预期签单日]
 probability[成交概率] campaignId[营销活动]
 utmMedium[UTM Medium] utmSource[UTM Source]
 ownerId[负责人] teamId[销售团队]
 lostReasonId[丢单原因] lostReasonDesc[丢单描述]
 lastContactDate[最后联系日期] nextActivityDate[下次活动日期]
 relatedBillType[转化结果单据类型] relatedBillCode[转化结果单据号]
 docStatus[单据状态] remark[备注]
 territoryId[销售区域] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-线索/商机" i18n-en:title="Edit Lead / Opportunity">
            <layout>
 id[ID] code[编码]
 orgId[业务组织] leadType[线索/商机类型]
 partnerId[客户] contactName[联系人姓名]
 contactPhone[联系电话] contactEmail[联系邮箱]
 companyName[公司名称] jobTitle[职位]
 department[部门] sourceId[线索来源]
 leadStatusId[线索状态] stageId[漏斗阶段]
 expectedRevenue[预期收入] bestCaseAmount[乐观预期]
 worstCaseAmount[悲观预期] recurringRevenue[周期性收入]
 recurringPlan[周期性计划] expectedCloseDate[预期签单日]
 probability[成交概率] campaignId[营销活动]
 utmMedium[UTM Medium] utmSource[UTM Source]
 ownerId[负责人] teamId[销售团队]
 lostReasonId[丢单原因] lostReasonDesc[丢单描述]
 lastContactDate[最后联系日期] nextActivityDate[下次活动日期]
 relatedBillType[转化结果单据类型] relatedBillCode[转化结果单据号]
 docStatus[单据状态] remark[备注]
 delVersion[逻辑删除版本] territoryId[销售区域]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-线索/商机"
              i18n-en:title="Update Lead / Opportunity"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmLead__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpCrmLead__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpCrmLead__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpCrmLead__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpCrmLead__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpCrmLead__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpCrmLead__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpCrmLead__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpCrmLead__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpCrmLead__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>