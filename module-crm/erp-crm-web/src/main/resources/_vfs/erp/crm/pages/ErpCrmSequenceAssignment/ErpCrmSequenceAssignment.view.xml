<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmSequenceAssignment.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="sequenceId" label="销售序列"/>
                <col id="priority" ui:number="true" sortable="true"/>
                <col id="conditionType" sortable="true"/>
                <col id="isActive" sortable="true"/>
                <col id="isDefault" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>