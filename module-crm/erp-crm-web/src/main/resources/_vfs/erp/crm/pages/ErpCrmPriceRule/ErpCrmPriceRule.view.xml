<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmPriceRule.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="ruleType" sortable="true"/>
                <col id="priority" ui:number="true" sortable="true"/>
                <col id="materialId" label="产品"/>
                <col id="customerId" label="客户"/>
                <col id="currencyId" label="币种"/>
                <col id="discountPercent" ui:number="true" sortable="true"/>
                <col id="effectiveFrom" sortable="true"/>
                <col id="effectiveTo" sortable="true"/>
                <col id="isActive" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>