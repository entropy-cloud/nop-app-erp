<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmForecastLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="forecastId" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="lead" label="商机"/>
                <col id="probability" ui:number="true" sortable="true"/>
                <col id="expectedRevenue" ui:number="true" sortable="true"/>
                <col id="weightedRevenue" ui:number="true" sortable="true"/>
                <col id="forecastCategory" sortable="true"/>
                <col id="includedInCommit" sortable="true"/>
                <col id="stageName" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 forecastId[预测头] orgId[业务组织]
 leadId[线索] probability[概率(%)]
=========>amount[金额]======
 expectedRevenue[预期收入] weightedRevenue[加权收入]
 forecastCategory[预测类别] includedInCommit[纳入承诺]
 stageName[阶段名称]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 forecastId[预测头] orgId[业务组织]
 leadId[线索] probability[概率(%)]
=========>amount[金额]======
 expectedRevenue[预期收入] weightedRevenue[加权收入]
 forecastCategory[预测类别] includedInCommit[纳入承诺]
 stageName[阶段名称]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 forecastId[预测头] leadId[线索]
 orgId[业务组织] forecastCategory[预测类别]
 stageName[阶段名称]
            </layout>
            <cells>
                <cell id="forecastId" filterOp="eq"/>
                <cell id="leadId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="forecastCategory" filterOp="eq"/>
                <cell id="stageName" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>