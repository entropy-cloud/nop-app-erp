<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmForecastLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="forecastId" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="leadCode" label="商机"/>
                <col id="probability" ui:number="true" sortable="true"/>
                <col id="expectedRevenue" ui:number="true" sortable="true"/>
                <col id="weightedRevenue" ui:number="true" sortable="true"/>
                <col id="forecastCategory" sortable="true"/>
                <col id="includedInCommit" sortable="true"/>
                <col id="stageId" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>