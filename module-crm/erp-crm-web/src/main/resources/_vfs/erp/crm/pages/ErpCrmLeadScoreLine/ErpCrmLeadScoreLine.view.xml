<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmLeadScoreLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="scoreId" ui:number="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="configLineId" ui:number="true" sortable="true"/>
                <col id="criterionCode" sortable="true"/>
                <col id="criterionName" sortable="true"/>
                <col id="rawScore" ui:number="true" sortable="true"/>
                <col id="weightedScore" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>