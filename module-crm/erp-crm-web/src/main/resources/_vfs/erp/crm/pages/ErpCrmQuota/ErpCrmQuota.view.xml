<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmQuota.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="territoryName" label="销售区域"/>
                <col id="teamName" label="销售团队"/>
                <col id="currencyName" label="币种"/>
                <col id="periodType" sortable="true"/>
                <col id="fiscalYear" ui:number="true" sortable="true"/>
                <col id="periodLabel" sortable="true"/>
                <col id="quotaAmount" ui:number="true" sortable="true"/>
                <col id="isFinalized" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>