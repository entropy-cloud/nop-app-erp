<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmQuota.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="territoryId" label="销售区域"/>
                <col id="teamId" label="销售团队"/>
                <col id="currencyId" label="币种"/>
                <col id="periodType" sortable="true"/>
                <col id="fiscalYear" ui:number="true" sortable="true"/>
                <col id="periodLabel" sortable="true"/>
                <col id="quotaAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="isFinalized" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] territoryId[销售区域]
 teamId[销售团队] ownerId[负责人]
=========>period[周期]======
 periodType[周期类型] fiscalYear[财年]
 periodLabel[周期标签]
=========>amount[金额]======
 quotaAmount[配额金额] currencyId[币种]
 isFinalized[是否最终] notes[备注]
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] territoryId[销售区域]
 teamId[销售团队] ownerId[负责人]
=========>period[周期]======
 periodType[周期类型] fiscalYear[财年]
 periodLabel[周期标签]
=========>amount[金额]======
 quotaAmount[配额金额] currencyId[币种]
 isFinalized[是否最终] notes[备注](2)
========^audit[审计信息]=========
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织] territoryId[销售区域]
 teamId[销售团队] ownerId[负责人]
 fiscalYear[财年] periodType[周期类型]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="territoryId" filterOp="eq"/>
                <cell id="teamId" filterOp="eq"/>
                <cell id="ownerId" filterOp="eq"/>
                <cell id="fiscalYear" filterOp="eq"/>
                <cell id="periodType" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>