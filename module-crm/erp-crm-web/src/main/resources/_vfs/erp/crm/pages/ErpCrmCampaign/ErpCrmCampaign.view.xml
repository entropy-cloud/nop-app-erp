<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmCampaign.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="campaignName" sortable="true"/>
                <col id="medium" sortable="true"/>
                <col id="source" sortable="true"/>
                <col id="startDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="budgetAmount" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualCost" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[活动编码] name[活动名称]
 orgId[业务组织] campaignName[活动主题]
 medium[渠道] source[来源]
=========>schedule[活动周期]======
 startDate[开始日期] endDate[结束日期]
=========>amount[预算与实际]======
 budgetAmount[预算金额] actualCost[实际成本]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[活动编码] name[活动名称]
 orgId[业务组织] campaignName[活动主题]
 medium[渠道] source[来源]
=========>schedule[活动周期]======
 startDate[开始日期] endDate[结束日期]
=========>amount[预算与实际]======
 budgetAmount[预算金额] actualCost[实际成本]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 orgId[业务组织] medium[渠道]
 source[来源] startDate[开始日期]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="medium" filterOp="eq"/>
                <cell id="source" filterOp="eq"/>
                <cell id="startDate" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[活动编码] campaignName[活动主题]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="campaignName" filterOp="like"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>