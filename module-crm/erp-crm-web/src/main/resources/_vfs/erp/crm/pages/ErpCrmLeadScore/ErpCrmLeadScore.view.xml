<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpCrmLeadScore.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="lead" label="关联线索"/>
                <col id="orgId" label="业务组织"/>
                <col id="configId" label="评分配置"/>
                <col id="totalScore" ui:number="true" sortable="true"/>
                <col id="autoQualified" sortable="true"/>
                <col id="triggeredAction" sortable="true"/>
                <col id="calculatedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit" x:abstract="true"/>
        <form id="add" x:abstract="true"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 leadId[关联线索] configId[评分配置]
 autoQualified[自动合格] triggeredAction[触发动作]
 orgId[业务组织] calculatedAt[计算时间]
            </layout>
            <cells>
                <cell id="leadId" filterOp="eq"/>
                <cell id="configId" filterOp="eq"/>
                <cell id="autoQualified" filterOp="eq"/>
                <cell id="triggeredAction" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="calculatedAt" filterOp="date-between"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 leadId[关联线索]
            </layout>
            <cells>
                <cell id="leadId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge"/>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
