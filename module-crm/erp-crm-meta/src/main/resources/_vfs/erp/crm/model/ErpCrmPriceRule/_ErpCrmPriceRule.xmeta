            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="customerId" displayName="适用客户" propId="9" i18n-en:displayName="Customer" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="customer">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="customerCategory" displayName="适用客户类别" propId="10" i18n-en:displayName="Customer Category"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="minQuantity" displayName="最小数量" propId="11" i18n-en:displayName="Min Quantity" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="quantity" type="java.lang.String" precision="20" scale="4"/>
        </prop>
        <prop name="maxQuantity" displayName="最大数量" propId="12" i18n-en:displayName="Max Quantity" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="quantity" type="java.lang.String" precision="20" scale="4"/>
        </prop>
        <prop name="priceOverride" displayName="覆盖单价" propId="13" i18n-en:displayName="Price Override" queryable="true"
