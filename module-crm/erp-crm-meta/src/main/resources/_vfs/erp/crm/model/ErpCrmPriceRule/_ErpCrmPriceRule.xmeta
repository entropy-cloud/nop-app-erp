            <schema domain="unitPrice" type="java.lang.String" precision="20" scale="4"/>
        </prop>
        <prop name="discountPercent" displayName="折扣百分比" propId="14" i18n-en:displayName="Discount Percent"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.Double" precision="10" scale="2"/>
        </prop>
        <prop name="discountAmount" displayName="折扣固定金额" propId="15" i18n-en:displayName="Discount Amount"
