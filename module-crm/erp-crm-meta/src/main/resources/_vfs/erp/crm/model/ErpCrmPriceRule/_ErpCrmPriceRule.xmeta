            <schema domain="amount" type="java.lang.String" precision="20" scale="4"/>
        </prop>
        <prop name="currencyId" displayName="币种" propId="16" i18n-en:displayName="Currency" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="currency">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="effectiveFrom" displayName="生效开始日期" propId="17" i18n-en:displayName="Effective From"
