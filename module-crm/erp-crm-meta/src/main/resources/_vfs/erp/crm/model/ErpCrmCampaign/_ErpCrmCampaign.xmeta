            <schema type="java.lang.Long"/>
        </prop>
        <prop name="campaignName" displayName="活动名称" propId="5" i18n-en:displayName="Campaign Name" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema domain="name" type="java.lang.String" precision="200"/>
        </prop>
        <prop name="medium" displayName="UTM Medium" propId="6" i18n-en:displayName="UTM Medium" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="100"/>
        </prop>
        <prop name="source" displayName="UTM Source" propId="7" i18n-en:displayName="UTM Source" queryable="true"
