            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="budgetAmount" displayName="预算金额" propId="10" i18n-en:displayName="Budget Amount" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="amount" type="java.math.BigDecimal" precision="20" scale="4"/>
        </prop>
        <prop name="actualCost" displayName="实际成本" propId="11" i18n-en:displayName="Actual Cost" queryable="true"
