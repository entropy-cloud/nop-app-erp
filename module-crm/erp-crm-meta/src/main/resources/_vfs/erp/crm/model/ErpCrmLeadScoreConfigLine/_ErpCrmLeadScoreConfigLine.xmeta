        <prop name="lookupTable" displayName="值表(JSON)" propId="8" i18n-en:displayName="Lookup Table" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="jsonStr" type="java.lang.String" precision="4000"/>
        </prop>
        <prop name="formula" displayName="公式表达式" propId="9" i18n-en:displayName="Formula" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="500"/>
        </prop>
        <prop name="maxScore" displayName="最高分" propId="10" i18n-en:displayName="Max Score" queryable="true"
