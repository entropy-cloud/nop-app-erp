            <schema type="java.lang.Long"/>
        </prop>
        <prop name="criterionCode" displayName="准则编码" propId="4" i18n-en:displayName="Criterion Code" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema domain="code" type="java.lang.String" precision="50"/>
        </prop>
        <prop name="criterionName" displayName="准则名称" propId="5" i18n-en:displayName="Criterion Name" queryable="true"
              sortable="true" insertable="true" updatable="true">
            <schema domain="name" type="java.lang.String" precision="200"/>
        </prop>
        <prop name="weight" displayName="权重系数" propId="6" i18n-en:displayName="Weight" queryable="true" sortable="true"
              insertable="true" updatable="true" defaultValue="0">
