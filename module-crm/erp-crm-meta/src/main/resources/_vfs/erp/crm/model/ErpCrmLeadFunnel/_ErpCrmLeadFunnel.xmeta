            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="periodEnd" displayName="分析期间结束" propId="5" i18n-en:displayName="Period End" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="territoryId" displayName="区域维度" propId="6" i18n-en:displayName="Territory" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="territory">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="teamId" displayName="团队维度" propId="7" i18n-en:displayName="Team" queryable="true" sortable="true"
