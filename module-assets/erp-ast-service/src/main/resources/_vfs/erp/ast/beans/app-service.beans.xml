<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 资产业财过账：执行器 + 资本化派发器 + 资本化 Provider（Registry 容器级 collect-by-type 自动收录） -->
    <bean id="app.erp.ast.service.posting.AssetPostingExecutor"
          class="app.erp.ast.service.posting.AssetPostingExecutor"/>
    <bean id="app.erp.ast.service.posting.CapitalizationPostingDispatcher"
          class="app.erp.ast.service.posting.CapitalizationPostingDispatcher"/>
    <bean id="app.erp.ast.service.posting.CapitalizationAcctDocProvider"
          class="app.erp.ast.service.posting.CapitalizationAcctDocProvider"/>

    <!-- 折旧业财过账：派发器 + Provider（复用 AssetPostingExecutor） -->
    <bean id="app.erp.ast.service.posting.DepreciationPostingDispatcher"
          class="app.erp.ast.service.posting.DepreciationPostingDispatcher"/>
    <bean id="app.erp.ast.service.posting.DepreciationAcctDocProvider"
          class="app.erp.ast.service.posting.DepreciationAcctDocProvider"/>

    <!-- 处置业财过账：派发器 + Provider（复用 AssetPostingExecutor） -->
    <bean id="app.erp.ast.service.posting.DisposalPostingDispatcher"
          class="app.erp.ast.service.posting.DisposalPostingDispatcher"/>
    <bean id="app.erp.ast.service.posting.DisposalAcctDocProvider"
          class="app.erp.ast.service.posting.DisposalAcctDocProvider"/>

    <!-- assets 域状态机编排 Processor（Facade + Processor 两层结构，protected step 方法供下游覆盖）。
         各 Facade BizModel 仅负责入口/事务/委托，编排委托对应 Processor。 -->
    <bean id="app.erp.ast.service.processor.ErpAstAssetCapitalizationProcessor"
          class="app.erp.ast.service.processor.ErpAstAssetCapitalizationProcessor"/>
    <bean id="app.erp.ast.service.processor.ErpAstDepreciationScheduleProcessor"
          class="app.erp.ast.service.processor.ErpAstDepreciationScheduleProcessor"/>
    <bean id="app.erp.ast.service.processor.ErpAstDisposalProcessor"
          class="app.erp.ast.service.processor.ErpAstDisposalProcessor"/>

    <!-- 定时批量折旧 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-ast.depreciation-cron 配置门控。 -->
    <bean id="erpAstDepreciationJob"
          class="app.erp.ast.service.job.ErpAstDepreciationJob"/>
</beans>