<?xml version="1.0" encoding="UTF-8" ?>
<!-- 资产折旧明细报表（种子报表）。数据集 ds 由 ErpAstReportBizModel.buildAssetDepreciationDetailDataset 注入，
     每行 {assetId, assetCode, assetName, categoryId, categoryName, originalValue, accumulatedDepreciation,
     netBookValue, periodDepreciation}。口径对齐 docs/design/assets/state-machine.md：按资产×类别维度汇总。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="asset-depreciation" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="80.0"/>
                    <col width="100.0"/>
                    <col width="120.0"/>
                    <col width="100.0"/>
                    <col width="90.0"/>
                    <col width="110.0"/>
                    <col width="100.0"/>
                    <col width="100.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="7" styleId="title"><model/><value>资产折旧明细表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>资产ID</value></cell>
                            <cell styleId="header"><model/><value>资产编码</value></cell>
                            <cell styleId="header"><model/><value>资产名称</value></cell>
                            <cell styleId="header"><model/><value>类别</value></cell>
                            <cell styleId="header"><model/><value>原值</value></cell>
                            <cell styleId="header"><model/><value>累计折旧</value></cell>
                            <cell styleId="header"><model/><value>净值</value></cell>
                            <cell styleId="header"><model/><value>本期折旧</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="assetId"/>
                                <value>*=^ds!assetId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=assetCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=assetName</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=categoryName</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=originalValue</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=accumulatedDepreciation</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=netBookValue</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=periodDepreciation</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="3" styleId="total"><model/><value>本期折旧合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(E3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(F3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(G3)</valueExpr></model>
                            </cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(H3)</valueExpr></model>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
