<?xml version="1.0" encoding="UTF-8" ?>
<!-- 资产处置明细报表（种子报表）。数据集 ds 由 ErpAstReportBizModel.buildAssetDisposalDetailDataset 注入，
     每行 {id, code, assetId, assetCode, assetName, disposalType, disposalAmount, businessDate, gainLoss,
     reason, docStatus}。口径对齐 docs/design/assets/state-machine.md：处置行 + 清理损益维度。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="asset-disposal" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="100.0"/>
                    <col width="100.0"/>
                    <col width="120.0"/>
                    <col width="80.0"/>
                    <col width="90.0"/>
                    <col width="80.0"/>
                    <col width="90.0"/>
                    <col width="100.0"/>
                    <col width="80.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="8" styleId="title"><model/><value>资产处置明细表</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>单据编码</value></cell>
                            <cell styleId="header"><model/><value>资产编码</value></cell>
                            <cell styleId="header"><model/><value>资产名称</value></cell>
                            <cell styleId="header"><model/><value>处置类型</value></cell>
                            <cell styleId="header"><model/><value>处置金额</value></cell>
                            <cell styleId="header"><model/><value>业务日期</value></cell>
                            <cell styleId="header"><model/><value>清理损益</value></cell>
                            <cell styleId="header"><model/><value>原因</value></cell>
                            <cell styleId="header"><model/><value>单据状态</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="cell">
                                <model ds="ds" expandType="r" field="id"/>
                                <value>*=^ds!code</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=assetCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=assetName</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=disposalType</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=disposalAmount</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=businessDate</value>
                            </cell>
                            <cell styleId="alert">
                                <model rowParent="A3"/>
                                <value>*=gainLoss</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=reason</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=docStatus</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell mergeAcross="3" styleId="total"><model/><value>合计</value></cell>
                            <cell styleId="num">
                                <model><valueExpr>SUM(E3)</valueExpr></model>
                            </cell>
                            <cell styleId="cell"/>
                            <cell styleId="num">
                                <model><valueExpr>SUM(G3)</valueExpr></model>
                            </cell>
                            <cell styleId="cell"/>
                            <cell styleId="cell"/>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="alert" fillPattern="solid" fillBgColor="FFFFF9C4" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="total" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
