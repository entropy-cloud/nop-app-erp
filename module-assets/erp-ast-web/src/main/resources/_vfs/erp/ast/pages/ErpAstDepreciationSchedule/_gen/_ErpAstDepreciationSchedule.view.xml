<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpAstDepreciationSchedule" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ast/model/ErpAstDepreciationSchedule/ErpAstDepreciationSchedule.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--资产ID-->
                <col id="assetId" mandatory="true" ui:number="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--折旧期间-->
                <col id="period" mandatory="true" sortable="true"/>

                <!--计划折旧额-->
                <col id="plannedAmount" mandatory="true" ui:number="true" sortable="true"/>

                <!--实际折旧额-->
                <col id="actualAmount" ui:number="true" sortable="true"/>

                <!--累计折旧-->
                <col id="accumulatedDepreciation" ui:number="true" sortable="true"/>

                <!--净值-->
                <col id="netBookValue" ui:number="true" sortable="true"/>

                <!--执行状态-->
                <col id="status" mandatory="true" ui:number="true" sortable="true"/>

                <!--执行时间-->
                <col id="executedAt" sortable="true"/>

                <!--已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--凭证ID-->
                <col id="voucherId" ui:number="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--业务日期-->
                <col id="businessDate" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" mandatory="true" sortable="true"/>

                <!--源币种金额-->
                <col id="amountSource" sortable="true"/>

                <!--本位币金额-->
                <col id="amountFunctional" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-折旧计划" i18n-en:title="View Depreciation Schedule">
            <layout>
 id[ID] assetId[资产ID]
 orgId[所属组织] period[折旧期间]
 plannedAmount[计划折旧额] actualAmount[实际折旧额]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
 status[执行状态] executedAt[执行时间]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] voucherId[凭证ID]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] businessDate[业务日期]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-折旧计划" i18n-en:title="Add Depreciation Schedule">
            <layout>
 id[ID] assetId[资产ID]
 orgId[所属组织] period[折旧期间]
 plannedAmount[计划折旧额] actualAmount[实际折旧额]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
 status[执行状态] executedAt[执行时间]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] voucherId[凭证ID]
 businessDate[业务日期] currencyId[币种]
 exchangeRate[汇率] amountSource[源币种金额]
 amountFunctional[本位币金额] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-折旧计划" i18n-en:title="Edit Depreciation Schedule">
            <layout>
 id[ID] assetId[资产ID]
 orgId[所属组织] period[折旧期间]
 plannedAmount[计划折旧额] actualAmount[实际折旧额]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
 status[执行状态] executedAt[执行时间]
 posted[已过账] postedAt[过账时间]
 postedBy[过账人] voucherId[凭证ID]
 delVersion[逻辑删除版本] businessDate[业务日期]
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-折旧计划"
              i18n-en:title="Update Depreciation Schedule"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstDepreciationSchedule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstDepreciationSchedule__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpAstDepreciationSchedule__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpAstDepreciationSchedule__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpAstDepreciationSchedule__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpAstDepreciationSchedule__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpAstDepreciationSchedule__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpAstDepreciationSchedule__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpAstDepreciationSchedule__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpAstDepreciationSchedule__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>