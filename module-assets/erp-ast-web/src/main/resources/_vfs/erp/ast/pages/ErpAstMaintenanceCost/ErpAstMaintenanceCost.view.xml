<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstMaintenanceCost.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="maintenance" label="维修单编码"/>
                <col id="orgId" label="所属组织"/>
                <col id="lineNo" ui:number="true" sortable="true"/>
                <col id="costType" sortable="true"/>
                <col id="amount" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="businessDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId" label="币种"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] costType[成本类型]
 businessDate[业务日期]
=========>amount[金额信息]======
 amount[金额] currencyId[币种]
=========>reference[业务关联]======
 maintenanceId[维修单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] costType[成本类型]
 businessDate[业务日期]
=========>amount[金额信息]======
 amount[金额] currencyId[币种]
=========>reference[业务关联]======
 maintenanceId[维修单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] costType[成本类型]
 maintenanceId[维修单] currencyId[币种]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="costType" filterOp="eq"/>
                <cell id="maintenanceId" filterOp="eq"/>
                <cell id="currencyId" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>