<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstAssetCapitalization.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="assetCode" sortable="true"/>
                <col id="assetName" sortable="true"/>
                <col id="categoryId" label="资产类别"/>
                <col id="currencyId" label="币种"/>
                <col id="capitalizationDate" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" sortable="true"/>
                <col id="amountSource" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpAstAssetCapitalization__submitForApproval?id=$id"/>
                    <confirmText>确认提交此资产资本化审批？</confirmText>
                    <messages>
                        <success>资产资本化已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpAstAssetCapitalization__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此资产资本化的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>资产资本化已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpAstAssetCapitalization__approve?id=$id"/>
                    <confirmText>确认批准此资产资本化？</confirmText>
                    <messages>
                        <success>资产资本化已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpAstAssetCapitalization__reject?id=$id"/>
                    <confirmText>确认驳回此资产资本化？</confirmText>
                    <messages>
                        <success>资产资本化已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpAstAssetCapitalization__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此资产资本化？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>资产资本化已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>