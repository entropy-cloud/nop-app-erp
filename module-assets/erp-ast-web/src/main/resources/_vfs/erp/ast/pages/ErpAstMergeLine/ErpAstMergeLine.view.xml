<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstMergeLine.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="merge" label="合并单编码"/>
                <col id="orgId" label="所属组织"/>
                <col id="lineNo" ui:number="true" sortable="true"/>
                <col id="sourceAsset" label="源资产编码"/>
                <col id="contributionProportion" sortable="true"/>
                <col id="originalCostAmount" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="accumulatedDepreciationAmount" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="netBookValue" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] sourceAssetId[源资产]
 contributionProportion[贡献比例]
=========>value[价值信息]======
 originalCostAmount[原值成本] accumulatedDepreciationAmount[累计折旧]
 netBookValue[账面净值]
=========>reference[业务关联]======
 mergeId[合并单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 lineNo[行号] sourceAssetId[源资产]
 contributionProportion[贡献比例]
=========>value[价值信息]======
 originalCostAmount[原值成本] accumulatedDepreciationAmount[累计折旧]
 netBookValue[账面净值]
=========>reference[业务关联]======
 mergeId[合并单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 lineNo[行号] sourceAssetId[源资产]
 mergeId[合并单] contributionProportion[贡献比例]
 netBookValue[账面净值]
            </layout>
            <cells>
                <cell id="lineNo" filterOp="eq"/>
                <cell id="sourceAssetId" filterOp="eq"/>
                <cell id="mergeId" filterOp="eq"/>
                <cell id="contributionProportion" filterOp="eq"/>
                <cell id="netBookValue" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>