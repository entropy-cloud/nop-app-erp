<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstInventoryLine.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="inventoryCode" label="盘点单编码"/>
                <col id="orgId" label="所属组织"/>
                <col id="lineNo" ui:number="true" sortable="true"/>
                <col id="assetCodeSnapshot" sortable="true"/>
                <col id="assetNameSnapshot" sortable="true"/>
                <col id="categoryId" label="资产类别"/>
                <col id="bookQuantity" ui:number="true" sortable="true"/>
                <col id="actualQuantity" ui:number="true" sortable="true"/>
                <col id="varianceQuantity" ui:number="true" sortable="true"/>
                <col id="disposition" sortable="true"/>
                <col id="newAssetCode" label="新增资产编码"/>
                <col id="capitalizationCode" label="资本化单编码"/>
                <col id="disposalCode" label="处置单编码"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>