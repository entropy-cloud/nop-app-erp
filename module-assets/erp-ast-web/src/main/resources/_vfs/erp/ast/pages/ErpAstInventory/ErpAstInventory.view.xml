<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstInventory.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="rangeDepartmentId" label="盘点部门"/>
                <col id="rangeCategoryId" label="盘点类别"/>
                <col id="rangeLocationId" label="盘点地点"/>
                <col id="responsibleById" label="负责人"/>
                <col id="businessDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId" label="币种"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[盘点单号] name[盘点名称]
 orgId[业务组织] status[状态]
 rangeDepartmentId[盘点部门] rangeCategoryId[盘点类别]
 rangeLocationId[盘点地点] responsibleById[负责人]
 businessDate[盘点日期] currencyId[币种]
=========>lines[明细行]======
 lines[明细行](2)
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="lines">
                    <view path="/erp/ast/pages/ErpAstInventoryLine/ErpAstInventoryLine.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="edit">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[盘点单号] name[盘点名称]
 orgId[业务组织] status[状态]
 rangeDepartmentId[盘点部门] rangeCategoryId[盘点类别]
 rangeLocationId[盘点地点] responsibleById[负责人]
 businessDate[盘点日期] currencyId[币种]
=========>lines[明细行]======
 lines[明细行](2)
 remark[备注](2)
            </layout>
            <cells>
                <cell id="lines">
                    <view path="/erp/ast/pages/ErpAstInventoryLine/ErpAstInventoryLine.view.xml" grid="sub-grid-edit"/>
                </cell>
            </cells>
        </form>
        <form id="add" x:prototype="edit" editMode="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>