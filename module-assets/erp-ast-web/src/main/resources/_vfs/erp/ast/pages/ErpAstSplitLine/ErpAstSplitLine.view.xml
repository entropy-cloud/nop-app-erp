<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstSplitLine.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="split" label="拆分单编码"/>
                <col id="orgId" label="所属组织"/>
                <col id="lineNo" ui:number="true" sortable="true"/>
                <col id="targetAssetCode" label="目标资产编码"/>
                <col id="targetAssetId" sortable="true"/>
                <col id="categoryId" label="资产类别"/>
                <col id="allocationMethod" sortable="true"/>
                <col id="proportion" sortable="true"/>
                <col id="netBookValue" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>