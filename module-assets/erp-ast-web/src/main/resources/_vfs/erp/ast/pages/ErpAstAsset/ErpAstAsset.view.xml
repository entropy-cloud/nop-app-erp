<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstAsset.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="categoryId" label="资产类别"/>
                <col id="acquisitionDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="currencyId" label="币种"/>
                <col id="originalValue" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="netBookValue" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="departmentId" label="使用部门"/>
                <col id="locationId" label="使用地点"/>
                <col id="employeeId" label="使用人(职员)"/>
                <col id="staffId" label="使用人(往来单位)"/>
            </cols>
        </grid>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="categoryId" label="资产类别"/>
                <col id="netBookValue" ui:number="true" sortable="true"/>
                <col id="status" sortable="true"/>
            </cols>
        </grid>
        <!-- Drawer 相关 crud grid：仅展示直接字段（custom="true" 因为字段属于关联实体 ErpAstDepreciationSchedule）。
             跨域凭证 tab 因 ErpFinVoucherBillR 无 assetId/sourceEntityType 字段，降级 Deferred（见 plan §Deferred）。 -->
        <grid id="archive-depreciation-list">
            <cols>
                <col id="id" custom="true" mandatory="true" ui:number="true" sortable="true" domain="long"/>
                <col id="period" custom="true" sortable="true" domain="string"/>
                <col id="plannedAmount" custom="true" sortable="true" align="right" domain="amount">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualAmount" custom="true" sortable="true" align="right" domain="amount">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="netBookValue" custom="true" sortable="true" align="right" domain="amount">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="status" custom="true" mandatory="true" sortable="true" domain="string"/>
                <col id="posted" custom="true" sortable="true" domain="boolean"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg" layoutControl="tabs">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[资产编码] name[资产名称]
 orgId[所属组织] categoryId[资产类别]
 acquisitionDate[取得日期] status[资产状态]
==========>value[价值信息]======
 currencyId[币种] originalValue[原值]
 currentValue[当前价值] residualValue[残值]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
==========>depreciation[折旧信息]======
 depreciationMethod[折旧方法] depreciationRate[折旧率]
 usefulLifeMonths[使用年限(月)]
==========^usage[使用信息]=========
 departmentId[使用部门] locationId[使用地点]
 employeeId[使用人(职员)] staffId[使用人(往来单位,旧字段保留)]
 brandModel[品牌型号]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg" layoutControl="tabs">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[资产编码] name[资产名称]
 orgId[所属组织] categoryId[资产类别]
 acquisitionDate[取得日期] status[资产状态]
==========>value[价值信息]======
 currencyId[币种] originalValue[原值]
 currentValue[当前价值] residualValue[残值]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
==========>depreciation[折旧信息]======
 depreciationMethod[折旧方法] depreciationRate[折旧率]
 usefulLifeMonths[使用年限(月)]
==========>usage[使用信息]======
 departmentId[使用部门] locationId[使用地点]
 employeeId[使用人(职员)] staffId[使用人(往来单位,旧字段保留)]
 brandModel[品牌型号]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[资产编码] name[资产名称]
 status[资产状态] categoryId[资产类别]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="status" filterOp="eq"/>
                <cell id="categoryId" filterOp="eq"/>
            </cells>
        </form>
        <form id="pick-query" editMode="query" title="查询条件">
            <layout>
 code[资产编码] name[资产名称]
 categoryId[资产类别] status[资产状态]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="categoryId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-view-asset-dashboard-button" label="完整仪表板" level="info" icon="fa fa-tachometer"
                        actionType="drawer">
                    <dialog page="assetDashboard" size="xl">
                        <data>
                            <id>${'$'}{id}</id>
                        </data>
                    </dialog>
                </action>
                <action id="row-transfer-button" label="移动" level="primary" icon="fa fa-arrows-alt">
                    <api url="@mutation:ErpAstAsset__save/id"/>
                    <confirmText>移动操作请打开资产卡片详情后在子表中操作</confirmText>
                </action>
                <action id="row-value-adjust-button" label="价值调整" level="primary" icon="fa fa-money">
                    <api url="@mutation:ErpAstAsset__save/id"/>
                    <confirmText>价值调整操作请通过资产价值调整单据进行</confirmText>
                </action>
                <action id="row-dispose-button" label="处置" level="danger" icon="fa fa-times-circle">
                    <api url="@mutation:ErpAstAsset__save/id"/>
                    <confirmText>处置操作请通过资产处置单据进行</confirmText>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>

        <!-- 完整仪表板 drawer（机制 B）：headerForm simple + 折旧时间线 crud tab。
             跨域凭证 tab（assets → finance ErpFinVoucherBillR）Deferred：ErpFinVoucherBillR 无 assetId/sourceEntityType 字段。 -->
        <simple name="assetHeader" form="view">
            <initApi url="@query:ErpAstAsset__get?id=${'$'}{id}" gql:selection="{@formSelection}"/>
        </simple>

        <crud name="assetDepreciation" grid="archive-depreciation-list">
            <table noOperations="true">
                <api url="@query:ErpAstDepreciationSchedule__findPage/{@pageSelection}?filter_assetId=${'$'}{id}"/>
            </table>
        </crud>

        <tabs name="assetDashboard" mountOnEnter="true" unmountOnExit="false">
            <tab name="header" page="assetHeader" title="基本信息"/>
            <tab name="depreciation" page="assetDepreciation" title="折旧时间线"/>
        </tabs>

        <picker name="picker" filterForm="pick-query"/>
    </pages>
</view>