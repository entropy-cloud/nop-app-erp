<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstValueAdjustment.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="asset" label="资产编码"/>
                <col id="currencyId" label="币种"/>
                <col id="businessDate" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="adjustmentType" sortable="true"/>
                <col id="adjustmentAmount" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 2 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[调整单号] orgId[业务组织]
 assetId[资产] businessDate[业务日期]
 adjustmentType[调整类型] adjustmentAmount[调整金额]
 reason[调整原因]
=========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
 approvedBy[审核人] approvedAt[审核时间]
=========>posting[过账信息]======
 posted[已过账] postedAt[过账时间]
 postedBy[过账人]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[调整单号] orgId[业务组织]
 assetId[资产] businessDate[业务日期]
 adjustmentType[调整类型] adjustmentAmount[调整金额]
 reason[调整原因]
=========>amount[金额信息]======
 currencyId[币种] exchangeRate[汇率]
 amountSource[源币种金额] amountFunctional[本位币金额]
=========>status[状态信息]======
 docStatus[单据状态] approveStatus[审核状态]
 approvedBy[审核人] approvedAt[审核时间]
=========>posting[过账信息]======
 posted[已过账] postedAt[过账时间]
 postedBy[过账人]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[调整单号] docStatus[单据状态]
 approveStatus[审核状态] assetId[资产]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="docStatus" filterOp="eq"/>
                <cell id="approveStatus" filterOp="eq"/>
                <cell id="assetId" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpAstValueAdjustment__submitForApproval?id=$id"/>
                    <confirmText>确认提交此资产价值调整审批？</confirmText>
                    <messages>
                        <success>资产价值调整已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-withdraw-approval-button" label="撤回提交" level="default" icon="fa fa-mail-reply">
                    <api url="@mutation:ErpAstValueAdjustment__withdrawApproval?id=$id"/>
                    <confirmText>确认撤回此资产价值调整的提交？撤回后单据将回到未提交状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>资产价值调整已撤回提交</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpAstValueAdjustment__approve?id=$id"/>
                    <confirmText>确认批准此资产价值调整？</confirmText>
                    <messages>
                        <success>资产价值调整已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpAstValueAdjustment__reject?id=$id"/>
                    <confirmText>确认驳回此资产价值调整？</confirmText>
                    <messages>
                        <success>资产价值调整已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reverse-approve-button" label="反审批" level="info" icon="fa fa-undo">
                    <api url="@mutation:ErpAstValueAdjustment__reverseApprove?id=$id"/>
                    <confirmText>确认反审批此资产价值调整？反审批后单据将回到驳回状态，可重新编辑提交。</confirmText>
                    <messages>
                        <success>资产价值调整已反审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>