<?xml version="1.0" encoding="UTF-8" ?>
<auth x:extends="_erp-ast.action-auth.xml" x:schema="/nop/schema/action-auth.xdef"
     xmlns:x="/nop/schema/xdsl.xdef" xmlns:i18n-en="i18n-en" xmlns:app="app">

    <site id="main">
        <!-- 删除自动生成的测试菜单根 -->
        <resource id="test-orm-erp-ast" x:override="remove"/>

        <!-- 固定资产管理:assets域一级菜单 -->
        <resource id="erp-ast" displayName="固定资产管理" i18n-en:displayName="Fixed Assets"
                  icon="truck" resourceType="TOPM" orderNo="600"
                  routePath="/erp-ast" component="layouts/default/index">
            <children>
                <!-- 资产台账 -->
                <resource id="ast-ledger" displayName="资产台账" i18n-en:displayName="Asset Ledger"
                          icon="truck" resourceType="SUBM" orderNo="100">
                    <children>
                        <resource id="ErpAstAsset-main" app:useCases="UC-AST-01,UC-AST-02,UC-AST-03,UC-AST-04,UC-AST-05" displayName="固定资产"
                                  i18n-en:displayName="Fixed Asset" icon="truck"
                                  component="AMIS" resourceType="SUBM" orderNo="100"
                                  url="/erp/ast/pages/ErpAstAsset/main.page.yaml"/>
                        <resource id="ErpAstAssetCategory-main" app:useCases="UC-AST-01" displayName="资产类别"
                                  i18n-en:displayName="Asset Category" icon="folder-tree"
                                  component="AMIS" resourceType="SUBM" orderNo="110"
                                  url="/erp/ast/pages/ErpAstAssetCategory/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 折旧 -->
                <resource id="ast-depreciation" displayName="折旧" i18n-en:displayName="Depreciation"
                          icon="trending-down" resourceType="SUBM" orderNo="200">
                    <children>
                        <resource id="ErpAstDepreciationSchedule-main" app:useCases="UC-AST-02,UC-AST-07,UC-AST-08" displayName="折旧计划"
                                  i18n-en:displayName="Depreciation Schedule" icon="trending-down"
                                  component="AMIS" resourceType="SUBM" orderNo="200"
                                  url="/erp/ast/pages/ErpAstDepreciationSchedule/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 资产变动 -->
                <resource id="ast-movement" displayName="资产变动" i18n-en:displayName="Asset Movement"
                          icon="move" resourceType="SUBM" orderNo="300">
                    <children>
                        <resource id="ErpAstMovement-main" app:useCases="UC-AST-03" displayName="资产移动"
                                  i18n-en:displayName="Asset Movement" icon="move"
                                  component="AMIS" resourceType="SUBM" orderNo="300"
                                  url="/erp/ast/pages/ErpAstMovement/main.page.yaml"/>
                        <resource id="ErpAstValueAdjustment-main" app:useCases="UC-AST-02" displayName="资产价值调整"
                                  i18n-en:displayName="Asset Value Adjustment" icon="sliders-horizontal"
                                  component="AMIS" resourceType="SUBM" orderNo="310"
                                  url="/erp/ast/pages/ErpAstValueAdjustment/main.page.yaml"/>
                        <resource id="ErpAstSplit-main" app:useCases="UC-AST-11" displayName="资产拆分单"
                                  i18n-en:displayName="Asset Split" icon="split"
                                  component="AMIS" resourceType="SUBM" orderNo="320"
                                  url="/erp/ast/pages/ErpAstSplit/main.page.yaml"/>
                        <resource id="ErpAstMerge-main" app:useCases="UC-AST-11" displayName="资产合并单"
                                  i18n-en:displayName="Asset Merge" icon="git-merge"
                                  component="AMIS" resourceType="SUBM" orderNo="330"
                                  url="/erp/ast/pages/ErpAstMerge/main.page.yaml"/>
                    
                        <resource id="asset-repair" app:useCases="UC-AST-10" displayName="资产维修"
                                  i18n-en:displayName="Asset Repair" icon="wrench"
                                  component="AMIS" resourceType="SUBM" orderNo="350"
                                  url="/erp/ast/pages/asset-repair/main.page.yaml"/></children>
                </resource>
                <!-- 处置资本化 -->
                <resource id="ast-disposal" displayName="处置资本化" i18n-en:displayName="Disposal &amp; Capitalization"
                          icon="trash-2" resourceType="SUBM" orderNo="400">
                    <children>
                        <resource id="ErpAstDisposal-main" app:useCases="UC-AST-04,UC-AST-05" displayName="资产处置"
                                  i18n-en:displayName="Asset Disposal" icon="trash-2"
                                  component="AMIS" resourceType="SUBM" orderNo="400"
                                  url="/erp/ast/pages/ErpAstDisposal/main.page.yaml"/>
                        <resource id="ErpAstAssetCapitalization-main" app:useCases="UC-AST-01,UC-AST-06" displayName="资产资本化"
                                  i18n-en:displayName="Asset Capitalization" icon="badge-plus"
                                  component="AMIS" resourceType="SUBM" orderNo="410"
                                  url="/erp/ast/pages/ErpAstAssetCapitalization/main.page.yaml"/>
                        <resource id="ErpAstCip-main" app:useCases="UC-AST-06" displayName="在建工程"
                                  i18n-en:displayName="CIP" icon="hard-hat"
                                  component="AMIS" resourceType="SUBM" orderNo="420"
                                  url="/erp/ast/pages/ErpAstCip/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 资产盘点 -->
                <resource id="ast-stocktake" displayName="资产盘点" i18n-en:displayName="Asset Stocktake"
                          icon="clipboard-list" resourceType="SUBM" orderNo="600">
                    <children>
                        <resource id="asset-stocktake" app:useCases="UC-AST-09" displayName="资产盘点单"
                                  i18n-en:displayName="Asset Stocktake" icon="clipboard-list"
                                  component="AMIS" resourceType="SUBM" orderNo="6010"
                                  url="/erp/ast/pages/asset-stocktake/main.page.yaml"/>
                    </children>
                </resource>
                <!-- 报表看板 -->
                <resource id="ast-dashboard" displayName="资产概览" i18n-en:displayName="Assets Overview"
                          icon="truck" resourceType="SUBM" orderNo="999">
                    <children>
                        <resource id="ast-dashboard-main" app:useCases="UC-AST-12" displayName="资产概览"
                                  i18n-en:displayName="Assets Overview" icon="truck"
                                  component="AMIS" resourceType="SUBM" orderNo="9990"
                                  url="/erp/ast/pages/dashboard/main.page.yaml"/>
                    </children>
                </resource>
            </children>
        </resource>
    </site>
</auth>
