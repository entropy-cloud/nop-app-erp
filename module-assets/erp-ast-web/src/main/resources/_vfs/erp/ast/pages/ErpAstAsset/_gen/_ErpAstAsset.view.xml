<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpAstAsset" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ast/model/ErpAstAsset/ErpAstAsset.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--资产编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--资产名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--资产类别-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--取得日期-->
                <col id="acquisitionDate" mandatory="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--原值-->
                <col id="originalValue" mandatory="true" ui:number="true" sortable="true"/>

                <!--当前价值-->
                <col id="currentValue" ui:number="true" sortable="true"/>

                <!--残值-->
                <col id="residualValue" ui:number="true" sortable="true"/>

                <!--折旧方法-->
                <col id="depreciationMethod" sortable="true"/>

                <!--折旧率-->
                <col id="depreciationRate" ui:number="true" sortable="true"/>

                <!--使用年限(月)-->
                <col id="usefulLifeMonths" ui:number="true" sortable="true"/>

                <!--使用部门-->
                <col id="departmentId" ui:number="true" sortable="true"/>

                <!--使用地点-->
                <col id="locationId" ui:number="true" sortable="true"/>

                <!--使用人(职员)-->
                <col id="employeeId" ui:number="true" sortable="true"/>

                <!--使用人(往来单位,旧字段保留)-->
                <col id="staffId" ui:number="true" sortable="true"/>

                <!--品牌型号-->
                <col id="brandModel" sortable="true"/>

                <!--资产状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--累计折旧-->
                <col id="accumulatedDepreciation" ui:number="true" sortable="true"/>

                <!--净值-->
                <col id="netBookValue" ui:number="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgName"/>

                <!--资产类别-->
                <col id="categoryName"/>

                <!--币种-->
                <col id="currencyName"/>

                <!--使用部门-->
                <col id="departmentName"/>

                <!--使用地点-->
                <col id="locationName"/>

                <!--使用人(职员)-->
                <col id="employeeName"/>

                <!--使用人(往来单位)-->
                <col id="staffName"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-固定资产" i18n-en:title="View Fixed Asset">
            <layout>
 code[资产编码] name[资产名称]
 orgId[所属组织] categoryId[资产类别]
 acquisitionDate[取得日期] currencyId[币种]
 originalValue[原值] currentValue[当前价值]
 residualValue[残值] depreciationMethod[折旧方法]
 depreciationRate[折旧率] usefulLifeMonths[使用年限(月)]
 departmentId[使用部门] locationId[使用地点]
 employeeId[使用人(职员)] staffId[使用人(往来单位,旧字段保留)]
 brandModel[品牌型号] status[资产状态]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
 accumulatedDepreciation[累计折旧] netBookValue[净值]
 orgName[所属组织] categoryName[资产类别]
 currencyName[币种] departmentName[使用部门]
 locationName[使用地点] employeeName[使用人(职员)]
 staffName[使用人(往来单位)] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-固定资产" i18n-en:title="Add Fixed Asset" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-固定资产" i18n-en:title="Edit Fixed Asset">
            <layout>
 code[资产编码] name[资产名称]
 orgId[所属组织] categoryId[资产类别]
 acquisitionDate[取得日期] currencyId[币种]
 originalValue[原值] currentValue[当前价值]
 residualValue[残值] depreciationMethod[折旧方法]
 depreciationRate[折旧率] usefulLifeMonths[使用年限(月)]
 departmentId[使用部门] locationId[使用地点]
 employeeId[使用人(职员)] staffId[使用人(往来单位,旧字段保留)]
 brandModel[品牌型号] status[资产状态]
 remark[备注] accumulatedDepreciation[累计折旧]
 netBookValue[净值] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-固定资产" i18n-en:title="Update Fixed Asset"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstAsset__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstAsset__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpAstAsset__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpAstAsset__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpAstAsset__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpAstAsset__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpAstAsset__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpAstAsset__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpAstAsset__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpAstAsset__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>