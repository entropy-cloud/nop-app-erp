<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstCip.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="categoryId" label="资产类别"/>
                <col id="currencyId" label="币种"/>
                <col id="businessDate" sortable="true"/>
                <col id="accumulatedCost" sortable="true"/>
                <col id="isCompleted" sortable="true"/>
                <col id="completedAsset" label="转固资产编码"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="projectId" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>