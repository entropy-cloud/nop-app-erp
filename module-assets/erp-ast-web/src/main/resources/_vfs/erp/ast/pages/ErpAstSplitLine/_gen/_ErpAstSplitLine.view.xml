<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpAstSplitLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ast/model/ErpAstSplitLine/ErpAstSplitLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--拆分单-->
                <col id="splitId" mandatory="true" ui:number="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" ui:number="true" sortable="true"/>

                <!--拆分单编码-->
                <col id="splitCode"/>

                <!--所属组织-->
                <col id="orgName"/>

                <!--资产类别-->
                <col id="categoryName"/>

                <!--目标资产编码-->
                <col id="targetAssetCode" mandatory="true"/>

                <!--目标资产名称-->
                <col id="targetAssetName" sortable="true"/>

                <!--目标资产类别-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--分摊方式-->
                <col id="allocationMethod" sortable="true"/>

                <!--比例-->
                <col id="proportion" ui:number="true" sortable="true"/>

                <!--原值金额-->
                <col id="originalCostAmount" mandatory="true" ui:number="true" sortable="true"/>

                <!--累计折旧金额-->
                <col id="accumulatedDepreciationAmount" ui:number="true" sortable="true"/>

                <!--账面净值-->
                <col id="netBookValue" ui:number="true" sortable="true"/>

                <!--目标资产-->
                <col id="targetAssetId" ui:number="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-资产拆分行" i18n-en:title="View Asset Split Line">
            <layout>
 splitId[拆分单] orgId[所属组织]
 lineNo[行号] splitCode[拆分单编码]
 orgName[所属组织] categoryName[资产类别]
 targetAssetCode[目标资产编码] targetAssetName[目标资产名称]
 categoryId[目标资产类别] allocationMethod[分摊方式]
 proportion[比例] originalCostAmount[原值金额]
 accumulatedDepreciationAmount[累计折旧金额] netBookValue[账面净值]
 targetAssetId[目标资产] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-资产拆分行" i18n-en:title="Add Asset Split Line" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-资产拆分行" i18n-en:title="Edit Asset Split Line">
            <layout>
 splitId[拆分单] orgId[所属组织]
 lineNo[行号] targetAssetCode[目标资产编码]
 targetAssetName[目标资产名称] categoryId[目标资产类别]
 allocationMethod[分摊方式] proportion[比例]
 originalCostAmount[原值金额] accumulatedDepreciationAmount[累计折旧金额]
 netBookValue[账面净值] targetAssetId[目标资产]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-资产拆分行"
              i18n-en:title="Update Asset Split Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstSplitLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstSplitLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpAstSplitLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpAstSplitLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpAstSplitLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpAstSplitLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpAstSplitLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpAstSplitLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpAstSplitLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpAstSplitLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>