<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpAstCip" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ast/model/ErpAstCip/ErpAstCip.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--工程编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--工程名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--预定资产类别(完工后转入)-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--开工日期-->
                <col id="businessDate" mandatory="true" sortable="true"/>

                <!--预计完工日期-->
                <col id="estimatedCompletionDate" sortable="true"/>

                <!--累计归集成本-->
                <col id="accumulatedCost" ui:number="true" sortable="true"/>

                <!--是否已转固-->
                <col id="isCompleted" sortable="true"/>

                <!--完工转出资产-->
                <col id="completedAssetId" ui:number="true" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--关联项目(可空)-->
                <col id="projectId" ui:number="true" sortable="true"/>

                <!--转固时类别快照-->
                <col id="cipAssetCategorySnapshot" sortable="true"/>

                <!--是否已过账-->
                <col id="posted" sortable="true"/>

                <!--过账时间-->
                <col id="postedAt" sortable="true"/>

                <!--过账人-->
                <col id="postedBy" sortable="true"/>

                <!--汇率-->
                <col id="exchangeRate" mandatory="true" ui:number="true" sortable="true"/>

                <!--源币种金额-->
                <col id="amountSource" ui:number="true" sortable="true"/>

                <!--本位币金额-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-在建工程" i18n-en:title="View CIP">
            <layout>
 code[工程编码] name[工程名称]
 orgId[所属组织] categoryId[预定资产类别(完工后转入)]
 currencyId[币种] businessDate[开工日期]
 estimatedCompletionDate[预计完工日期] accumulatedCost[累计归集成本]
 isCompleted[是否已转固] completedAssetId[完工转出资产]
 status[状态] delVersion[逻辑删除版本]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
 remark[备注] projectId[关联项目(可空)]
 cipAssetCategorySnapshot[转固时类别快照] posted[是否已过账]
 postedAt[过账时间] postedBy[过账人]
 exchangeRate[汇率] amountSource[源币种金额]
 amountFunctional[本位币金额] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-在建工程" i18n-en:title="Add CIP" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-在建工程" i18n-en:title="Edit CIP">
            <layout>
 code[工程编码] name[工程名称]
 orgId[所属组织] categoryId[预定资产类别(完工后转入)]
 currencyId[币种] businessDate[开工日期]
 estimatedCompletionDate[预计完工日期] accumulatedCost[累计归集成本]
 isCompleted[是否已转固] completedAssetId[完工转出资产]
 status[状态] remark[备注]
 projectId[关联项目(可空)] cipAssetCategorySnapshot[转固时类别快照]
 exchangeRate[汇率] amountSource[源币种金额]
 amountFunctional[本位币金额] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-在建工程" i18n-en:title="Update CIP"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstCip__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstCip__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpAstCip__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpAstCip__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpAstCip__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpAstCip__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpAstCip__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpAstCip__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpAstCip__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpAstCip__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>