<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpAstInventoryLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/ast/model/ErpAstInventoryLine/ErpAstInventoryLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--盘点单-->
                <col id="inventoryId" mandatory="true" ui:number="true" sortable="true"/>

                <!--所属组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" ui:number="true" sortable="true"/>

                <!--账面资产-->
                <col id="assetId" ui:number="true" sortable="true"/>

                <!--资产编码快照-->
                <col id="assetCodeSnapshot" sortable="true"/>

                <!--资产名称快照-->
                <col id="assetNameSnapshot" sortable="true"/>

                <!--资产类别-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--账面数量-->
                <col id="bookQuantity" ui:number="true" sortable="true"/>

                <!--实盘数量-->
                <col id="actualQuantity" ui:number="true" sortable="true"/>

                <!--差异数量-->
                <col id="varianceQuantity" ui:number="true" sortable="true"/>

                <!--差异类型-->
                <col id="varianceType" sortable="true"/>

                <!--账面价值-->
                <col id="bookValue" ui:number="true" sortable="true"/>

                <!--评估价值-->
                <col id="assessedValue" ui:number="true" sortable="true"/>

                <!--差异金额-->
                <col id="varianceAmount" ui:number="true" sortable="true"/>

                <!--差异处置-->
                <col id="disposition" sortable="true"/>

                <!--盘盈新建资产-->
                <col id="newAssetId" ui:number="true" sortable="true"/>

                <!--盘盈资本化单-->
                <col id="capitalizationId" ui:number="true" sortable="true"/>

                <!--盘亏处置单-->
                <col id="disposalId" ui:number="true" sortable="true"/>

                <!--调查备注-->
                <col id="investigatedRemark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-资产盘点行" i18n-en:title="View Asset Inventory Line">
            <layout>
 id[ID] inventoryId[盘点单]
 orgId[所属组织] lineNo[行号]
 assetId[账面资产] assetCodeSnapshot[资产编码快照]
 assetNameSnapshot[资产名称快照] categoryId[资产类别]
 bookQuantity[账面数量] actualQuantity[实盘数量]
 varianceQuantity[差异数量] varianceType[差异类型]
 bookValue[账面价值] assessedValue[评估价值]
 varianceAmount[差异金额] disposition[差异处置]
 newAssetId[盘盈新建资产] capitalizationId[盘盈资本化单]
 disposalId[盘亏处置单] investigatedRemark[调查备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-资产盘点行" i18n-en:title="Add Asset Inventory Line" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-资产盘点行" i18n-en:title="Edit Asset Inventory Line">
            <layout>
 id[ID] inventoryId[盘点单]
 orgId[所属组织] lineNo[行号]
 assetId[账面资产] assetCodeSnapshot[资产编码快照]
 assetNameSnapshot[资产名称快照] categoryId[资产类别]
 bookQuantity[账面数量] actualQuantity[实盘数量]
 varianceQuantity[差异数量] varianceType[差异类型]
 bookValue[账面价值] assessedValue[评估价值]
 varianceAmount[差异金额] disposition[差异处置]
 newAssetId[盘盈新建资产] capitalizationId[盘盈资本化单]
 disposalId[盘亏处置单] investigatedRemark[调查备注]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-资产盘点行"
              i18n-en:title="Update Asset Inventory Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstInventoryLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpAstInventoryLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpAstInventoryLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpAstInventoryLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpAstInventoryLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpAstInventoryLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpAstInventoryLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpAstInventoryLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpAstInventoryLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpAstInventoryLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>