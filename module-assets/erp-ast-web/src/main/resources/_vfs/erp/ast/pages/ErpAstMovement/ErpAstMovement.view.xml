<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstMovement.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="所属组织"/>
                <col id="assetCode" label="资产编码"/>
                <col id="businessDate" sortable="true"/>
                <col id="fromDepartmentName" label="源部门"/>
                <col id="toDepartmentName" label="目标部门"/>
                <col id="fromStaffName" label="源使用人"/>
                <col id="toStaffName" label="目标使用人"/>
                <col id="fromLocationName" label="源地点"/>
                <col id="toLocationName" label="目标地点"/>
                <col id="handlerName" label="经办人"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="currencyName" label="币种"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>