<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpAstMovement.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="所属组织"/>
                <col id="asset" label="资产编码"/>
                <col id="businessDate" sortable="true"/>
                <col id="fromDepartmentId" label="源部门"/>
                <col id="toDepartmentId" label="目标部门"/>
                <col id="fromStaffId" label="源使用人"/>
                <col id="toStaffId" label="目标使用人"/>
                <col id="fromLocationId" label="源地点"/>
                <col id="toLocationId" label="目标地点"/>
                <col id="handlerId" label="经办人"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="currencyId" label="币种"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>