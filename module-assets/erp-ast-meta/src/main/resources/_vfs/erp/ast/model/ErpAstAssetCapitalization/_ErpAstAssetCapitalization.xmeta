            <schema type="java.time.LocalDate"/>
        </prop>
        <prop name="originalValue" displayName="原值" propId="9" mandatory="true" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema domain="amount" type="java.math.BigDecimal" precision="20" scale="4"/>
        </prop>
        <prop name="sourceType" displayName="来源类型" propId="10" mandatory="true" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema type="java.lang.Integer" dict="erp-ast/capitalization-source-type"/>
        </prop>
        <prop name="sourceCode" displayName="来源单号" propId="11" queryable="true" sortable="true" insertable="true"
              updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="docStatus" displayName="单据状态" propId="12" mandatory="true" queryable="true" sortable="true"
