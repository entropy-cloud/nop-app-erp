            <schema type="java.lang.Integer" dict="erp-ast/doc-status"/>
        </prop>
        <prop name="approveStatus" displayName="审核状态" propId="13" mandatory="true" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema type="java.lang.Integer" dict="erp-ast/approve-status"/>
        </prop>
        <prop name="posted" displayName="已过账" propId="14" queryable="true" sortable="true" insertable="true"
