                <column code="ORDER_BILL_CODE" displayName="生成单据号" name="orderBillCode" precision="50" propId="17"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Order Bill Code"/>
                <column code="STATUS" displayName="状态" mandatory="true" name="status" propId="18" stdDataType="int"
                        stdSqlType="INTEGER" ext:dict="erp-drp/drp-line-status" i18n-en:displayName="Status"/>
                <column code="ORG_ID" displayName="业务组织" name="orgId" propId="19" stdDataType="long" stdSqlType="BIGINT"
