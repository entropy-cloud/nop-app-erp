                <column code="NET_REQUIREMENT" displayName="净需求" domain="quantity" name="netRequirement" precision="20"
                        propId="13" scale="4" stdDataType="decimal" stdSqlType="DECIMAL"
                        i18n-en:displayName="Net Requirement"/>
                <column code="SUGGESTED_QTY" displayName="建议补货量" domain="quantity" name="suggestedQty" precision="20"
