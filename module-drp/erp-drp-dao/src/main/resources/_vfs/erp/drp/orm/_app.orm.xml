<?xml version="1.0" encoding="UTF-8" ?>
<orm ext:registerShortName="true" ext:appName="erp-drp" ext:entityPackageName="app.erp.drp.dao.entity"
     ext:basePackageName="app.erp.drp" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-drp"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" ext:icon="git-branch" xmlns:i18n-en="i18n-en" xmlns:biz="biz"
     x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef" xmlns:ref-i18n-en="ref-i18n-en" xmlns:ext="ext"
     xmlns:orm-gen="orm-gen" xmlns:xpl="xpl" xmlns:ui="ui">

    <x:post-extends x:override="replace">
        <orm-gen:DefaultPostExtends xpl:lib="/nop/orm/xlib/orm-gen.xlib"/>
    </x:post-extends>

    <x:gen-extends x:override="replace">
        <orm-gen:DefaultGenExtends xpl:lib="/nop/orm/xlib/orm-gen.xlib"/>
    </x:gen-extends>

    <dicts>
        <dict label="DRP计划状态" name="erp-drp/drp-plan-status" valueType="int" i18n-en:label="DRP Plan Status">
            <option code="DRAFT" label="草稿" value="10" i18n-en:label="Draft"/>
            <option code="COMPUTED" label="已计算" value="20" i18n-en:label="Computed"/>
            <option code="APPROVED" label="已批准" value="30" i18n-en:label="Approved"/>
            <option code="EXECUTED" label="已执行" value="40" i18n-en:label="Executed"/>
        </dict>
        <dict label="DRP明细行状态" name="erp-drp/drp-line-status" valueType="int" i18n-en:label="DRP Line Status">
            <option code="SUGGESTED" label="建议" value="10" i18n-en:label="Suggested"/>
            <option code="APPROVED" label="已批准" value="20" i18n-en:label="Approved"/>
            <option code="ORDERED" label="已下单" value="30" i18n-en:label="Ordered"/>
            <option code="CANCELLED" label="已取消" value="40" i18n-en:label="Cancelled"/>
        </dict>
        <dict label="补货类型" name="erp-drp/drp-replenishment-type" valueType="int" i18n-en:label="Replenishment Type">
            <option code="TRANSFER" label="仓间调拨" value="10" i18n-en:label="Transfer"/>
            <option code="PURCHASE" label="向供应商采购" value="20" i18n-en:label="Purchase"/>
        </dict>
        <dict label="补货方法" name="erp-drp/drp-replenishment-method" valueType="int" i18n-en:label="Replenishment Method">
            <option code="MIN_MAX" label="最小-最大" value="10" i18n-en:label="Min-Max"/>
            <option code="PERIODIC" label="定期" value="20" i18n-en:label="Periodic"/>
            <option code="LOT_FOR_LOT" label="按需" value="30" i18n-en:label="Lot-for-Lot"/>
        </dict>
    </dicts>

    <domains>
        <domain name="boolFlag" stdSqlType="TINYINT"/>
        <domain name="delVersion" stdSqlType="BIGINT"/>
        <domain name="version" stdSqlType="INTEGER"/>
        <domain name="createTime" stdSqlType="TIMESTAMP"/>
        <domain name="createdBy" precision="50" stdSqlType="VARCHAR"/>
        <domain name="updateTime" stdSqlType="TIMESTAMP"/>
        <domain name="updatedBy" precision="50" stdSqlType="VARCHAR"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="code" precision="50" stdSqlType="VARCHAR"/>
        <domain name="name" precision="200" stdSqlType="VARCHAR"/>
        <domain name="amount" precision="20" scale="4" stdSqlType="DECIMAL"/>
        <domain name="quantity" precision="20" scale="4" stdSqlType="DECIMAL"/>
        <domain name="orderCode" precision="50" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <entity className="app.erp.drp.dao.entity.ErpDrpPlan" createTimeProp="createTime" createrProp="createdBy"
                deleteFlagProp="delVersion" deleteVersionProp="delVersion" displayName="DRP计划"
                name="app.erp.drp.dao.entity.ErpDrpPlan" registerShortName="true" tableName="erp_drp_plan"
                tagSet="gid,erp.drp" updateTimeProp="updateTime" updaterProp="updatedBy" useLogicalDelete="true"
                versionProp="version" ext:icon="git-branch" i18n-en:displayName="DRP Plan">
            <columns>
                <column code="ID" displayName="ID" mandatory="true" name="id" primary="true" propId="1"
                        stdDataType="long" stdSqlType="BIGINT" tagSet="seq-default" i18n-en:displayName="ID"/>
                <column code="CODE" displayName="编号" domain="orderCode" mandatory="true" name="code" precision="50"
                        propId="2" stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Code"/>
                <column code="PLAN_NAME" displayName="计划名称" domain="name" mandatory="true" name="planName"
                        precision="200" propId="3" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Plan Name"/>
                <column code="PERIOD_FROM" displayName="期间开始" mandatory="true" name="periodFrom" propId="4"
                        stdDataType="date" stdSqlType="DATE" i18n-en:displayName="Period From"/>
                <column code="PERIOD_TO" displayName="期间结束" mandatory="true" name="periodTo" propId="5"
                        stdDataType="date" stdSqlType="DATE" i18n-en:displayName="Period To"/>
                <column code="STATUS" displayName="状态" mandatory="true" name="status" propId="6" stdDataType="int"
                        stdSqlType="INTEGER" ext:dict="erp-drp/drp-plan-status" i18n-en:displayName="Status"/>
                <column code="TOTAL_REPLENISHMENT_QTY" displayName="总补货数量" domain="quantity"
                        name="totalReplenishmentQty" precision="20" propId="7" scale="4" stdDataType="decimal"
                        stdSqlType="DECIMAL" i18n-en:displayName="Total Replenishment Qty"/>
                <column code="RUN_AT" displayName="运行时间" name="runAt" propId="8" stdDataType="datetime"
                        stdSqlType="DATETIME" i18n-en:displayName="Run At"/>
                <column code="RUN_BY" displayName="运行人" name="runBy" precision="50" propId="9" stdDataType="string"
                        stdSqlType="VARCHAR" i18n-en:displayName="Run By"/>
                <column code="ORG_ID" displayName="业务组织" name="orgId" propId="10" stdDataType="long" stdSqlType="BIGINT"
                        i18n-en:displayName="Organization"/>
                <column code="REMARK" displayName="备注" domain="remark" name="remark" precision="1000" propId="11"
                        stdDataType="string" stdSqlType="VARCHAR" i18n-en:displayName="Remark"/>
                <column code="DEL_VERSION" defaultValue="0" displayName="逻辑删除版本" domain="delVersion" mandatory="true"
                        name="delVersion" propId="12" stdDataType="long" stdSqlType="BIGINT"
                        i18n-en:displayName="Del Flag"/>
                <column code="VERSION" defaultValue="0" displayName="数据版本" domain="version" mandatory="true"
                        name="version" propId="13" stdDataType="int" stdSqlType="INTEGER" i18n-en:displayName="Version"/>
                <column code="CREATED_BY" displayName="创建人" domain="createdBy" mandatory="true" name="createdBy"
                        precision="50" propId="14" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Created By"/>
                <column code="CREATE_TIME" displayName="创建时间" domain="createTime" mandatory="true" name="createTime"
                        propId="15" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Create Time"/>
                <column code="UPDATED_BY" displayName="修改人" domain="updatedBy" mandatory="true" name="updatedBy"
                        precision="50" propId="16" stdDataType="string" stdSqlType="VARCHAR"
                        i18n-en:displayName="Updated By"/>
                <column code="UPDATE_TIME" displayName="修改时间" domain="updateTime" mandatory="true" name="updateTime"
                        propId="17" stdDataType="timestamp" stdSqlType="TIMESTAMP" i18n-en:displayName="Update Time"/>
            </columns>
            <relations>
                <to-many cascadeDelete="true" name="lines" refEntityName="app.erp.drp.dao.entity.ErpDrpLine"
                         tagSet="pub,cascade-delete,insertable,updatable" i18n-en:displayName="Lines"
                         ref-i18n-en:displayName="DRP Plan">
                    <join>
                        <on leftProp="id" rightProp="planId"/>
                    </join>
                </to-many>
                <to-one name="org" notGenCode="true" refEntityName="app.erp.md.dao.entity.ErpMdOrganization"
                        tagSet="pub" biz:moduleId="erp/md" i18n-en:displayName="Org" ref-i18n-en:displayName="DRP Plan">
                    <join>
                        <on leftProp="orgId" rightProp="id"/>
                    </join>
                </to-one>
            </relations>
        </entity>
