<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvDrpSafetyStockCalc.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="materialId" label="物料"/>
                <col id="warehouseId" label="仓库"/>
                <col id="method" mandatory="true" sortable="true"/>
                <col id="serviceLevel" mandatory="true" sortable="true"/>
                <col id="historyMonths" ui:number="true" sortable="true"/>
                <col id="leadTimeDays" mandatory="true" ui:number="true" sortable="true"/>
                <col id="calculatedSafetyStock" ui:number="true" sortable="true"/>
                <col id="calculatedRop" ui:number="true" sortable="true"/>
                <col id="overrideSafetyStock" ui:number="true" sortable="true"/>
                <col id="lastCalculatedAt" sortable="true"/>
                <col id="overwrittenBy" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] orgId[业务组织]
 materialId[物料] warehouseId[仓库]
=========>method[计算方法]======
 method[计算方法] serviceLevel[服务水平]
 historyMonths[分析月数] leadTimeDays[提前期(天)]
=========>result[计算结果]======
 calculatedSafetyStock[建议安全库存] calculatedRop[建议再订货点]
 overrideSafetyStock[覆盖安全库存] lastCalculatedAt[计算时间]
 overwrittenBy[覆盖人]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] orgId[业务组织]
 materialId[物料] warehouseId[仓库]
=========>method[计算方法]======
 method[计算方法] serviceLevel[服务水平]
 historyMonths[分析月数] leadTimeDays[提前期(天)]
=========>result[计算结果]======
 calculatedSafetyStock[建议安全库存] calculatedRop[建议再订货点]
 overrideSafetyStock[覆盖安全库存] lastCalculatedAt[计算时间]
 overwrittenBy[覆盖人]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编号] orgId[业务组织]
 materialId[物料] warehouseId[仓库]
 method[计算方法]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="warehouseId" filterOp="eq"/>
                <cell id="method" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>