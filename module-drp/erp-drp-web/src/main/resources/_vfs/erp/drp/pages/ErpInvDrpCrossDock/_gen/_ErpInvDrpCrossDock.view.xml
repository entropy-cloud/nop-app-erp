<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpInvDrpCrossDock" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/drp/model/ErpInvDrpCrossDock/ErpInvDrpCrossDock.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--编号-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--DRP行-->
                <col id="drpLineId" ui:number="true" sortable="true"/>

                <!--入站移动单-->
                <col id="inboundMoveId" ui:number="true" sortable="true"/>

                <!--出站移动单-->
                <col id="outboundMoveId" ui:number="true" sortable="true"/>

                <!--来源单据类型-->
                <col id="sourceBillType" sortable="true"/>

                <!--来源单据号-->
                <col id="sourceBillCode" sortable="true"/>

                <!--目标单据类型-->
                <col id="targetBillType" sortable="true"/>

                <!--目标单据号-->
                <col id="targetBillCode" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--越库数量-->
                <col id="quantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--暂存库位-->
                <col id="stagingLocationId" ui:number="true" sortable="true"/>

                <!--月台时间窗口-->
                <col id="dockSlotTime" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--匹配时间-->
                <col id="matchedAt" sortable="true"/>

                <!--装车完成时间-->
                <col id="loadedAt" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-越库执行记录" i18n-en:title="View Cross Dock">
            <layout>
 id[ID] code[编号]
 orgId[业务组织] drpLineId[DRP行]
 inboundMoveId[入站移动单] outboundMoveId[出站移动单]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 targetBillType[目标单据类型] targetBillCode[目标单据号]
 materialId[物料] quantity[越库数量]
 stagingLocationId[暂存库位] dockSlotTime[月台时间窗口]
 status[状态] matchedAt[匹配时间]
 loadedAt[装车完成时间] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-越库执行记录" i18n-en:title="Add Cross Dock">
            <layout>
 id[ID] code[编号]
 orgId[业务组织] drpLineId[DRP行]
 inboundMoveId[入站移动单] outboundMoveId[出站移动单]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 targetBillType[目标单据类型] targetBillCode[目标单据号]
 materialId[物料] quantity[越库数量]
 stagingLocationId[暂存库位] dockSlotTime[月台时间窗口]
 status[状态] matchedAt[匹配时间]
 loadedAt[装车完成时间] remark[备注]
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-越库执行记录" i18n-en:title="Edit Cross Dock">
            <layout>
 id[ID] code[编号]
 orgId[业务组织] drpLineId[DRP行]
 inboundMoveId[入站移动单] outboundMoveId[出站移动单]
 sourceBillType[来源单据类型] sourceBillCode[来源单据号]
 targetBillType[目标单据类型] targetBillCode[目标单据号]
 materialId[物料] quantity[越库数量]
 stagingLocationId[暂存库位] dockSlotTime[月台时间窗口]
 status[状态] matchedAt[匹配时间]
 loadedAt[装车完成时间] remark[备注]
 delVersion[逻辑删除版本] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-越库执行记录" i18n-en:title="Update Cross Dock"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvDrpCrossDock__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvDrpCrossDock__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpInvDrpCrossDock__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpInvDrpCrossDock__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpInvDrpCrossDock__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpInvDrpCrossDock__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpInvDrpCrossDock__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpInvDrpCrossDock__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpInvDrpCrossDock__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpInvDrpCrossDock__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>