<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpInvDrpLeadTimeRecord" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/drp/model/ErpInvDrpLeadTimeRecord/ErpInvDrpLeadTimeRecord.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--供应商-->
                <col id="supplierId" mandatory="true" ui:number="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--订单日期-->
                <col id="orderDate" mandatory="true" sortable="true"/>

                <!--入库日期-->
                <col id="receiptDate" mandatory="true" sortable="true"/>

                <!--实际提前期(天)-->
                <col id="actualLeadTime" mandatory="true" ui:number="true" sortable="true"/>

                <!--预期提前期(天)-->
                <col id="expectedLeadTime" ui:number="true" sortable="true"/>

                <!--偏差天数-->
                <col id="varianceDays" ui:number="true" sortable="true"/>

                <!--采购单号-->
                <col id="purchaseOrderCode" sortable="true"/>

                <!--是否准时-->
                <col id="isOnTime" sortable="true"/>

                <!--提前/延迟标记-->
                <col id="earlyLateFlag" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-提前期记录" i18n-en:title="View Lead Time Record">
            <layout>
 orgId[业务组织] supplierId[供应商]
 materialId[物料] orderDate[订单日期]
 receiptDate[入库日期] actualLeadTime[实际提前期(天)]
 expectedLeadTime[预期提前期(天)] varianceDays[偏差天数]
 purchaseOrderCode[采购单号] isOnTime[是否准时]
 earlyLateFlag[提前/延迟标记] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-提前期记录" i18n-en:title="Add Lead Time Record" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-提前期记录" i18n-en:title="Edit Lead Time Record">
            <layout>
 orgId[业务组织] supplierId[供应商]
 materialId[物料] orderDate[订单日期]
 receiptDate[入库日期] actualLeadTime[实际提前期(天)]
 expectedLeadTime[预期提前期(天)] varianceDays[偏差天数]
 purchaseOrderCode[采购单号] isOnTime[是否准时]
 earlyLateFlag[提前/延迟标记] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-提前期记录"
              i18n-en:title="Update Lead Time Record"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvDrpLeadTimeRecord__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpInvDrpLeadTimeRecord__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpInvDrpLeadTimeRecord__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpInvDrpLeadTimeRecord__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpInvDrpLeadTimeRecord__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpInvDrpLeadTimeRecord__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpInvDrpLeadTimeRecord__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpInvDrpLeadTimeRecord__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpInvDrpLeadTimeRecord__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpInvDrpLeadTimeRecord__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>