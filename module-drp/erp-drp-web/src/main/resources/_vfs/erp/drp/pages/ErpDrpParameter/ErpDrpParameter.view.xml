<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpDrpParameter.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="warehouseId" label="仓库"/>
                <col id="materialId" label="物料"/>
                <col id="safetyStock" ui:number="true" sortable="true"/>
                <col id="replenishmentLeadTime" ui:number="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orderMultiple" ui:number="true" sortable="true"/>
                <col id="preferredSourceWarehouseId" label="首选调出仓库"/>
                <col id="preferredSupplierId" label="首选供应商"/>
                <col id="replenishmentMethod" mandatory="true" sortable="true"/>
                <col id="minStockLevel" ui:number="true" sortable="true"/>
                <col id="maxStockLevel" ui:number="true" sortable="true"/>
                <col id="reviewPeriodDays" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
        <form id="asideFilter" editMode="query" submitOnChange="true">
            <layout>
 warehouseId[仓库] materialId[物料]
 replenishmentMethod[补货方法] preferredSupplierId[首选供应商]
 orgId[业务组织]
            </layout>
            <cells>
                <cell id="warehouseId" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="replenishmentMethod" filterOp="eq"/>
                <cell id="preferredSupplierId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 preferredSourceWarehouseId[首选调出仓库]
            </layout>
            <cells>
                <cell id="preferredSourceWarehouseId" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>