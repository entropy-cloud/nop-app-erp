<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpDrpParameter.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="warehouseName" label="仓库"/>
                <col id="materialName" label="物料"/>
                <col id="safetyStock" ui:number="true" sortable="true"/>
                <col id="replenishmentLeadTime" ui:number="true" sortable="true"/>
                <col id="orderMultiple" ui:number="true" sortable="true"/>
                <col id="preferredSourceWarehouseName" label="首选调出仓库"/>
                <col id="preferredSupplierName" label="首选供应商"/>
                <col id="replenishmentMethod" mandatory="true" sortable="true"/>
                <col id="minStockLevel" ui:number="true" sortable="true"/>
                <col id="maxStockLevel" ui:number="true" sortable="true"/>
                <col id="reviewPeriodDays" ui:number="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>