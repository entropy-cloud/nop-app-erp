<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpDrpLine.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="planId" label="计划"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="materialId" label="物料"/>
                <col id="warehouseId" label="目标仓库"/>
                <col id="sourceWarehouseId" label="来源仓库"/>
                <col id="replenishmentType" mandatory="true" sortable="true"/>
                <col id="currentStock" ui:number="true" sortable="true"/>
                <col id="allocatedQty" ui:number="true" sortable="true"/>
                <col id="onOrderQty" ui:number="true" sortable="true"/>
                <col id="forecastDemand" ui:number="true" sortable="true"/>
                <col id="safetyStock" ui:number="true" sortable="true"/>
                <col id="netRequirement" ui:number="true" sortable="true"/>
                <col id="suggestedQty" ui:number="true" sortable="true"/>
                <col id="approvedQty" ui:number="true" sortable="true"/>
                <col id="orderBillType" sortable="true"/>
                <col id="orderBillCode" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orgId" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpDrpLine__approveLine?lineId=$id"/>
                    <confirmText>确认批准此补货建议？</confirmText>
                    <messages>
                        <success>补货建议已批准</success>
                    </messages>
                    <visibleOn>${status == 'SUGGESTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpDrpLine__rejectLine?lineId=$id"/>
                    <confirmText>确认驳回此补货建议？</confirmText>
                    <messages>
                        <success>补货建议已驳回</success>
                    </messages>
                    <visibleOn>${status == 'SUGGESTED'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpDrpLine__cancelLine?lineId=$id"/>
                    <confirmText>确认作废此补货建议？</confirmText>
                    <messages>
                        <success>补货建议已作废</success>
                    </messages>
                    <visibleOn>${status == 'SUGGESTED' || status == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>