<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvDrpLeadTimeRecord.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="supplierId" label="供应商"/>
                <col id="materialId" label="物料"/>
                <col id="orderDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="receiptDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="actualLeadTime" mandatory="true" ui:number="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="expectedLeadTime" ui:number="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="varianceDays" ui:number="true" sortable="true"/>
                <col id="purchaseOrderCode" sortable="true"/>
                <col id="isOnTime" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="earlyLateFlag" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] supplierId[供应商]
 materialId[物料]
=========>order[订单信息]======
 orderDate[订单日期] receiptDate[入库日期]
 purchaseOrderCode[采购单号] actualLeadTime[实际提前期(天)]
 expectedLeadTime[预期提前期(天)] varianceDays[偏差天数]
=========>result[结果]======
 isOnTime[是否准时] earlyLateFlag[提前/延迟标记]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 orgId[业务组织] supplierId[供应商]
 materialId[物料]
=========>order[订单信息]======
 orderDate[订单日期] receiptDate[入库日期]
 purchaseOrderCode[采购单号] actualLeadTime[实际提前期(天)]
 expectedLeadTime[预期提前期(天)] varianceDays[偏差天数]
=========>result[结果]======
 isOnTime[是否准时] earlyLateFlag[提前/延迟标记]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 orgId[业务组织] supplierId[供应商]
 materialId[物料] orderDate[订单日期]
 isOnTime[是否准时]
            </layout>
            <cells>
                <cell id="orgId" filterOp="eq"/>
                <cell id="supplierId" filterOp="eq"/>
                <cell id="materialId" filterOp="eq"/>
                <cell id="orderDate" filterOp="date-between"/>
                <cell id="isOnTime" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>