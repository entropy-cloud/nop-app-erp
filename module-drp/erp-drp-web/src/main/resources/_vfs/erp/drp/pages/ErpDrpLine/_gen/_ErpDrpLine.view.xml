<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpDrpLine" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/drp/model/ErpDrpLine/ErpDrpLine.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--计划ID-->
                <col id="planId" mandatory="true" ui:number="true" sortable="true"/>

                <!--行号-->
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--目标仓库-->
                <col id="warehouseId" mandatory="true" ui:number="true" sortable="true"/>

                <!--来源仓库-->
                <col id="sourceWarehouseId" ui:number="true" sortable="true"/>

                <!--补货类型-->
                <col id="replenishmentType" mandatory="true" sortable="true"/>

                <!--当前库存-->
                <col id="currentStock" ui:number="true" sortable="true"/>

                <!--已分配量-->
                <col id="allocatedQty" ui:number="true" sortable="true"/>

                <!--在单量-->
                <col id="onOrderQty" ui:number="true" sortable="true"/>

                <!--预测需求量-->
                <col id="forecastDemand" ui:number="true" sortable="true"/>

                <!--安全库存-->
                <col id="safetyStock" ui:number="true" sortable="true"/>

                <!--净需求-->
                <col id="netRequirement" ui:number="true" sortable="true"/>

                <!--建议补货量-->
                <col id="suggestedQty" ui:number="true" sortable="true"/>

                <!--批准补货量-->
                <col id="approvedQty" ui:number="true" sortable="true"/>

                <!--生成单据类型-->
                <col id="orderBillType" sortable="true"/>

                <!--生成单据号-->
                <col id="orderBillCode" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" sortable="true"/>

                <!--业务组织-->
                <col id="orgId" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-DRP明细" i18n-en:title="View DRP Line">
            <layout>
 id[ID] planId[计划ID]
 lineNo[行号] materialId[物料]
 warehouseId[目标仓库] sourceWarehouseId[来源仓库]
 replenishmentType[补货类型] currentStock[当前库存]
 allocatedQty[已分配量] onOrderQty[在单量]
 forecastDemand[预测需求量] safetyStock[安全库存]
 netRequirement[净需求] suggestedQty[建议补货量]
 approvedQty[批准补货量] orderBillType[生成单据类型]
 orderBillCode[生成单据号] status[状态]
 orgId[业务组织] remark[备注]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-DRP明细" i18n-en:title="Add DRP Line" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-DRP明细" i18n-en:title="Edit DRP Line">
            <layout>
 id[ID] planId[计划ID]
 lineNo[行号] materialId[物料]
 warehouseId[目标仓库] sourceWarehouseId[来源仓库]
 replenishmentType[补货类型] currentStock[当前库存]
 allocatedQty[已分配量] onOrderQty[在单量]
 forecastDemand[预测需求量] safetyStock[安全库存]
 netRequirement[净需求] suggestedQty[建议补货量]
 approvedQty[批准补货量] orderBillType[生成单据类型]
 orderBillCode[生成单据号] status[状态]
 orgId[业务组织] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-DRP明细" i18n-en:title="Update DRP Line"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpDrpLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpDrpLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpDrpLine__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpDrpLine__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpDrpLine__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpDrpLine__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpDrpLine__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpDrpLine__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpDrpLine__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpDrpLine__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>