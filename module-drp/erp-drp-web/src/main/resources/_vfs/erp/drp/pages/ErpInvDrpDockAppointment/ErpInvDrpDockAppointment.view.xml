<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvDrpDockAppointment.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="warehouseName" label="仓库"/>
                <col id="dockName" label="月台"/>
                <col id="appointmentDate" mandatory="true" sortable="true"/>
                <col id="slotStart" mandatory="true" sortable="true"/>
                <col id="slotEnd" mandatory="true" sortable="true"/>
                <col id="crossDockName" label="关联越库"/>
                <col id="carrierInfo" sortable="true"/>
                <col id="status" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
                <col id="orgName" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>