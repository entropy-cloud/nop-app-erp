<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvDrpDockAppointment.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="warehouseId" label="仓库"/>
                <col id="dockId" label="月台"/>
                <col id="appointmentDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="slotStart" mandatory="true" sortable="true"/>
                <col id="slotEnd" mandatory="true" sortable="true"/>
                <col id="crossDockId" label="关联越库"/>
                <col id="carrierInfo" sortable="true"/>
                <col id="status" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="orgId" label="业务组织"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 warehouseId[仓库] dockId[月台]
 orgId[业务组织] appointmentDate[预约日期]
=========>slot[时间窗口]======
 slotStart[时间窗口开始] slotEnd[时间窗口结束]
 crossDockId[关联越库] carrierInfo[承运商信息]
 status[状态]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 warehouseId[仓库] dockId[月台]
 orgId[业务组织] appointmentDate[预约日期]
=========>slot[时间窗口]======
 slotStart[时间窗口开始] slotEnd[时间窗口结束]
 crossDockId[关联越库] carrierInfo[承运商信息]
 status[状态]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 warehouseId[仓库] dockId[月台]
 orgId[业务组织] status[状态]
 appointmentDate[预约日期]
            </layout>
            <cells>
                <cell id="warehouseId" filterOp="eq"/>
                <cell id="dockId" filterOp="eq"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="appointmentDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>