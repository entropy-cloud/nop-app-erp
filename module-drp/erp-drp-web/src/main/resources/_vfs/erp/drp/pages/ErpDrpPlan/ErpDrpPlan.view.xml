<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpDrpPlan.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="periodFrom" mandatory="true" sortable="true"/>
                <col id="periodTo" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalReplenishmentQty" ui:number="true" sortable="true" align="right">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'number', kilometer: true, precision: 4 };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="runAt" sortable="true"/>
                <col id="runBy" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="businessDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] planName[计划名称]
 orgId[业务组织] businessDate[业务日期]
=========>period[期间]======
 periodFrom[期间开始] periodTo[期间结束]
 status[状态]
=========>run[运行信息]======
 runAt[运行时间] runBy[运行人]
 totalReplenishmentQty[总补货数量]
=========>lines[DRP 计算结果行]======
 lines[DRP 计算结果行](2)
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="lines">
                    <view path="/erp/drp/pages/ErpDrpLine/ErpDrpLine.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[编号] planName[计划名称]
 orgId[业务组织] businessDate[业务日期]
=========>period[期间]======
 periodFrom[期间开始] periodTo[期间结束]
 status[状态]
=========>run[运行信息]======
 runAt[运行时间] runBy[运行人]
 totalReplenishmentQty[总补货数量]
=========>lines[DRP 计算结果行]======
 lines[DRP 计算结果行](2)
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
            <cells>
                <cell id="lines">
                    <view path="/erp/drp/pages/ErpDrpLine/ErpDrpLine.view.xml" grid="sub-grid-view"/>
                </cell>
            </cells>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编号] planName[计划名称]
 orgId[业务组织] status[状态]
 businessDate[业务日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="planName" filterOp="like"/>
                <cell id="orgId" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
                <cell id="businessDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <listActions x:override="bounded-merge">
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-run-drp-button" label="运行DRP" level="primary" icon="fa fa-cogs">
                    <api url="@mutation:ErpDrpPlan__runDrp?planId=$id"/>
                    <confirmText>确认运行此 DRP 计算？</confirmText>
                    <messages>
                        <success>DRP 计算已运行</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT' || status == 'COMPUTED'}</visibleOn>
                </action>
                <action id="row-approve-all-button" label="批准全部" level="success" icon="fa fa-check-double">
                    <api url="@mutation:ErpDrpPlan__approvePlan?planId=$id"/>
                    <confirmText>确认批准此计划下全部补货建议？</confirmText>
                    <messages>
                        <success>全部补货建议已批准</success>
                    </messages>
                    <visibleOn>${status == 'COMPUTED'}</visibleOn>
                </action>
                <action id="row-generate-order-button" label="生成单据" level="primary" icon="fa fa-file-text">
                    <api url="@mutation:ErpDrpLine__releaseApproved?planId=$id"/>
                    <confirmText>确认按已批准行生成采购/调拨单？</confirmText>
                    <messages>
                        <success>已按已批准行生成下游单据</success>
                    </messages>
                    <visibleOn>${status == 'APPROVED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>