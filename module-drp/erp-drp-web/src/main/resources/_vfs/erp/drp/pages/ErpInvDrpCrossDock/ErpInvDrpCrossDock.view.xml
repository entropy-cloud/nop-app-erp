<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpInvDrpCrossDock.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="业务组织"/>
                <col id="drpLineId" label="DRP行"/>
                <col id="inboundMoveId" label="入站移动单"/>
                <col id="outboundMoveId" label="出站移动单"/>
                <col id="sourceBillType" sortable="true"/>
                <col id="sourceBillCode" sortable="true"/>
                <col id="targetBillType" sortable="true"/>
                <col id="targetBillCode" sortable="true"/>
                <col id="materialId" label="物料"/>
                <col id="quantity" mandatory="true" ui:number="true" sortable="true"/>
                <col id="stagingLocationId" label="暂存库位"/>
                <col id="dockSlotTime" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="matchedAt" sortable="true"/>
                <col id="loadedAt" sortable="true"/>
                <col id="remark" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>