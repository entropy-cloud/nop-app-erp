<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- DRP 净需求只读聚合服务（plan 2026-07-04-1115-2 Phase 2）：StockBalance/TransferOrder/PurOrder → 净需求输入上下文 -->
    <bean id="app.erp.drp.service.drp.DrpDemandAggregator"
          class="app.erp.drp.service.drp.DrpDemandAggregator"/>

    <!-- DRP 净需求计算引擎（plan 2026-07-04-1115-2 Phase 2）：netRequirement + orderMultiple 取整 + TRANSFER/PURCHASE 决策 → ErpDrpLine -->
    <bean id="app.erp.drp.service.drp.DrpEngine"
          class="app.erp.drp.service.drp.DrpEngine"/>

    <!-- DRP 计划释放服务（plan 2026-07-04-1115-2 Phase 3）：APPROVED 行→调拨单/采购订单，回写 orderBillCode，DrpLine→ORDERED -->
    <bean id="app.erp.drp.service.drp.DrpReleaseService"
          class="app.erp.drp.service.drp.DrpReleaseService"/>

    <!-- 安全库存优化引擎（plan 2026-07-04-1115-2 Phase 4）：STATISTICAL/SIMPLE/DDMRP 三法 → ErpInvDrpSafetyStockCalc -->
    <bean id="app.erp.drp.service.safetystock.SafetyStockEngine"
          class="app.erp.drp.service.safetystock.SafetyStockEngine"/>

    <!-- DRP 仿真引擎（plan 2026-07-22-1000-2 §DRP 对应物；权威：docs/design/manufacturing/simulation-engine.md）：
           ErpDrpSimulationParamResolver = 场景参数变体覆盖解析器（同构 MRP）；
           SimulationDrpEngine = DRP 仿真计算引擎（fork DrpEngine 算法，单次路径零触及零回归）；
           DrpSimulationVersionComparator = DRP 版本对比引擎（2 维 diff）。 -->
    <bean id="app.erp.drp.service.simulation.ErpDrpSimulationParamResolver"
          class="app.erp.drp.service.simulation.ErpDrpSimulationParamResolver"/>
    <bean id="app.erp.drp.service.simulation.SimulationDrpEngine"
          class="app.erp.drp.service.simulation.SimulationDrpEngine"/>
    <bean id="app.erp.drp.service.simulation.DrpSimulationVersionComparator"
          class="app.erp.drp.service.simulation.DrpSimulationVersionComparator"/>
</beans>
