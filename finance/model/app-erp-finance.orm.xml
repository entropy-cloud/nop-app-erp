<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-finance ORM 模型 — 财务域（权威数据模型来源）
  ==================================================
  业务范围：会计凭证（头/借贷分录行）、凭证模板（头/行）、业财回链表、
            会计期间、期间结账状态

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-fin
    - entityPackage:  app.erp.fin.dao.entity
    - 实体类名:        ErpFin<Entity>     （如 ErpFinVoucher、ErpFinVoucherLine、ErpFinAccount、ErpFinVoucherModel）
    - 表名:           erp_fin_<entity>   （如 erp_fin_voucher、erp_fin_voucher_line、erp_fin_account）
    - 字典命名空间:    erp-fin/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（科目表/币种/结算方式）
    - 通过 I*Biz 引用 purchase/sales/inventory 的业务单据（凭证生成的源单），不做 ORM 强引用
    - 处于 DAG 顶层，无下游业务工程依赖

  业财打通机制：
    - 财务工程定义凭证生成接口（IErpFinAcctDocProvider）+ 注册中心（ErpFinAcctDocRegistry）
    - 各业务工程实现自己的 provider（@Component），声明本工程哪些单据类型如何过账
    - 财务过账引擎按 entityName 查 provider，调用 createFacts() 生成凭证
-->
<orm ext:registerShortName="true" ext:appName="app-erp-fin" ext:entityPackageName="app.erp.fin.dao.entity"
     ext:basePackageName="app.erp.fin" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-finance"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="凭证字" name="erp-fin/voucher-type" valueType="int">
            <option code="RECEIPT" label="收" value="0"/>
            <option code="PAYMENT" label="付" value="1"/>
            <option code="TRANSFER" label="转" value="2"/>
        </dict>
        <dict label="凭证状态" name="erp-fin/voucher-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="POSTED" label="已过账" value="1"/>
            <option code="CANCELLED" label="已作废" value="2"/>
        </dict>
        <dict label="借贷方向" name="erp-fin/dc-direction" valueType="int">
            <option code="DEBIT" label="借" value="0"/>
            <option code="CREDIT" label="贷" value="1"/>
        </dict>
        <dict label="业务类型" name="erp-fin/business-type" valueType="int">
            <option code="PURCHASE_INPUT" label="采购入库" value="0"/>
            <option code="SALES_OUTPUT" label="销售出库" value="1"/>
            <option code="AP_INVOICE" label="应付发票" value="2"/>
            <option code="AR_INVOICE" label="应收发票" value="3"/>
            <option code="PAYMENT" label="付款" value="4"/>
            <option code="RECEIPT" label="收款" value="5"/>
            <option code="DEPRECIATION" label="折旧" value="6"/>
            <option code="CAPITALIZATION" label="资本化" value="7"/>
            <option code="DISPOSAL" label="处置" value="8"/>
        </dict>
        <dict label="期间状态" name="erp-fin/period-status" valueType="int">
            <option code="OPEN" label="开启" value="0"/>
            <option code="CLOSING" label="结账中" value="1"/>
            <option code="CLOSED" label="已结账" value="2"/>
        </dict>
        <dict label="账户类型" name="erp-fin/fund-account-type" valueType="int">
            <option code="BANK" label="银行" value="0"/>
            <option code="CASH" label="现金" value="1"/>
            <option code="OTHER" label="其他" value="2"/>
        </dict>
        <dict label="账户状态" name="erp-fin/fund-account-status" valueType="int">
            <option code="ACTIVE" label="启用" value="0"/>
            <option code="INACTIVE" label="停用" value="1"/>
        </dict>
    </dicts>

    <domains>
        <domain name="voucherCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="subjectCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="subjectName" precision="200" stdSqlType="VARCHAR"/>
        <domain name="voucherNo" precision="50" stdSqlType="VARCHAR"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="memo" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="memoTemplate" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="amountExpression" precision="200" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <!-- 会计凭证头 -->
        <entity className="app.erp.fin.dao.entity.ErpFinVoucher"
                displayName="会计凭证" name="app.erp.fin.dao.entity.ErpFinVoucher"
                tableName="erp_fin_voucher" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="凭证号" domainName="voucherCode" mandatory="true"/>
                <column name="voucherType" displayName="凭证字" dictName="erp-fin/voucher-type" mandatory="true"/>
                <column name="voucherDate" displayName="凭证日期" stdSqlType="DATE" mandatory="true"/>
                <column name="voucherNo" displayName="凭证编号" domainName="voucherNo"/>
                <column name="periodId" displayName="会计期间" stdSqlType="BIGINT" mandatory="true"/>
                <column name="totalDebit" displayName="借方合计" domainName="amount" defaultValue="0"/>
                <column name="totalCredit" displayName="贷方合计" domainName="amount" defaultValue="0"/>
                <column name="docStatus" displayName="凭证状态" dictName="erp-fin/voucher-status" mandatory="true"/>
                <column name="postedBy" displayName="过账人" stdSqlType="BIGINT"/>
                <column name="postedAt" displayName="过账时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="period" refEntityName="app.erp.fin.dao.entity.ErpFinAccountingPeriod" joinColumnName="periodId"/>
                <to-many name="lines" refEntityName="app.erp.fin.dao.entity.ErpFinVoucherLine" myFieldName="id" refFieldName="voucherId"/>
                <to-many name="billLinks" refEntityName="app.erp.fin.dao.entity.ErpFinVoucherBillR" myFieldName="id" refFieldName="voucherId"/>
            </relations>
        </entity>

        <!-- 凭证分录行 -->
        <entity className="app.erp.fin.dao.entity.ErpFinVoucherLine"
                displayName="凭证分录行" name="app.erp.fin.dao.entity.ErpFinVoucherLine"
                tableName="erp_fin_voucher_line" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="voucherId" displayName="凭证ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="subjectCode" displayName="科目编码" domainName="subjectCode" mandatory="true"/>
                <column name="subjectName" displayName="科目名称" domainName="subjectName"/>
                <column name="debitAmount" displayName="借方金额" domainName="amount" defaultValue="0"/>
                <column name="creditAmount" displayName="贷方金额" domainName="amount" defaultValue="0"/>
                <column name="currencyId" displayName="币种" stdSqlType="BIGINT" mandatory="true"/>
                <column name="originalAmount" displayName="原币金额" domainName="amount"/>
                <column name="memo" displayName="摘要" domainName="memo"/>
                <column name="partnerId" displayName="往来单位" stdSqlType="BIGINT"/>
                <column name="departmentId" displayName="部门" stdSqlType="BIGINT"/>
                <column name="projectId" displayName="项目" stdSqlType="BIGINT"/>
                <column name="warehouseId" displayName="仓库" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="voucher" refEntityName="app.erp.fin.dao.entity.ErpFinVoucher" joinColumnName="voucherId"/>
                <to-one name="currency" refEntityName="app.erp.md.dao.entity.ErpMdCurrency" joinColumnName="currencyId"/>
                <to-one name="partner" refEntityName="app.erp.md.dao.entity.ErpMdPartner" joinColumnName="partnerId"/>
                <to-one name="department" refEntityName="app.erp.md.dao.entity.ErpMdOrganization" joinColumnName="departmentId"/>
                <to-one name="warehouse" refEntityName="app.erp.md.dao.entity.ErpMdWarehouse" joinColumnName="warehouseId"/>
            </relations>
        </entity>

        <!-- 凭证模板头 -->
        <entity className="app.erp.fin.dao.entity.ErpFinVoucherTemplate"
                displayName="凭证模板" name="app.erp.fin.dao.entity.ErpFinVoucherTemplate"
                tableName="erp_fin_voucher_template" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="模板编码" domainName="voucherCode" mandatory="true"/>
                <column name="name" displayName="模板名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="businessType" displayName="业务类型" dictName="erp-fin/business-type" mandatory="true"/>
                <column name="templateType" displayName="模板类型" stdSqlType="VARCHAR" precision="50"/>
                <column name="isActive" displayName="是否启用" stdSqlType="BOOLEAN" defaultValue="true"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-many name="lines" refEntityName="app.erp.fin.dao.entity.ErpFinVoucherTemplateLine" myFieldName="id" refFieldName="templateId"/>
            </relations>
        </entity>

        <!-- 凭证模板行 -->
        <entity className="app.erp.fin.dao.entity.ErpFinVoucherTemplateLine"
                displayName="凭证模板行" name="app.erp.fin.dao.entity.ErpFinVoucherTemplateLine"
                tableName="erp_fin_voucher_template_line" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="templateId" displayName="模板ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="subjectCode" displayName="科目编码" domainName="subjectCode" mandatory="true"/>
                <column name="dcDirection" displayName="借贷方向" dictName="erp-fin/dc-direction" mandatory="true"/>
                <column name="amountExpression" displayName="金额表达式" domainName="amountExpression"/>
                <column name="memoTemplate" displayName="摘要模板" domainName="memoTemplate"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="template" refEntityName="app.erp.fin.dao.entity.ErpFinVoucherTemplate" joinColumnName="templateId"/>
            </relations>
        </entity>

        <!-- 业财回链表 -->
        <entity className="app.erp.fin.dao.entity.ErpFinVoucherBillR"
                displayName="业财回链" name="app.erp.fin.dao.entity.ErpFinVoucherBillR"
                tableName="erp_fin_voucher_bill_r" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="voucherId" displayName="凭证ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="billType" displayName="单据类型" stdSqlType="VARCHAR" precision="50" mandatory="true"/>
                <column name="billCode" displayName="单据编号" stdSqlType="VARCHAR" precision="50" mandatory="true"/>
                <column name="billLineCode" displayName="单据行号" stdSqlType="VARCHAR" precision="50"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="voucher" refEntityName="app.erp.fin.dao.entity.ErpFinVoucher" joinColumnName="voucherId"/>
            </relations>
        </entity>

        <!-- 会计期间 -->
        <entity className="app.erp.fin.dao.entity.ErpFinAccountingPeriod"
                displayName="会计期间" name="app.erp.fin.dao.entity.ErpFinAccountingPeriod"
                tableName="erp_fin_accounting_period" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="期间编码" domainName="voucherCode" mandatory="true"/>
                <column name="name" displayName="期间名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="year" displayName="年度" stdSqlType="INT" mandatory="true"/>
                <column name="month" displayName="月份" stdSqlType="INT" mandatory="true"/>
                <column name="startDate" displayName="开始日期" stdSqlType="DATE" mandatory="true"/>
                <column name="endDate" displayName="结束日期" stdSqlType="DATE" mandatory="true"/>
                <column name="status" displayName="期间状态" dictName="erp-fin/period-status" mandatory="true"/>
                <column name="closedBy" displayName="结账人" stdSqlType="BIGINT"/>
                <column name="closedAt" displayName="结账时间" stdSqlType="DATETIME"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-many name="statusRecords" refEntityName="app.erp.fin.dao.entity.ErpFinAccountingPeriodStatus" myFieldName="id" refFieldName="periodId"/>
            </relations>
        </entity>

        <!-- 期间结账状态 -->
        <entity className="app.erp.fin.dao.entity.ErpFinAccountingPeriodStatus"
                displayName="期间结账状态" name="app.erp.fin.dao.entity.ErpFinAccountingPeriodStatus"
                tableName="erp_fin_accounting_period_status" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="periodId" displayName="期间ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="totalVouchers" displayName="凭证总数" stdSqlType="INT" defaultValue="0"/>
                <column name="postedVouchers" displayName="已过账凭证数" stdSqlType="INT" defaultValue="0"/>
                <column name="unpostedVouchers" displayName="未过账凭证数" stdSqlType="INT" defaultValue="0"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="period" refEntityName="app.erp.fin.dao.entity.ErpFinAccountingPeriod" joinColumnName="periodId"/>
            </relations>
        </entity>

        <!-- 账户 -->
        <entity className="app.erp.fin.dao.entity.ErpFinFundAccount"
                displayName="账户" name="app.erp.fin.dao.entity.ErpFinFundAccount"
                tableName="erp_fin_fund_account" tag="erp.finance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="账户编码" domainName="voucherCode" mandatory="true"/>
                <column name="name" displayName="账户名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="accountType" displayName="账户类型" dictName="erp-fin/fund-account-type" mandatory="true"/>
                <column name="bankName" displayName="开户银行" stdSqlType="VARCHAR" precision="200"/>
                <column name="bankAccount" displayName="银行账号" stdSqlType="VARCHAR" precision="50"/>
                <column name="currencyId" displayName="币种" stdSqlType="BIGINT" mandatory="true"/>
                <column name="openingBalance" displayName="期初余额" domainName="amount" defaultValue="0"/>
                <column name="currentBalance" displayName="当前余额" domainName="amount" defaultValue="0"/>
                <column name="status" displayName="状态" dictName="erp-fin/fund-account-status" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="currency" refEntityName="app.erp.md.dao.entity.ErpMdCurrency" joinColumnName="currencyId"/>
            </relations>
        </entity>
    </entities>
</orm>