    <entityName>app.erp.md.dao.entity.ErpMdUoMConversion</entityName>

    <primaryKey>id</primaryKey>

    <x:gen-extends>
        <meta-gen:DefaultMetaGenExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <meta-gen:DefaultMetaPostExtends xpl:lib="/nop/core/xlib/meta-gen.xlib"/>
    </x:post-extends>

    <keys/>

    <props>
        <prop name="id" displayName="ID" propId="1" tagSet="seq-default" mandatory="true" queryable="true"
              sortable="true" insertable="true" updatable="false" graphql:type="String">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="materialId" displayName="物料(空表示通用)" propId="2" queryable="true" sortable="true" insertable="true"
              updatable="true" ext:relation="material">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="fromUoMId" displayName="源单位" propId="3" mandatory="true" queryable="true" sortable="true"
