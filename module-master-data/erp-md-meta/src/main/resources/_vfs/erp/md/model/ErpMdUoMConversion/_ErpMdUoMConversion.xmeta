            <schema type="java.lang.Long"/>
        </prop>
        <prop name="toUoMId" displayName="目标单位" propId="4" mandatory="true" queryable="true" sortable="true"
              insertable="true" updatable="true" ext:relation="toUoM">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="conversionRate" displayName="换算系数" propId="5" mandatory="true" queryable="true" sortable="true"
              insertable="true" updatable="true">
            <schema type="java.math.BigDecimal" precision="20" scale="8"/>
        </prop>
        <prop name="delVersion" displayName="逻辑删除版本" propId="6" mandatory="true" queryable="true" sortable="true"
              insertable="false" updatable="true" defaultValue="0">
            <schema domain="delVersion" type="java.lang.Long"/>
        </prop>
        <prop name="version" displayName="数据版本" propId="7" mandatory="true" queryable="true" sortable="true"
