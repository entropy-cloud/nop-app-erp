            <schema domain="code" type="java.lang.String" precision="50"/>
        </prop>
        <prop name="materialId" displayName="物料" propId="3" i18n-en:displayName="Material" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true" ext:relation="material">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="declarationNo" displayName="报关单号" propId="4" i18n-en:displayName="Declaration No" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.lang.String" precision="50"/>
        </prop>
        <prop name="partnerId" displayName="报关行" propId="5" i18n-en:displayName="Customs Broker" queryable="true"
