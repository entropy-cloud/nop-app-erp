            <schema type="java.lang.String" precision="20"/>
        </prop>
        <prop name="amountDeclared" displayName="申报金额" propId="9" i18n-en:displayName="Amount Declared" mandatory="true"
              queryable="true" sortable="true" insertable="true" updatable="true">
            <schema type="java.math.BigDecimal" precision="18" scale="2"/>
        </prop>
        <prop name="currencyId" displayName="申报币种" propId="10" i18n-en:displayName="Currency" queryable="true"
              sortable="true" insertable="true" updatable="true" ext:relation="currency">
            <schema type="java.lang.Long"/>
        </prop>
        <prop name="exchangeRate" displayName="报关日汇率" propId="11" i18n-en:displayName="Exchange Rate" queryable="true"
