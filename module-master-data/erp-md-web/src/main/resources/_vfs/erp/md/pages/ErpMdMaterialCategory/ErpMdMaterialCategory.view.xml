<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMdMaterialCategory.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="parentId" label="父级"/>
                <col id="sortNum" ui:number="true" sortable="true"/>
                <col id="priceValidationLevel" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="tree-list" x:prototype="list">
            <selection>children @TreeChildren(max:5)</selection>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit">
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpMdMaterialCategory__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="add">
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpMdMaterialCategory__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[编码] name[名称]
 sortNum[排序号]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="sortNum" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main" grid="tree-list">
            <table loadDataOnce="true" sortable="false" pager="none" x:override="replace">
                <api url="@query:ErpMdMaterialCategory__findList?filter_parentId=__null"
                     gql:selection="{@listSelection}"/>
            </table>
            <rowActions>
                <action id="row-add-child-button" level="primary" label="新增子节点">
                    <dialog page="add-child"/>
                </action>
            </rowActions>
        </crud>
        <simple name="add-child" form="add">
            <data>
                <parentId>$id</parentId>
            </data>
        </simple>
        <picker name="picker">
            <table loadDataOnce="true" sortable="false" pager="none" x:override="replace">
                <api url="@query:ErpMdMaterialCategory__findList?filter_parentId=__null"
                     gql:selection="{@listSelection}"/>
            </table>
        </picker>
    </pages>
</view>
