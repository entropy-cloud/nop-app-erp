<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpMdMaterialCustoms" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/md/model/ErpMdMaterialCustoms/ErpMdMaterialCustoms.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--报关记录编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--物料-->
                <col id="materialId" mandatory="true" ui:number="true" sortable="true"/>

                <!--报关单号-->
                <col id="declarationNo" mandatory="true" sortable="true"/>

                <!--报关行-->
                <col id="partnerId" ui:number="true" sortable="true"/>

                <!--报关日期-->
                <col id="declarationDate" mandatory="true" sortable="true"/>

                <!--申报数量-->
                <col id="qtyDeclared" mandatory="true" ui:number="true" sortable="true"/>

                <!--申报计量单位-->
                <col id="uomDeclared" mandatory="true" sortable="true"/>

                <!--申报金额-->
                <col id="amountDeclared" mandatory="true" ui:number="true" sortable="true"/>

                <!--申报币种-->
                <col id="currencyId" ui:number="true" sortable="true"/>

                <!--报关日汇率-->
                <col id="exchangeRate" ui:number="true" sortable="true"/>

                <!--本位币金额-->
                <col id="amountFunctional" ui:number="true" sortable="true"/>

                <!--关税金额-->
                <col id="dutyAmount" ui:number="true" sortable="true"/>

                <!--增值税金额-->
                <col id="vatAmount" ui:number="true" sortable="true"/>

                <!--退税收据号-->
                <col id="drawbackReceiptNo" sortable="true"/>

                <!--业务单据类型-->
                <col id="sourceBillType" sortable="true"/>

                <!--业务单据编码-->
                <col id="sourceBillCode" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-物料报关记录" i18n-en:title="View Material Customs Declaration">
            <layout>
 code[报关记录编码] materialId[物料]
 declarationNo[报关单号] partnerId[报关行]
 declarationDate[报关日期] qtyDeclared[申报数量]
 uomDeclared[申报计量单位] amountDeclared[申报金额]
 currencyId[申报币种] exchangeRate[报关日汇率]
 amountFunctional[本位币金额] dutyAmount[关税金额]
 vatAmount[增值税金额] drawbackReceiptNo[退税收据号]
 sourceBillType[业务单据类型] sourceBillCode[业务单据编码]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-物料报关记录" i18n-en:title="Add Material Customs Declaration"
              x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-物料报关记录" i18n-en:title="Edit Material Customs Declaration">
            <layout>
 code[报关记录编码] materialId[物料]
 declarationNo[报关单号] partnerId[报关行]
 declarationDate[报关日期] qtyDeclared[申报数量]
 uomDeclared[申报计量单位] amountDeclared[申报金额]
 currencyId[申报币种] exchangeRate[报关日汇率]
 amountFunctional[本位币金额] dutyAmount[关税金额]
 vatAmount[增值税金额] drawbackReceiptNo[退税收据号]
 sourceBillType[业务单据类型] sourceBillCode[业务单据编码]
 remark[备注] 
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-物料报关记录"
              i18n-en:title="Update Material Customs Declaration"/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMdMaterialCustoms__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMdMaterialCustoms__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpMdMaterialCustoms__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpMdMaterialCustoms__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpMdMaterialCustoms__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpMdMaterialCustoms__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpMdMaterialCustoms__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpMdMaterialCustoms__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpMdMaterialCustoms__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpMdMaterialCustoms__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>