<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMdSubject.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="parentId" label="父级科目"/>
                <col id="subjectClass" mandatory="true" sortable="true"/>
                <col id="direction" mandatory="true" sortable="true"/>
                <col id="balanceType" sortable="true"/>
                <col id="currencyId" label="核算币种"/>
                <col id="isAuxiliaryPartner" sortable="true"/>
                <col id="isAuxiliaryDepartment" sortable="true"/>
                <col id="isAuxiliaryProject" sortable="true"/>
                <col id="isAuxiliaryWarehouse" sortable="true"/>
                <col id="isAuxiliaryProduct" sortable="true"/>
                <col id="isAuxiliaryCostCenter" sortable="true"/>
                <col id="isBudgetable" sortable="true"/>
                <col id="isLeaf" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="tree-list" x:prototype="list">
            <selection>children @TreeChildren(max:5)</selection>
        </grid>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="subjectClass" sortable="true"/>
                <col id="direction" sortable="true"/>
                <col id="isLeaf" sortable="true"/>
            </cols>
            <filter>
                <eq name="isLeaf" value="1"/>
            </filter>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[科目编码] name[科目名称]
 parentId[父级科目] subjectClass[科目类别]
 direction[余额方向] balanceType[余额类型]
 status[状态]
=========>auxiliary[辅助核算]======
 isAuxiliaryPartner[辅助-往来单位] isAuxiliaryDepartment[辅助-部门]
 isAuxiliaryProject[辅助-项目] isAuxiliaryWarehouse[辅助-仓库]
 isAuxiliaryProduct[辅助-物料] isAuxiliaryCostCenter[辅助-成本中心]
==========^control[控制属性]=========
 currencyId[核算币种] isBudgetable[是否预算控制]
 isLeaf[是否明细科目]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[科目编码] name[科目名称]
 parentId[父级科目] subjectClass[科目类别]
 direction[余额方向] balanceType[余额类型]
 status[状态]
=========>auxiliary[辅助核算]======
 isAuxiliaryPartner[辅助-往来单位] isAuxiliaryDepartment[辅助-部门]
 isAuxiliaryProject[辅助-项目] isAuxiliaryWarehouse[辅助-仓库]
 isAuxiliaryProduct[辅助-物料] isAuxiliaryCostCenter[辅助-成本中心]
 currencyId[核算币种] isBudgetable[是否预算控制]
 isLeaf[是否明细科目] remark[备注](2)
            </layout>
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpMdSubject__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
                <cell id="code">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-text',
                                name: 'code',
                                required: true,
                                onEvent: {
                                    blur: {
                                        actions: [
                                            {
                                                actionType: 'ajax',
                                                api: {
                                                    method: 'post',
                                                    url: '/graphql',
                                                    dataType: 'raw',
                                                    data: {
                                                        query: '${"query{ErpMdSubject__isCodeUnique(code:\"" + code + "\",excludeId:" + (id || "null") + "){v}}"}'
                                                    },
                                                    responseType: 'response',
                                                    adapt: 'function(payload){ var ok = payload && payload.data && payload.data.ErpMdSubject__isCodeUnique === true; return { status: ok ? 0 : 500, msg: ok ? "" : "编码已存在" }; }'
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="add">
            <cells>
                <cell id="parentId">
                    <gen-control>
                        <tree-select clearable="@:true">
                            <source>
                                <url>@query:ErpMdSubject__findList/{@listSelection}?filter_parentId=__null&amp;filter_id__ne=$id</url>
                            </source>
                        </tree-select>
                    </gen-control>
                </cell>
                <cell id="code">
                    <gen-control>
                        <c:script><![CDATA[
                            return {
                                type: 'input-text',
                                name: 'code',
                                required: true,
                                onEvent: {
                                    blur: {
                                        actions: [
                                            {
                                                actionType: 'ajax',
                                                api: {
                                                    method: 'post',
                                                    url: '/graphql',
                                                    dataType: 'raw',
                                                    data: {
                                                        query: '${"query{ErpMdSubject__isCodeUnique(code:\"" + code + "\",excludeId:" + (id || "null") + "){v}}"}'
                                                    },
                                                    responseType: 'response',
                                                    adapt: 'function(payload){ var ok = payload && payload.data && payload.data.ErpMdSubject__isCodeUnique === true; return { status: ok ? 0 : 500, msg: ok ? "" : "编码已存在" }; }'
                                                }
                                            }
                                        ]
                                    }
                                }
                            };
                        ]]></c:script>
                    </gen-control>
                </cell>
            </cells>
        </form>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[科目编码] name[科目名称]
 status[状态] subjectClass[科目类别]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="status" filterOp="eq"/>
                <cell id="subjectClass" filterOp="eq"/>
            </cells>
        </form>
        <form id="pick-query" editMode="query" title="查询条件">
            <layout>
 code[科目编码] name[科目名称]
 subjectClass[科目类别] direction[余额方向]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="subjectClass" filterOp="eq"/>
                <cell id="direction" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main" grid="tree-list">
            <table loadDataOnce="true" sortable="false" pager="none">
                <api url="@query:ErpMdSubject__findList?filter_parentId=__null"
                     gql:selection="{@listSelection}"/>
            </table>
            <rowActions>
                <action id="row-add-child-button" level="primary" label="新增子节点">
                    <dialog page="add-child"/>
                </action>
            </rowActions>
        </crud>
        <simple name="add-child" form="add">
            <data>
                <parentId>$id</parentId>
            </data>
        </simple>
        <picker name="picker" filterForm="pick-query">
            <table loadDataOnce="true" sortable="false" pager="none">
                <api url="@query:ErpMdSubject__findList?filter_parentId=__null&amp;filter_isLeaf=1"
                     gql:selection="{@listSelection}"/>
            </table>
        </picker>
    </pages>
</view>
