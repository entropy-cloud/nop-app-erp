<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="ErpMdMaterial" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/erp/md/model/ErpMdMaterial/ErpMdMaterial.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--ID-->
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>

                <!--物料编码-->
                <col id="code" mandatory="true" sortable="true"/>

                <!--物料名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--物料类型-->
                <col id="materialType" mandatory="true" ui:number="true" sortable="true"/>

                <!--分类ID-->
                <col id="categoryId" ui:number="true" sortable="true"/>

                <!--主计量单位-->
                <col id="uoMId" mandatory="true" ui:number="true" sortable="true"/>

                <!--状态-->
                <col id="status" mandatory="true" ui:number="true" sortable="true"/>

                <!--存货计价方法-->
                <col id="costMethod" ui:number="true" sortable="true"/>

                <!--是否批次管理-->
                <col id="isBatchManaged" sortable="true"/>

                <!--是否序列号管理-->
                <col id="isSerialManaged" sortable="true"/>

                <!--默认仓库-->
                <col id="defaultWarehouseId" ui:number="true" sortable="true"/>

                <!--最低库存-->
                <col id="minStock" ui:number="true" sortable="true"/>

                <!--最高库存-->
                <col id="maxStock" ui:number="true" sortable="true"/>

                <!--安全库存-->
                <col id="safetyStock" ui:number="true" sortable="true"/>

                <!--采购提前期(天)-->
                <col id="leadTimeDays" ui:number="true" sortable="true"/>

                <!--重量(kg)-->
                <col id="weight" ui:number="true" sortable="true"/>

                <!--体积(m3)-->
                <col id="volume" ui:number="true" sortable="true"/>

                <!--默认税率-->
                <col id="defaultTaxRateId" ui:number="true" sortable="true"/>

                <!--逻辑删除版本-->
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>

                <!--创建人-->
                <col id="createdBy" mandatory="true" sortable="true"/>

                <!--创建时间-->
                <col id="createTime" mandatory="true" sortable="true"/>

                <!--修改人-->
                <col id="updatedBy" mandatory="true" sortable="true"/>

                <!--修改时间-->
                <col id="updateTime" mandatory="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-物料" i18n-en:title="">
            <layout>
 id[ID] code[物料编码]
 name[物料名称] materialType[物料类型]
 categoryId[分类ID] uoMId[主计量单位]
 status[状态] costMethod[存货计价方法]
 isBatchManaged[是否批次管理] isSerialManaged[是否序列号管理]
 defaultWarehouseId[默认仓库] minStock[最低库存]
 maxStock[最高库存] safetyStock[安全库存]
 leadTimeDays[采购提前期(天)] weight[重量(kg)]
 volume[体积(m3)] defaultTaxRateId[默认税率]
 delVersion[逻辑删除版本] createdBy[创建人]
 createTime[创建时间] updatedBy[修改人]
 updateTime[修改时间] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-物料" i18n-en:title="">
            <layout>
 id[ID] code[物料编码]
 name[物料名称] materialType[物料类型]
 categoryId[分类ID] uoMId[主计量单位]
 status[状态] costMethod[存货计价方法]
 isBatchManaged[是否批次管理] isSerialManaged[是否序列号管理]
 defaultWarehouseId[默认仓库] minStock[最低库存]
 maxStock[最高库存] safetyStock[安全库存]
 leadTimeDays[采购提前期(天)] weight[重量(kg)]
 volume[体积(m3)] defaultTaxRateId[默认税率]
 remark[备注] 
</layout>
        </form>
        <form id="edit" editMode="edit" title="编辑-物料" i18n-en:title="">
            <layout>
 id[ID] code[物料编码]
 name[物料名称] materialType[物料类型]
 categoryId[分类ID] uoMId[主计量单位]
 status[状态] costMethod[存货计价方法]
 isBatchManaged[是否批次管理] isSerialManaged[是否序列号管理]
 defaultWarehouseId[默认仓库] minStock[最低库存]
 maxStock[最高库存] safetyStock[安全库存]
 leadTimeDays[采购提前期(天)] weight[重量(kg)]
 volume[体积(m3)] defaultTaxRateId[默认税率]
 delVersion[逻辑删除版本] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-物料" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMdMaterial__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:ErpMdMaterial__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:ErpMdMaterial__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:ErpMdMaterial__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:ErpMdMaterial__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:ErpMdMaterial__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:ErpMdMaterial__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:ErpMdMaterial__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:ErpMdMaterial__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:ErpMdMaterial__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>