<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMdBankAccount.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="partnerName" label="往来单位"/>
                <col id="bankName" mandatory="true" sortable="true"/>
                <col id="bankBranch" sortable="true"/>
                <col id="bankAccount" mandatory="true" sortable="true"/>
                <col id="accountType" sortable="true"/>
                <col id="accountHolder" sortable="true"/>
                <col id="isDefault" sortable="true"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>