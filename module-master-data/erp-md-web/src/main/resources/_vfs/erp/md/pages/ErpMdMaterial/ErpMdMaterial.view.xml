<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMdMaterial.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
                <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="materialType" mandatory="true" sortable="true"/>
                <col id="categoryId" label="分类"/>
                <col id="uoMId" label="主计量单位"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="costMethod" sortable="true"/>
                <col id="isBatchManaged" sortable="true"/>
                <col id="isSerialManaged" sortable="true"/>
                <col id="defaultWarehouseId" label="默认仓库"/>
                <col id="minStock" ui:number="true" sortable="true"/>
                <col id="maxStock" ui:number="true" sortable="true"/>
                <col id="safetyStock" ui:number="true" sortable="true"/>
                <col id="leadTimeDays" ui:number="true" sortable="true"/>
                <col id="weight" ui:number="true" sortable="true"/>
                <col id="volume" ui:number="true" sortable="true"/>
                <col id="defaultTaxRateId" label="默认税率"/>
                <col id="delVersion" mandatory="true" ui:number="true" sortable="true"/>
                <col id="createdBy" mandatory="true" sortable="true"/>
                <col id="createTime" mandatory="true" sortable="true"/>
                <col id="updatedBy" mandatory="true" sortable="true"/>
                <col id="updateTime" mandatory="true" sortable="true"/>
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="materialType" sortable="true"/>
                <col id="categoryId" label="分类"/>
                <col id="uoMId" label="主计量单位"/>
                <col id="status" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'success' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[物料编码] name[物料名称]
 materialType[物料类型] categoryId[分类ID]
 uoMId[主计量单位] status[状态]
==========>inventory[库存管理]======
 isBatchManaged[是否批次管理] isSerialManaged[是否序列号管理]
 defaultWarehouseId[默认仓库] minStock[最低库存]
 maxStock[最高库存] safetyStock[安全库存]
 leadTimeDays[采购提前期(天)]
==========>physical[物理属性]======
 weight[重量(kg)] volume[体积(m3)]
==========^finance[财务信息]=========
 costMethod[存货计价方法] defaultTaxRateId[默认税率]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[物料编码] name[物料名称]
 materialType[物料类型] categoryId[分类ID]
 uoMId[主计量单位] status[状态]
==========>inventory[库存管理]======
 isBatchManaged[是否批次管理] isSerialManaged[是否序列号管理]
 defaultWarehouseId[默认仓库] minStock[最低库存]
 maxStock[最高库存] safetyStock[安全库存]
 leadTimeDays[采购提前期(天)]
==========>physical[物理属性]======
 weight[重量(kg)] volume[体积(m3)]
 costMethod[存货计价方法] defaultTaxRateId[默认税率]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[物料编码] name[物料名称]
 status[状态] materialType[物料类型]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="status" filterOp="eq"/>
                <cell id="materialType" filterOp="eq"/>
            </cells>
        </form>
        <form id="pick-query" editMode="query" title="查询条件">
            <layout>
 code[物料编码] name[物料名称]
 materialType[物料类型] status[状态]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="materialType" filterOp="eq"/>
                <cell id="status" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker" filterForm="pick-query"/>
    </pages>
</view>