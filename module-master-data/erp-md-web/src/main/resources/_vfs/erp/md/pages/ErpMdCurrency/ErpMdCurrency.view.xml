<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMdCurrency.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list"/>
        <grid id="pick-list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="symbol" sortable="true"/>
                <col id="decimalPlaces" ui:number="true" sortable="true"/>
                <col id="isActive" sortable="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
        <form id="pick-query" editMode="query" title="查询条件">
            <layout>
 code[币种代码] name[名称]
 isActive[是否启用]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="name" filterOp="like"/>
                <cell id="isActive" filterOp="eq"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker" filterForm="pick-query"/>
    </pages>
</view>