<?xml version="1.0" encoding="UTF-8" ?>
<!-- 往来单位清单报表（种子报表）。数据集 ds 由 ErpMdReportBizModel.buildPartnerListDataset 注入，
     每行 {partnerId, partnerCode, partnerName, partnerType, status, contactPerson, phone, email,
     creditLimit, creditPeriodDays}。口径对齐 docs/design/master-data/README.md：客户/供应商分类清单。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="partner-list" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="80.0"/>
                    <col width="100.0"/>
                    <col width="140.0"/>
                    <col width="80.0"/>
                    <col width="60.0"/>
                    <col width="90.0"/>
                    <col width="110.0"/>
                    <col width="140.0"/>
                    <col width="100.0"/>
                    <col width="80.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="9" styleId="title"><model/><value>往来单位清单</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>往来单位ID</value></cell>
                            <cell styleId="header"><model/><value>编码</value></cell>
                            <cell styleId="header"><model/><value>名称</value></cell>
                            <cell styleId="header"><model/><value>类型</value></cell>
                            <cell styleId="header"><model/><value>状态</value></cell>
                            <cell styleId="header"><model/><value>联系人</value></cell>
                            <cell styleId="header"><model/><value>电话</value></cell>
                            <cell styleId="header"><model/><value>邮箱</value></cell>
                            <cell styleId="header"><model/><value>信用额度</value></cell>
                            <cell styleId="header"><model/><value>信用期(天)</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="partnerId"/>
                                <value>*=^ds!partnerId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=partnerCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=partnerName</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=partnerType</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=status</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=contactPerson</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=phone</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=email</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=creditLimit</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=creditPeriodDays</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
