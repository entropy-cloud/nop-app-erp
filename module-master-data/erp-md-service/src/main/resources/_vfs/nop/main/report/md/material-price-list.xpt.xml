<?xml version="1.0" encoding="UTF-8" ?>
<!-- 物料价格清单报表（种子报表）。数据集 ds 由 ErpMdReportBizModel.buildMaterialPriceListDataset 注入，
     每行 {materialId, materialCode, materialName, materialType, status, skuCode, purchasePrice, salePrice,
     wholesalePrice, retailPrice}。口径对齐 docs/design/master-data/README.md：物料×默认SKU 四档价格。 -->
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <sheets>
        <sheet name="material-price-list" defaultColumnWidth="60.0" defaultRowHeight="16.0">
            <model/>
            <table>
                <cols>
                    <col width="80.0"/>
                    <col width="100.0"/>
                    <col width="140.0"/>
                    <col width="70.0"/>
                    <col width="60.0"/>
                    <col width="100.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                    <col width="90.0"/>
                </cols>
                <rows>
                    <row height="24.0">
                        <cells>
                            <cell mergeAcross="9" styleId="title"><model/><value>物料价格清单</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="18.0">
                        <cells>
                            <cell styleId="header"><model/><value>物料ID</value></cell>
                            <cell styleId="header"><model/><value>物料编码</value></cell>
                            <cell styleId="header"><model/><value>物料名称</value></cell>
                            <cell styleId="header"><model/><value>类型</value></cell>
                            <cell styleId="header"><model/><value>状态</value></cell>
                            <cell styleId="header"><model/><value>默认SKU</value></cell>
                            <cell styleId="header"><model/><value>采购价</value></cell>
                            <cell styleId="header"><model/><value>销售价</value></cell>
                            <cell styleId="header"><model/><value>批发价</value></cell>
                            <cell styleId="header"><model/><value>零售价</value></cell>
                        </cells>
                        <model/>
                    </row>
                    <row height="16.0">
                        <cells>
                            <cell styleId="num">
                                <model ds="ds" expandType="r" field="materialId"/>
                                <value>*=^ds!materialId</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=materialCode</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=materialName</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=materialType</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=status</value>
                            </cell>
                            <cell styleId="cell">
                                <model rowParent="A3"/>
                                <value>*=skuCode</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=purchasePrice</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=salePrice</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=wholesalePrice</value>
                            </cell>
                            <cell styleId="num">
                                <model rowParent="A3"/>
                                <value>*=retailPrice</value>
                            </cell>
                        </cells>
                        <model/>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>

    <styles>
        <style id="title" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="14.0" bold="true"/>
            <numberFormat>General</numberFormat>
        </style>
        <style id="header" fillPattern="solid" fillBgColor="FFECEFF4" horizontalAlign="center" verticalAlign="center">
            <font fontName="等线" fontSize="11.0" bold="true"/>
            <numberFormat>General</numberFormat>
            <topBorder type="thin" weight="1"/>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="cell" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>General</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
        <style id="num" horizontalAlign="right" verticalAlign="center">
            <font fontName="等线" fontSize="11.0"/>
            <numberFormat>#,##0.00</numberFormat>
            <bottomBorder type="thin" weight="1"/>
            <leftBorder type="thin" weight="1"/>
            <rightBorder type="thin" weight="1"/>
        </style>
    </styles>
</workbook>
