<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 主数据看板聚合入口（plan 2026-07-06-1606-1）：非实体 BizModel，注入 IDaoProvider/IOrmTemplate，
          经 @BizQuery 暴露 getDashboardKpi/findMaterialWithoutSkuAlert/findSkuWithoutPriceAlert。 -->
    <bean id="app.erp.md.service.dashboard.ErpMdDashboardBizModel" ioc:type="@bean:id"/>

    <!-- 主数据域报表渲染入口（plan 2026-07-06-1815-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。镜像 finance ErpFinReportBizModel（域隔离 /md/）。 -->
    <bean id="app.erp.md.service.report.ErpMdReportBizModel" ioc:type="@bean:id"/>

    <!-- 统一 Party 跨实体查询入口（plan 2026-07-21-0827-2 C1）：非实体 BizModel，注入
          IDaoProvider/IOrmTemplate + 3 跨域引用计数 SPI（Path A 单实例 nullable），
          经 @BizQuery 暴露 findParties/getParty/findReferences（IErpPartyBiz 实现）。 -->
    <bean id="app.erp.md.service.party.ErpPartyBizModel" ioc:type="@bean:id"/>

    <!-- 跨账套科目映射解析器（多套账传播时科目翻译） -->
    <bean id="app.erp.md.dao.SubjectMappingResolver"
          class="app.erp.md.dao.SubjectMappingResolver"/>

    <!-- D1 外部 API 集成参考实现：汇率查询 API 客户端工厂（plan 2026-07-21-1206-3）。
          对应 docs/architecture/external-api-integration-pattern.md §7.3 案例 C。
          范式：单 provider per 配置切换 + 内置 IRateLimiter（Nop 令牌桶）+ TTL 缓存，
          Client/Factory 两层（无 Registry，与 logistics Client/Factory/Registry 三层异构）。
          被 ErpMdCurrencyBizModel.refreshRatesFromApi 注入调用；config-gated 默认 false。 -->
    <bean id="app.erp.md.service.exchange.ErpMdExchangeRateApiClientFactory"
          class="app.erp.md.service.exchange.ErpMdExchangeRateApiClientFactory"/>
</beans>