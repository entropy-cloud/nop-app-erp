<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-finance ORM 模型 — 财务域（权威数据模型来源）
  ==================================================
  业务范围：会计凭证（头/借贷分录行）、凭证模板（头/行）、业财回链表、
            会计科目表/科目、会计期间、期末结账、账户/日记账、
            凭证生成注册中心（跨工程聚合各业务域的凭证生成 provider）

  当前状态：骨架（bootstrap skeleton），实体待设计阶段填充。

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-fin
    - entityPackage:  app.erp.fin.dao.entity
    - 实体类名:        ErpFin<Entity>     （如 ErpFinVoucher、ErpFinVoucherLine、ErpFinAccount、ErpFinVoucherModel）
    - 表名:           erp_fin_<entity>   （如 erp_fin_voucher、erp_fin_voucher_line、erp_fin_account）
    - 字典命名空间:    erp-fin/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（科目表/币种/结算方式）
    - 通过 I*Biz 引用 purchase/sales/inventory 的业务单据（凭证生成的源单），不做 ORM 强引用
    - 处于 DAG 顶层，无下游业务工程依赖

  业财打通机制：
    - 财务工程定义凭证生成接口（IErpFinAcctDocProvider）+ 注册中心（ErpFinAcctDocRegistry）
    - 各业务工程实现自己的 provider（@Component），声明本工程哪些单据类型如何过账
    - 财务过账引擎按 entityName 查 provider，调用 createFacts() 生成凭证
-->
<orm ext:registerShortName="true" ext:appName="app-erp-fin" ext:entityPackageName="app.erp.fin.dao.entity"
     ext:basePackageName="app.erp.fin" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-finance"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <!--
          字典定义（待设计阶段填充），例如：
          <dict label="凭证字" name="erp-fin/voucher-type" valueType="int">
              <option code="RECEIPT" label="收" value="0"/>
              <option code="PAYMENT" label="付" value="1"/>
              <option code="TRANSFER" label="转" value="2"/>
          </dict>
          <dict label="凭证状态" name="erp-fin/voucher-status" valueType="int">
              <option code="DRAFT" label="草稿" value="0"/>
              <option code="POSTED" label="已过账" value="1"/>
              <option code="CANCELLED" label="已作废" value="2"/>
          </dict>
          <dict label="借贷方向" name="erp-fin/dc-direction" valueType="int">
              <option code="DEBIT" label="借" value="0"/>
              <option code="CREDIT" label="贷" value="1"/>
          </dict>
          <dict label="业务类型" name="erp-fin/business-type" valueType="int">
              <option code="PURCHASE_INPUT" label="采购入库" value="0"/>
              <option code="SALES_OUTPUT" label="销售出库" value="1"/>
              <option code="AP_INVOICE" label="应付发票" value="2"/>
              <option code="AR_INVOICE" label="应收发票" value="3"/>
              <option code="PAYMENT" label="付款" value="4"/>
              <option code="RECEIPT" label="收款" value="5"/>
          </dict>
        -->
    </dicts>

    <domains>
        <!--
          公共领域类型（待设计阶段填充），例如：
          <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
          <domain name="subjectCode" precision="50" stdSqlType="VARCHAR"/>
          <domain name="voucherNo" precision="50" stdSqlType="VARCHAR"/>
        -->
    </domains>

    <entities>
        <!--
          实体定义（待设计阶段填充），例如：
          <entity className="app.erp.fin.dao.entity.ErpFinVoucher"
                  displayName="会计凭证" tableName="erp_fin_voucher">
              ...
          </entity>
        -->
    </entities>
</orm>
