<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-sales ORM 模型 — 销售域（权威数据模型来源）
  ==================================================
  业务范围：销售订单（头/行）、销售出库单（头/行）、销售发票（头/行）、
            销售退货单（头/行）、收款单（头/行）、收款核销明细

  当前状态：骨架（bootstrap skeleton），实体待设计阶段填充。

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-sal
    - entityPackage:  app.erp.sal.dao.entity
    - 实体类名:        ErpSal<Entity>     （如 ErpSalOrder、ErpSalDelivery、ErpSalInvoice、ErpSalReceipt）
    - 表名:           erp_sal_<entity>   （如 erp_sal_order、erp_sal_delivery、erp_sal_invoice）
    - 字典命名空间:    erp-sal/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（物料/客户/仓库/币种/科目）
    - 依赖 app-erp-inventory（出库写库存，通过 I*Biz 调用）
    - 被 app-erp-finance 引用（销售发票/收款触发应收凭证）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-sal" ext:entityPackageName="app.erp.sal.dao.entity"
     ext:basePackageName="app.erp.sal" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-sales"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <!--
          字典定义（待设计阶段填充），例如：
          <dict label="销售单据状态" name="erp-sal/doc-status" valueType="int">
              <option code="DRAFT" label="草稿" value="0"/>
              <option code="SUBMITTED" label="已提交" value="1"/>
              <option code="APPROVED" label="已审核" value="2"/>
              <option code="REJECTED" label="已驳回" value="3"/>
              <option code="CANCELLED" label="已取消" value="4"/>
          </dict>
          <dict label="收款进度" name="erp-sal/received-status" valueType="int">
              <option code="UNRECEIVED" label="未收款" value="0"/>
              <option code="PARTIAL" label="部分收款" value="1"/>
              <option code="RECEIVED" label="已收清" value="2"/>
          </dict>
        -->
    </dicts>

    <domains>
        <!--
          公共领域类型（待设计阶段填充），例如：
          <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
          <domain name="orderCode" precision="50" stdSqlType="VARCHAR"/>
          <domain name="taxRate" stdSqlType="DECIMAL" precision="10" scale="4"/>
        -->
    </domains>

    <entities>
        <!--
          实体定义（待设计阶段填充），例如：
          <entity className="app.erp.sal.dao.entity.ErpSalOrder"
                  displayName="销售订单" tableName="erp_sal_order">
              ...
          </entity>
        -->
    </entities>
</orm>
