<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-projects ORM 模型 — 项目管理域（权威数据模型来源）
  ==================================================
  业务范围：项目、任务、工时记录、项目模板、项目类型、活动类型与成本、项目成员

  当前状态：骨架（bootstrap skeleton），实体待设计阶段填充。

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-prj
    - entityPackage:  app.erp.prj.dao.entity
    - 实体类名:        ErpPrj<Entity>     （如 ErpPrjProject、ErpPrjTask、ErpPrjTimesheet）
    - 表名:           erp_prj_<entity>   （如 erp_prj_project、erp_prj_task、erp_prj_timesheet）
    - 字典命名空间:    erp-prj/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（项目类型、活动类型、币种）
    - 被 app-erp-finance 引用（项目作为辅助核算维度；工时计入成本生成凭证）
    - 可被 app-erp-sales 引用（按项目销售/结算）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-prj" ext:entityPackageName="app.erp.prj.dao.entity"
     ext:basePackageName="app.erp.prj" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-projects"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <!--
          字典定义（待设计阶段填充），例如：
          <dict label="项目状态" name="erp-prj/project-status" valueType="int">
              <option code="DRAFT" label="草稿" value="0"/>
              <option code="OPEN" label="进行中" value="1"/>
              <option code="ON_HOLD" label="暂停" value="2"/>
              <option code="COMPLETED" label="已完成" value="3"/>
              <option code="CANCELLED" label="已取消" value="4"/>
          </dict>
          <dict label="任务状态" name="erp-prj/task-status" valueType="int">
              <option code="TODO" label="待开始" value="0"/>
              <option code="IN_PROGRESS" label="进行中" value="1"/>
              <option code="DONE" label="已完成" value="2"/>
              <option code="BLOCKED" label="阻塞" value="3"/>
          </dict>
        -->
    </dicts>

    <domains>
        <!--
          公共领域类型（待设计阶段填充），例如：
          <domain name="projectCode" precision="50" stdSqlType="VARCHAR"/>
          <domain name="taskCode" precision="50" stdSqlType="VARCHAR"/>
          <domain name="hours" stdSqlType="DECIMAL" precision="10" scale="2"/>
        -->
    </domains>

    <entities>
        <!--
          实体定义（待设计阶段填充），例如：
          <entity className="app.erp.prj.dao.entity.ErpPrjProject"
                  displayName="项目" tableName="erp_prj_project">
              ...
          </entity>
        -->
    </entities>
</orm>
