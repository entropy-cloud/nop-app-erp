<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-assets ORM 模型 — 固定资产域（权威数据模型来源）
  ==================================================
  业务范围：固定资产卡片、资产类别、折旧计划、资产移动、资产价值调整、资产处置

  三轴状态分离：
    - docStatus: 草稿/已生效/已作废（单据生命周期，用于调整和处置）
    - approveStatus: 未提交/已提交/已审核/已驳回（审核流程）
    - assetStatus: 草稿/使用中/闲置/已报废/已出售（资产卡片自身状态）

  跨工程依赖：
    - 依赖 app-erp-master-data（组织、人员、科目、库位）
    - 被 app-erp-finance 引用（折旧自动生成会计凭证，期末结账触发折旧）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz

  命名约定：
    - appName:        app-erp-ast
    - entityPackage:  app.erp.ast.dao.entity
    - 实体类名:        ErpAst<Entity>
    - 表名:           erp_ast_<entity>
    - 字典命名空间:    erp-ast/<dict-name>
-->
<orm ext:registerShortName="true" ext:appName="app-erp-ast" ext:entityPackageName="app.erp.ast.dao.entity"
     ext:basePackageName="app.erp.ast" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-assets"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="资产状态" name="erp-ast/asset-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="IN_SERVICE" label="使用中" value="1"/>
            <option code="IDLE" label="闲置" value="2"/>
            <option code="SCRAPPED" label="已报废" value="3"/>
            <option code="SOLD" label="已出售" value="4"/>
        </dict>
        <dict label="折旧方法" name="erp-ast/depreciation-method" valueType="int">
            <option code="STRAIGHT_LINE" label="直线法" value="0"/>
            <option code="DECLINING" label="双倍余额递减" value="1"/>
            <option code="UNITS" label="工作量法" value="2"/>
        </dict>
        <dict label="折旧计划状态" name="erp-ast/depreciation-schedule-status" valueType="int">
            <option code="PENDING" label="待执行" value="0"/>
            <option code="EXECUTED" label="已执行" value="1"/>
            <option code="REVERSED" label="已冲销" value="2"/>
        </dict>
        <dict label="价值调整类型" name="erp-ast/adjustment-type" valueType="int">
            <option code="IMPAIRMENT" label="减值" value="0"/>
            <option code="REVALUATION" label="重估" value="1"/>
        </dict>
        <dict label="处置类型" name="erp-ast/disposal-type" valueType="int">
            <option code="SCRAPPED" label="报废" value="0"/>
            <option code="SOLD" label="出售" value="1"/>
        </dict>
        <dict label="单据状态" name="erp-ast/doc-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="ACTIVE" label="已生效" value="1"/>
            <option code="CANCELLED" label="已作废" value="2"/>
        </dict>
        <dict label="审核状态" name="erp-ast/approve-status" valueType="int">
            <option code="UNSUBMITTED" label="未提交" value="0"/>
            <option code="SUBMITTED" label="已提交" value="1"/>
            <option code="APPROVED" label="已审核" value="2"/>
            <option code="REJECTED" label="已驳回" value="3"/>
        </dict>
        <dict label="资本化来源类型" name="erp-ast/capitalization-source-type" valueType="int">
            <option code="INVENTORY" label="库存" value="0"/>
            <option code="CIP" label="在建工程" value="1"/>
        </dict>
    </dicts>

    <domains>
        <domain name="assetCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="depreciationRate" stdSqlType="DECIMAL" precision="10" scale="6"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <!-- 固定资产卡片 -->
        <entity className="app.erp.ast.dao.entity.ErpAstAsset"
                displayName="固定资产" name="app.erp.ast.dao.entity.ErpAstAsset"
                tableName="erp_ast_asset" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="资产编码" domainName="assetCode" mandatory="true"/>
                <column name="name" displayName="资产名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="categoryId" displayName="资产类别" stdSqlType="BIGINT"/>
                <column name="acquisitionDate" displayName="取得日期" stdSqlType="DATE" mandatory="true"/>
                <column name="originalValue" displayName="原值" domainName="amount" mandatory="true"/>
                <column name="currentValue" displayName="当前价值" domainName="amount"/>
                <column name="residualValue" displayName="残值" domainName="amount" defaultValue="0"/>
                <column name="depreciationMethod" displayName="折旧方法" dictName="erp-ast/depreciation-method"/>
                <column name="depreciationRate" displayName="折旧率" domainName="depreciationRate"/>
                <column name="usefulLifeMonths" displayName="使用年限(月)" stdSqlType="INT"/>
                <column name="departmentId" displayName="使用部门" stdSqlType="BIGINT"/>
                <column name="locationId" displayName="使用地点" stdSqlType="BIGINT"/>
                <column name="staffId" displayName="使用人" stdSqlType="BIGINT"/>
                <column name="status" displayName="资产状态" dictName="erp-ast/asset-status" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="category" refEntityName="app.erp.ast.dao.entity.ErpAstAssetCategory" joinColumnName="categoryId"/>
                <to-one name="department" refEntityName="app.erp.md.dao.entity.ErpMdOrganization" joinColumnName="departmentId"/>
                <to-one name="location" refEntityName="app.erp.md.dao.entity.ErpMdLocation" joinColumnName="locationId"/>
                <to-one name="staff" refEntityName="app.erp.md.dao.entity.ErpMdPartner" joinColumnName="staffId"/>
            </relations>
        </entity>

        <!-- 资产类别 -->
        <entity className="app.erp.ast.dao.entity.ErpAstAssetCategory"
                displayName="资产类别" name="app.erp.ast.dao.entity.ErpAstAssetCategory"
                tableName="erp_ast_asset_category" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="类别编码" domainName="assetCode" mandatory="true"/>
                <column name="name" displayName="类别名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="depreciationMethod" displayName="默认折旧方法" dictName="erp-ast/depreciation-method"/>
                <column name="usefulLifeMonths" displayName="默认使用年限(月)" stdSqlType="INT"/>
                <column name="subjectId" displayName="资产科目" stdSqlType="BIGINT"/>
                <column name="depreciationSubjectId" displayName="累计折旧科目" stdSqlType="BIGINT"/>
                <column name="expenseSubjectId" displayName="折旧费用科目" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="subject" refEntityName="app.erp.md.dao.entity.ErpMdSubject" joinColumnName="subjectId"/>
                <to-one name="depreciationSubject" refEntityName="app.erp.md.dao.entity.ErpMdSubject" joinColumnName="depreciationSubjectId"/>
                <to-one name="expenseSubject" refEntityName="app.erp.md.dao.entity.ErpMdSubject" joinColumnName="expenseSubjectId"/>
            </relations>
        </entity>

        <!-- 折旧计划 -->
        <entity className="app.erp.ast.dao.entity.ErpAstDepreciationSchedule"
                displayName="折旧计划" name="app.erp.ast.dao.entity.ErpAstDepreciationSchedule"
                tableName="erp_ast_depreciation_schedule" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="assetId" displayName="资产ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="period" displayName="折旧期间" stdSqlType="VARCHAR" precision="20" mandatory="true"/>
                <column name="plannedAmount" displayName="计划折旧额" domainName="amount" mandatory="true"/>
                <column name="actualAmount" displayName="实际折旧额" domainName="amount"/>
                <column name="accumulatedDepreciation" displayName="累计折旧" domainName="amount" defaultValue="0"/>
                <column name="netBookValue" displayName="净值" domainName="amount"/>
                <column name="status" displayName="执行状态" dictName="erp-ast/depreciation-schedule-status" mandatory="true"/>
                <column name="executedAt" displayName="执行时间" stdSqlType="DATETIME"/>
                <column name="voucherId" displayName="凭证ID" stdSqlType="BIGINT"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="asset" refEntityName="app.erp.ast.dao.entity.ErpAstAsset" joinColumnName="assetId"/>
            </relations>
        </entity>

        <!-- 资产移动 -->
        <entity className="app.erp.ast.dao.entity.ErpAstMovement"
                displayName="资产移动" name="app.erp.ast.dao.entity.ErpAstMovement"
                tableName="erp_ast_movement" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="assetId" displayName="资产ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="fromDate" displayName="开始日期" stdSqlType="DATE" mandatory="true"/>
                <column name="thruDate" displayName="截止日期" stdSqlType="DATE"/>
                <column name="fromDepartmentId" displayName="原使用部门" stdSqlType="BIGINT"/>
                <column name="toDepartmentId" displayName="新使用部门" stdSqlType="BIGINT"/>
                <column name="fromStaffId" displayName="原使用人" stdSqlType="BIGINT"/>
                <column name="toStaffId" displayName="新使用人" stdSqlType="BIGINT"/>
                <column name="fromLocationId" displayName="原使用地点" stdSqlType="BIGINT"/>
                <column name="toLocationId" displayName="新使用地点" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="asset" refEntityName="app.erp.ast.dao.entity.ErpAstAsset" joinColumnName="assetId"/>
            </relations>
        </entity>

        <!-- 资产价值调整 -->
        <entity className="app.erp.ast.dao.entity.ErpAstValueAdjustment"
                displayName="资产价值调整" name="app.erp.ast.dao.entity.ErpAstValueAdjustment"
                tableName="erp_ast_value_adjustment" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="assetId" displayName="资产ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="adjustmentType" displayName="调整类型" dictName="erp-ast/adjustment-type" mandatory="true"/>
                <column name="adjustmentAmount" displayName="调整金额" domainName="amount" mandatory="true"/>
                <column name="reason" displayName="调整原因" stdSqlType="VARCHAR" precision="500"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-ast/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-ast/approve-status" mandatory="true"/>
                <column name="approvedBy" displayName="审核人" stdSqlType="BIGINT"/>
                <column name="approvedAt" displayName="审核时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="asset" refEntityName="app.erp.ast.dao.entity.ErpAstAsset" joinColumnName="assetId"/>
            </relations>
        </entity>

        <!-- 资产处置 -->
        <entity className="app.erp.ast.dao.entity.ErpAstDisposal"
                displayName="资产处置" name="app.erp.ast.dao.entity.ErpAstDisposal"
                tableName="erp_ast_disposal" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="assetId" displayName="资产ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="disposalType" displayName="处置类型" dictName="erp-ast/disposal-type" mandatory="true"/>
                <column name="disposalAmount" displayName="处置金额" domainName="amount"/>
                <column name="disposalDate" displayName="处置日期" stdSqlType="DATE" mandatory="true"/>
                <column name="gainLoss" displayName="损益" domainName="amount"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-ast/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-ast/approve-status" mandatory="true"/>
                <column name="approvedBy" displayName="审核人" stdSqlType="BIGINT"/>
                <column name="approvedAt" displayName="审核时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="asset" refEntityName="app.erp.ast.dao.entity.ErpAstAsset" joinColumnName="assetId"/>
            </relations>
        </entity>

        <!-- 资产资本化 -->
        <entity className="app.erp.ast.dao.entity.ErpAstAssetCapitalization"
                displayName="资产资本化" name="app.erp.ast.dao.entity.ErpAstAssetCapitalization"
                tableName="erp_ast_asset_capitalization" tag="erp.assets">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="单号" domainName="assetCode" mandatory="true"/>
                <column name="assetCode" displayName="资产编码" domainName="assetCode"/>
                <column name="assetName" displayName="资产名称" stdSqlType="VARCHAR" precision="200"/>
                <column name="categoryId" displayName="资产类别" stdSqlType="BIGINT"/>
                <column name="capitalizationDate" displayName="资本化日期" stdSqlType="DATE" mandatory="true"/>
                <column name="originalValue" displayName="原值" domainName="amount" mandatory="true"/>
                <column name="sourceType" displayName="来源类型" dictName="erp-ast/capitalization-source-type" mandatory="true"/>
                <column name="sourceCode" displayName="来源单号" stdSqlType="VARCHAR" precision="50"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-ast/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-ast/approve-status" mandatory="true"/>
                <column name="approvedBy" displayName="审核人" stdSqlType="BIGINT"/>
                <column name="approvedAt" displayName="审核时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="category" refEntityName="app.erp.ast.dao.entity.ErpAstAssetCategory" joinColumnName="categoryId"/>
            </relations>
        </entity>
    </entities>
</orm>
