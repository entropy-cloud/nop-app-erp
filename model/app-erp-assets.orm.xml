<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-assets ORM 模型 — 固定资产域（权威数据模型来源）
  ==================================================
  业务范围：固定资产卡片、资产类别、折旧计划、资产移动、资产维修、资产价值调整、资产资本化

  当前状态：骨架（bootstrap skeleton），实体待设计阶段填充。

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-ast
    - entityPackage:  app.erp.ast.dao.entity
    - 实体类名:        ErpAst<Entity>     （如 ErpAstAsset、ErpAstDepreciation、ErpAstMovement）
    - 表名:           erp_ast_<entity>   （如 erp_ast_asset、erp_ast_depreciation_schedule）
    - 字典命名空间:    erp-ast/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（资产类别科目映射、币种）
    - 依赖 app-erp-inventory（资产资本化时的库存出入）
    - 被 app-erp-finance 引用（折旧自动生成会计凭证，期末结账触发折旧）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-ast" ext:entityPackageName="app.erp.ast.dao.entity"
     ext:basePackageName="app.erp.ast" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-assets"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <!--
          字典定义（待设计阶段填充），例如：
          <dict label="资产状态" name="erp-ast/asset-status" valueType="int">
              <option code="DRAFT" label="草稿" value="0"/>
              <option code="IN_SERVICE" label="使用中" value="1"/>
              <option code="IDLE" label="闲置" value="2"/>
              <option code="SCRAPPED" label="已报废" value="3"/>
              <option code="SOLD" label="已出售" value="4"/>
          </dict>
          <dict label="折旧方法" name="erp-ast/depreciation-method" valueType="int">
              <option code="STRAIGHT_LINE" label="直线法" value="0"/>
              <option code="DECLINING" label="双倍余额递减" value="1"/>
              <option code="UNITS" label="工作量法" value="2"/>
          </dict>
        -->
    </dicts>

    <domains>
        <!--
          公共领域类型（待设计阶段填充），例如：
          <domain name="assetCode" precision="50" stdSqlType="VARCHAR"/>
          <domain name="amount" stdSqlType="DECIMAL" precision="20" scale="4"/>
          <domain name="depreciationRate" stdSqlType="DECIMAL" precision="10" scale="6"/>
        -->
    </domains>

    <entities>
        <!--
          实体定义（待设计阶段填充），例如：
          <entity className="app.erp.ast.dao.entity.ErpAstAsset"
                  displayName="固定资产" tableName="erp_ast_asset">
              ...
          </entity>
        -->
    </entities>
</orm>
