<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-quality ORM 模型 — 质量管理域（权威数据模型来源）
  ==================================================
  业务范围：质检单（关联采购入库/销售出库/工单）、质检模板与参数、
            不合格品处理（NCR 不符合报告）、纠正预防措施（CAPA）、风险登记

  三轴状态分离：
    - docStatus: 草稿/已生效/已作废（单据生命周期）
    - approveStatus: 未提交/已提交/已审核/已驳回（审核流程）
    - result/result: 质检结果独立维度

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-qa
    - entityPackage:  app.erp.qa.dao.entity
    - 实体类名:        ErpQa<Entity>     （如 ErpQaInspection、ErpQaNonConformance、ErpQaAction）
    - 表名:           erp_qa_<entity>   （如 erp_qa_inspection、erp_qa_non_conformance）
    - 字典命名空间:    erp-qa/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-master-data（物料、检验标准）
    - 被 app-erp-purchase 引用（采购入库触发来料质检）
    - 被 app-erp-sales 引用（销售出库触发发货质检）
    - 被 app-erp-manufacturing 引用（工单完工触发制程质检）
    - 质检不合格可触发采购退货/销售退货/工单返工（通过 I*Biz 反向通知）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-qa" ext:entityPackageName="app.erp.qa.dao.entity"
     ext:basePackageName="app.erp.qa" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-quality"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="检验类型" name="erp-qa/inspection-type" valueType="int">
            <option code="INCOMING" label="来料检验" value="0"/>
            <option code="IN_PROCESS" label="制程检验" value="1"/>
            <option code="FINAL" label="完工检验" value="2"/>
            <option code="OUTGOING" label="出货检验" value="3"/>
        </dict>
        <dict label="质检结果" name="erp-qa/inspection-result" valueType="int">
            <option code="PENDING" label="待检" value="0"/>
            <option code="ACCEPTED" label="合格" value="1"/>
            <option code="CONDITIONAL" label="让步接收" value="2"/>
            <option code="REJECTED" label="不合格" value="3"/>
        </dict>
        <dict label="不符合项状态" name="erp-qa/ncr-status" valueType="int">
            <option code="OPEN" label="待处理" value="0"/>
            <option code="IN_REVIEW" label="评审中" value="1"/>
            <option code="RESOLVED" label="已解决" value="2"/>
            <option code="CANCELLED" label="已取消" value="3"/>
        </dict>
        <dict label="纠正措施类型" name="erp-qa/action-type" valueType="int">
            <option code="CORRECTIVE" label="纠正" value="0"/>
            <option code="PREVENTIVE" label="预防" value="1"/>
            <option code="CAPA" label="纠正预防" value="2"/>
        </dict>
        <dict label="单据状态" name="erp-qa/doc-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="ACTIVE" label="已生效" value="1"/>
            <option code="CANCELLED" label="已作废" value="2"/>
        </dict>
        <dict label="审核状态" name="erp-qa/approve-status" valueType="int">
            <option code="UNSUBMITTED" label="未提交" value="0"/>
            <option code="SUBMITTED" label="已提交" value="1"/>
            <option code="APPROVED" label="已审核" value="2"/>
            <option code="REJECTED" label="已驳回" value="3"/>
        </dict>
        <dict label="不合格严重程度" name="erp-qa/severity" valueType="int">
            <option code="LOW" label="低" value="0"/>
            <option code="NORMAL" label="一般" value="1"/>
            <option code="HIGH" label="高" value="2"/>
            <option code="CRITICAL" label="严重" value="3"/>
        </dict>
        <dict label="纠正措施状态" name="erp-qa/action-status" valueType="int">
            <option code="PENDING" label="待执行" value="0"/>
            <option code="IN_PROGRESS" label="执行中" value="1"/>
            <option code="COMPLETED" label="已完成" value="2"/>
            <option code="OVERDUE" label="已逾期" value="3"/>
        </dict>
        <dict label="风险状态" name="erp-qa/risk-status" valueType="int">
            <option code="OPEN" label="待处理" value="0"/>
            <option code="MITIGATED" label="已缓解" value="1"/>
            <option code="CLOSED" label="已关闭" value="2"/>
        </dict>
        <dict label="质量目标状态" name="erp-qa/goal-status" valueType="int">
            <option code="ACTIVE" label="进行中" value="0"/>
            <option code="ACHIEVED" label="已达成" value="1"/>
            <option code="FAILED" label="未达成" value="2"/>
            <option code="CANCELLED" label="已取消" value="3"/>
        </dict>
        <dict label="评审类型" name="erp-qa/review-type" valueType="int">
            <option code="INTERNAL" label="内部评审" value="0"/>
            <option code="EXTERNAL" label="外部评审" value="1"/>
            <option code="SUPPLIER" label="供应商评审" value="2"/>
        </dict>
    </dicts>

    <domains>
        <domain name="orderCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="measuredValue" stdSqlType="DECIMAL" precision="20" scale="6"/>
        <domain name="specLimit" stdSqlType="DECIMAL" precision="20" scale="6"/>
        <domain name="quantity" stdSqlType="DECIMAL" precision="20" scale="4"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
    </domains>

    <entities>
        <!-- 质检单 -->
        <entity className="app.erp.qa.dao.entity.ErpQaInspection"
                displayName="质检单" name="app.erp.qa.dao.entity.ErpQaInspection"
                tableName="erp_qa_inspection" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="单号" domainName="orderCode" mandatory="true"/>
                <column name="inspectionType" displayName="检验类型" dictName="erp-qa/inspection-type" mandatory="true"/>
                <column name="relatedBillType" displayName="关联单据类型" stdSqlType="VARCHAR" precision="50"/>
                <column name="relatedBillCode" displayName="关联单据号" stdSqlType="VARCHAR" precision="50"/>
                <column name="relatedLineCode" displayName="关联单据行号" stdSqlType="VARCHAR" precision="50"/>
                <column name="materialId" displayName="物料" stdSqlType="BIGINT" mandatory="true"/>
                <column name="supplierId" displayName="供应商" stdSqlType="BIGINT"/>
                <column name="warehouseId" displayName="仓库" stdSqlType="BIGINT"/>
                <column name="inspectionDate" displayName="检验日期" stdSqlType="DATE" mandatory="true"/>
                <column name="inspectorId" displayName="检验员" stdSqlType="BIGINT"/>
                <column name="result" displayName="质检结果" dictName="erp-qa/inspection-result" mandatory="true"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-qa/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-qa/approve-status" mandatory="true"/>
                <column name="approvedBy" displayName="审核人" stdSqlType="BIGINT"/>
                <column name="approvedAt" displayName="审核时间" stdSqlType="DATETIME"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-many name="lines" refEntityName="app.erp.qa.dao.entity.ErpQaInspectionLine" myFieldName="id" refFieldName="inspectionId"/>
            </relations>
        </entity>

        <!-- 质检单行 -->
        <entity className="app.erp.qa.dao.entity.ErpQaInspectionLine"
                displayName="质检单行" name="app.erp.qa.dao.entity.ErpQaInspectionLine"
                tableName="erp_qa_inspection_line" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="inspectionId" displayName="质检单ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="parameterId" displayName="检验参数" stdSqlType="BIGINT"/>
                <column name="parameterName" displayName="检验参数名称" stdSqlType="VARCHAR" precision="200"/>
                <column name="specMin" displayName="规格下限" domainName="specLimit"/>
                <column name="specMax" displayName="规格上限" domainName="specLimit"/>
                <column name="measuredValue" displayName="实测值" domainName="measuredValue"/>
                <column name="unit" displayName="计量单位" stdSqlType="VARCHAR" precision="50"/>
                <column name="result" displayName="行结果" dictName="erp-qa/inspection-result" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="inspection" refEntityName="app.erp.qa.dao.entity.ErpQaInspection" joinColumnName="inspectionId"/>
            </relations>
        </entity>

        <!-- 质检模板 -->
        <entity className="app.erp.qa.dao.entity.ErpQaInspectionTemplate"
                displayName="质检模板" name="app.erp.qa.dao.entity.ErpQaInspectionTemplate"
                tableName="erp_qa_inspection_template" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="编码" domainName="orderCode" mandatory="true"/>
                <column name="name" displayName="名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="inspectionType" displayName="检验类型" dictName="erp-qa/inspection-type" mandatory="true"/>
                <column name="materialId" displayName="适用物料" stdSqlType="BIGINT"/>
                <column name="isActive" displayName="是否启用" stdSqlType="INT" mandatory="true" defaultValue="1"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-many name="lines" refEntityName="app.erp.qa.dao.entity.ErpQaInspectionTemplateLine" myFieldName="id" refFieldName="templateId"/>
            </relations>
        </entity>

        <!-- 质检模板行 -->
        <entity className="app.erp.qa.dao.entity.ErpQaInspectionTemplateLine"
                displayName="质检模板行" name="app.erp.qa.dao.entity.ErpQaInspectionTemplateLine"
                tableName="erp_qa_inspection_template_line" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="templateId" displayName="模板ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="parameterName" displayName="检验参数名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="specMin" displayName="规格下限" domainName="specLimit"/>
                <column name="specMax" displayName="规格上限" domainName="specLimit"/>
                <column name="unit" displayName="计量单位" stdSqlType="VARCHAR" precision="50"/>
                <column name="isRequired" displayName="是否必检" stdSqlType="INT" mandatory="true" defaultValue="1"/>
                <column name="sortNum" displayName="排序" stdSqlType="INT" defaultValue="0"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="template" refEntityName="app.erp.qa.dao.entity.ErpQaInspectionTemplate" joinColumnName="templateId"/>
            </relations>
        </entity>

        <!-- 不合格品报告 -->
        <entity className="app.erp.qa.dao.entity.ErpQaNonConformance"
                displayName="不合格品报告" name="app.erp.qa.dao.entity.ErpQaNonConformance"
                tableName="erp_qa_non_conformance" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="单号" domainName="orderCode" mandatory="true"/>
                <column name="ncrDate" displayName="报告日期" stdSqlType="DATE" mandatory="true"/>
                <column name="sourceType" displayName="来源类型" stdSqlType="VARCHAR" precision="50"/>
                <column name="sourceCode" displayName="来源单号" stdSqlType="VARCHAR" precision="50"/>
                <column name="materialId" displayName="物料" stdSqlType="BIGINT" mandatory="true"/>
                <column name="quantity" displayName="不合格数量" domainName="quantity"/>
                <column name="description" displayName="问题描述" stdSqlType="VARCHAR" precision="2000"/>
                <column name="severity" displayName="严重程度" dictName="erp-qa/severity" mandatory="true"/>
                <column name="status" displayName="状态" dictName="erp-qa/ncr-status" mandatory="true"/>
                <column name="assignedTo" displayName="责任人" stdSqlType="BIGINT"/>
                <column name="resolvedBy" displayName="解决人" stdSqlType="BIGINT"/>
                <column name="resolvedAt" displayName="解决时间" stdSqlType="DATETIME"/>
                <column name="resolution" displayName="解决措施" stdSqlType="VARCHAR" precision="2000"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-many name="actions" refEntityName="app.erp.qa.dao.entity.ErpQaAction" myFieldName="id" refFieldName="ncrId"/>
            </relations>
        </entity>

        <!-- 纠正预防措施 -->
        <entity className="app.erp.qa.dao.entity.ErpQaAction"
                displayName="纠正预防措施" name="app.erp.qa.dao.entity.ErpQaAction"
                tableName="erp_qa_action" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="ncrId" displayName="不合格品报告ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="actionType" displayName="措施类型" dictName="erp-qa/action-type" mandatory="true"/>
                <column name="description" displayName="措施描述" stdSqlType="VARCHAR" precision="2000"/>
                <column name="responsiblePerson" displayName="负责人" stdSqlType="BIGINT"/>
                <column name="dueDate" displayName="计划完成日期" stdSqlType="DATE"/>
                <column name="status" displayName="状态" dictName="erp-qa/action-status" mandatory="true"/>
                <column name="completedBy" displayName="完成人" stdSqlType="BIGINT"/>
                <column name="completedAt" displayName="完成时间" stdSqlType="DATETIME"/>
                <column name="verificationPerson" displayName="验证人" stdSqlType="BIGINT"/>
                <column name="verificationDate" displayName="验证日期" stdSqlType="DATE"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="ncr" refEntityName="app.erp.qa.dao.entity.ErpQaNonConformance" joinColumnName="ncrId"/>
            </relations>
        </entity>

        <!-- 风险登记 -->
        <entity className="app.erp.qa.dao.entity.ErpQaRiskRegister"
                displayName="风险登记" name="app.erp.qa.dao.entity.ErpQaRiskRegister"
                tableName="erp_qa_risk_register" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="编号" domainName="orderCode" mandatory="true"/>
                <column name="riskDate" displayName="登记日期" stdSqlType="DATE" mandatory="true"/>
                <column name="description" displayName="风险描述" stdSqlType="VARCHAR" precision="2000"/>
                <column name="category" displayName="风险类别" stdSqlType="VARCHAR" precision="100"/>
                <column name="likelihood" displayName="发生可能性" stdSqlType="INT" mandatory="true"/>
                <column name="severity" displayName="影响严重性" stdSqlType="INT" mandatory="true"/>
                <column name="riskScore" displayName="风险评分" stdSqlType="INT"/>
                <column name="mitigation" displayName="缓解措施" stdSqlType="VARCHAR" precision="2000"/>
                <column name="ownerId" displayName="责任人" stdSqlType="BIGINT"/>
                <column name="status" displayName="状态" dictName="erp-qa/risk-status" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
        </entity>

        <!-- 质量目标 -->
        <entity className="app.erp.qa.dao.entity.ErpQaQualityGoal"
                displayName="质量目标" name="app.erp.qa.dao.entity.ErpQaQualityGoal"
                tableName="erp_qa_quality_goal" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="编码" domainName="orderCode" mandatory="true"/>
                <column name="name" displayName="名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="description" displayName="描述" stdSqlType="VARCHAR" precision="2000"/>
                <column name="targetValue" displayName="目标值" stdSqlType="VARCHAR" precision="100"/>
                <column name="currentValue" displayName="当前值" stdSqlType="VARCHAR" precision="100"/>
                <column name="unit" displayName="单位" stdSqlType="VARCHAR" precision="50"/>
                <column name="responsiblePersonId" displayName="责任人" stdSqlType="BIGINT"/>
                <column name="startDate" displayName="开始日期" stdSqlType="DATE"/>
                <column name="endDate" displayName="结束日期" stdSqlType="DATE"/>
                <column name="status" displayName="状态" dictName="erp-qa/goal-status" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
        </entity>

        <!-- 质量评审 -->
        <entity className="app.erp.qa.dao.entity.ErpQaReview"
                displayName="质量评审" name="app.erp.qa.dao.entity.ErpQaReview"
                tableName="erp_qa_review" tag="erp.quality">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="编号" domainName="orderCode" mandatory="true"/>
                <column name="reviewDate" displayName="评审日期" stdSqlType="DATE" mandatory="true"/>
                <column name="reviewType" displayName="评审类型" dictName="erp-qa/review-type" mandatory="true"/>
                <column name="relatedBillType" displayName="关联单据类型" stdSqlType="VARCHAR" precision="50"/>
                <column name="relatedBillCode" displayName="关联单据号" stdSqlType="VARCHAR" precision="50"/>
                <column name="participants" displayName="参与人员" stdSqlType="VARCHAR" precision="500"/>
                <column name="conclusion" displayName="评审结论" stdSqlType="VARCHAR" precision="2000"/>
                <column name="actionRequired" displayName="是否需要措施" stdSqlType="INT" defaultValue="0"/>
                <column name="docStatus" displayName="单据状态" dictName="erp-qa/doc-status" mandatory="true"/>
                <column name="approveStatus" displayName="审核状态" dictName="erp-qa/approve-status" mandatory="true"/>
                <column name="createdBy" displayName="创建人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
        </entity>
    </entities>
</orm>
