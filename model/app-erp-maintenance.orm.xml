<?xml version="1.0" encoding="UTF-8" ?>
<!--
  app-erp-maintenance ORM 模型 — 设备维护域（权威数据模型来源）
  ==================================================
  业务范围：设备/资产维护（与资产域协作）、维护计划（周期性预防维护）、维护访问（实际执行）、
            维护请求（报修）、维护团队与任务、停机记录（与制造域协作）

  注意：本域聚焦"设备/资产的维护执行"，与 app-erp-assets 的"资产卡片与折旧"分工：
    - assets 域：资产的价值管理（卡片、折旧、资本化、价值调整）
    - maintenance 域：资产的实物维护（计划、访问、维修、停机）
    - 资产维护历史可被 assets 域引用查询，但维护执行由本域负责

  命名约定（见 docs/architecture/domain-module-split-analysis.md）：
    - appName:        app-erp-mnt
    - entityPackage:  app.erp.mnt.dao.entity
    - 实体类名:        ErpMnt<Entity>     （如 ErpMntEquipment、ErpMntSchedule、ErpMntVisit、ErpMntRequest）
    - 表名:           erp_mnt_<entity>   （如 erp_mnt_equipment、erp_mnt_schedule、erp_mnt_visit）
    - 字典命名空间:    erp-mnt/<dict-name>

  跨工程依赖：
    - 依赖 app-erp-assets（资产/设备主数据引用，资产停机状态联动）
    - 依赖 app-erp-master-data（物料/备件、人员）
    - 可被 app-erp-manufacturing 引用（工作中心停机影响排产）
    - 维修消耗备件触发 inventory 出库（通过 I*Biz）
    - 跨工程实体不做 ORM refEntityName 强引用，走 I*Biz
-->
<orm ext:registerShortName="true" ext:appName="app-erp-mnt" ext:entityPackageName="app.erp.mnt.dao.entity"
     ext:basePackageName="app.erp.mnt" ext:mavenGroupId="io.nop.app" ext:mavenArtifactId="app-erp-maintenance"
     ext:mavenVersion="1.0-SNAPSHOT" ext:platformVersion="2.0.0-SNAPSHOT" ext:dialect="mysql,oracle,postgresql"
     ext:allowIdAsColName="true" x:schema="/nop/schema/orm/orm.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <dicts>
        <dict label="维护计划类型" name="erp-mnt/schedule-type" valueType="int">
            <option code="PREVENTIVE" label="预防性维护" value="0"/>
            <option code="PREDICTIVE" label="预测性维护" value="1"/>
            <option code="CALIBRATION" label="校准" value="2"/>
        </dict>
        <dict label="维护访问状态" name="erp-mnt/visit-status" valueType="int">
            <option code="DRAFT" label="草稿" value="0"/>
            <option code="SCHEDULED" label="已排程" value="1"/>
            <option code="IN_PROGRESS" label="执行中" value="2"/>
            <option code="COMPLETED" label="已完成" value="3"/>
            <option code="CANCELLED" label="已取消" value="4"/>
        </dict>
        <dict label="维护请求状态" name="erp-mnt/request-status" valueType="int">
            <option code="OPEN" label="待受理" value="0"/>
            <option code="ACCEPTED" label="已受理" value="1"/>
            <option code="IN_PROGRESS" label="维修中" value="2"/>
            <option code="COMPLETED" label="已完成" value="3"/>
            <option code="REJECTED" label="已拒绝" value="4"/>
            <option code="CANCELLED" label="已取消" value="5"/>
        </dict>
        <dict label="设备状态" name="erp-mnt/equipment-status" valueType="int">
            <option code="RUNNING" label="运行中" value="0"/>
            <option code="IDLE" label="闲置" value="1"/>
            <option code="UNDER_MAINTENANCE" label="维护中" value="2"/>
            <option code="DOWN" label="故障停机" value="3"/>
            <option code="DECOMMISSIONED" label="已停用" value="4"/>
        </dict>
        <dict label="重复类型" name="erp-mnt/recurrence-type" valueType="int">
            <option code="DAILY" label="每日" value="0"/>
            <option code="WEEKLY" label="每周" value="1"/>
            <option code="MONTHLY" label="每月" value="2"/>
            <option code="YEARLY" label="每年" value="3"/>
        </dict>
        <dict label="优先级" name="erp-mnt/priority" valueType="int">
            <option code="LOW" label="低" value="0"/>
            <option code="NORMAL" label="普通" value="1"/>
            <option code="HIGH" label="高" value="2"/>
            <option code="URGENT" label="紧急" value="3"/>
        </dict>
    </dicts>

    <domains>
        <domain name="equipmentCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="visitCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="scheduleCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="requestCode" precision="50" stdSqlType="VARCHAR"/>
        <domain name="remark" precision="1000" stdSqlType="VARCHAR"/>
        <domain name="downtimeMinutes" stdSqlType="DECIMAL" precision="12" scale="2"/>
    </domains>

    <entities>
        <!-- 设备 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntEquipment"
                displayName="设备" name="app.erp.mnt.dao.entity.ErpMntEquipment"
                tableName="erp_mnt_equipment" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="设备编码" domainName="equipmentCode" mandatory="true"/>
                <column name="name" displayName="设备名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="assetId" displayName="资产ID" stdSqlType="BIGINT"/>
                <column name="locationId" displayName="位置ID" stdSqlType="BIGINT"/>
                <column name="categoryId" displayName="分类ID" stdSqlType="BIGINT"/>
                <column name="status" displayName="状态" dictName="erp-mnt/equipment-status" mandatory="true"/>
                <column name="serialNo" displayName="序列号" stdSqlType="VARCHAR" precision="100"/>
                <column name="manufacturer" displayName="制造商" stdSqlType="VARCHAR" precision="200"/>
                <column name="model" displayName="型号" stdSqlType="VARCHAR" precision="200"/>
                <column name="installDate" displayName="安装日期" stdSqlType="DATE"/>
                <column name="warrantyExpiry" displayName="保修到期" stdSqlType="DATE"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="location" refEntityName="app.erp.md.dao.entity.ErpMdLocation" joinColumnName="locationId"/>
                <to-one name="category" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipmentCategory" joinColumnName="categoryId"/>
            </relations>
        </entity>

        <!-- 设备分类 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntEquipmentCategory"
                displayName="设备分类" name="app.erp.mnt.dao.entity.ErpMntEquipmentCategory"
                tableName="erp_mnt_equipment_category" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="分类编码" stdSqlType="VARCHAR" precision="50" mandatory="true"/>
                <column name="name" displayName="分类名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="parentId" displayName="上级分类ID" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="parent" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipmentCategory" joinColumnName="parentId"/>
            </relations>
        </entity>

        <!-- 维护计划 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntSchedule"
                displayName="维护计划" name="app.erp.mnt.dao.entity.ErpMntSchedule"
                tableName="erp_mnt_schedule" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="计划编码" domainName="scheduleCode" mandatory="true"/>
                <column name="name" displayName="计划名称" stdSqlType="VARCHAR" precision="200" mandatory="true"/>
                <column name="equipmentId" displayName="设备ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="scheduleType" displayName="计划类型" dictName="erp-mnt/schedule-type" mandatory="true"/>
                <column name="frequency" displayName="频率" stdSqlType="INT"/>
                <column name="recurrenceType" displayName="重复类型" dictName="erp-mnt/recurrence-type"/>
                <column name="daysOfWeek" displayName="星期几" stdSqlType="VARCHAR" precision="50"/>
                <column name="startDate" displayName="开始日期" stdSqlType="DATE" mandatory="true"/>
                <column name="endDate" displayName="结束日期" stdSqlType="DATE"/>
                <column name="nextDueDate" displayName="下次到期日" stdSqlType="DATE"/>
                <column name="isActive" displayName="是否启用" stdSqlType="INT" defaultValue="1"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="equipment" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipment" joinColumnName="equipmentId"/>
            </relations>
        </entity>

        <!-- 维护访问 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntVisit"
                displayName="维护访问" name="app.erp.mnt.dao.entity.ErpMntVisit"
                tableName="erp_mnt_visit" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="访问编码" domainName="visitCode" mandatory="true"/>
                <column name="scheduleId" displayName="维护计划ID" stdSqlType="BIGINT"/>
                <column name="equipmentId" displayName="设备ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="visitDate" displayName="访问日期" stdSqlType="DATE" mandatory="true"/>
                <column name="status" displayName="状态" dictName="erp-mnt/visit-status" mandatory="true"/>
                <column name="assignedTo" displayName="指派人" stdSqlType="BIGINT"/>
                <column name="completedBy" displayName="完成人" stdSqlType="BIGINT"/>
                <column name="completedAt" displayName="完成时间" stdSqlType="DATETIME"/>
                <column name="startTime" displayName="开始时间" stdSqlType="DATETIME"/>
                <column name="endTime" displayName="结束时间" stdSqlType="DATETIME"/>
                <column name="totalMinutes" displayName="总分钟数" domainName="downtimeMinutes"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="schedule" refEntityName="app.erp.mnt.dao.entity.ErpMntSchedule" joinColumnName="scheduleId"/>
                <to-one name="equipment" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipment" joinColumnName="equipmentId"/>
                <to-many name="tasks" refEntityName="app.erp.mnt.dao.entity.ErpMntVisitTask" myFieldName="id" refFieldName="visitId"/>
            </relations>
        </entity>

        <!-- 维护任务 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntVisitTask"
                displayName="维护任务" name="app.erp.mnt.dao.entity.ErpMntVisitTask"
                tableName="erp_mnt_visit_task" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="visitId" displayName="维护访问ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="lineNo" displayName="行号" stdSqlType="INT" mandatory="true"/>
                <column name="taskDescription" displayName="任务描述" stdSqlType="VARCHAR" precision="500" mandatory="true"/>
                <column name="status" displayName="状态" stdSqlType="VARCHAR" precision="20" mandatory="true"/>
                <column name="completedBy" displayName="完成人" stdSqlType="BIGINT"/>
                <column name="completedAt" displayName="完成时间" stdSqlType="DATETIME"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="visit" refEntityName="app.erp.mnt.dao.entity.ErpMntVisit" joinColumnName="visitId"/>
            </relations>
        </entity>

        <!-- 维护请求 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntRequest"
                displayName="维护请求" name="app.erp.mnt.dao.entity.ErpMntRequest"
                tableName="erp_mnt_request" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="code" displayName="请求编码" domainName="requestCode" mandatory="true"/>
                <column name="equipmentId" displayName="设备ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="requestDate" displayName="请求日期" stdSqlType="DATE" mandatory="true"/>
                <column name="description" displayName="问题描述" stdSqlType="VARCHAR" precision="2000" mandatory="true"/>
                <column name="priority" displayName="优先级" dictName="erp-mnt/priority" mandatory="true"/>
                <column name="status" displayName="状态" dictName="erp-mnt/request-status" mandatory="true"/>
                <column name="requestedBy" displayName="请求人" stdSqlType="BIGINT" mandatory="true"/>
                <column name="assignedTo" displayName="指派人" stdSqlType="BIGINT"/>
                <column name="acceptedBy" displayName="受理人" stdSqlType="BIGINT"/>
                <column name="completedBy" displayName="完成人" stdSqlType="BIGINT"/>
                <column name="completedAt" displayName="完成时间" stdSqlType="DATETIME"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="version" displayName="版本号" stdSqlType="INT" defaultValue="0"/>
            </columns>
            <relations>
                <to-one name="equipment" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipment" joinColumnName="equipmentId"/>
            </relations>
        </entity>

        <!-- 停机记录 -->
        <entity className="app.erp.mnt.dao.entity.ErpMntDowntimeEntry"
                displayName="停机记录" name="app.erp.mnt.dao.entity.ErpMntDowntimeEntry"
                tableName="erp_mnt_downtime_entry" tag="erp.maintenance">
            <columns>
                <column name="id" displayName="ID" stdSqlType="BIGINT" primary="true" mandatory="true"/>
                <column name="equipmentId" displayName="设备ID" stdSqlType="BIGINT" mandatory="true"/>
                <column name="startTime" displayName="开始时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="endTime" displayName="结束时间" stdSqlType="DATETIME"/>
                <column name="totalMinutes" displayName="总分钟数" domainName="downtimeMinutes"/>
                <column name="reason" displayName="原因" stdSqlType="VARCHAR" precision="500"/>
                <column name="relatedJobOrderId" displayName="关联生产工单ID" stdSqlType="BIGINT"/>
                <column name="remark" displayName="备注" domainName="remark"/>
                <column name="tenantId" displayName="租户ID" stdSqlType="BIGINT"/>
                <column name="createdAt" displayName="创建时间" stdSqlType="DATETIME" mandatory="true"/>
                <column name="updatedAt" displayName="更新时间" stdSqlType="DATETIME" mandatory="true"/>
            </columns>
            <relations>
                <to-one name="equipment" refEntityName="app.erp.mnt.dao.entity.ErpMntEquipment" joinColumnName="equipmentId"/>
            </relations>
        </entity>
    </entities>
</orm>
