<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>

    <import resource="_service.beans.xml"/>

    <!-- 维护域服务（非 BizModel）：设备状态联动器（访问/停机触发设备状态，经 erp-mnt.equipment-status-link-enabled 门控） -->
    <bean id="app.erp.mnt.service.support.EquipmentStatusLinker"
          class="app.erp.mnt.service.support.EquipmentStatusLinker"/>

    <!-- 维护域服务（非 BizModel）：备件领料出库服务（按行调 IErpInvStockMoveBiz.generateMove 跨域出库） -->
    <bean id="app.erp.mnt.service.support.SparePartIssueService"
          class="app.erp.mnt.service.support.SparePartIssueService"/>

    <!-- 备件消耗 GL 过账（plan 2026-07-10-1100-6）：备件消耗 confirm 后 → Dr: 维修费用 / Cr: 存货 凭证。
           Dispatcher 由 ErpMntSparePartUsageBizModel.confirm 显式调用（config-gated 默认关）；
           Provider 由 finance ErpFinAcctDocRegistry 跨模块 collect-beans 自动聚合（同 ManufacturingIssue 范式）。 -->
    <bean id="app.erp.mnt.service.posting.MntPostingExecutor"
          class="app.erp.mnt.service.posting.MntPostingExecutor"/>
    <bean id="app.erp.mnt.service.posting.MaintenanceIssuePostingDispatcher"
          class="app.erp.mnt.service.posting.MaintenanceIssuePostingDispatcher"/>
    <bean id="app.erp.mnt.service.posting.MaintenanceIssueAcctDocProvider"
          class="app.erp.mnt.service.posting.MaintenanceIssueAcctDocProvider"/>

    <!-- 维修工时费用化 GL 过账（plan 2026-07-18-0949-1）：Visit complete 后 → Dr: 折旧费用 6602
           / Cr: 应付职工薪酬 2211 凭证。镜像 1100-6 bean 注册范式（全限定类名 bean id）。Dispatcher 由
           ErpMntVisitBizModel.doComplete 显式调用（config erp-mnt.labor-posting-enabled 默认关）。 -->
    <bean id="app.erp.mnt.service.posting.MaintenanceLaborPostingDispatcher"
          class="app.erp.mnt.service.posting.MaintenanceLaborPostingDispatcher"/>
    <bean id="app.erp.mnt.service.posting.MaintenanceLaborAcctDocProvider"
          class="app.erp.mnt.service.posting.MaintenanceLaborAcctDocProvider"/>

    <!-- 维护域服务（非 BizModel）：维护计划到期生成访问生成器（扫描 active 计划生成 PLANNED 访问 + 推进 nextDueDate） -->
    <bean id="app.erp.mnt.service.support.ScheduleDueGenerator"
          class="app.erp.mnt.service.support.ScheduleDueGenerator"/>

    <!-- 定时到期访问生成 Job Bean（plan 2026-07-05-0306-1 Phase 1）。由 nop-job-local scheduler.yaml
          经 BeanMethodJobInvoker 反射调用 execute()。cron 经 erp-mnt.due-visit-cron 配置门控。 -->
    <bean id="erpMntDueVisitJob"
          class="app.erp.mnt.service.job.ErpMntDueVisitJob"/>

    <!-- 维护看板聚合入口（plan 2026-07-06-1606-1）：非实体 BizModel，注入 IDaoProvider/IOrmTemplate，
          经 @BizQuery 暴露 getDashboardKpi/getEquipmentStatusDistribution/findEquipmentDowntimeAlert/findMaintenanceOverdueAlert。 -->
    <bean id="app.erp.mnt.service.dashboard.ErpMntDashboardBizModel" ioc:type="@bean:id"/>

    <!-- 维护域报表渲染入口（plan 2026-07-06-1815-1）：非实体 BizModel，注入平台 IReportEngine，
          经 @BizQuery 暴露 renderHtml/download。镜像 finance ErpFinReportBizModel（域隔离 /mnt/）。 -->
    <bean id="app.erp.mnt.service.report.ErpMntReportBizModel" ioc:type="@bean:id"/>
</beans>