<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntSparePartUsage.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgName" label="组织"/>
                <col id="visitCode" label="维护访问"/>
                <col id="requestCode" label="维护请求"/>
                <col id="equipmentCode" label="设备"/>
                <col id="warehouseName" label="仓库"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="totalAmount" ui:number="true" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
                <col id="posted" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>