<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntDowntimeEntry.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="equipment" label="设备"/>
                <col id="startTime" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="endTime" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'datetime', format: 'YYYY-MM-DD HH:mm:ss' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="totalMinutes" ui:number="true" sortable="true"/>
                <col id="reason" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 equipmentId[设备] startTime[开始时间]
 endTime[结束时间] totalMinutes[总分钟数]
=========>reason[原因信息]======
 reason[原因] relatedJobOrderId[关联工单]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 equipmentId[设备] startTime[开始时间]
 endTime[结束时间] totalMinutes[总分钟数]
=========>reason[原因信息]======
 reason[原因] relatedJobOrderId[关联工单]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 equipmentId[设备] startTime[开始时间]
 endTime[结束时间] reason[原因]
 totalMinutes[总分钟数]
            </layout>
            <cells>
                <cell id="equipmentId" filterOp="eq"/>
                <cell id="startTime" filterOp="date-between"/>
                <cell id="endTime" filterOp="date-between"/>
                <cell id="reason" filterOp="like"/>
                <cell id="totalMinutes" filterOp="gt"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>