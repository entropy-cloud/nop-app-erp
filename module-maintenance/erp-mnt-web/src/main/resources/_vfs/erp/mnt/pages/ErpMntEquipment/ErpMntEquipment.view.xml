<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntEquipment.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="name" mandatory="true" sortable="true"/>
                <col id="orgId" label="组织"/>
                <col id="categoryId" label="设备类别"/>
                <col id="locationId" label="位置"/>
                <col id="assetCode" label="资产"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="serialNo" sortable="true"/>
                <col id="manufacturer" sortable="true"/>
                <col id="model" sortable="true"/>
                <col id="installDate" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>