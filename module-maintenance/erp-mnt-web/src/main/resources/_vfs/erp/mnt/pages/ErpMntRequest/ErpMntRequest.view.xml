<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntRequest.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="equipment" label="设备"/>
                <col id="requestDate" mandatory="true" sortable="true"/>
                <col id="description" mandatory="true" sortable="true"/>
                <col id="priority" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpMntRequest__submitForApproval?id=$id"/>
                    <confirmText>确认提交此报修单审批？</confirmText>
                    <messages>
                        <success>报修单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpMntRequest__approve?id=$id"/>
                    <confirmText>确认批准此报修单？</confirmText>
                    <messages>
                        <success>报修单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpMntRequest__reject?id=$id"/>
                    <confirmText>确认驳回此报修单？</confirmText>
                    <messages>
                        <success>报修单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-accept-button" label="受理" level="primary" icon="fa fa-hand-paper-o">
                    <api url="@mutation:ErpMntRequest__accept?requestId=$id"/>
                    <confirmText>确认受理此报修单？</confirmText>
                    <messages>
                        <success>报修单已受理</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED' &amp;&amp; status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check-circle">
                    <api url="@mutation:ErpMntRequest__complete?requestId=$id"/>
                    <confirmText>确认完成此报修单？</confirmText>
                    <messages>
                        <success>报修单已完成</success>
                    </messages>
                    <visibleOn>${status == 'ACCEPTED' || status == 'IN_PROGRESS'}</visibleOn>
                </action>
                <action id="row-reject-request-button" label="拒绝" level="warning" icon="fa fa-ban">
                    <api url="@mutation:ErpMntRequest__rejectRequest?requestId=$id"/>
                    <confirmText>确认拒绝此报修单？</confirmText>
                    <messages>
                        <success>报修单已拒绝</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED' &amp;&amp; status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpMntRequest__cancel?requestId=$id"/>
                    <confirmText>确认作废此报修单？</confirmText>
                    <messages>
                        <success>报修单已作废</success>
                    </messages>
                    <visibleOn>${status != 'CANCELLED' &amp;&amp; status != 'COMPLETED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>