<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntRequest.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="equipment" label="设备"/>
                <col id="requestDate" mandatory="true" sortable="true" align="center">
                    <gen-control>
                        <c:script><![CDATA[
                            return { type: 'date', format: 'YYYY-MM-DD' };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="description" mandatory="true" sortable="true"/>
                <col id="priority" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'status';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            const successVals = ['COMPLETED','APPROVED','RECEIVED','DELIVERED','PAID','SETTLED','HONORED','RETRIED','EXECUTED','COMPUTED','CONFIRMED','RUNNING','MATERIAL_TRANSFERRED','ACTIVE','CLOSED','DONE','SUCCESS'];
                            const dangerVals = ['REJECTED','CANCELLED','FAILED','DISHONORED','OVERDUE','DOWN','TERMINATED','WRITE_OFF'];
                            const warningVals = ['ON_HOLD','SUSPENDED','EXPIRED','RETRYING'];
                            const primaryVals = ['SUBMITTED','IN_PROGRESS','PARTIAL','PARTIALLY_TRANSFERRED','WORK_IN_PROGRESS','PROCESSING','NEGOTIATION','OPEN','UNDER_MAINTENANCE','COLLECTION_PENDING','DISCOUNTED','ENDORSED','ISSUED'];
                            function quote(v){return "'" + v + "'";}
                            function inList(vals){return "[" + vals.map(quote).join(",") + "].indexOf(" + valueProp + ") >= 0";}
                            const expr = inList(successVals) + " ? 'success' : "
                                + inList(dangerVals) + " ? 'danger' : "
                                + inList(warningVals) + " ? 'warning' : "
                                + inList(primaryVals) + " ? 'primary' : 'default'";
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + expr + "}"
                                    + ">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[请求单号] equipmentId[设备]
 requestDate[请求日期] description[问题描述]
 priority[优先级] requestedBy[请求人]
=========>dispatch[派工信息]======
 assignedTo[指派给] acceptedBy[受理人]
=========>status[状态信息]======
 status[状态] completedBy[完成人]
 completedAt[完成时间]
========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit" size="lg">
            <layout x:override="replace">
=========>baseInfo[基本信息]======
 code[请求单号] equipmentId[设备]
 requestDate[请求日期] description[问题描述]
 priority[优先级] requestedBy[请求人]
=========>dispatch[派工信息]======
 assignedTo[指派给] acceptedBy[受理人]
=========>status[状态信息]======
 status[状态] completedBy[完成人]
 completedAt[完成时间]
========^audit[审计信息]=========
 remark[备注](2)
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[请求单号] status[状态]
 equipmentId[设备] priority[优先级]
 requestDate[请求日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="status" filterOp="eq"/>
                <cell id="equipmentId" filterOp="eq"/>
                <cell id="priority" filterOp="eq"/>
                <cell id="requestDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-submit-button" label="提交" level="primary" icon="fa fa-paper-plane">
                    <api url="@mutation:ErpMntRequest__submitForApproval?id=$id"/>
                    <confirmText>确认提交此报修单审批？</confirmText>
                    <messages>
                        <success>报修单已提交审批</success>
                    </messages>
                    <visibleOn>${approveStatus == 'UNSUBMITTED' || approveStatus == 'REJECTED'}</visibleOn>
                </action>
                <action id="row-approve-button" label="批准" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpMntRequest__approve?id=$id"/>
                    <confirmText>确认批准此报修单？</confirmText>
                    <messages>
                        <success>报修单已批准</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-reject-button" label="驳回" level="warning" icon="fa fa-times">
                    <api url="@mutation:ErpMntRequest__reject?id=$id"/>
                    <confirmText>确认驳回此报修单？</confirmText>
                    <messages>
                        <success>报修单已驳回</success>
                    </messages>
                    <visibleOn>${approveStatus == 'SUBMITTED'}</visibleOn>
                </action>
                <action id="row-accept-button" label="受理" level="primary" icon="fa fa-hand-paper-o">
                    <api url="@mutation:ErpMntRequest__accept?requestId=$id"/>
                    <confirmText>确认受理此报修单？</confirmText>
                    <messages>
                        <success>报修单已受理</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED' &amp;&amp; status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check-circle">
                    <api url="@mutation:ErpMntRequest__complete?requestId=$id"/>
                    <confirmText>确认完成此报修单？</confirmText>
                    <messages>
                        <success>报修单已完成</success>
                    </messages>
                    <visibleOn>${status == 'ACCEPTED' || status == 'IN_PROGRESS'}</visibleOn>
                </action>
                <action id="row-reject-request-button" label="拒绝" level="warning" icon="fa fa-ban">
                    <api url="@mutation:ErpMntRequest__rejectRequest?requestId=$id"/>
                    <confirmText>确认拒绝此报修单？</confirmText>
                    <messages>
                        <success>报修单已拒绝</success>
                    </messages>
                    <visibleOn>${approveStatus == 'APPROVED' &amp;&amp; status == 'OPEN'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpMntRequest__cancel?requestId=$id"/>
                    <confirmText>确认作废此报修单？</confirmText>
                    <messages>
                        <success>报修单已作废</success>
                    </messages>
                    <visibleOn>${status != 'CANCELLED' &amp;&amp; status != 'COMPLETED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>