<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntVisitTask.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="visitCode" label="维护访问"/>
                <col id="lineNo" mandatory="true" ui:number="true" sortable="true"/>
                <col id="taskId" mandatory="true" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="completedAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>