<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntMaintenanceTeamMember.view.xml" x:schema="/nop/schema/xui/xview.xdef"
      xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="teamName" label="维护团队"/>
                <col id="employeeName" label="成员"/>
                <col id="role" sortable="true"/>
                <col id="joinedAt" sortable="true"/>
                <col id="leftAt" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>