<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntVisit.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="组织"/>
                <col id="visitDate" mandatory="true" sortable="true"/>
                <col id="visitType" sortable="true"/>
                <col id="status" mandatory="true" sortable="true"/>
                <col id="startTime" sortable="true"/>
                <col id="endTime" sortable="true"/>
                <col id="totalMinutes" ui:number="true" sortable="true"/>
                <col id="result" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[访问编码] scheduleId[维护计划ID]
 equipmentId[设备ID] visitDate[访问日期]
 status[状态] visitType[维护类型]
 orgId[业务组织] businessDate[业务日期]
==========>execution[执行信息]======
 assignedTo[指派人] completedBy[完成人]
 completedAt[完成时间] startTime[开始时间]
 endTime[结束时间] totalMinutes[总分钟数]
 result[执行结果]
==========^audit[审计信息]=========
 remark[备注]
 createdBy[创建人] createTime[创建时间]
 updatedBy[修改人] updateTime[修改时间]
            </layout>
        </form>
        <form id="edit">
            <layout x:override="replace">
==========>baseInfo[基本信息]======
 code[访问编码] scheduleId[维护计划ID]
 equipmentId[设备ID] visitDate[访问日期]
 status[状态] visitType[维护类型]
 orgId[业务组织] businessDate[业务日期]
==========>execution[执行信息]======
 assignedTo[指派人] completedBy[完成人]
 completedAt[完成时间] startTime[开始时间]
 endTime[结束时间] totalMinutes[总分钟数]
 result[执行结果]
 remark[备注](2)
            </layout>
        </form>
        <form id="add"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
 code[访问编码] status[状态]
 equipmentId[设备ID] visitDate[访问日期]
            </layout>
            <cells>
                <cell id="code" filterOp="like"/>
                <cell id="visitDate" filterOp="date-between"/>
            </cells>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button"/>
                <action id="row-update-button" actionType="drawer"/>
                <action id="row-schedule-button" label="排程" level="primary" icon="fa fa-calendar">
                    <api url="@mutation:ErpMntVisit__schedule?visitId=$id"/>
                    <confirmText>确认排程此维保任务？</confirmText>
                    <messages>
                        <success>维保任务已排程</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT'}</visibleOn>
                </action>
                <action id="row-start-button" label="开始" level="primary" icon="fa fa-play">
                    <api url="@mutation:ErpMntVisit__start?visitId=$id"/>
                    <confirmText>确认开始此维保任务？</confirmText>
                    <messages>
                        <success>维保任务已开始</success>
                    </messages>
                    <visibleOn>${status == 'SCHEDULED'}</visibleOn>
                </action>
                <action id="row-complete-button" label="完成" level="success" icon="fa fa-check">
                    <api url="@mutation:ErpMntVisit__complete?visitId=$id"/>
                    <confirmText>确认完成此维保任务？</confirmText>
                    <messages>
                        <success>维保任务已完成</success>
                    </messages>
                    <visibleOn>${status == 'IN_PROGRESS'}</visibleOn>
                </action>
                <action id="row-cancel-button" label="作废" level="danger" icon="fa fa-ban">
                    <api url="@mutation:ErpMntVisit__cancel?visitId=$id"/>
                    <confirmText>确认作废此维保任务？</confirmText>
                    <messages>
                        <success>维保任务已作废</success>
                    </messages>
                    <visibleOn>${status == 'DRAFT' || status == 'SCHEDULED'}</visibleOn>
                </action>
                <action id="row-delete-button"/>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>