<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntCalibration.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="组织"/>
                <col id="equipmentCode" label="设备"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="standardRef" sortable="true"/>
                <col id="measuredValue" ui:number="true" sortable="true"/>
                <col id="targetValue" ui:number="true" sortable="true"/>
                <col id="tolerance" ui:number="true" sortable="true"/>
                <col id="result" mandatory="true" sortable="true"/>
                <col id="nextCalibrationDate" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true"/>
                <col id="approveStatus" mandatory="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>