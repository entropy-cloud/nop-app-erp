<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_ErpMntCalibration.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id" mandatory="true" ui:number="true" sortable="true"/>
                <col id="code" mandatory="true" sortable="true"/>
                <col id="orgId" label="组织"/>
                <col id="equipment" label="设备"/>
                <col id="businessDate" mandatory="true" sortable="true"/>
                <col id="standardRef" sortable="true"/>
                <col id="measuredValue" ui:number="true" sortable="true"/>
                <col id="targetValue" ui:number="true" sortable="true"/>
                <col id="tolerance" ui:number="true" sortable="true"/>
                <col id="result" mandatory="true" sortable="true"/>
                <col id="nextCalibrationDate" sortable="true"/>
                <col id="docStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'docStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'ACTIVE' ? 'primary' : 'default'}\" "
                                    + "${" + valueProp
                                    + " == 'CANCELLED' ? \"style='text-decoration:line-through'\" : ''}>"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
                <col id="approveStatus" mandatory="true" sortable="true">
                    <gen-control>
                        <c:script><![CDATA[
                            const valueProp = dispMeta?.id || 'approveStatus';
                            const labelProp = propMeta?.['graphql:labelProp'] || (valueProp + '_label');
                            return {
                                type: "tpl",
                                tpl: '<span class="label label-${' + valueProp
                                    + " == 'APPROVED' ? 'success' : "
                                    + valueProp + " == 'REJECTED' ? 'danger' : "
                                    + valueProp + " == 'SUBMITTED' ? 'info' : 'default'}\">"
                                    + "${" + labelProp + "}</span>"
                            };
                        ]]></c:script>
                    </gen-control>
                </col>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>